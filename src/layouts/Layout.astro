---
import '../styles/global.css';
import AutoJack from '../components/AutoJack.astro';
import AutoJackPeek from '../components/AutoJackPeek.astro';

export interface Props {
  title: string;
  description?: string;
}

const { title, description = 'automem.ai - Intelligent Memory Service for AI Agents' } = Astro.props;
const pageTitle = `${title} | automem.ai`;
const pageUrl = Astro.site ? new URL(Astro.url.pathname || '/', Astro.site).toString() : undefined;
const ogImage = Astro.site ? new URL('/og-image.png', Astro.site).toString() : 'https://automem.ai/og-image.png';
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:ital,wght@0,100..800;1,100..800&display=swap" rel="stylesheet">
    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle}</title>
    <script defer src="https://api.pirsch.io/pa.js" id="pianjs" data-code="y8vzF2XcYTd2TFNyVLk2l2IaUyKdQTE6"></script>
    {pageUrl && (<link rel="canonical" href={pageUrl} />)}
    <meta property="og:type" content="website" />
    {pageUrl && (<meta property="og:url" content={pageUrl} />)}
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
  </head>
  <body class="bg-lab-bg text-lab-text min-h-screen flex font-mono selection:bg-lab-accent/20 relative">
    
    <!-- Line Numbers (Scrolls with content) -->
    <div class="hidden md:block w-20 border-r border-lab-border bg-lab-bg flex-shrink-0 text-right pr-4 py-6 select-none text-lab-muted/30 text-xs font-mono leading-7 min-h-screen">
      {Array.from({ length: 200 }).map((_, i) => (
        <div>0x{(i * 16).toString(16).toUpperCase().padStart(4, '0')}</div>
      ))}
    </div>

    <!-- Main Content Area -->
    <div class="flex-1 w-full max-w-full overflow-x-hidden relative">
      
      <div class="max-w-7xl mx-auto px-0 md:px-6 border-r border-lab-border min-h-screen bg-lab-bg/50 backdrop-blur-[2px]">
        <slot />
        
        <!-- Footer Signature -->
        <footer class="py-12 border-t border-lab-border mt-20 text-lab-muted text-sm relative">
          <div class="flex flex-col sm:flex-row justify-between items-center gap-4">
            <div class="flex items-center gap-3">
              <AutoJack size={24} expression="happy" animate={false} />
              <span>Made with <span class="text-lab-accent">memory</span> by cool people</span>
            </div>
            <div class="flex items-center gap-4">
              <a href="https://automem.ai/discord" target="_blank" rel="noopener noreferrer" class="hover:text-[#5865F2] transition-colors flex items-center gap-1">
                <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
                  <path d="M20.317 4.37a19.791 19.791 0 0 0-4.885-1.515.074.074 0 0 0-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0 12.64 12.64 0 0 0-.617-1.25.077.077 0 0 0-.079-.037A19.736 19.736 0 0 0 3.677 4.37a.07.07 0 0 0-.032.027C.533 9.046-.32 13.58.099 18.057c.001.022.015.04.033.05a19.886 19.886 0 0 0 5.993 3.03.078.078 0 0 0 .084-.028 14.09 14.09 0 0 0 1.226-1.994.076.076 0 0 0-.041-.106 13.107 13.107 0 0 1-1.872-.892.077.077 0 0 1-.008-.128 10.2 10.2 0 0 0 .372-.292.074.074 0 0 1 .077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 0 1 .078.01c.12.098.246.198.373.292a.077.077 0 0 1-.006.127 12.299 12.299 0 0 1-1.873.892.077.077 0 0 0-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 0 0 .084.028 19.839 19.839 0 0 0 6.002-3.03.077.077 0 0 0 .032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 0 0-.031-.03z"/>
                </svg>
                Discord
              </a>
              <span class="text-lab-border">|</span>
              <a href="https://github.com/verygoodplugins/automem" target="_blank" class="hover:text-lab-accent transition-colors">GitHub</a>
              <span class="text-lab-border">|</span>
              <span>automem.ai v1.0.0</span>
            </div>
          </div>
        </footer>
      </div>
      
      <!-- AutoJack Peek Helper -->
      <AutoJackPeek position="bottom-right" />
    </div>
    
    <!-- Film Grain Overlay -->
    <div class="grain-overlay"></div>
    
    <style is:global>
      .grain-overlay {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        pointer-events: none;
        z-index: 1000;
        opacity: 0.03;
        background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)'/%3E%3C/svg%3E");
      }
    </style>
  </body>
</html>