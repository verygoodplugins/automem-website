---
export interface Props {
  title: string;
  description?: string;
}

const { title, description = 'automem.ai - Intelligent Memory Service for AI Agents' } = Astro.props;
const pageTitle = `${title} | automem.ai`;
const pageUrl = Astro.site ? new URL(Astro.url.pathname || '/', Astro.site).toString() : undefined;
const ogImage = Astro.site ? new URL('/og-image.png', Astro.site).toString() : 'https://automem.ai/og-image.png';
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:ital,wght@0,100..800;1,100..800&display=swap" rel="stylesheet">
    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle}</title>
    <script defer src="https://api.pirsch.io/pa.js" id="pianjs" data-code="y8vzF2XcYTd2TFNyVLk2l2IaUyKdQTE6"></script>
    {pageUrl && (<link rel="canonical" href={pageUrl} />)}
    <meta property="og:type" content="website" />
    {pageUrl && (<meta property="og:url" content={pageUrl} />)}
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
  </head>
  <body class="bg-core-bg text-core-text min-h-screen flex font-mono selection:bg-core-accent/20 relative">
    
    <!-- Line Numbers (Scrolls with content) -->
    <div class="hidden md:block w-20 border-r border-core-line bg-core-bg flex-shrink-0 text-right pr-4 py-6 select-none text-core-muted/30 text-xs font-mono leading-7 min-h-screen">
      {Array.from({ length: 200 }).map((_, i) => (
        <div>0x{(i * 16).toString(16).toUpperCase().padStart(4, '0')}</div>
      ))}
    </div>

    <!-- Main Content Area -->
    <div class="flex-1 w-full max-w-full overflow-x-hidden relative">
       <!-- Grid overlay -->
      <div class="absolute inset-0 bg-[radial-gradient(#E5E5E5_1px,transparent_1px)] [background-size:24px_24px] pointer-events-none -z-10"></div>

      <div class="max-w-7xl mx-auto px-6 border-r border-core-line min-h-screen bg-core-bg/50 backdrop-blur-[2px]">
        <slot />
        
        <!-- Footer Signature -->
        <footer class="py-12 border-t border-core-line mt-20 text-core-muted text-sm">
          <div class="flex justify-between items-center">
            <div>
              <span class="text-core-accent">→</span> End of file
            </div>
            <div>
              automem.ai v1.0.0
            </div>
          </div>
        </footer>
      </div>
    </div>
  </body>
</html>
