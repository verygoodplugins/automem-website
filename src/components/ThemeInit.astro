{/* Inline FOUC-prevention script. MUST be rendered early in <head> so it
    runs synchronously before the body paints. Reads localStorage["theme"]
    (with legacy fallback to "starlight-theme"), then applies BOTH
    class="light" (consumed by global.css --lab-* swap) and data-theme
    (consumed by Starlight's --sl-* selectors). Mirrors both keys so any
    leftover Starlight reader stays in sync. */}
<script is:inline>
  (() => {
    let stored = null;
    try {
      stored = localStorage.getItem('theme') || localStorage.getItem('starlight-theme');
    } catch (_) {}
    let theme = stored;
    if (!theme) {
      try {
        theme = window.matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark';
      } catch (_) {
        theme = 'dark';
      }
    }
    const isLight = theme === 'light';
    document.documentElement.classList.toggle('light', isLight);
    document.documentElement.dataset.theme = isLight ? 'light' : 'dark';
    try {
      localStorage.setItem('theme', isLight ? 'light' : 'dark');
      localStorage.setItem('starlight-theme', isLight ? 'light' : 'dark');
    } catch (_) {}
  })();
</script>
