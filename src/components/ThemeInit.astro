{/* Inline FOUC-prevention script. MUST be rendered early in <head> so it
    runs synchronously before the body paints. Applies BOTH class="light"
    (consumed by global.css --lab-* swap) and data-theme (consumed by
    Starlight's --sl-* selectors).

    Theme resolution: an explicit user choice — set by ThemeToggle and flagged
    with localStorage["theme-explicit"] === "1" — always wins. Otherwise we
    follow the OS via prefers-color-scheme and do NOT persist that value.
    Persisting the auto-detected theme is what used to freeze every visitor on
    whatever they first saw, ignoring any later change to their system setting. */}
<script is:inline>
  (() => {
    const isExplicit = () => {
      try {
        return localStorage.getItem('theme-explicit') === '1';
      } catch (_) {
        return false;
      }
    };
    const pinned = () => {
      try {
        return localStorage.getItem('theme') || localStorage.getItem('starlight-theme');
      } catch (_) {
        return null;
      }
    };
    const system = () => {
      try {
        return window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
      } catch (_) {
        return 'dark';
      }
    };

    let theme;
    if (isExplicit()) {
      theme = pinned() === 'light' ? 'light' : 'dark';
    } else {
      theme = system();
    }
    const isLight = theme === 'light';
    document.documentElement.classList.toggle('light', isLight);
    document.documentElement.dataset.theme = isLight ? 'light' : 'dark';
  })();
</script>
