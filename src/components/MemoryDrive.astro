---
---

<div class="memory-graph relative w-full max-w-5xl mx-auto h-[340px] sm:h-[480px]">
  <!-- Ambient glows -->
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-64 h-64 rounded-full bg-lab-secondary/[0.06] blur-[100px] pointer-events-none"></div>
  <div class="absolute top-[25%] right-[25%] w-40 h-40 rounded-full bg-lab-accent/[0.04] blur-[80px] pointer-events-none"></div>

  <!-- SVG Edges -->
  <svg class="absolute inset-0 w-full h-full overflow-visible" viewBox="0 0 100 100" preserveAspectRatio="none">
    <g class="graph-edges">
      <!-- Core connections -->
      <line data-edge="core:retrieval" x1="50" y1="54" x2="50" y2="10" vector-effect="non-scaling-stroke" />
      <line data-edge="core:idea" x1="50" y1="54" x2="15" y2="46" vector-effect="non-scaling-stroke" />
      <line data-edge="core:research" x1="50" y1="54" x2="85" y2="46" vector-effect="non-scaling-stroke" />
      <line data-edge="core:habit" x1="50" y1="54" x2="18" y2="84" vector-effect="non-scaling-stroke" />
      <line data-edge="core:code" x1="50" y1="54" x2="82" y2="84" vector-effect="non-scaling-stroke" />
      <!-- Retrieval sub-graph -->
      <line data-edge="retrieval:session" x1="50" y1="10" x2="28" y2="22" vector-effect="non-scaling-stroke" />
      <line data-edge="retrieval:thread" x1="50" y1="10" x2="72" y2="22" vector-effect="non-scaling-stroke" />
      <!-- Side connections -->
      <line data-edge="habit:idea" x1="18" y1="84" x2="15" y2="46" vector-effect="non-scaling-stroke" />
      <line data-edge="research:code" x1="85" y1="46" x2="82" y2="84" vector-effect="non-scaling-stroke" />
      <!-- Cross connections -->
      <line data-edge="idea:research" x1="15" y1="46" x2="85" y2="46" vector-effect="non-scaling-stroke" />
      <line data-edge="habit:code" x1="18" y1="84" x2="82" y2="84" vector-effect="non-scaling-stroke" />
    </g>
  </svg>

  <!-- Nodes -->
  <div class="mg-node core" data-node="core" style="left: 50%; top: 54%;">
    <div class="core-ring"></div>
    <div class="core-inner">
      <span class="core-label">MEMORY CORE</span>
      <span class="core-title">AutoMem</span>
    </div>
  </div>

  <div class="mg-node pill" data-node="retrieval" style="left: 50%; top: 10%;">Retrieval Graph</div>
  <div class="mg-node sm hidden sm:block" data-node="session" style="left: 28%; top: 22%;">Session</div>
  <div class="mg-node sm hidden sm:block" data-node="thread" style="left: 72%; top: 22%;">Thread</div>
  <div class="mg-node" data-node="idea" style="left: 15%; top: 46%;">Ideas</div>
  <div class="mg-node" data-node="research" style="left: 85%; top: 46%;">Research</div>
  <div class="mg-node" data-node="habit" style="left: 18%; top: 84%;">Habits</div>
  <div class="mg-node" data-node="code" style="left: 82%; top: 84%;">Code</div>

  <!-- Floating daemon readout -->
  <div class="absolute bottom-4 left-1/2 -translate-x-1/2 flex items-center gap-3 font-mono text-[11px] px-4 py-2.5 rounded-full bg-lab-surface/80 backdrop-blur-sm border border-lab-border/50 whitespace-nowrap">
    <span class="flex items-center gap-1.5 text-lab-success uppercase tracking-widest">
      <span class="w-1.5 h-1.5 rounded-full bg-lab-success animate-pulse"></span>
      recall.service
    </span>
    <span class="text-lab-border">|</span>
    <span class="text-lab-muted">ingest → normalize → link · 48ms</span>
  </div>
</div>

<style>
  /* ── Theme tokens ── */
  .memory-graph {
    --mg-surface: rgb(var(--lab-bg) / 0.8);
    --mg-surface-strong: rgb(var(--lab-bg) / 0.9);
    --mg-text: rgb(var(--lab-text) / 0.5);
    --mg-text-dim: rgb(var(--lab-text) / 0.3);
    --mg-text-hover: rgb(var(--lab-text) / 0.7);
    --mg-border: rgb(255 255 255 / 0.06);
    --mg-border-dim: rgb(255 255 255 / 0.03);
    --mg-border-hover: rgb(255 255 255 / 0.12);
    --mg-secondary: rgb(var(--lab-secondary) / 0.7);
    --mg-secondary-border: rgb(var(--lab-secondary) / 0.2);
    --mg-secondary-dim: rgb(var(--lab-secondary) / 0.5);
    --mg-secondary-strong: rgb(var(--lab-secondary) / 0.85);
    --mg-secondary-ring: rgb(var(--lab-secondary) / 0.1);
    --mg-secondary-core-border: rgb(var(--lab-secondary) / 0.25);
    --mg-accent: rgb(var(--lab-accent) / 0.85);
    --mg-accent-border: rgb(var(--lab-accent) / 0.4);
    --mg-accent-glow: rgb(var(--lab-accent) / 0.06);
    --mg-accent-glow-strong: rgb(var(--lab-accent) / 0.08);
    --mg-accent-dim: rgb(var(--lab-accent) / 0.5);
    --mg-accent-strong: rgb(var(--lab-accent) / 0.9);
    --mg-accent-edge: rgb(var(--lab-accent) / 0.35);
    --mg-edge: rgb(255 255 255 / 0.1);
    --mg-success: rgb(var(--lab-success) / 0.7);
    --mg-success-border: rgb(var(--lab-success) / 0.2);
  }

  :global(html.light) .memory-graph {
    /* On white the glow-based depth vanishes, so light mode leans on opaque
       node surfaces, higher-contrast ink text, and visible edges instead. */
    --mg-surface: rgb(255 255 255 / 0.9);
    --mg-surface-strong: rgb(255 255 255 / 0.96);
    --mg-text: rgb(var(--lab-text) / 0.72);
    --mg-text-dim: rgb(var(--lab-text) / 0.5);
    --mg-text-hover: rgb(var(--lab-text) / 0.92);
    --mg-border: rgb(var(--lab-line) / 0.5);
    --mg-border-dim: rgb(var(--lab-line) / 0.3);
    --mg-border-hover: rgb(var(--lab-secondary) / 0.5);
    --mg-edge: rgb(var(--lab-line) / 0.5);
    --mg-secondary: rgb(var(--lab-secondary) / 0.95);
    --mg-secondary-border: rgb(var(--lab-secondary) / 0.4);
    --mg-secondary-dim: rgb(var(--lab-secondary) / 0.7);
    --mg-secondary-strong: rgb(var(--lab-secondary));
    --mg-secondary-ring: rgb(var(--lab-secondary) / 0.3);
    --mg-secondary-core-border: rgb(var(--lab-secondary) / 0.45);
    --mg-accent: rgb(var(--lab-accent-text) / 0.95);
    --mg-accent-border: rgb(var(--lab-accent-text) / 0.55);
    --mg-accent-edge: rgb(var(--lab-accent-text) / 0.5);
    --mg-success: rgb(var(--lab-success) / 0.9);
    --mg-success-border: rgb(var(--lab-success) / 0.45);
  }

  /* Core node needs a cast shadow on light to read as the focal point. */
  :global(html.light) .core-inner {
    box-shadow: 0 12px 30px rgb(14 20 28 / 0.1);
  }

  /* ── Nodes ── */
  .memory-graph .mg-node {
    position: absolute;
    transform: translate(-50%, -50%);
    padding: 9px 16px;
    background: var(--mg-surface);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 1px solid var(--mg-border);
    border-radius: 12px;
    color: var(--mg-text);
    font-weight: 600;
    font-size: 13px;
    letter-spacing: 0.015em;
    white-space: nowrap;
    z-index: 2;
    cursor: default;
    transition: border-color 0.5s ease, color 0.5s ease, box-shadow 0.5s ease, transform 0.5s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .memory-graph .mg-node.pill {
    border-color: var(--mg-success-border);
    color: var(--mg-success);
  }

  .memory-graph .mg-node.sm {
    font-size: 11px;
    padding: 6px 11px;
    color: var(--mg-text-dim);
    border-color: var(--mg-border-dim);
  }

  /* ── Core node ── */
  .memory-graph .mg-node.core {
    padding: 0;
    background: none;
    border: none;
    backdrop-filter: none;
    -webkit-backdrop-filter: none;
  }

  .core-inner {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2px;
    padding: 18px 28px;
    background: var(--mg-surface-strong);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border: 1.5px solid var(--mg-secondary-core-border);
    border-radius: 16px;
  }

  .core-ring {
    position: absolute;
    inset: -10px;
    border-radius: 26px;
    border: 1px solid var(--mg-secondary-ring);
    animation: ring-breathe 4s ease-in-out infinite;
    pointer-events: none;
  }

  .core-label {
    font-size: 9px;
    letter-spacing: 0.14em;
    color: var(--mg-secondary-dim);
    font-weight: 500;
    text-transform: uppercase;
  }

  .core-title {
    font-size: 17px;
    font-weight: 700;
    color: var(--mg-secondary-strong);
    letter-spacing: -0.01em;
  }

  /* ── Active states (gold accent) ── */
  .memory-graph .mg-node.active {
    border-color: var(--mg-accent-border);
    color: var(--mg-accent);
    box-shadow: 0 0 24px var(--mg-accent-glow);
    transform: translate(-50%, -50%) scale(1.05);
  }

  .memory-graph .mg-node.core.active .core-inner {
    border-color: var(--mg-accent-edge);
    box-shadow: 0 0 30px var(--mg-accent-glow-strong);
  }

  .memory-graph .mg-node.core.active .core-title {
    color: var(--mg-accent-strong);
  }

  .memory-graph .mg-node.core.active .core-label {
    color: var(--mg-accent-dim);
  }

  .memory-graph .mg-node:not(.core):hover {
    border-color: var(--mg-border-hover);
    color: var(--mg-text-hover);
  }

  /* ── Edges ── */
  .graph-edges line {
    stroke: var(--mg-edge);
    stroke-width: 1;
    stroke-dasharray: 3 9;
    transition: stroke 0.5s ease, stroke-width 0.5s ease;
  }

  .graph-edges line.active {
    stroke: var(--mg-accent-edge);
    stroke-width: 1.5;
    stroke-dasharray: 2 8;
    animation: edge-flow 2s linear infinite;
  }

  /* ── Animations ── */
  @keyframes ring-breathe {
    0%, 100% { opacity: 0.3; transform: scale(1); }
    50% { opacity: 0.7; transform: scale(1.06); }
  }

  @keyframes edge-flow {
    to { stroke-dashoffset: -20; }
  }

  /* ── Mobile ── */
  @media (max-width: 640px) {
    .graph-edges [data-edge="retrieval:session"],
    .graph-edges [data-edge="retrieval:thread"] {
      display: none;
    }

    .memory-graph .mg-node {
      font-size: 11px;
      padding: 6px 11px;
    }
    .core-inner {
      padding: 14px 20px;
    }
    .core-title {
      font-size: 14px;
    }
  }
</style>

<script>
  const graphNodes = Array.from(document.querySelectorAll('.memory-graph [data-node]'));
  const graphEdges = Array.from(document.querySelectorAll('.memory-graph [data-edge]'));

  const isMobile = window.matchMedia('(max-width: 640px)').matches;

  const sequences = [
    { nodes: ['idea', 'core', 'research'], edges: ['core:idea', 'core:research', 'idea:research'] },
    { nodes: ['habit', 'core', 'code'], edges: ['core:habit', 'core:code', 'habit:code'] },
    isMobile
      ? { nodes: ['retrieval', 'core'], edges: ['core:retrieval'] }
      : { nodes: ['retrieval', 'thread', 'session', 'core'], edges: ['core:retrieval', 'retrieval:thread', 'retrieval:session'] },
    { nodes: ['code', 'research'], edges: ['research:code'] },
  ];

  function clearActive() {
    graphNodes.forEach(n => n.classList.remove('active'));
    graphEdges.forEach(e => e.classList.remove('active'));
  }

  function runSequence(index = 0) {
    const seq = sequences[index % sequences.length];
    clearActive();

    seq.nodes.forEach((id, i) => {
      const el = graphNodes.find(n => n.dataset.node === id);
      if (el) setTimeout(() => el.classList.add('active'), 350 * i);
    });

    seq.edges.forEach((id, i) => {
      const el = graphEdges.find(e => e.dataset.edge === id);
      if (el) setTimeout(() => el.classList.add('active'), 450 * i);
    });

    setTimeout(() => runSequence(index + 1), 5500);
  }

  runSequence();
</script>
