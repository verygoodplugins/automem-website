---
---

<div class="memory-graph-shell relative w-full max-w-6xl mx-auto px-4 py-12 overflow-hidden rounded-3xl border-2 border-lab-text bg-lab-bg shadow-hard">
  <div class="absolute inset-0 bg-[radial-gradient(#1f1f1f_1px,transparent_1px)] [background-size:18px_18px] opacity-30 pointer-events-none"></div>
  <div class="graph-glow absolute -inset-x-24 inset-y-6 bg-gradient-to-br from-lab-secondary/10 via-lab-accent/5 to-transparent blur-3xl"></div>

  <div class="relative z-10 grid md:grid-cols-[1.3fr_1fr] gap-8 items-center">
    <!-- Graph stage -->
    <div class="relative h-[420px]">
      <svg class="graph-lines absolute inset-0 w-full h-full" viewBox="0 0 1000 520" preserveAspectRatio="none">
        <g stroke="currentColor" stroke-width="2" stroke-linecap="round" class="text-lab-border/80">
          <line data-edge="core:idea" x1="500" y1="291" x2="220" y2="166" class="edge" />
          <line data-edge="core:research" x1="500" y1="291" x2="780" y2="177" class="edge" />
          <line data-edge="core:habit" x1="500" y1="291" x2="180" y2="385" class="edge" />
          <line data-edge="core:code" x1="500" y1="291" x2="820" y2="364" class="edge" />
          <line data-edge="idea:research" x1="220" y1="166" x2="780" y2="177" class="edge" />
          <line data-edge="habit:code" x1="180" y1="385" x2="820" y2="364" class="edge" />
          <line data-edge="research:code" x1="780" y1="177" x2="820" y2="364" class="edge" />
          <line data-edge="habit:idea" x1="180" y1="385" x2="220" y2="166" class="edge" />
          <line data-edge="core:retrieval" x1="500" y1="291" x2="500" y2="83" class="edge" />
          <line data-edge="retrieval:thread" x1="500" y1="83" x2="700" y2="125" class="edge" />
          <line data-edge="retrieval:session" x1="500" y1="83" x2="300" y2="125" class="edge" />
        </g>
      </svg>

      <!-- Nodes -->
      <div class="node core" data-node="core" style="left: 50%; top: 56%;">
        <div class="node-body">
          <div class="node-label text-xs tracking-wider text-lab-muted">MEMORY CORE</div>
          <div class="text-lab-text font-bold">AutoMem</div>
        </div>
      </div>

      <div class="node" data-node="idea" style="left: 22%; top: 32%;">Ideas</div>
      <div class="node" data-node="research" style="left: 78%; top: 34%;">Research</div>
      <div class="node" data-node="habit" style="left: 18%; top: 74%;">Habits</div>
      <div class="node" data-node="code" style="left: 82%; top: 70%;">Code</div>
      <div class="node pill" data-node="retrieval" style="left: 50%; top: 16%;">Retrieval Graph</div>
      <div class="node small" data-node="thread" style="left: 70%; top: 24%;">Thread</div>
      <div class="node small" data-node="session" style="left: 30%; top: 24%;">Session</div>
    </div>

    <!-- Copy -->
    <div class="space-y-4 relative">
      <div class="comment-header">:: BACKGROUND_PROCESS</div>
      <h3 class="text-3xl font-bold leading-tight">Organizes itself while you work.</h3>
      <p class="text-lab-muted leading-relaxed">
        AutoMem runs quietly in the background, stitching every thought into a retrieval graph. It notices patterns,
        links context, and keeps the right edges warm so your agents answer with your voice—without you ever thinking about it.
      </p>
      <div class="bg-lab-surface border border-lab-border rounded-xl p-4 font-mono text-sm shadow-hard">
        <div class="flex items-center gap-2 mb-2 text-lab-secondary uppercase text-xs tracking-widest">
          <span class="w-2 h-2 rounded-full bg-lab-success animate-pulse"></span>
          daemon: recall.service
        </div>
        <div class="space-y-1 text-lab-text">
          <div>&gt; ingest(stream) → normalize → link()</div>
          <div class="text-lab-muted">paths warmed: 12 · associations refreshed: 48ms</div>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  .memory-graph-shell .node {
    position: absolute;
    transform: translate(-50%, -50%);
    padding: 10px 14px;
    background: #0A0A0A;
    border: 2px solid #1f1f1f;
    border-radius: 14px;
    color: #cbd5e1;
    font-weight: 700;
    font-size: 14px;
    letter-spacing: 0.01em;
    box-shadow: 6px 6px 0 #000;
    transition: border-color 0.3s ease, color 0.3s ease, transform 0.3s ease, box-shadow 0.3s ease, background 0.3s ease;
  }

  .memory-graph-shell .node.core {
    padding: 18px 24px;
    border-radius: 18px;
    border-color: #6ee7ff;
    background: linear-gradient(145deg, rgba(110, 231, 255, 0.12), rgba(79, 70, 229, 0.12));
    box-shadow: 10px 10px 0 #000;
  }

  .memory-graph-shell .node.pill {
    border-color: #22c55e;
    background: rgba(34, 197, 94, 0.08);
  }

  .memory-graph-shell .node.small {
    font-size: 12px;
    padding: 8px 10px;
  }

  .memory-graph-shell .node.active {
    border-color: #f472b6;
    color: #fdf2f8;
    background: linear-gradient(135deg, rgba(244, 114, 182, 0.18), rgba(56, 189, 248, 0.12));
    box-shadow: 0 0 0 1px rgba(244, 114, 182, 0.35), 8px 8px 0 #000;
    transform: translate(-50%, -50%) scale(1.04);
  }

  .memory-graph-shell .node:hover {
    border-color: #f472b6;
    color: #fdf2f8;
  }

  .memory-graph-shell .edge {
    stroke: currentColor;
    stroke-dasharray: 6 6;
    opacity: 0.35;
    transition: opacity 0.4s ease, stroke 0.4s ease;
  }

  .memory-graph-shell .edge.active {
    stroke: #f472b6;
    opacity: 0.9;
    stroke-dasharray: 2 8;
    animation: dash-move 1.2s linear infinite;
  }

  .graph-lines {
    filter: drop-shadow(0 0 12px rgba(0,0,0,0.2));
  }

  @keyframes dash-move {
    to {
      stroke-dashoffset: -20;
    }
  }
</style>

<script>
  const nodes = Array.from(document.querySelectorAll('[data-node]'));
  const edges = Array.from(document.querySelectorAll('[data-edge]'));

  const sequences = [
    { nodes: ['idea', 'core', 'research'], edges: ['core:idea', 'core:research', 'idea:research'] },
    { nodes: ['habit', 'core', 'code'], edges: ['core:habit', 'core:code', 'habit:code'] },
    { nodes: ['retrieval', 'thread', 'session', 'core'], edges: ['core:retrieval', 'retrieval:thread', 'retrieval:session'] },
    { nodes: ['code', 'research'], edges: ['research:code'] },
  ];

  function clearActive() {
    nodes.forEach((n) => n.classList.remove('active'));
    edges.forEach((e) => e.classList.remove('active'));
  }

  function runSequence(index = 0) {
    const seq = sequences[index % sequences.length];
    clearActive();

    seq.nodes.forEach((id, i) => {
      const nodeEl = nodes.find((n) => n.dataset.node === id);
      if (nodeEl) setTimeout(() => nodeEl.classList.add('active'), 120 * i);
    });

    seq.edges.forEach((id, i) => {
      const edgeEl = edges.find((e) => e.dataset.edge === id);
      if (edgeEl) setTimeout(() => edgeEl.classList.add('active'), 160 * i);
    });

    setTimeout(() => runSequence(index + 1), 3200);
  }

  runSequence();
</script>
