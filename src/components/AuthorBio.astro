---
export interface Props {
  showFullBio?: boolean;
}

const { showFullBio = false } = Astro.props;
---

<div class="author-bio bg-automem-surface rounded-xl p-6 border border-automem-border mt-12">
  <div class="flex gap-6 items-start">
    <!-- Author Photo -->
    <a href="/authors/jack-arturo" class="flex-shrink-0">
      <img
        src="/jack-arturo.jpeg"
        alt="Jack Arturo"
        class="w-24 h-24 rounded-full object-cover border-2 border-automem-accent hover:scale-105 transition-transform"
      />
    </a>

    <!-- Author Info -->
    <div class="flex-1">
      <h3 class="text-xl font-semibold mb-2 text-automem-text">
        <a href="/authors/jack-arturo" class="hover:text-automem-accent transition">
          Jack Arturo
        </a>
      </h3>

      {showFullBio ? (
        <div class="text-automem-muted space-y-3">
          <p>
            Jack has been writing code since he was 12 years old. For the past 12 years, he's been running <a href="https://verygoodplugins.com?utm_source=automem.ai&utm_medium=author-bio&utm_campaign=link" target="_blank" rel="noopener noreferrer" class="text-automem-accent hover:underline">Very Good Plugins</a>, where he built <a href="https://wpfusion.com?utm_source=automem.ai&utm_medium=author-bio&utm_campaign=link" target="_blank" rel="noopener noreferrer" class="text-automem-accent hover:underline">WP Fusion</a>. He co-founded <a href="https://echodash.com?utm_source=automem.ai&utm_medium=author-bio&utm_campaign=link" target="_blank" rel="noopener noreferrer" class="text-automem-accent hover:underline">EchoDash</a> and is deep into AI development with AutoJack, his personal AI assistant.
          </p>
          <p>
            Jack believes in open source software and giving good stuff away. AutoMem is his contribution to making AI memory universal and portable across all platforms.
          </p>
        </div>
      ) : (
        <p class="text-automem-muted mb-4">
          Developer, open source advocate, and builder of AI tools. Creator of AutoMem, WP Fusion, and EchoDash.
        </p>
      )}

      <!-- Social Links -->
      <div class="flex items-center gap-4 mt-4">
        <a
          href="https://github.com/verygoodplugins?utm_source=automem.ai&utm_medium=author-bio&utm_campaign=social"
          target="_blank"
          rel="noopener noreferrer"
          class="text-automem-muted hover:text-automem-accent transition"
          aria-label="GitHub"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
          </svg>
        </a>

        <a
          href="https://drunk.support?utm_source=automem.ai&utm_medium=author-bio&utm_campaign=social"
          target="_blank"
          rel="noopener noreferrer"
          class="text-automem-muted hover:text-automem-accent transition text-sm"
        >
          Blog
        </a>

        <a
          href="/authors/jack-arturo"
          class="text-automem-accent hover:underline text-sm ml-auto"
        >
          More by Jack →
        </a>
      </div>
    </div>
  </div>
</div>
