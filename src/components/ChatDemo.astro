---
// Animated chat demo component
---

<div class="chat-demo-container">
  <div class="chat-window bg-automem-surface rounded-xl shadow-2xl border border-automem-border overflow-hidden max-w-5xl mx-auto">
    <!-- Header -->
    <div class="chat-header bg-automem-bgdark border-b border-automem-border px-6 py-4 flex items-center gap-4">
      <div class="flex items-center gap-3">
        <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-automem-accent">
          <path d="M12 8V4H8"></path>
          <rect width="16" height="12" x="4" y="8" rx="2"></rect>
          <path d="M2 14h2"></path>
          <path d="M20 14h2"></path>
          <path d="M15 13v2"></path>
          <path d="M9 13v2"></path>
        </svg>
        <span class="font-semibold text-automem-text text-lg">AutoJack</span>
      </div>
      <div class="flex-1"></div>
      <div class="flex items-center gap-2">
        <div class="w-2.5 h-2.5 rounded-full bg-automem-green animate-pulse"></div>
        <span class="text-sm text-automem-muted">Online</span>
      </div>
    </div>

    <!-- Messages -->
    <div class="chat-messages p-6 min-h-[600px] max-h-[700px] overflow-y-auto">
      <div class="messages-wrapper space-y-4">
        <!-- Initial greeting - visible from start -->
        <div class="message visible" data-delay="0">
        <div class="flex justify-start">
          <div class="bg-automem-bgdark border border-automem-border px-5 py-3 rounded-lg max-w-[85%]">
            <p class="text-automem-text text-base">👋 Hi! I'm AutoJack. How can I help you today?</p>
          </div>
        </div>
      </div>

      <!-- User message 1 -->
      <div class="message opacity-0" data-delay="800">
        <div class="flex justify-end">
          <div class="bg-automem-accent text-white px-5 py-3 rounded-lg max-w-[80%] text-base">
            Hey! I'm starting a new web project.
          </div>
        </div>
      </div>

      <!-- Typing indicator -->
      <div class="message opacity-0" data-delay="1600">
        <div class="flex justify-start">
          <div class="bg-automem-bgdark border border-automem-border px-5 py-3 rounded-lg">
            <div class="flex gap-1.5">
              <div class="w-2.5 h-2.5 bg-automem-muted rounded-full animate-bounce" style="animation-delay: 0s"></div>
              <div class="w-2.5 h-2.5 bg-automem-muted rounded-full animate-bounce" style="animation-delay: 0.2s"></div>
              <div class="w-2.5 h-2.5 bg-automem-muted rounded-full animate-bounce" style="animation-delay: 0.4s"></div>
            </div>
          </div>
        </div>
      </div>

      <!-- Bot response 1 -->
      <div class="message opacity-0" data-delay="2400">
        <div class="flex justify-start">
          <div class="bg-automem-bgdark border border-automem-border px-5 py-3 rounded-lg max-w-[85%]">
            <p class="text-automem-text text-base">Awesome! Let me check what you usually work with...</p>
          </div>
        </div>
      </div>

      <!-- Thinking block -->
      <div class="message opacity-0" data-delay="3200">
        <div class="bg-purple-900/20 border-l-2 border-purple-500 px-4 py-3 rounded text-sm">
          <div class="flex items-center gap-2 text-purple-400 mb-1.5">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="animate-pulse">
              <path d="M12 2v4m0 12v4M4.93 4.93l2.83 2.83m8.48 8.48l2.83 2.83M2 12h4m12 0h4M4.93 19.07l2.83-2.83m8.48-8.48l2.83-2.83"></path>
            </svg>
            <span>Thinking...</span>
          </div>
          <p class="text-automem-muted text-sm">Let me recall their development preferences</p>
        </div>
      </div>

      <!-- Tool call: recall_memory with spinner -->
      <div class="message opacity-0" data-delay="4000">
        <div class="bg-automem-bgdark/50 border border-automem-border/50 rounded-lg p-3">
          <div class="flex items-center gap-2 mb-2">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-automem-blue animate-spin">
              <path d="M21 12a9 9 0 1 1-6.219-8.56"></path>
            </svg>
            <span class="text-sm font-mono text-automem-blue">recall_memory</span>
          </div>
          <div class="text-sm text-automem-muted font-mono pl-6">
            query: "web development stack"<br/>
            tags: ["coding", "preferences"]
          </div>
        </div>
      </div>

      <!-- Memory cards -->
      <div class="message opacity-0" data-delay="5200">
        <div class="space-y-2.5">
          <div class="memory-card bg-automem-bgdark border border-green-500/30 rounded-lg p-3.5">
            <div class="flex items-start gap-3">
              <span class="px-2.5 py-1 bg-green-900/40 text-green-400 rounded text-sm">Preference</span>
              <div class="flex-1 text-sm text-automem-text">
                Prefers React with TypeScript for web apps
              </div>
              <span class="text-sm text-automem-muted">⭐⭐⭐</span>
            </div>
          </div>
          <div class="memory-card bg-automem-bgdark border border-blue-500/30 rounded-lg p-3.5">
            <div class="flex items-start gap-3">
              <span class="px-2.5 py-1 bg-blue-900/40 text-blue-400 rounded text-sm">Pattern</span>
              <div class="flex-1 text-sm text-automem-text">
                Always uses Tailwind CSS for styling
              </div>
              <span class="text-sm text-automem-muted">⭐⭐⭐</span>
            </div>
          </div>
        </div>
      </div>

      <!-- Bot response 2 -->
      <div class="message opacity-0" data-delay="6400">
        <div class="flex justify-start">
          <div class="bg-automem-bgdark border border-automem-border px-5 py-3 rounded-lg max-w-[85%]">
            <p class="text-automem-text text-base">Perfect! I remember you like <strong class="text-automem-accent">React + TypeScript</strong> with <strong class="text-automem-accent">Tailwind CSS</strong>. Want me to set that up?</p>
          </div>
        </div>
      </div>

      <!-- User message 2 -->
      <div class="message opacity-0" data-delay="7600">
        <div class="flex justify-end">
          <div class="bg-automem-accent text-white px-5 py-3 rounded-lg max-w-[80%] text-base">
            Yes! And use Vite this time.
          </div>
        </div>
      </div>

      <!-- Typing indicator 2 -->
      <div class="message opacity-0" data-delay="8400">
        <div class="flex justify-start">
          <div class="bg-automem-bgdark border border-automem-border px-5 py-3 rounded-lg">
            <div class="flex gap-1.5">
              <div class="w-2.5 h-2.5 bg-automem-muted rounded-full animate-bounce" style="animation-delay: 0s"></div>
              <div class="w-2.5 h-2.5 bg-automem-muted rounded-full animate-bounce" style="animation-delay: 0.2s"></div>
              <div class="w-2.5 h-2.5 bg-automem-muted rounded-full animate-bounce" style="animation-delay: 0.4s"></div>
            </div>
          </div>
        </div>
      </div>

      <!-- Bot asks clarification -->
      <div class="message opacity-0" data-delay="9200">
        <div class="flex justify-start">
          <div class="bg-automem-bgdark border border-automem-border px-5 py-3 rounded-lg max-w-[85%]">
            <p class="text-automem-text text-base">Great choice! Do you want your usual folder structure too?</p>
          </div>
        </div>
      </div>

      <!-- User confirms -->
      <div class="message opacity-0" data-delay="10400">
        <div class="flex justify-end">
          <div class="bg-automem-accent text-white px-5 py-3 rounded-lg max-w-[80%] text-base">
            Yes please!
          </div>
        </div>
      </div>

      <!-- Typing indicator 3 -->
      <div class="message opacity-0" data-delay="11200">
        <div class="flex justify-start">
          <div class="bg-automem-bgdark border border-automem-border px-5 py-3 rounded-lg">
            <div class="flex gap-1.5">
              <div class="w-2.5 h-2.5 bg-automem-muted rounded-full animate-bounce" style="animation-delay: 0s"></div>
              <div class="w-2.5 h-2.5 bg-automem-muted rounded-full animate-bounce" style="animation-delay: 0.2s"></div>
              <div class="w-2.5 h-2.5 bg-automem-muted rounded-full animate-bounce" style="animation-delay: 0.4s"></div>
            </div>
          </div>
        </div>
      </div>

      <!-- Thinking + storing -->
      <div class="message opacity-0" data-delay="12000">
        <div class="bg-purple-900/20 border-l-2 border-purple-500 px-4 py-3 rounded text-sm">
          <div class="flex items-center gap-2 text-purple-400 mb-1.5">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="animate-pulse">
              <path d="M12 2v4m0 12v4M4.93 4.93l2.83 2.83m8.48 8.48l2.83 2.83M2 12h4m12 0h4M4.93 19.07l2.83-2.83m8.48-8.48l2.83-2.83"></path>
            </svg>
            <span>Thinking...</span>
          </div>
          <p class="text-automem-muted text-sm">Vite is new - I should store this preference</p>
        </div>
      </div>

      <!-- Tool call: store_memory with spinner -->
      <div class="message opacity-0" data-delay="13200">
        <div class="bg-automem-bgdark/50 border border-automem-border/50 rounded-lg p-3">
          <div class="flex items-center gap-2 mb-2">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-automem-green animate-spin">
              <path d="M21 12a9 9 0 1 1-6.219-8.56"></path>
            </svg>
            <span class="text-sm font-mono text-automem-green">store_memory</span>
          </div>
          <div class="text-sm text-automem-muted font-mono pl-6">
            content: "Prefers Vite as build tool"<br/>
            type: "Preference"<br/>
            importance: 0.9
          </div>
        </div>
      </div>

      <!-- Tool call: associate_memories with spinner -->
      <div class="message opacity-0" data-delay="14400">
        <div class="bg-automem-bgdark/50 border border-automem-border/50 rounded-lg p-3">
          <div class="flex items-center gap-2 mb-2">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-automem-accent animate-spin">
              <path d="M21 12a9 9 0 1 1-6.219-8.56"></path>
            </svg>
            <span class="text-sm font-mono text-automem-accent">associate_memories</span>
          </div>
          <div class="text-sm text-automem-muted font-mono pl-6">
            type: "RELATES_TO"<br/>
            Vite ↔ React + TypeScript
          </div>
        </div>
      </div>

      <!-- Bot confirmation -->
      <div class="message opacity-0" data-delay="16000">
        <div class="flex justify-start">
          <div class="bg-automem-bgdark border border-automem-border px-5 py-3 rounded-lg max-w-[85%]">
            <p class="text-automem-text text-base">✅ Perfect! Setting up <span class="text-automem-accent font-mono text-sm">React + TypeScript + Vite + Tailwind</span></p>
            <div class="mt-2.5 pt-2.5 border-t border-automem-border/30 text-sm text-automem-muted">
              💾 Remembered your Vite preference for next time!
            </div>
          </div>
        </div>
      </div>

      <!-- User thanks -->
      <div class="message opacity-0" data-delay="17200">
        <div class="flex justify-end">
          <div class="bg-automem-accent text-white px-5 py-3 rounded-lg max-w-[80%] text-base">
            Perfect, thanks! 🙌
          </div>
        </div>
      </div>

      <!-- Typing indicator 4 -->
      <div class="message opacity-0" data-delay="18000">
        <div class="flex justify-start">
          <div class="bg-automem-bgdark border border-automem-border px-5 py-3 rounded-lg">
            <div class="flex gap-1.5">
              <div class="w-2.5 h-2.5 bg-automem-muted rounded-full animate-bounce" style="animation-delay: 0s"></div>
              <div class="w-2.5 h-2.5 bg-automem-muted rounded-full animate-bounce" style="animation-delay: 0.2s"></div>
              <div class="w-2.5 h-2.5 bg-automem-muted rounded-full animate-bounce" style="animation-delay: 0.4s"></div>
            </div>
          </div>
        </div>
      </div>

      <!-- Final bot message -->
      <div class="message opacity-0" data-delay="19200">
        <div class="flex justify-start">
          <div class="bg-automem-bgdark border border-automem-border px-5 py-3 rounded-lg max-w-[85%]">
            <p class="text-automem-text text-base">You're all set! I'll remember these preferences for your future projects. Happy coding! 🚀</p>
          </div>
        </div>
      </div>

      <!-- Summary card -->
      <div class="message opacity-0" data-delay="20400">
        <div class="bg-gradient-to-r from-automem-accent/10 to-automem-blue/10 border border-automem-accent/30 rounded-lg p-4">
          <div class="flex items-center gap-2 mb-2">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-automem-accent">
              <path d="M12 2v20M2 12h20"></path>
            </svg>
            <span class="text-sm font-semibold text-automem-text">Session Summary</span>
          </div>
          <div class="text-sm text-automem-muted space-y-1">
            <div>✅ Retrieved 2 existing memories</div>
            <div>💾 Stored 1 new preference</div>
            <div>🔗 Created 1 memory association</div>
          </div>
        </div>
      </div>
      </div>
    </div>
  </div>
</div>

<style>
  .chat-demo-container {
    perspective: 1000px;
  }

  .chat-messages {
    scrollbar-width: thin;
    scrollbar-color: #4A4744 #3A3734;
  }

  .chat-messages::-webkit-scrollbar {
    width: 6px;
  }

  .chat-messages::-webkit-scrollbar-track {
    background: #3A3734;
  }

  .chat-messages::-webkit-scrollbar-thumb {
    background: #4A4744;
    border-radius: 3px;
  }

  .message {
    transition: opacity 0.4s ease-out, transform 0.4s ease-out;
    opacity: 0;
    transform: translateY(-10px);
  }

  .message.visible {
    opacity: 1;
    transform: translateY(0);
  }

  .memory-card {
    transform: scale(0.95);
    transition: transform 0.4s ease-out;
  }

  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes scaleIn {
    from {
      transform: scale(0.95);
      opacity: 0;
    }
    to {
      transform: scale(1);
      opacity: 1;
    }
  }

  .memory-card:nth-child(2) {
    animation-delay: 0.2s;
  }
</style>

<script>
  const container = document.querySelector('.chat-messages');
  const messages = document.querySelectorAll('.message');

  function scrollToBottom(smooth = false) {
    if (container) {
      container.scrollTo({
        top: container.scrollHeight,
        behavior: smooth ? 'smooth' : 'auto'
      });
    }
  }

  // Ensure we start at the top (first message visible)
  if (container) {
    container.scrollTop = 0;
  }

  function animateMessages() {
    messages.forEach((message, index) => {
      const delay = parseInt(message.getAttribute('data-delay') || '0');
      setTimeout(() => {
        message.classList.add('visible');

        // Smooth scroll to bottom after each message appears
        setTimeout(() => {
          scrollToBottom(true);
        }, 100);
      }, delay);
    });
  }

  // Start animation after a brief moment
  setTimeout(animateMessages, 500);

  // Loop the animation - full cycle is ~21 seconds + 3 second pause = 24 seconds
  setInterval(() => {
    // Reset all messages except the first greeting
    messages.forEach((message, index) => {
      if (index > 0) {
        message.classList.remove('visible');
      }
    });

    // Scroll back to top
    if (container) {
      container.scrollTop = 0;
    }

    // Restart animation after brief pause
    setTimeout(() => {
      animateMessages();
    }, 3000);
  }, 24000);
</script>

