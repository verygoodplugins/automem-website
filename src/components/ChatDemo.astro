---
// Animated chat demo for the hero. Tells one story in two scenes: AutoJack
// recalls the user's stack (lead with recall — the payoff lands immediately),
// then a HARD CUT re-chromes the window to Cursor pulling the *same* memory,
// closing on "one memory. every tool." The whole thing is decorative
// (aria-hidden); the real value prop lives in the H1 + subhead beside it.
//
// Engine notes: beats are declarative with RELATIVE gaps (`after`), so
// reordering/cutting a beat needs no timestamp recompute. A single timeline
// driver owns every timer and cancels them on re-run, so loops never stack.
// IntersectionObserver + visibilitychange gate playback to "visible & focused",
// and `prefers-reduced-motion` swaps the loop for a static end-frame.
---

<div class="chat-demo-container font-mono" aria-hidden="true">
  <div class="chat-window bg-lab-bg border-2 border-lab-text shadow-hard max-w-5xl mx-auto rounded-lg overflow-hidden relative z-10" id="hero-chat-window">
    <!-- Header (re-chromes ./autojack -> Cursor on the scene cut) -->
    <div class="chat-header bg-lab-surface border-b-2 border-lab-text px-4 py-2 flex items-center gap-4 text-sm">
      <div class="flex items-center gap-3">
        <span class="font-bold text-lab-accent-text transition-colors duration-300" id="chrome-name">./autojack</span>
      </div>
      <div class="flex-1 text-center text-lab-muted text-xs opacity-50" id="chrome-subtitle">PID: 8492</div>
      <div class="flex items-center gap-2">
        <div class="w-2 h-2 bg-lab-success animate-pulse"></div>
        <span class="text-xs text-lab-text uppercase">Active</span>
      </div>
    </div>

    <!-- Messages Container -->
    <div class="chat-messages p-6 h-[420px] md:h-[520px] overflow-y-auto bg-lab-bg relative flex flex-col" id="chat-container">

      <!-- Grid overlay -->
      <div class="absolute inset-0 bg-[radial-gradient(#808080_1px,transparent_1px)] [background-size:16px_16px] opacity-10 pointer-events-none"></div>

      <!-- Dynamic spacer that shrinks as messages fill (MSN-style bottom-up) -->
      <div class="spacer flex-shrink-0 transition-all duration-300" id="chat-spacer"></div>

      <!-- Messages are appended here -->
      <div class="messages-list flex flex-col space-y-5 relative z-10" id="messages-list"></div>
    </div>
  </div>
</div>

<style>
  .chat-messages {
    scrollbar-width: thin;
    scrollbar-color: rgb(128 128 128 / 0.45) transparent;
    /* Fade the top edge so overflowing messages scroll out gracefully instead of
       hard-clipping under the header. An alpha mask is theme-agnostic — no color
       token to keep in sync between dark and light. */
    -webkit-mask-image: linear-gradient(to bottom, transparent 0, #000 2.5rem);
    mask-image: linear-gradient(to bottom, transparent 0, #000 2.5rem);
  }

  .chat-messages::-webkit-scrollbar {
    width: 6px;
  }

  .chat-messages::-webkit-scrollbar-track {
    background: transparent;
  }

  .chat-messages::-webkit-scrollbar-thumb {
    background: rgb(128 128 128 / 0.45);
    border-radius: 3px;
  }

  .message-enter {
    animation: slideUp 0.4s ease-out forwards;
  }

  /* The "↳ result" line of a recall card reveals just after the call settles,
     so it reads as "querying → resolved" rather than appearing all at once. */
  .tool-result {
    animation: fadeIn 0.45s ease-out 0.4s both;
  }

  @keyframes slideUp {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes fadeIn {
    from { opacity: 0; }
    to { opacity: 1; }
  }

  @media (prefers-reduced-motion: reduce) {
    .message-enter,
    .tool-result {
      animation: none;
      opacity: 1;
    }
  }
</style>

<script>
  // --- Story (declarative beats; `after` = ms gap BEFORE this beat) -----------
  // kinds: agent | user | tool | system | tagline | scene
  const beats = [
    // Scene 1 — ./autojack
    { kind: 'agent', text: "Hi! I'm AutoJack. How can I help you today?", after: 400 },
    { kind: 'user', text: "Hey! I'm starting a new web project.", after: 1600 },
    { kind: 'tool', arg: '"build tooling, framework prefs"', result: '3 memories found', after: 1400 },
    { kind: 'agent', html: 'Same stack as always? <strong class="text-lab-secondary">React + TS + Tailwind</strong>, Vite over webpack. I’ve got it from last time.', after: 2400 },
    { kind: 'user', text: 'Yeah, exactly that.', after: 1900 },
    { kind: 'agent', text: 'Scaffolding now. ✓', after: 1500 },

    // HARD CUT — re-chrome the window to Cursor
    { kind: 'scene', name: 'Cursor', subtitle: '~/web-project', accent: 'violet', after: 1500 },

    // Scene 2 — Cursor (a visibly different tool, pulling the SAME memory)
    { kind: 'system', label: 'Cursor', text: 'Configuring build…', after: 700 },
    { kind: 'tool', arg: 'via AutoMem', result: 'using Vite (your saved preference)', after: 1400 },
    { kind: 'tagline', after: 1600 },
  ];

  const LOOP_HOLD = 4200; // dwell on the tagline before restarting

  // --- DOM refs ---------------------------------------------------------------
  const windowEl = document.getElementById('hero-chat-window');
  const container = document.getElementById('chat-container');
  const spacer = document.getElementById('chat-spacer');
  const list = document.getElementById('messages-list');
  const nameEl = document.getElementById('chrome-name');
  const subtitleEl = document.getElementById('chrome-subtitle');

  const prefersReduced =
    typeof window.matchMedia === 'function' &&
    window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  // --- Renderers (one per kind; reuse the established lab-token vocabulary) ----
  function renderHTML(beat) {
    switch (beat.kind) {
      case 'agent':
        return `<div class="flex justify-start">
          <div class="bg-lab-surface border-2 border-lab-text px-4 py-3 rounded-lg max-w-[85%] shadow-hard">
            <div class="text-lab-muted text-[0.65rem] font-bold mb-1.5 uppercase tracking-wider">AutoJack</div>
            <p class="text-lab-text text-sm leading-relaxed">${beat.html ?? beat.text}</p>
          </div>
        </div>`;

      case 'user':
        return `<div class="flex justify-end">
          <div class="bg-lab-text text-lab-bg px-4 py-3 max-w-[80%] text-sm font-bold border-2 border-lab-text rounded-lg shadow-hard">
            ${beat.text}
          </div>
        </div>`;

      // A build-tool log line — deliberately NOT a chat bubble, to read as a
      // different kind of app. Violet hairline ties it to the re-chromed header.
      case 'system':
        return `<div class="flex justify-start">
          <div class="bg-lab-surface/60 border border-lab-secondary/40 px-4 py-3 rounded-lg max-w-[85%] font-mono text-sm">
            <div class="text-lab-secondary text-[0.65rem] font-bold mb-1.5 uppercase tracking-wider">${beat.label}</div>
            <p class="text-lab-text">${beat.text}</p>
          </div>
        </div>`;

      // The visible MCP function call — "real plumbing, not vibes."
      case 'tool':
        return `<div class="bg-lab-bg border border-lab-muted/30 p-3 text-xs font-mono">
          <div class="flex items-center gap-2 flex-wrap">
            <span class="text-lab-accent-text">⟳</span>
            <span class="text-lab-secondary font-bold">recall_memory</span>
            <span class="text-lab-muted">·</span>
            <span class="text-lab-success">${beat.arg}</span>
          </div>
          <div class="tool-result mt-2 pl-5 flex items-center gap-1.5 text-lab-muted">
            <span class="text-lab-accent-text">↳</span>
            <span>${beat.result}</span>
          </div>
        </div>`;

      // The punch line. Gold "one memory." + violet "every tool." braids the
      // two scenes' accents together.
      case 'tagline':
        return `<div class="flex justify-center pt-3">
          <div class="flex items-center gap-2.5 text-base md:text-lg font-bold tracking-tight">
            <span aria-hidden="true">💾</span>
            <span class="text-lab-accent-text">one memory. <span class="text-lab-secondary">every tool.</span></span>
          </div>
        </div>`;

      default:
        return '';
    }
  }

  // --- Layout helpers ---------------------------------------------------------
  function resetSpacer() {
    if (!container || !spacer) return;
    spacer.style.height = Math.max(0, container.clientHeight - 48) + 'px';
    container.scrollTop = 0;
  }

  function updateSpacerHeight() {
    if (!container || !spacer || !list) return;
    const containerHeight = container.clientHeight - 48; // account for padding
    const listHeight = list.scrollHeight;
    spacer.style.height = Math.max(0, containerHeight - listHeight) + 'px';
    if (listHeight > containerHeight) {
      container.scrollTo({ top: container.scrollHeight, behavior: 'smooth' });
    }
  }

  function setChrome(name, subtitle, accent) {
    if (nameEl) {
      nameEl.textContent = name;
      nameEl.classList.toggle('text-lab-secondary', accent === 'violet');
      nameEl.classList.toggle('text-lab-accent-text', accent !== 'violet');
    }
    if (subtitleEl) subtitleEl.textContent = subtitle;
  }

  function addMessage(html) {
    if (!list) return;
    const msg = document.createElement('div');
    msg.className = 'message-enter';
    msg.innerHTML = html;
    list.appendChild(msg);
    requestAnimationFrame(updateSpacerHeight);
  }

  function resetToScene1() {
    if (list) list.innerHTML = '';
    setChrome('./autojack', 'PID: 8492', 'gold');
    resetSpacer();
  }

  function renderBeat(beat) {
    if (beat.kind === 'scene') {
      // The cut: re-chrome the header, wipe the transcript, reset the spacer so
      // Scene 2 also fills bottom-up.
      setChrome(beat.name, beat.subtitle, beat.accent);
      if (list) list.innerHTML = '';
      resetSpacer();
      return;
    }
    addMessage(renderHTML(beat));
  }

  // --- Timeline driver (owns every timer; restart-safe) -----------------------
  let timers = [];
  let running = false;

  function clearTimers() {
    timers.forEach((id) => clearTimeout(id));
    timers = [];
  }

  function play() {
    clearTimers();
    resetToScene1();
    let t = 0;
    for (const beat of beats) {
      t += beat.after;
      timers.push(setTimeout(() => renderBeat(beat), t));
    }
    // Computed loop gap — no magic number to keep in sync with the script length.
    timers.push(setTimeout(play, t + LOOP_HOLD));
  }

  // --- Static frame for reduced-motion: the Cursor payoff, no animation -------
  function renderStaticEndFrame() {
    setChrome('Cursor', '~/web-project', 'violet');
    resetSpacer();
    addMessage(renderHTML({ kind: 'system', label: 'Cursor', text: 'Configuring build…' }));
    addMessage(renderHTML({ kind: 'tool', arg: 'via AutoMem', result: 'using Vite (your saved preference)' }));
    addMessage(renderHTML({ kind: 'tagline' }));
  }

  // --- Playback gating: only run when visible AND the tab is focused -----------
  let inView = false;

  function sync() {
    const shouldRun = inView && !document.hidden;
    if (shouldRun && !running) {
      running = true;
      play();
    } else if (!shouldRun && running) {
      running = false;
      clearTimers();
    }
  }

  function start() {
    if (prefersReduced) {
      renderStaticEndFrame();
      return;
    }
    if (windowEl && typeof IntersectionObserver === 'function') {
      const io = new IntersectionObserver(
        (entries) => {
          inView = entries.some((e) => e.isIntersecting);
          sync();
        },
        { threshold: 0.25 }
      );
      io.observe(windowEl);
    } else {
      inView = true;
    }
    document.addEventListener('visibilitychange', sync);
    sync();
  }

  start();
</script>
