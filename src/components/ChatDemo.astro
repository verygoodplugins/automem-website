---
// Animated chat demo component with MSN Messenger-style bottom-up animation
---

<div class="chat-demo-container font-mono">
  <div class="chat-window bg-lab-bg border-2 border-lab-text shadow-hard max-w-5xl mx-auto rounded-lg overflow-hidden relative z-10">
    <!-- Header -->
    <div class="chat-header bg-lab-surface border-b-2 border-lab-text px-4 py-2 flex items-center gap-4 text-sm">
      <div class="flex items-center gap-3">
        <span class="text-lab-accent font-bold">./autojack</span>
      </div>
      <div class="flex-1 text-center text-lab-muted text-xs opacity-50">PID: 8492</div>
      <div class="flex items-center gap-2">
        <div class="w-2 h-2 bg-lab-success animate-pulse"></div>
        <span class="text-xs text-lab-text uppercase">Active</span>
      </div>
    </div>

    <!-- Messages Container -->
    <div class="chat-messages p-6 h-[420px] md:h-[480px] overflow-y-auto bg-lab-bg relative flex flex-col" id="chat-container">
      
      <!-- Grid overlay -->
      <div class="absolute inset-0 bg-[radial-gradient(#333_1px,transparent_1px)] [background-size:16px_16px] opacity-10 pointer-events-none"></div>
      
      <!-- Dynamic spacer that shrinks as messages fill -->
      <div class="spacer flex-shrink-0 transition-all duration-300" id="chat-spacer"></div>
      
      <!-- Messages will be appended here -->
      <div class="messages-list flex flex-col space-y-6 relative z-10" id="messages-list"></div>
    </div>
  </div>
</div>

<style>
  .chat-messages {
    scrollbar-width: thin;
    scrollbar-color: #333 #0A0A0A;
  }

  .chat-messages::-webkit-scrollbar {
    width: 6px;
  }

  .chat-messages::-webkit-scrollbar-track {
    background: #0A0A0A;
  }

  .chat-messages::-webkit-scrollbar-thumb {
    background: #333;
    border-radius: 3px;
  }

  .message-enter {
    animation: slideUp 0.4s ease-out forwards;
  }

  @keyframes slideUp {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .message-enter {
      animation: none;
      opacity: 1;
    }
  }
</style>

<script>
  const messageTemplates = [
    {
      delay: 0,
      html: `<div class="flex justify-start">
        <div class="bg-lab-surface border-2 border-lab-text px-4 py-4 rounded-lg max-w-[85%] shadow-hard">
          <div class="text-lab-muted text-xs font-bold mb-2 uppercase tracking-wider">AutoJack</div>
          <p class="text-lab-text text-sm">Hi! I'm AutoJack. How can I help you today?</p>
        </div>
      </div>`
    },
    {
      delay: 800,
      html: `<div class="flex justify-end">
        <div class="bg-lab-text text-lab-bg px-4 py-3 max-w-[80%] text-sm font-bold border-2 border-lab-text rounded-lg shadow-hard">
          Hey! I'm starting a new web project.
        </div>
      </div>`
    },
    {
      delay: 1600,
      html: `<div class="flex justify-start">
        <div class="pl-4 text-lab-muted text-xs animate-pulse">
          analyzing...
        </div>
      </div>`
    },
    {
      delay: 2400,
      html: `<div class="flex justify-start">
        <div class="bg-lab-surface border border-lab-text px-4 py-3 text-sm w-full md:w-auto">
          <p class="text-lab-text">> Awesome! Let me check what you usually work with...</p>
        </div>
      </div>`
    },
    {
      delay: 3200,
      html: `<div class="bg-lab-accent/10 border-l-4 border-lab-accent px-4 py-3 text-xs font-mono">
        <div class="flex items-center gap-2 text-lab-accent mb-1.5 font-bold uppercase">
          <span class="animate-pulse">●</span>
          <span>PROCESSING...</span>
        </div>
        <p class="text-lab-muted">Let me recall their development preferences</p>
      </div>`
    },
    {
      delay: 4000,
      html: `<div class="bg-lab-bg border border-lab-muted/30 p-3 text-xs font-mono">
        <div class="flex items-center gap-2 mb-2 border-b border-lab-muted/20 pb-1">
          <span class="text-lab-accent">> function call:</span>
        </div>
        <div class="text-lab-text pl-2">
          <span class="text-lab-secondary">recall_memory</span>(<span class="text-lab-success">"web development stack"</span>)
        </div>
      </div>`
    },
    {
      delay: 5200,
      html: `<div class="space-y-3 pl-4 border-l-2 border-lab-border">
        <div class="memory-card bg-lab-surface border border-lab-text p-3 shadow-hard transform transition-transform hover:-translate-y-1">
          <div class="flex items-center gap-3 mb-2">
            <span class="px-2 py-0.5 bg-lab-bg border border-lab-text text-xs uppercase font-bold text-lab-text">Preference</span>
            <span class="text-xs text-lab-muted ml-auto">0x1A4F</span>
          </div>
          <div class="text-sm text-lab-text">
            Prefers <span class="text-lab-secondary">React</span> with <span class="text-lab-secondary">TypeScript</span> for web apps
          </div>
        </div>
        <div class="memory-card bg-lab-secondary/10 border border-lab-secondary p-3 shadow-hard transform transition-transform hover:-translate-y-1">
          <div class="flex items-center gap-3 mb-2">
            <span class="px-2 py-0.5 bg-lab-secondary text-lab-bg text-xs uppercase font-bold">Pattern</span>
            <div class="flex ml-auto gap-0.5">
              <span class="text-lab-success text-xs">★</span>
              <span class="text-lab-success text-xs">★</span>
              <span class="text-lab-success text-xs">★</span>
            </div>
          </div>
          <div class="text-sm text-lab-text">
            Always uses <span class="text-lab-secondary">Tailwind CSS</span> for styling
          </div>
        </div>
      </div>`
    },
    {
      delay: 6400,
      html: `<div class="flex justify-start">
        <div class="bg-lab-surface border border-lab-text px-4 py-3 max-w-[85%] shadow-hard">
          <p class="text-lab-text text-base">Perfect! I remember you like <strong class="text-lab-secondary">React + TypeScript</strong> with <strong class="text-lab-secondary">Tailwind CSS</strong>. Want me to set that up?</p>
        </div>
      </div>`
    },
    {
      delay: 7600,
      html: `<div class="flex justify-end">
        <div class="bg-lab-text text-lab-bg px-4 py-3 max-w-[80%] text-sm font-bold border-2 border-lab-text rounded-lg shadow-hard">
          Yes! And use Vite this time.
        </div>
      </div>`
    },
    {
      delay: 8400,
      html: `<div class="flex justify-start">
        <div class="bg-lab-surface border border-lab-text px-4 py-3">
          <div class="flex gap-1.5">
            <div class="w-2.5 h-2.5 bg-lab-text rounded-full animate-bounce" style="animation-delay: 0s"></div>
            <div class="w-2.5 h-2.5 bg-lab-text rounded-full animate-bounce" style="animation-delay: 0.2s"></div>
            <div class="w-2.5 h-2.5 bg-lab-text rounded-full animate-bounce" style="animation-delay: 0.4s"></div>
          </div>
        </div>
      </div>`
    },
    {
      delay: 9200,
      html: `<div class="flex justify-start">
        <div class="bg-lab-surface border border-lab-text px-4 py-3 max-w-[85%] shadow-hard">
          <p class="text-lab-text text-base">Great choice! Do you want your usual folder structure too?</p>
        </div>
      </div>`
    },
    {
      delay: 10400,
      html: `<div class="flex justify-end">
        <div class="bg-lab-text text-lab-bg px-4 py-3 max-w-[80%] text-sm font-bold border-2 border-lab-text rounded-lg shadow-hard">
          Yes please!
        </div>
      </div>`
    },
    {
      delay: 12000,
      html: `<div class="bg-lab-secondary/10 border-l-4 border-lab-secondary px-4 py-3 text-xs font-mono">
        <div class="flex items-center gap-2 text-lab-secondary mb-1.5 font-bold uppercase">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="animate-spin">
            <path d="M12 2v4m0 12v4M4.93 4.93l2.83 2.83m8.48 8.48l2.83 2.83M2 12h4m12 0h4M4.93 19.07l2.83-2.83m8.48-8.48l2.83-2.83"></path>
          </svg>
          <span>STORING_NEW_MEMORY...</span>
        </div>
        <p class="text-lab-muted text-sm">Vite is new - I should store this preference</p>
      </div>`
    },
    {
      delay: 13200,
      html: `<div class="bg-lab-bg border border-lab-success/30 p-3 text-xs font-mono shadow-hard">
        <div class="flex items-center gap-2 mb-2">
          <span class="text-lab-success">> function call:</span>
          <span class="text-lab-text font-bold">store_memory</span>
        </div>
        <div class="text-lab-muted pl-2 border-l border-lab-success/20 ml-1">
          content: <span class="text-lab-success">"Prefers Vite as build tool"</span><br/>
          type: <span class="text-lab-secondary">"Preference"</span><br/>
          importance: <span class="text-lab-accent">0.9</span>
        </div>
      </div>`
    },
    {
      delay: 16000,
      html: `<div class="flex justify-start">
        <div class="bg-lab-surface border border-lab-text px-4 py-3 max-w-[85%] shadow-hard">
          <p class="text-lab-text text-base">✅ Perfect! Setting up <span class="text-lab-secondary font-mono text-sm">React + TypeScript + Vite + Tailwind</span></p>
          <div class="mt-2.5 pt-2.5 border-t border-lab-border text-xs text-lab-muted flex items-center gap-2">
            <span>💾</span> Remembered your Vite preference for next time!
          </div>
        </div>
      </div>`
    },
    {
      delay: 17200,
      html: `<div class="flex justify-end">
        <div class="bg-lab-text text-lab-bg px-4 py-3 max-w-[80%] text-sm font-bold border-2 border-lab-text rounded-lg shadow-hard">
          Perfect, thanks! 🙌
        </div>
      </div>`
    },
    {
      delay: 18500,
      html: `<div class="bg-lab-surface border-2 border-lab-accent p-4 shadow-hard">
        <div class="flex items-center gap-2 mb-3 pb-2 border-b border-lab-border">
          <span class="text-lab-accent font-bold uppercase text-xs tracking-widest">:: SESSION_LOG</span>
        </div>
        <div class="text-sm text-lab-text space-y-2 font-mono">
          <div class="flex items-center gap-2"><span class="text-lab-success">✔</span> Retrieved 2 existing memories</div>
          <div class="flex items-center gap-2"><span class="text-lab-secondary">💾</span> Stored 1 new preference</div>
          <div class="flex items-center gap-2"><span class="text-lab-accent">∞</span> Created 1 memory association</div>
        </div>
      </div>`
    }
  ];

  const container = document.getElementById('chat-container');
  const spacer = document.getElementById('chat-spacer');
  const list = document.getElementById('messages-list');

  function updateSpacerHeight() {
    if (!container || !spacer || !list) return;
    const containerHeight = container.clientHeight - 48; // Account for padding
    const listHeight = list.scrollHeight;
    const newSpacerHeight = Math.max(0, containerHeight - listHeight);
    spacer.style.height = newSpacerHeight + 'px';
    
    // If content overflows, scroll to bottom
    if (listHeight > containerHeight) {
      container.scrollTo({ top: container.scrollHeight, behavior: 'smooth' });
    }
  }

  function addMessage(html) {
    if (!list) return;
    const msgDiv = document.createElement('div');
    msgDiv.className = 'message-enter';
    msgDiv.innerHTML = html;
    list.appendChild(msgDiv);
    
    // Update spacer after message is added
    requestAnimationFrame(() => {
      updateSpacerHeight();
    });
  }

  function runAnimation() {
    // Clear previous messages
    if (list) list.innerHTML = '';
    if (spacer) spacer.style.height = (container ? container.clientHeight - 48 : 400) + 'px';
    if (container) container.scrollTop = 0;

    // Schedule each message
    messageTemplates.forEach((msg) => {
      setTimeout(() => {
        addMessage(msg.html);
      }, msg.delay);
    });
  }

  // Initial run
  setTimeout(runAnimation, 500);

  // Loop every 25 seconds
  setInterval(runAnimation, 25000);
</script>
