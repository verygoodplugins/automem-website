---
import AutoJack from './AutoJack.astro';

const INSTAPODS_REFERRAL_URL = 'https://instapods.com/apps/automem/?ref=jack';
---

<footer class="border-t border-lab-border/80 px-4 py-8 text-xs text-lab-muted sm:px-7 lg:px-10">
  <div class="mx-auto flex max-w-[1440px] flex-col gap-5 md:flex-row md:items-center md:justify-between">
    <div class="flex flex-wrap items-center gap-x-8 gap-y-3">
      <span>© 2026 AutoMem</span>
      <a href="/docs/development/releases/" class="no-underline transition-colors hover:text-lab-accent-text">Apache-2.0</a>
      <a href="https://github.com/verygoodplugins/automem" target="_blank" rel="noopener noreferrer" class="no-underline transition-colors hover:text-lab-accent-text">GitHub</a>
      <a href="https://automem.ai/discord" target="_blank" rel="noopener noreferrer" class="no-underline transition-colors hover:text-lab-accent-text">Discord</a>
      <a href={INSTAPODS_REFERRAL_URL} target="_blank" rel="noopener noreferrer" class="no-underline transition-colors hover:text-lab-accent-text">InstaPods</a>
    </div>

    <div class="flex items-center gap-2">
      <span>Made with</span>
      <span class="text-lab-accent-text" aria-hidden="true">♥</span>
      <span>by the community</span>
      <span class="ml-2 inline-flex h-8 w-8 items-center justify-center" aria-label="AutoJack mascot" title="AutoJack mascot">
        <AutoJack size={30} expression="happy" animate={false} />
      </span>
    </div>
  </div>
</footer>
