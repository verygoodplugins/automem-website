---
import AutoJack from './AutoJack.astro';
import type { ChromeLink } from '../lib/cms-chrome';

interface Props {
  menuItems?: ChromeLink[];
}

const INSTAPODS_REFERRAL_URL = 'https://instapods.com/apps/automem/?ref=jack';
const fallbackLinks: ChromeLink[] = [
  {
    href: 'https://github.com/verygoodplugins/automem/blob/main/LICENSE',
    label: 'MIT License',
    target: '_blank',
    rel: 'noopener noreferrer',
  },
  {
    href: 'https://github.com/verygoodplugins/automem',
    label: 'GitHub',
    target: '_blank',
    rel: 'noopener noreferrer',
  },
  {
    href: 'https://automem.ai/discord',
    label: 'Discord',
    target: '_blank',
    rel: 'noopener noreferrer',
  },
  {
    href: INSTAPODS_REFERRAL_URL,
    label: 'InstaPods',
    target: '_blank',
    rel: 'noopener noreferrer',
  },
];

const { menuItems = fallbackLinks } = Astro.props;
---

<footer class="border-t border-lab-border/80 px-4 py-8 text-xs text-lab-muted sm:px-7 lg:px-10">
  <div class="mx-auto flex max-w-[1440px] flex-col gap-5 md:flex-row md:items-center md:justify-between">
    <div class="flex flex-wrap items-center gap-x-8 gap-y-3">
      <span>© 2026 AutoMem</span>
      {menuItems.map((item) => (
        <a
          href={item.href}
          target={item.target}
          rel={item.rel}
          class="no-underline transition-colors hover:text-lab-accent-text"
        >
          {item.label}
        </a>
      ))}
    </div>

    <div class="flex items-center gap-2">
      <span>Made with</span>
      <span class="text-lab-accent-text" aria-hidden="true">♥</span>
      <span>by the community</span>
      <span class="ml-2 inline-flex h-8 w-8 items-center justify-center" aria-label="AutoJack mascot" title="AutoJack mascot">
        <AutoJack size={30} expression="happy" animate={false} />
      </span>
    </div>
  </div>
</footer>
