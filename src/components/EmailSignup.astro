---
// EmailSignup Component
const siteKey = import.meta.env.PUBLIC_TURNSTILE_SITE_KEY;
---

<div id="signup-form" class="w-full max-w-md mx-auto">
  <form id="waitlist-form" class="flex flex-col sm:flex-row gap-3">
    <input
      type="email"
      id="email-input"
      placeholder="Enter your email"
      required
      class="flex-1 px-4 py-3 rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 focus:outline-none focus:border-automem-primary transition"
    />
    <button
      type="submit"
      id="submit-btn"
      class="gradient-bg text-white px-6 py-3 rounded-lg font-semibold hover:opacity-90 transition disabled:opacity-50"
    >
      Get Early Access
    </button>
  </form>
  <div id="message" class="mt-3 text-sm text-center hidden"></div>
  <div id="count" class="mt-2 text-xs text-gray-500 text-center hidden"></div>
  <div id="success-actions" class="mt-4 text-center hidden">
    <a
      id="repo-button"
      href="https://github.com/verygoodplugins/automem?utm_source=automem.ai&utm_medium=gate&utm_campaign=waitlist"
      class="border-2 border-automem-accent text-automem-accent px-6 py-3 rounded-lg font-semibold hover:bg-automem-surface transition inline-block"
    >
      Open GitHub Repo
    </a>
  </div>
  <div class="mt-4">
    <div id="turnstile-container" class="cf-turnstile" data-sitekey={siteKey} data-theme="auto" data-callback="__turnstileCb"></div>
  </div>
</div>

{siteKey && (
  <script src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>
)}
<script>
  const form = document.getElementById('waitlist-form');
  const emailInput = document.getElementById('email-input');
  const submitBtn = document.getElementById('submit-btn');
  const message = document.getElementById('message');
  const count = document.getElementById('count');
  let turnstileToken = '';
  const tsContainer = document.getElementById('turnstile-container');
  let siteKeyFromAttr = (tsContainer?.getAttribute?.('data-sitekey') || '').trim();
  let runtimeSiteKey = '';
  const hasTurnstile = true; // we always render the container; decide key at runtime
  const actions = document.getElementById('success-actions');
  const repoBtn = document.getElementById('repo-button');

  // Callback invoked by Turnstile when ready/solved
  window.__turnstileCb = function(token) {
    turnstileToken = token || '';
  }

  function ensureScriptLoaded() {
    return new Promise((resolve) => {
      if (window.turnstile) return resolve();
      const existing = document.querySelector('script[src*="challenges.cloudflare.com/turnstile"]');
      if (existing) {
        existing.addEventListener('load', () => resolve());
        return;
      }
      const s = document.createElement('script');
      s.src = 'https://challenges.cloudflare.com/turnstile/v0/api.js';
      s.async = true;
      s.defer = true;
      s.onload = () => resolve();
      document.head.appendChild(s);
    });
  }

  let configPromise = null;

  async function fetchSiteKey() {
    if (siteKeyFromAttr) return siteKeyFromAttr;
    if (runtimeSiteKey) return runtimeSiteKey;
    if (!configPromise) {
      configPromise = fetch('/api/public-config').then(r => r.json()).catch(() => ({}));
    }
    const cfg = await configPromise;
    runtimeSiteKey = (cfg && (cfg.turnstileSiteKey || cfg.siteKey || '')) || '';
    return runtimeSiteKey;
  }

  async function ensureWidgetRendered() {
    if (!hasTurnstile) return;
    await ensureScriptLoaded();
    // Wait a tick so modal becomes visible
    await new Promise(r => setTimeout(r, 0));
    try {
      const key = await fetchSiteKey();
      if (!key) return; // no key available
      // If not rendered yet (no iframe), render programmatically
      const already = tsContainer && tsContainer.querySelector && tsContainer.querySelector('iframe');
      if (!already && window.turnstile && tsContainer) {
        window.turnstile.render(tsContainer, {
          sitekey: key,
          callback: window.__turnstileCb,
          theme: 'auto'
        });
      } else if (window.turnstile) {
        // Reset to ensure a fresh challenge
        try { window.turnstile.reset(); } catch {}
      }
    } catch {}
  }

  // When modal opens, ensure the widget is rendered (or reset)
  window.addEventListener('github:modal-open', () => {
    ensureWidgetRendered();
  });

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    
    const email = (emailInput && 'value' in emailInput ? emailInput.value : '').trim();
    if (!email) return;

    // Disable form
    if (submitBtn) submitBtn.disabled = true;
    if (submitBtn) submitBtn.textContent = 'Joining...';
    
    try {
      if (hasTurnstile && !turnstileToken) {
        if (message) {
          message.classList.remove('hidden');
          message.classList.remove('text-green-600');
          message.classList.add('text-red-600');
          message.textContent = 'Please complete the verification.';
        }
        if (submitBtn) {
          submitBtn.disabled = false;
          submitBtn.textContent = 'Get Early Access';
        }
        return;
      }
      const response = await fetch('/api/signup', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json'
        },
        body: JSON.stringify({ 
          email,
          source: window.location.pathname,
          turnstileToken
        })
      });

      const data = await response.json();
      
      // Show message
      if (message) message.classList.remove('hidden');
      
      if (data.success) {
        if (message) {
          message.classList.remove('text-red-600');
          message.classList.add('text-green-600');
          message.textContent = data.message || 'Successfully joined the waitlist!';
        }
        
        if (data.position && count) {
          count.classList.remove('hidden');
          count.textContent = `You're among the first ${data.position}`;
        }

        // If not a confirm-required flow, show the repo button as a clear next step
        const requiresConfirm = typeof data.message === 'string' && /confirm/i.test(data.message);
        if (!requiresConfirm && actions) {
          actions.classList.remove('hidden');
          if (repoBtn && repoBtn.focus) {
            try { repoBtn.focus(); } catch {}
          }
        }
        
        // Clear form
        if (emailInput && 'value' in emailInput) emailInput.value = '';
        
        // Track conversion if analytics present
        if (typeof window.gtag !== 'undefined') {
          window.gtag('event', 'conversion', {
            'event_category': 'Waitlist',
            'event_label': 'Homepage Signup'
          });
        }
      } else {
        if (message) {
          message.classList.remove('text-green-600');
          message.classList.add('text-red-600');
          message.textContent = data.error || 'Something went wrong. Please try again.';
        }
      }
    } catch (error) {
      if (message) {
        message.classList.remove('hidden', 'text-green-600');
        message.classList.add('text-red-600');
        message.textContent = 'Network error. Please try again.';
      }
    } finally {
      // Re-enable form
      if (submitBtn) submitBtn.disabled = false;
      if (submitBtn) submitBtn.textContent = 'Get Early Access';
    }
  });
</script>
