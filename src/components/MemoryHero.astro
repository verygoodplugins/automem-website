---
// MemoryHero - Animated transformation showing AI before/after memory
---

<section class="memory-hero relative overflow-hidden py-16 md:py-24" id="memory-hero">
  
  <div class="memory-graph absolute inset-0 pointer-events-none" id="memory-graph">
    <svg class="w-full h-full" viewBox="0 0 800 500" preserveAspectRatio="xMidYMid slice">
      <defs>
        <radialGradient id="nodeGlow" cx="50%" cy="50%" r="50%">
          <stop offset="0%" style="stop-color:#F9D857;stop-opacity:1"/>
          <stop offset="100%" style="stop-color:#F9D857;stop-opacity:0"/>
        </radialGradient>
        <filter id="glow">
          <feGaussianBlur stdDeviation="3" result="coloredBlur"/>
          <feMerge>
            <feMergeNode in="coloredBlur"/>
            <feMergeNode in="SourceGraphic"/>
          </feMerge>
        </filter>
      </defs>
      
      <g class="connections" id="connections">
        <line class="connection c1" x1="400" y1="250" x2="200" y2="120"/>
        <line class="connection c2" x1="400" y1="250" x2="600" y2="100"/>
        <line class="connection c3" x1="400" y1="250" x2="150" y2="300"/>
        <line class="connection c4" x1="400" y1="250" x2="650" y2="280"/>
        <line class="connection c5" x1="400" y1="250" x2="300" y2="400"/>
        <line class="connection c6" x1="400" y1="250" x2="550" y2="420"/>
        <line class="connection c7" x1="200" y1="120" x2="150" y2="300"/>
        <line class="connection c8" x1="600" y1="100" x2="650" y2="280"/>
      </g>
      
      <g class="nodes" id="nodes">
        <g class="node node-center" data-delay="0">
          <circle cx="400" cy="250" r="25" fill="url(#nodeGlow)" filter="url(#glow)"/>
          <circle cx="400" cy="250" r="12" fill="#F9D857"/>
          <text x="400" y="255" text-anchor="middle" class="node-label center-label">JACK</text>
        </g>
        
        <g class="node node-1" data-delay="200">
          <circle cx="200" cy="120" r="18" fill="url(#nodeGlow)" filter="url(#glow)"/>
          <circle cx="200" cy="120" r="8" fill="#FFD966"/>
          <text x="200" y="95" text-anchor="middle" class="node-label">Berlin</text>
        </g>
        
        <g class="node node-2" data-delay="350">
          <circle cx="600" cy="100" r="20" fill="url(#nodeGlow)" filter="url(#glow)"/>
          <circle cx="600" cy="100" r="9" fill="#5B21B6"/>
          <text x="600" y="75" text-anchor="middle" class="node-label">React Dev</text>
        </g>
        
        <g class="node node-3" data-delay="500">
          <circle cx="150" cy="300" r="16" fill="url(#nodeGlow)" filter="url(#glow)"/>
          <circle cx="150" cy="300" r="7" fill="#34D399"/>
          <text x="150" y="325" text-anchor="middle" class="node-label">WP Fusion</text>
        </g>
        
        <g class="node node-4" data-delay="650">
          <circle cx="650" cy="280" r="22" fill="url(#nodeGlow)" filter="url(#glow)"/>
          <circle cx="650" cy="280" r="10" fill="#F9D857"/>
          <text x="650" y="310" text-anchor="middle" class="node-label">Dashboard</text>
        </g>
        
        <g class="node node-5" data-delay="800">
          <circle cx="300" cy="400" r="14" fill="url(#nodeGlow)" filter="url(#glow)"/>
          <circle cx="300" cy="400" r="6" fill="#FFD966"/>
          <text x="300" y="425" text-anchor="middle" class="node-label">utm: automem</text>
        </g>
        
        <g class="node node-6" data-delay="950">
          <circle cx="550" cy="420" r="17" fill="url(#nodeGlow)" filter="url(#glow)"/>
          <circle cx="550" cy="420" r="7" fill="#5B21B6"/>
          <text x="550" y="445" text-anchor="middle" class="node-label">Kitty Rick</text>
        </g>
      </g>
    </svg>
  </div>

  <div class="max-w-5xl mx-auto px-6 relative z-10">
    
    <div class="chat-transform-container">
      <div class="chat-window bg-lab-surface/95 backdrop-blur border-2 border-lab-border rounded-xl overflow-hidden shadow-2xl max-w-2xl mx-auto">
        
        <div class="chat-header flex items-center justify-between px-4 py-3 border-b border-lab-border bg-lab-bg/50">
          <div class="flex items-center gap-3">
            <div class="status-dot w-3 h-3 rounded-full bg-lab-muted" id="status-dot"></div>
            <span class="text-sm font-mono text-lab-muted" id="status-text">Standard AI</span>
          </div>
          <div class="text-xs text-lab-muted font-mono">v0.0.0</div>
        </div>
        
        <div class="chat-body p-6 min-h-[200px] relative">
          
          <div class="drive-slot absolute right-4 top-4 w-20 h-16" id="drive-slot">
            <div class="slot-housing bg-lab-bg border-2 border-lab-border rounded-lg h-full relative overflow-hidden">
              <div class="slot-opening absolute bottom-2 left-1/2 -translate-x-1/2 w-14 h-3 bg-black/80 rounded-sm"></div>
              <div class="drive-indicator absolute top-2 right-2 w-2 h-2 rounded-full bg-lab-muted" id="drive-indicator"></div>
            </div>
            
            <div class="autojack-disk absolute bottom-0 left-1/2 -translate-x-1/2" id="autojack-disk">
              <svg viewBox="0 0 60 60" width="50" height="50">
                <defs>
                  <linearGradient id="diskGold" x1="0%" y1="0%" x2="0%" y2="100%">
                    <stop offset="0%" style="stop-color:#FFE082"/>
                    <stop offset="50%" style="stop-color:#F9D857"/>
                    <stop offset="100%" style="stop-color:#DAA520"/>
                  </linearGradient>
                </defs>
                <rect x="5" y="5" width="50" height="50" rx="5" fill="url(#diskGold)" stroke="#1a1a1a" stroke-width="2"/>
                <rect x="18" y="8" width="24" height="15" rx="2" fill="#e5e5e5" stroke="#1a1a1a" stroke-width="1.5"/>
                <rect x="33" y="11" width="7" height="9" rx="1" fill="#1a1a1a"/>
                <circle cx="24" cy="38" r="3" fill="#1a1a1a"/>
                <circle cx="36" cy="38" r="3" fill="#1a1a1a"/>
                <path d="M26 46 Q30 50 34 46" stroke="#1a1a1a" stroke-width="2" fill="none" stroke-linecap="round"/>
              </svg>
            </div>
          </div>
          
          <div class="messages space-y-4">
            <div class="message-bubble boring-message" id="boring-message">
              <div class="text-xs text-lab-muted mb-1 font-mono">ASSISTANT</div>
              <p class="text-lab-text" id="message-text">Good day. How can I help you?</p>
            </div>
            
            <div class="message-bubble user-message opacity-0" id="user-message">
              <div class="text-xs text-lab-muted mb-1 font-mono text-right">YOU</div>
              <p class="text-lab-text text-right">Can you help me with my project?</p>
            </div>
            
            <div class="message-bubble boring-response opacity-0" id="boring-response">
              <div class="text-xs text-lab-muted mb-1 font-mono">ASSISTANT</div>
              <p class="text-lab-muted italic" id="boring-text">I'm sorry, I don't have any context about your projects...</p>
            </div>
            
            <div class="message-bubble memory-response opacity-0 hidden" id="memory-response">
              <div class="text-xs text-lab-accent mb-1 font-mono flex items-center gap-2">
                <span class="w-2 h-2 bg-lab-accent rounded-full animate-pulse"></span>
                AUTOJACK
              </div>
              <p class="text-lab-text" id="memory-text">Good morning Jack! Ready to continue on the dashboard? I see you were working on the analytics component yesterday.</p>
            </div>
          </div>
          
        </div>
      </div>
      
      <div class="text-center mt-8">
        <button class="replay-btn px-6 py-3 bg-lab-accent text-lab-bg font-bold rounded-lg hover:scale-105 transition-transform" id="replay-btn">
          ↻ Replay Animation
        </button>
      </div>
    </div>
    
  </div>
</section>

<style>
  .memory-hero {
    min-height: 600px;
  }
  
  .memory-graph {
    opacity: 0;
    transition: opacity 0.5s ease;
  }
  
  .memory-graph.active {
    opacity: 1;
  }
  
  .connection {
    stroke: rgba(249, 216, 87, 0.3);
    stroke-width: 2;
    stroke-dasharray: 200;
    stroke-dashoffset: 200;
    transition: stroke-dashoffset 0.8s ease-out, stroke 0.3s ease;
  }
  
  .connection.active {
    stroke-dashoffset: 0;
    stroke: rgba(249, 216, 87, 0.6);
  }
  
  .node {
    opacity: 0;
    transform: scale(0);
    transform-origin: center;
    transition: opacity 0.4s ease, transform 0.5s cubic-bezier(0.34, 1.56, 0.64, 1);
  }
  
  .node.active {
    opacity: 1;
    transform: scale(1);
  }
  
  .node.active circle:first-child {
    animation: pulse-glow 2s ease-in-out infinite;
  }
  
  @keyframes pulse-glow {
    0%, 100% { opacity: 0.5; transform: scale(1); }
    50% { opacity: 0.8; transform: scale(1.1); }
  }
  
  .node-label {
    fill: rgba(249, 216, 87, 0.9);
    font-size: 11px;
    font-family: 'JetBrains Mono', monospace;
    font-weight: 600;
  }
  
  .center-label {
    fill: #1a1a1a;
    font-size: 10px;
  }
  
  .message-bubble {
    background: rgba(var(--lab-bg), 0.8);
    border: 1px solid rgba(var(--lab-border), 0.5);
    padding: 12px 16px;
    border-radius: 12px;
    transition: all 0.4s ease;
  }
  
  .message-bubble.fade-out {
    opacity: 0;
    transform: translateY(-10px);
  }
  
  .autojack-disk {
    transform: translateY(60px);
    transition: transform 0.8s cubic-bezier(0.34, 1.56, 0.64, 1);
    filter: drop-shadow(0 4px 12px rgba(249, 216, 87, 0.4));
  }
  
  .autojack-disk.inserting {
    transform: translateY(-20px);
  }
  
  .autojack-disk.inserted {
    transform: translateY(-35px);
  }
  
  .drive-indicator.active {
    background: #34D399;
    box-shadow: 0 0 8px #34D399, 0 0 16px #34D399;
    animation: blink 0.3s ease-in-out 3;
  }
  
  @keyframes blink {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.3; }
  }
  
  .status-dot.connected {
    background: #34D399;
    box-shadow: 0 0 8px #34D399;
  }
  
  .chat-window {
    transition: border-color 0.5s ease, box-shadow 0.5s ease;
  }
  
  .chat-window.memory-active {
    border-color: rgb(var(--lab-accent));
    box-shadow: 0 0 40px rgba(249, 216, 87, 0.2), 0 25px 50px rgba(0,0,0,0.3);
  }
  
  .replay-btn {
    opacity: 0;
    transition: opacity 0.3s ease;
  }
  
  .replay-btn.visible {
    opacity: 1;
  }
  
  @media (prefers-reduced-motion: reduce) {
    .node, .connection, .autojack-disk, .message-bubble {
      transition: none;
    }
    .node.active circle:first-child {
      animation: none;
    }
  }
</style>

<script>
  class MemoryHeroAnimation {
    constructor() {
      this.graph = document.getElementById('memory-graph');
      this.nodes = document.querySelectorAll('.node');
      this.connections = document.querySelectorAll('.connection');
      this.disk = document.getElementById('autojack-disk');
      this.indicator = document.getElementById('drive-indicator');
      this.statusDot = document.getElementById('status-dot');
      this.statusText = document.getElementById('status-text');
      this.chatWindow = document.querySelector('.chat-window');
      this.boringMessage = document.getElementById('boring-message');
      this.userMessage = document.getElementById('user-message');
      this.boringResponse = document.getElementById('boring-response');
      this.memoryResponse = document.getElementById('memory-response');
      this.replayBtn = document.getElementById('replay-btn');
      this.isPlaying = false;
      
      this.init();
    }
    
    init() {
      if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
        this.showFinalState();
        return;
      }
      
      if (this.replayBtn) {
        this.replayBtn.addEventListener('click', () => this.play());
      }
      
      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting && !this.isPlaying) {
            setTimeout(() => this.play(), 500);
          }
        });
      }, { threshold: 0.3 });
      
      const hero = document.getElementById('memory-hero');
      if (hero) observer.observe(hero);
    }
    
    async play() {
      if (this.isPlaying) return;
      this.isPlaying = true;
      this.reset();
      
      // Phase 1: Show boring conversation (0-2s)
      await this.delay(500);
      if (this.userMessage) this.userMessage.classList.remove('opacity-0');
      await this.delay(800);
      if (this.boringResponse) this.boringResponse.classList.remove('opacity-0');
      
      // Phase 2: Disk insertion (2-3.5s)
      await this.delay(1000);
      if (this.disk) this.disk.classList.add('inserting');
      await this.delay(400);
      if (this.disk) {
        this.disk.classList.remove('inserting');
        this.disk.classList.add('inserted');
      }
      if (this.indicator) this.indicator.classList.add('active');
      
      // Phase 3: Memory graph explosion (3.5-6s)
      await this.delay(500);
      if (this.graph) this.graph.classList.add('active');
      if (this.chatWindow) this.chatWindow.classList.add('memory-active');
      if (this.statusDot) this.statusDot.classList.add('connected');
      if (this.statusText) this.statusText.textContent = 'AutoMem Connected';
      
      // Animate nodes sequentially
      for (let i = 0; i < this.nodes.length; i++) {
        const node = this.nodes[i];
        const nodeDelay = parseInt(node.getAttribute('data-delay') || '0');
        setTimeout(() => node.classList.add('active'), nodeDelay);
      }
      
      // Animate connections
      await this.delay(200);
      this.connections.forEach((conn, i) => {
        setTimeout(() => conn.classList.add('active'), i * 120);
      });
      
      // Phase 4: Transform messages (6-7s)
      await this.delay(1500);
      if (this.boringMessage) this.boringMessage.classList.add('fade-out');
      if (this.boringResponse) this.boringResponse.classList.add('fade-out');
      
      await this.delay(400);
      if (this.memoryResponse) {
        this.memoryResponse.classList.remove('hidden');
        this.memoryResponse.classList.remove('opacity-0');
      }
      
      // Show replay button
      await this.delay(500);
      if (this.replayBtn) this.replayBtn.classList.add('visible');
      this.isPlaying = false;
    }
    
    reset() {
      if (this.graph) this.graph.classList.remove('active');
      if (this.chatWindow) this.chatWindow.classList.remove('memory-active');
      if (this.disk) this.disk.classList.remove('inserting', 'inserted');
      if (this.indicator) this.indicator.classList.remove('active');
      if (this.statusDot) this.statusDot.classList.remove('connected');
      if (this.statusText) this.statusText.textContent = 'Standard AI';
      
      this.nodes.forEach(n => n.classList.remove('active'));
      this.connections.forEach(c => c.classList.remove('active'));
      
      if (this.boringMessage) this.boringMessage.classList.remove('fade-out');
      if (this.userMessage) this.userMessage.classList.add('opacity-0');
      if (this.boringResponse) {
        this.boringResponse.classList.add('opacity-0');
        this.boringResponse.classList.remove('fade-out');
      }
      if (this.memoryResponse) {
        this.memoryResponse.classList.add('hidden');
        this.memoryResponse.classList.add('opacity-0');
      }
      if (this.replayBtn) this.replayBtn.classList.remove('visible');
    }
    
    showFinalState() {
      if (this.graph) this.graph.classList.add('active');
      if (this.chatWindow) this.chatWindow.classList.add('memory-active');
      if (this.statusDot) this.statusDot.classList.add('connected');
      if (this.statusText) this.statusText.textContent = 'AutoMem Connected';
      if (this.disk) this.disk.classList.add('inserted');
      if (this.indicator) this.indicator.classList.add('active');
      this.nodes.forEach(n => n.classList.add('active'));
      this.connections.forEach(c => c.classList.add('active'));
      if (this.boringMessage) this.boringMessage.classList.add('hidden');
      if (this.boringResponse) this.boringResponse.classList.add('hidden');
      if (this.userMessage) this.userMessage.classList.remove('opacity-0');
      if (this.memoryResponse) {
        this.memoryResponse.classList.remove('hidden');
        this.memoryResponse.classList.remove('opacity-0');
      }
    }
    
    delay(ms) {
      return new Promise(resolve => setTimeout(resolve, ms));
    }
  }
  
  new MemoryHeroAnimation();
</script>
