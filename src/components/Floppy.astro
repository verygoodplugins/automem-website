---
interface Props {
  variant?: 'idle' | 'wink' | 'peek' | 'walk' | 'happy';
  class?: string;
  width?: string;
  height?: string;
}

const { variant = 'idle', class: className = '', width = 'w-12', height = 'h-12' } = Astro.props;
---

<div class={`floppy-container ${className} ${width} ${height} inline-block relative group`}>
  <svg viewBox="0 0 200 200" class="w-full h-full drop-shadow-hard overflow-visible">
    <g class={`floppy-body ${variant === 'walk' ? 'animate-walk' : ''} origin-bottom`}>
      
      <!-- Body Rotation Wrapper for Peek -->
      <g class={variant === 'peek' ? 'peek-rotate' : ''}>
        
        <!-- Main Body -->
        <rect x="40" y="40" width="120" height="120" rx="8" fill="#00FFFF" stroke="#0A0A0A" stroke-width="4" class="transition-colors group-hover:fill-[#33FFFF]"/>
        
        <!-- Cut Corner -->
        <path d="M160 40 L160 70 L130 40 Z" fill="#0A0A0A"/>
        
        <!-- Shutter (Metal part) -->
        <rect x="65" y="40" width="70" height="52" rx="4" fill="#E0E0E0" stroke="#0A0A0A" stroke-width="3"/>
        <rect x="82" y="48" width="16" height="24" rx="2" fill="#0A0A0A" opacity="0.8"/>
        
        <!-- Label (Face Background) -->
        <rect x="50" y="105" width="100" height="45" rx="4" fill="#FF33CC" stroke="#0A0A0A" stroke-width="3"/>
        
        <!-- Face -->
        <g class="face">
          <!-- Happy/Anime Eyes -->
          {variant === 'happy' ? (
            <g>
               <!-- Left Arc -->
               <path d="M78 128 Q85 120 92 128" stroke="#0A0A0A" stroke-width="3" fill="none" stroke-linecap="round" />
               <!-- Right Arc -->
               <path d="M108 128 Q115 120 122 128" stroke="#0A0A0A" stroke-width="3" fill="none" stroke-linecap="round" />
               <!-- Happy Mouth (Bigger smile) -->
               <path d="M85 135 Q100 145 115 135" stroke="#0A0A0A" stroke-width="3" fill="none" stroke-linecap="round"/>
            </g>
          ) : (
            <g>
              <!-- Standard Eyes -->
              <circle cx="85" cy="125" r="6" fill="#0A0A0A">
                {variant === 'wink' && (
                  <animate attributeName="r" values="6;1;6" dur="2s" repeatCount="indefinite" begin="0s" />
                )}
              </circle>
              
              <!-- Right Eye (Wink Logic) -->
              {variant === 'wink' ? (
                <g>
                   <!-- Wink Line -->
                   <path d="M109 125 L121 125" stroke="#0A0A0A" stroke-width="3" stroke-linecap="round" class="group-hover:opacity-100 opacity-0 transition-opacity"/>
                   <!-- Normal Eye (Hidden on hover) -->
                   <circle cx="115" cy="125" r="6" fill="#0A0A0A" class="group-hover:opacity-0 transition-opacity"/>
                </g>
              ) : (
                <circle cx="115" cy="125" r="6" fill="#0A0A0A">
                   {variant === 'wink' && (
                    <animate attributeName="r" values="6;1;6" dur="2s" repeatCount="indefinite" begin="0.2s" />
                  )}
                </circle>
              )}

              <!-- Standard Mouth -->
              <path d="M92 132 Q100 138 108 132" stroke="#0A0A0A" stroke-width="3" fill="none" stroke-linecap="round"/>
            </g>
          )}
        </g>

        <!-- Legs (Hidden in peek mode usually, but kept for consistency) -->
        {variant !== 'peek' && (
          <g>
            <path d="M70 160 L70 180" stroke="#0A0A0A" stroke-width="4" stroke-linecap="round"/>
            <path d="M130 160 L130 180" stroke="#0A0A0A" stroke-width="4" stroke-linecap="round"/>
            <path d="M60 180 L80 180" stroke="#0A0A0A" stroke-width="4" stroke-linecap="round"/>
            <path d="M120 180 L140 180" stroke="#0A0A0A" stroke-width="4" stroke-linecap="round"/>
          </g>
        )}
      </g>
    </g>
  </svg>
</div>

<style>
  @keyframes walk {
    0%, 100% { transform: translateY(0) rotate(0deg); }
    25% { transform: translateY(-3px) rotate(-2deg); }
    75% { transform: translateY(-3px) rotate(2deg); }
  }
  .animate-walk {
    animation: walk 0.8s ease-in-out infinite;
  }
  .peek-rotate {
    transform-origin: bottom center;
    transform: rotate(-10deg);
  }
</style>