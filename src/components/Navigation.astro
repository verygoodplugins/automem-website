---
import AutoJack from './AutoJack.astro';
import ThemeToggle from './ThemeToggle.astro';
import DiscordIcon from './DiscordIcon.astro';

const { currentPath = '' } = Astro.props;

const links = [
  { href: '/', label: 'home' },
  { href: '/docs/overview', label: 'docs' },
  { href: '/benchmarks', label: 'benchmarks' },
  { href: '/blog', label: 'blog' },
  { href: '/about', label: 'about' },
];
---

<nav class="sticky top-0 z-40 bg-lab-bg border-b border-lab-border">
  <div class="max-w-7xl mx-auto flex items-center justify-between gap-2 px-3 sm:px-6 h-14">
    <!-- Left: Breadcrumbs / Logo -->
    <div class="flex items-center gap-2 sm:gap-4 flex-shrink-0">
      <a href="/" class="font-bold text-lab-text hover:text-lab-accent transition-colors flex items-center gap-3 group">
        <!-- AutoJack Logo -->
        <div class="transform transition-transform group-hover:rotate-12 group-hover:scale-110">
           <AutoJack size={32} expression="confident" animate={false} />
        </div>
        <span class="hidden sm:inline">~/automem</span>
      </a>
    </div>

    <!-- Right: Links -->
    <div class="flex items-center overflow-x-auto no-scrollbar min-w-0">
      {links.map((link) => (
        <a
          href={link.href}
          class={`
            h-14 px-3 md:px-6 flex items-center text-sm font-mono border-l border-lab-border transition-colors whitespace-nowrap
            ${currentPath === link.href
              ? 'bg-lab-accent text-[#1a1a1a] font-bold'
              : 'text-lab-muted hover:bg-lab-accent hover:text-[#1a1a1a]'}
          `}
        >
          {link.label}
        </a>
      ))}
      <a
        href="https://automem.ai/discord"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="Join our Discord community"
        title="Join our Discord community"
        class="h-14 px-3 md:px-6 flex items-center text-sm font-mono border-l border-lab-border hover:bg-lab-discord hover:text-lab-on-discord transition-colors whitespace-nowrap text-lab-muted"
      >
        <DiscordIcon class="w-4 h-4 mr-1.5" />
        <span class="sr-only sm:not-sr-only sm:inline">discord</span>
      </a>
      <a
        href="https://github.com/verygoodplugins/automem"
          target="_blank"
          rel="noopener noreferrer"
        class="h-14 px-3 md:px-6 flex items-center text-sm font-mono border-l border-lab-border hover:bg-lab-accent hover:text-lab-bg transition-colors whitespace-nowrap"
      >
        ★ Star us
      </a>
      <slot name="trailing" />
      <ThemeToggle />
    </div>
  </div>
</nav>
