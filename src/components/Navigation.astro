---
import ThemeToggle from './ThemeToggle.astro';

const { currentPath = '' } = Astro.props;

const GITHUB_URL = 'https://github.com/verygoodplugins/automem';
const links = [
  { href: '/docs/overview', label: 'Docs' },
  { href: '/install', label: 'Install' },
  { href: '/docs/getting-started/quick-start/', label: 'Guides' },
  { href: '/docs/core-concepts/memory-model/', label: 'Concepts' },
  { href: '/docs/reference/api/direct-vs-mcp/', label: 'API' },
];

const isActive = (href: string) => {
  if (href === '/docs/overview') return currentPath.startsWith('/docs') || currentPath === '/docs/overview';
  return currentPath === href;
};
---

<nav class="sticky top-0 z-40 border-b border-lab-border/80 bg-lab-bg/88 backdrop-blur-xl">
  <div class="mx-auto flex h-16 max-w-[1440px] items-center justify-between gap-4 px-4 sm:px-7 lg:px-10">
    <a href="/" class="group flex shrink-0 items-center gap-3 text-lab-text no-underline">
      <span class="inline-flex h-9 w-9 shrink-0 items-center justify-center transition-transform group-hover:scale-105">
        <img src="/automem-icon.svg" alt="" class="h-9 w-9 rounded-md" loading="eager" decoding="async" />
      </span>
      <span class="text-xl font-bold tracking-normal sm:text-2xl">AutoMem</span>
    </a>

    <div class="flex min-w-0 items-center justify-end gap-2">
      <div class="hidden items-center gap-1 md:flex">
        {links.map((link) => (
          <a
            href={link.href}
            class={`
              rounded px-4 py-2 text-sm font-medium text-lab-muted no-underline transition-colors
              hover:bg-lab-panel hover:text-lab-text
              ${isActive(link.href) ? 'text-lab-accent-text' : ''}
            `}
          >
            {link.label}
          </a>
        ))}
        <a
          href={GITHUB_URL}
          target="_blank"
          rel="noopener noreferrer"
          class="rounded px-4 py-2 text-sm font-medium text-lab-muted no-underline transition-colors hover:bg-lab-panel hover:text-lab-text"
        >
          GitHub
          <svg class="ml-1 inline h-3 w-3 align-[-1px]" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <path d="M5 4h7v7M12 4 4 12" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
        </a>
      </div>

      <a
        href={GITHUB_URL}
        target="_blank"
        rel="noopener noreferrer"
        class="glass-panel flex h-9 shrink-0 items-center gap-2 px-3 text-sm font-bold text-lab-text no-underline transition-colors hover:border-lab-accent hover:text-lab-accent-text"
        aria-label="Star AutoMem on GitHub"
      >
        <svg class="h-4 w-4" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
          <path d="M8 1.2 10.1 5.5l4.7.7-3.4 3.3.8 4.7L8 12l-4.2 2.2.8-4.7L1.2 6.2l4.7-.7L8 1.2Z" />
        </svg>
        <span>Star</span>
        <span class="hidden text-lab-muted sm:inline">745</span>
      </a>

      <ThemeToggle />
    </div>
  </div>
</nav>
