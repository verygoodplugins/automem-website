---
import AutoJack from './AutoJack.astro';
import ThemeToggle from './ThemeToggle.astro';

const { currentPath = '' } = Astro.props;

const links = [
  { href: '/', label: 'home' },
  { href: '/docs/overview', label: 'docs' },
  { href: '/blog', label: 'blog' },
  { href: '/about', label: 'about' },
];
---

<nav class="sticky top-0 z-40 bg-lab-bg border-b border-lab-border">
  <div class="max-w-7xl mx-auto flex items-center justify-between gap-2 px-3 sm:px-6 h-14">
    <!-- Left: Breadcrumbs / Logo -->
    <div class="flex items-center gap-2 sm:gap-4 flex-shrink-0">
      <a href="/" class="font-bold text-lab-text hover:text-lab-accent transition-colors flex items-center gap-3 group">
        <!-- AutoJack Logo -->
        <div class="transform transition-transform group-hover:rotate-12 group-hover:scale-110">
           <AutoJack size={32} expression="confident" animate={false} />
        </div>
        <span class="hidden sm:inline">~/automem</span>
      </a>
    </div>

    <!-- Right: Links -->
    <div class="flex items-center overflow-x-auto no-scrollbar min-w-0">
      {links.map((link) => (
        <a
          href={link.href}
          class={`
            h-14 px-3 md:px-6 flex items-center text-sm font-mono border-l border-lab-border hover:bg-lab-text hover:text-lab-bg transition-colors whitespace-nowrap
            ${currentPath === link.href ? 'bg-lab-text text-lab-bg font-bold' : 'text-lab-muted'}
          `}
        >
          {link.label}
        </a>
      ))}
      <a
        href="https://automem.ai/discord"
        target="_blank"
        rel="noopener noreferrer"
        title="Join our Discord community"
        class="h-14 px-3 md:px-6 flex items-center text-sm font-mono border-l border-lab-border hover:bg-[#5865F2] hover:text-white transition-colors whitespace-nowrap text-lab-muted"
      >
        <svg class="w-4 h-4 mr-1.5" viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
          <path d="M20.317 4.37a19.791 19.791 0 0 0-4.885-1.515.074.074 0 0 0-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0 12.64 12.64 0 0 0-.617-1.25.077.077 0 0 0-.079-.037A19.736 19.736 0 0 0 3.677 4.37a.07.07 0 0 0-.032.027C.533 9.046-.32 13.58.099 18.057c.001.022.015.04.033.05a19.886 19.886 0 0 0 5.993 3.03.078.078 0 0 0 .084-.028 14.09 14.09 0 0 0 1.226-1.994.076.076 0 0 0-.041-.106 13.107 13.107 0 0 1-1.872-.892.077.077 0 0 1-.008-.128 10.2 10.2 0 0 0 .372-.292.074.074 0 0 1 .077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 0 1 .078.01c.12.098.246.198.373.292a.077.077 0 0 1-.006.127 12.299 12.299 0 0 1-1.873.892.077.077 0 0 0-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 0 0 .084.028 19.839 19.839 0 0 0 6.002-3.03.077.077 0 0 0 .032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 0 0-.031-.03z"/>
        </svg>
        <span class="hidden sm:inline">discord</span>
      </a>
      <a
        href="https://github.com/verygoodplugins/automem"
          target="_blank"
          rel="noopener noreferrer"
        class="h-14 px-3 md:px-6 flex items-center text-sm font-mono border-l border-lab-border hover:bg-lab-accent hover:text-lab-bg transition-colors whitespace-nowrap"
      >
        ★ Star us
      </a>
      <ThemeToggle />
    </div>
  </div>
</nav>
