---
import AutoJack from './AutoJack.astro';
import ThemeToggle from './ThemeToggle.astro';

const { currentPath = '' } = Astro.props;

const links = [
  { href: '/', label: 'home' },
  { href: '/docs', label: 'docs' },
  { href: '/blog', label: 'blog' },
  { href: '/about', label: 'about' },
];
---

<nav class="sticky top-0 z-40 bg-lab-bg border-b border-lab-border">
  <div class="max-w-7xl mx-auto flex items-center justify-between px-6 h-14">
    <!-- Left: Breadcrumbs / Logo -->
    <div class="flex items-center gap-4">
      <a href="/" class="font-bold text-lab-text hover:text-lab-accent transition-colors flex items-center gap-3 group">
        <!-- AutoJack Logo -->
        <div class="transform transition-transform group-hover:rotate-12 group-hover:scale-110">
           <AutoJack size={32} expression="confident" animate={false} />
        </div>
        <span>~/automem</span>
      </a>
    </div>

    <!-- Right: Links -->
    <div class="flex items-center overflow-x-auto no-scrollbar">
      {links.map((link) => (
        <a
          href={link.href}
          class={`
            h-14 px-4 md:px-6 flex items-center text-sm font-mono border-l border-lab-border hover:bg-lab-text hover:text-lab-bg transition-colors whitespace-nowrap
            ${currentPath === link.href ? 'bg-lab-text text-lab-bg font-bold' : 'text-lab-muted'}
          `}
        >
          {link.label}
        </a>
      ))}
      <a
        href="https://github.com/verygoodplugins/automem"
          target="_blank"
          rel="noopener noreferrer"
        class="h-14 px-4 md:px-6 flex items-center text-sm font-mono border-l border-lab-border hover:bg-lab-accent hover:text-lab-bg transition-colors whitespace-nowrap"
      >
        ★ Star us
      </a>
      <ThemeToggle />
    </div>
  </div>
</nav>