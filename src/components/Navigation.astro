---
const { currentPath = '' } = Astro.props;

const links = [
  { href: '/', label: 'home' },
  { href: '/docs', label: 'docs' },
  { href: '/blog', label: 'blog' },
  { href: '/about', label: 'about' },
];
---

<nav class="sticky top-0 z-40 bg-core-bg border-b border-core-line">
  <div class="max-w-7xl mx-auto flex items-center justify-between px-6 h-14">
    <!-- Left: Breadcrumbs / Logo -->
    <div class="flex items-center gap-4">
      <a href="/" class="font-bold text-core-text hover:text-core-accent transition-colors flex items-center gap-2">
        <div class="w-3 h-3 bg-core-accent"></div>
        <span>~/automem</span>
      </a>
    </div>

    <!-- Right: Links -->
    <div class="flex items-center">
      {links.map((link) => (
        <a
          href={link.href}
          class={`
            h-14 px-6 flex items-center text-sm font-mono border-l border-core-line hover:bg-white transition-colors
            ${currentPath === link.href ? 'bg-white text-core-accent font-bold' : 'text-core-muted'}
          `}
        >
          {link.label}
        </a>
      ))}
      <a
        href="https://github.com/verygoodplugins/automem"
          target="_blank"
          rel="noopener noreferrer"
        class="h-14 px-6 flex items-center text-sm font-mono border-l border-core-line hover:bg-core-text hover:text-white transition-colors"
      >
        ★ Star us
      </a>
    </div>
  </div>
</nav>
