---
export const prerender = true;
import Layout from '../layouts/Layout.astro';
import Navigation from '../components/Navigation.astro';
import OrganizationSchema from '../components/schemas/OrganizationSchema.astro';
import benchmarkData from '../data/benchmarks.json';
import {
  benchmarkComparisonRows,
  benchmarkMeaningCards,
  benchmarkTimeline,
  publishedBenchmarkRows,
  formatGeneratedDate,
  primaryPercent,
  sourceLabel,
  statusTone,
} from '../lib/benchmarks.mjs';

const canonicalClaims = benchmarkData.canonicalClaims;
const canaryClaims = benchmarkData.canaryClaims;
const supplementalClaims = benchmarkData.supplementalClaims;
const amb = benchmarkData.ambSubmission;
// 'BEAM official 1M/10M' is covered by the AMB BEAM scaling section above (shown
// with its submitted/not-yet-canonical status), so listing it here too reads as a
// contradiction. Filter it (and the de-scoped Memora/FAMA) from the "Not yet
// canonical" box. Both still arrive from the synced manifest's notYetRun.
const notYetRunClaims = benchmarkData.notYetRun.filter(
  (item) => item !== 'Memora/FAMA' && item !== 'BEAM official 1M/10M',
);

const ambAsOf = formatGeneratedDate(amb?.asOf ?? benchmarkData.generatedAt);
const beam10m = amb?.beam?.rows?.find((row) => row.tier === '10M');
const LAUNCH_POST_URL = '/blog/automem-amb-neutral-numbers';

function toneClasses(status) {
  const tone = statusTone(status);
  if (tone === 'accent') {
    return 'border-lab-accent text-lab-accent-text bg-lab-accent/10';
  }
  if (tone === 'secondary') {
    return 'border-lab-secondary text-lab-secondary bg-lab-secondary/10';
  }
  return 'border-lab-border text-lab-muted bg-lab-surface';
}
---

<Layout
  title="Benchmarks"
  description="AutoMem benchmark results sourced from canonical automem benchmark artifacts, with clear separation between canonical, canary, exploratory, and external reported claims."
>
  <OrganizationSchema />
  <Navigation currentPath="/benchmarks" />

  <main class="w-full pb-24">
    <section class="px-4 md:px-12 pt-16 pb-20 border-b border-lab-border bg-lab-bg relative overflow-hidden">
      <div class="comment-header">:: BENCHMARK_SIGNAL</div>
      <div class="max-w-6xl mx-auto grid lg:grid-cols-[1.1fr_0.9fr] gap-12 items-end relative z-10">
        <div>
          <h1 class="text-4xl md:text-6xl font-bold tracking-normal leading-tight mb-6">
            Benchmarks for agent memory<br />
            <span class="text-lab-accent-text">under pressure.</span>
          </h1>
          <p class="text-lg md:text-xl text-lab-muted leading-relaxed max-w-2xl">
            AutoMem's primary numbers now come from the <span class="text-lab-text">neutral Agent Memory Benchmark</span> —
            the standardized answerer, judge, and grader the harness ran for AutoMem. <span class="text-lab-text">BEAM</span> is
            the one same-harness, apples-to-apples axis against published competitors, and there AutoMem is a clear
            <span class="text-lab-text">#2</span>: ahead of Honcho at every scale, with the lead widening to +16.8pp at
            10M. Competitor figures elsewhere are their own published / self-reported numbers, and the conversational-recall
            gap behind Hindsight is named here too, not hidden.
          </p>
          <div class="mt-8 flex flex-wrap gap-4">
            <a href={LAUNCH_POST_URL} class="btn-lab-accent">
              Read the AMB results →
            </a>
            <a href={benchmarkData.links.publicationBundle} target="_blank" rel="noopener noreferrer" class="btn-lab">
              Benchmark Artifacts
            </a>
          </div>
        </div>

        {amb && (
          <div class="border-2 border-lab-text bg-lab-surface rounded-lg shadow-hard p-6">
            <div class="flex items-center justify-between gap-4 border-b border-lab-border pb-4 mb-5">
              <span class="inline-flex border border-lab-secondary text-lab-secondary bg-lab-secondary/10 px-2 py-1 rounded text-[10px] font-bold uppercase tracking-widest">
                {amb.statusLabel}
              </span>
              <span class="font-mono text-xs text-lab-accent-text">{ambAsOf}</span>
            </div>
            <div class="grid grid-cols-2 gap-4">
              <div class="bg-lab-bg border border-lab-border rounded-lg p-4">
                <div class="text-xs text-lab-muted uppercase tracking-widest mb-2">BEAM @ 10M</div>
                <div class="text-4xl font-bold text-lab-accent-text">{beam10m?.automem ?? '57.4%'}</div>
                <div class="text-xs text-lab-muted mt-2">vs Honcho {beam10m?.honcho ?? '40.6%'}</div>
                <div class="text-xs text-lab-success mt-1">{beam10m?.deltaVsHoncho ?? '+16.8'}pp at the hardest tier</div>
              </div>
              <div class="bg-lab-bg border border-lab-border rounded-lg p-4">
                <div class="text-xs text-lab-muted uppercase tracking-widest mb-2">Context / answer</div>
                <div class="text-4xl font-bold text-lab-accent-text">{amb.efficiency.automemRange}</div>
                <div class="text-xs text-lab-muted mt-2">board leader {amb.efficiency.boardLeaderRange}</div>
                <div class="text-xs text-lab-success mt-1">flat across every scale</div>
              </div>
            </div>
            <p class="mt-5 text-xs leading-relaxed text-lab-muted">
              Neutral harness — every provider feeds the same answerer and judge, so the score measures retrieval, not
              grader mood. BEAM is the only apples-to-apples axis; AutoMem is #2 behind Hindsight. A reproducibility and
              scaling claim, not a state-of-the-art one.
            </p>
          </div>
        )}
      </div>
      <div class="absolute inset-0 bg-[radial-gradient(rgb(var(--lab-line))_1px,transparent_1px)] [background-size:16px_16px] opacity-20 pointer-events-none"></div>
    </section>

    {amb && (
      <section class="px-4 md:px-12 py-20 border-b border-lab-border bg-lab-surface">
        <div class="comment-header">:: AMB_NEUTRAL_HARNESS</div>
        <div class="max-w-6xl mx-auto">
          <div class="flex flex-wrap items-center gap-3 mb-4">
            <span class="inline-flex border border-lab-secondary text-lab-secondary bg-lab-secondary/10 px-2 py-1 rounded text-xs font-bold uppercase tracking-widest">
              {amb.statusLabel}
            </span>
            <span class="text-xs text-lab-muted uppercase tracking-widest">{amb.version}</span>
          </div>
          <h2 class="text-3xl md:text-4xl font-bold tracking-normal mb-4">
            Primary claim set: the neutral Agent Memory Benchmark
          </h2>
          <p class="text-lab-muted leading-relaxed max-w-4xl">
            AutoMem's current primary numbers come from the neutral {amb.harness}, run in {amb.mode} mode with a
            {' '}{amb.answerModel} answerer and {amb.judgeModel} judge. The provider self-spins its full stack
            ({amb.providerConfig}). The single biggest reason to trust these: you can run them yourself.
          </p>
          <div class="mt-4 border border-lab-border bg-lab-bg rounded-lg p-5 text-sm text-lab-muted leading-relaxed max-w-4xl">
            <span class="text-lab-text font-bold">Status:</span> {amb.statusNote}
          </div>

          <div class="mt-10">
            <h3 class="text-2xl font-bold tracking-normal">Core-3 (single-query / RAG)</h3>
            <p class="mt-2 text-lab-muted max-w-4xl text-sm leading-relaxed">{amb.core3Caveat}</p>
            <div class="mt-6 grid md:grid-cols-3 gap-4">
              {amb.core3.map((row) => (
                <article class="border-2 border-lab-text bg-lab-bg rounded-lg shadow-hard p-5">
                  <div class="text-xs text-lab-muted uppercase tracking-widest mb-2">{row.benchmark}</div>
                  <div class="flex items-end gap-2">
                    <span class="text-4xl font-bold text-lab-accent-text">{row.score}</span>
                    <span class="pb-1 text-xs text-lab-muted">{row.ci}</span>
                  </div>
                  <div class="text-xs text-lab-muted mt-1">{row.scope} - n={row.questions}</div>
                  <dl class="mt-4 space-y-1 text-xs border-t border-lab-border pt-3">
                    <div class="flex justify-between gap-3">
                      <dt class="text-lab-muted uppercase tracking-widest">Hindsight (AMB)</dt>
                      <dd class="text-lab-text font-bold">{row.hindsight}</dd>
                    </div>
                    <div class="flex justify-between gap-3">
                      <dt class="text-lab-muted uppercase tracking-widest">Honcho (self-rep.)</dt>
                      <dd class="text-lab-text font-bold">{row.honcho ?? 'n/a'}</dd>
                    </div>
                    <div class="flex justify-between gap-3">
                      <dt class="text-lab-muted uppercase tracking-widest">Mean ctx tokens</dt>
                      <dd class="text-lab-success font-bold">{row.contextTokens}</dd>
                    </div>
                  </dl>
                  <p class="mt-3 text-xs leading-relaxed text-lab-muted border-t border-lab-border pt-3">{row.comparable}</p>
                </article>
              ))}
            </div>
          </div>

          <div class="mt-12">
            <h3 class="text-2xl font-bold tracking-normal">BEAM scaling (apples-to-apples)</h3>
            <p class="mt-2 text-lab-muted max-w-4xl text-sm leading-relaxed">{amb.beam.note}</p>
            <p class="mt-1 text-xs text-lab-muted max-w-4xl">Scores are {amb.beam.scale}.</p>
            <figure class="mt-6">
              <div class="overflow-hidden rounded-lg shadow-hard">
                <img
                  src="/img/blog/automem-amb-beam-scaling.svg"
                  alt="BEAM scaling: AutoMem holds 67.5% at 100k and degrades gracefully to 57.4% at 10M, while Honcho stays flat near 63% through 1M then collapses to 40.6% at 10M; Hindsight holds a ~73-64% band across the curve."
                  loading="lazy"
                  decoding="async"
                  class="block h-auto w-full"
                />
              </div>
              <figcaption class="mt-2 text-xs text-lab-muted">
                BEAM rubric-mean accuracy as the haystack grows 100x. Neutral AMB, single-query mode. Hindsight band is approximate.
              </figcaption>
            </figure>
            <div class="mt-6 overflow-x-auto border-2 border-lab-text rounded-lg bg-lab-bg shadow-hard">
              <table class="w-full min-w-[760px] text-sm">
                <thead>
                  <tr class="border-b-2 border-lab-text text-left text-lab-muted">
                    <th class="p-4 font-normal uppercase tracking-widest text-xs">Scale</th>
                    <th class="p-4 font-normal uppercase tracking-widest text-xs">AutoMem</th>
                    <th class="p-4 font-normal uppercase tracking-widest text-xs">Honcho</th>
                    <th class="p-4 font-normal uppercase tracking-widest text-xs">Hindsight</th>
                    <th class="p-4 font-normal uppercase tracking-widest text-xs">vs Honcho (pp)</th>
                    <th class="p-4 font-normal uppercase tracking-widest text-xs">Mean ctx tokens</th>
                  </tr>
                </thead>
                <tbody>
                  {amb.beam.rows.map((row) => (
                    <tr class="border-b border-lab-border/60 last:border-b-0 align-top">
                      <td class="p-4 font-bold whitespace-nowrap">{row.tier}</td>
                      <td class="p-4 text-lab-accent-text font-bold whitespace-nowrap">
                        {row.automem}
                        <div class="text-xs text-lab-muted font-normal">{row.automemDetail}</div>
                      </td>
                      <td class="p-4 whitespace-nowrap">{row.honcho}</td>
                      <td class="p-4 text-lab-muted whitespace-nowrap">{row.hindsight}</td>
                      <td class="p-4 text-lab-success font-bold whitespace-nowrap">{row.deltaVsHoncho}</td>
                      <td class="p-4 text-lab-muted whitespace-nowrap">{row.contextTokens}</td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
            <div class="mt-6 grid md:grid-cols-2 gap-4">
              <div class="border border-lab-border bg-lab-bg rounded-lg p-5 text-sm text-lab-muted leading-relaxed">
                <div class="text-xs uppercase tracking-widest text-lab-accent-text mb-2">Graceful vs collapse</div>
                {amb.beam.scalingStory}
              </div>
              <div class="border border-lab-border bg-lab-bg rounded-lg p-5 text-sm text-lab-muted leading-relaxed">
                <div class="text-xs uppercase tracking-widest text-lab-accent-text mb-2">The 10M centerpiece</div>
                {amb.beam.headline10m}
              </div>
            </div>

            <div class="mt-6 border-2 border-lab-secondary bg-lab-bg rounded-lg shadow-hard p-6 md:p-8">
              <div class="flex flex-wrap items-baseline justify-between gap-3 border-b border-lab-border pb-4 mb-6">
                <div class="font-mono text-xs uppercase tracking-widest text-lab-secondary">// what does 10M tokens actually mean?</div>
                <div class="font-mono text-xs text-lab-muted">plain-English scale check</div>
              </div>
              <div class="grid md:grid-cols-[0.75fr_1.25fr] gap-6 md:gap-10 items-center">
                <div>
                  <div class="text-xs text-lab-muted uppercase tracking-widest mb-2">The haystack</div>
                  <div class="text-5xl md:text-6xl font-bold text-lab-accent-text leading-none">7.5M</div>
                  <div class="mt-2 text-lab-muted">words held in memory</div>
                </div>
                <div class="space-y-4 text-sm md:text-base leading-relaxed text-lab-muted">
                  <p>
                    Ten million tokens is about <span class="text-lab-text font-bold">7.5 million words</span> — the complete
                    works of Shakespeare roughly <span class="text-lab-text">eight times over</span>, or the entire seven-book
                    Harry Potter series read <span class="text-lab-text">seven times through</span>. One unbroken haystack.
                  </p>
                  <p>
                    Ask a single question against a memory store that size, and AutoMem returns just the part you needed —
                    about <span class="text-lab-text font-bold">3,900 tokens</span> of context, call it 3,000 words, in roughly
                    <span class="text-lab-text font-bold">1.7 seconds</span> (median, on our own hardware). Not the whole library.
                    The page you were looking for.
                  </p>
                </div>
              </div>
            </div>
          </div>

          <div class="mt-12 border-y border-lab-border py-8">
            <h3 class="text-2xl font-bold tracking-normal">Context-token efficiency</h3>
            <div class="mt-4 flex flex-wrap items-end gap-8">
              <div>
                <div class="text-xs text-lab-muted uppercase tracking-widest mb-1">AutoMem</div>
                <div class="text-4xl font-bold text-lab-accent-text">{amb.efficiency.automemRange}</div>
              </div>
              <div>
                <div class="text-xs text-lab-muted uppercase tracking-widest mb-1">Board leader</div>
                <div class="text-4xl font-bold text-lab-muted">{amb.efficiency.boardLeaderRange}</div>
              </div>
            </div>
            <p class="mt-4 text-sm text-lab-muted leading-relaxed max-w-4xl">
              {amb.efficiency.note} Reported as the {amb.efficiency.metric}.
            </p>
            <figure class="mt-6">
              <div class="overflow-hidden rounded-lg shadow-hard">
                <img
                  src="/img/blog/automem-amb-efficiency.svg"
                  alt="Context-token efficiency: AutoMem feeds the answerer a flat ~3.9k context tokens across BEAM tiers while the board leader feeds 17-27k for its scores."
                  loading="lazy"
                  decoding="async"
                  class="block h-auto w-full"
                />
              </div>
              <figcaption class="mt-2 text-xs text-lab-muted">
                Mean context tokens fed to the answerer at each BEAM tier — AutoMem stays flat while the haystack grows.
              </figcaption>
            </figure>
          </div>

          <p class="mt-8 text-xs leading-relaxed text-lab-muted max-w-4xl">
            {amb.competitorNote} Reproduce with the public image <code>{amb.image}</code> and
            {' '}<code>{amb.reproduceDoc}</code> (one command per split, no embedding API keys).
          </p>
        </div>
      </section>
    )}

    <section class="px-4 md:px-12 py-20 border-b border-lab-border bg-lab-surface">
      <div class="comment-header">:: WHAT_THE_SCORES_MEAN</div>
      <div class="max-w-6xl mx-auto">
        <div>
          <h2 class="text-3xl md:text-4xl font-bold tracking-normal mb-4">What these benchmarks mean</h2>
          <p class="text-lab-muted leading-relaxed max-w-3xl">
            LongMemEval and LoCoMo are not generic product leaderboards. They stress the two parts of agent memory that matter most in practice:
            recovering the right evidence from long histories, then using that evidence to answer questions without drifting.
          </p>

          <div class="mt-8 grid md:grid-cols-3 gap-4">
            {benchmarkMeaningCards.map((card) => (
              <article class="border-2 border-lab-text bg-lab-bg rounded-lg shadow-hard p-5">
                <h3 class="text-xl font-bold text-lab-accent-text">{card.title}</h3>
                <p class="mt-3 text-sm leading-relaxed text-lab-muted">{card.summary}</p>
                <p class="mt-4 text-xs leading-relaxed text-lab-text border-t border-lab-border pt-4">{card.detail}</p>
              </article>
            ))}
          </div>
        </div>

        <div class="mt-12 border-y border-lab-border py-8">
          <h2 class="text-2xl md:text-3xl font-bold tracking-normal">How to compare AutoMem</h2>
          <p class="mt-3 text-lab-muted leading-relaxed max-w-4xl">
            Treat this as market context, not a leaderboard. The external rows below are reported by their own projects or papers, usually with different models, judges, token budgets, and ingestion rules.
          </p>
          <div class="mt-8 grid md:grid-cols-2 gap-x-8 gap-y-5">
            {benchmarkComparisonRows.map((row) => (
              <div>
                <div class="flex flex-wrap items-center gap-3">
                  <h3 class="font-bold">{row.label}</h3>
                  <span class="inline-flex border border-lab-secondary text-lab-secondary bg-lab-secondary/10 px-2 py-1 rounded text-xs uppercase tracking-widest">
                    {row.status}
                  </span>
                </div>
                <p class="mt-2 text-sm leading-relaxed text-lab-muted">{row.note}</p>
              </div>
            ))}
          </div>
        </div>

        <div class="mt-12">
          <div class="flex flex-wrap items-end justify-between gap-4 mb-6">
            <div>
              <h2 class="text-2xl md:text-3xl font-bold tracking-normal">Published external context</h2>
              <p class="mt-2 text-lab-muted max-w-4xl">
                These are public claims and papers found in May 2026. They help readers orient AutoMem, but the rows are not apples-to-apples unless rerun under one harness.
              </p>
            </div>
          </div>

          <div class="benchmark-external-shell overflow-x-auto border-2 border-lab-text rounded-lg shadow-hard">
            <table class="w-full min-w-[980px] text-sm">
              <thead>
                <tr class="benchmark-external-head border-b-2 border-lab-text text-left">
                  <th class="p-4 font-normal uppercase tracking-widest text-xs">System</th>
                  <th class="p-4 font-normal uppercase tracking-widest text-xs">LoCoMo</th>
                  <th class="p-4 font-normal uppercase tracking-widest text-xs">LongMemEval</th>
                  <th class="p-4 font-normal uppercase tracking-widest text-xs">Other</th>
                  <th class="p-4 font-normal uppercase tracking-widest text-xs">Status</th>
                  <th class="p-4 font-normal uppercase tracking-widest text-xs">Source</th>
                </tr>
              </thead>
              <tbody>
                {publishedBenchmarkRows.map((row) => (
                  <tr class="benchmark-external-row border-b border-lab-border/70 last:border-b-0 align-top transition-colors">
                    <td class="p-4">
                      <div class="font-bold">{row.system}</div>
                      <p class="mt-2 text-xs leading-relaxed text-lab-muted">{row.note}</p>
                    </td>
                    <td class="benchmark-score p-4 font-bold whitespace-nowrap">{row.locomo}</td>
                    <td class="benchmark-score p-4 font-bold">{row.longMemEval}</td>
                    <td class="p-4 text-lab-muted">{row.other}</td>
                    <td class="p-4">
                      <span class="inline-flex border border-lab-border bg-lab-surface px-2 py-1 rounded text-xs uppercase tracking-widest">
                        {row.status}
                      </span>
                    </td>
                    <td class="p-4">
                      <a href={row.sourceUrl} target="_blank" rel="noopener noreferrer" class="benchmark-source hover:underline whitespace-nowrap">
                        {row.sourceLabel}
                      </a>
                    </td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </div>

        <div class="mt-12">
          <div class="flex flex-wrap items-end justify-between gap-4 mb-6">
            <div>
              <h2 class="text-2xl md:text-3xl font-bold tracking-normal">Why the current numbers are credible now</h2>
              <p class="mt-2 text-lab-muted">
                Recent changelog entries show the benchmark harness, evaluator, and recall system maturing before the May full-run verification.
              </p>
            </div>
            <a href="/docs/development/changelog/" class="btn-lab">Changelog</a>
          </div>

          <ol class="grid md:grid-cols-4 gap-4">
            {benchmarkTimeline.map((item) => (
              <li class="border border-lab-border bg-lab-bg rounded-lg p-5">
                <div class="text-xs font-mono uppercase tracking-widest text-lab-accent-text">{item.date}</div>
                <h3 class="mt-3 font-bold">{item.title}</h3>
                <p class="mt-2 text-sm leading-relaxed text-lab-muted">{item.summary}</p>
              </li>
            ))}
          </ol>
        </div>
      </div>
    </section>

    <section class="px-4 md:px-12 py-20 border-b border-lab-border bg-lab-bg">
      <div class="comment-header">:: INTERNAL_RUNS</div>
      <div class="max-w-6xl mx-auto">
        <h2 class="text-3xl md:text-4xl font-bold tracking-normal mb-4">Internal runs (own judge — directional)</h2>
        <p class="text-lab-muted leading-relaxed max-w-3xl">
          These full LongMemEval and LoCoMo runs use AutoMem's own answerer and judge, so they are <span class="text-lab-text">not</span> comparable
          to other systems' published numbers. The same answers scored 82.0% under a gpt-5-mini judge and 70.25% under a gpt-5 judge — a
          ~12-point swing from grader strictness alone. Read these as directional; the neutral AMB numbers above are the comparable ones.
        </p>
        <a href="/blog/automem-016-correctness-over-knobs" class="mt-3 inline-flex font-bold text-lab-accent-text hover:underline">
          Why these aren't a leaderboard claim →
        </a>
        <div class="mt-8 grid lg:grid-cols-2 gap-8">
          {canonicalClaims.map((claim) => (
          <article class="border-2 border-lab-text bg-lab-bg rounded-lg shadow-hard p-6 flex flex-col gap-6">
            <div>
              <div class="flex flex-wrap items-center gap-3 mb-4">
                <span class={`inline-flex border px-2 py-1 rounded text-xs font-bold uppercase tracking-widest ${toneClasses(claim.status)}`}>
                  {claim.statusLabel}
                </span>
                <span class="text-xs text-lab-muted uppercase tracking-widest">{claim.scope}</span>
              </div>
              <h2 class="text-3xl font-bold tracking-normal">{claim.benchmark}</h2>
              <div class="mt-4 flex items-end gap-4">
                <span class="text-5xl font-bold text-lab-accent-text">{primaryPercent(claim.score)}</span>
                <span class="pb-2 text-lab-muted">{claim.questions} questions</span>
              </div>
              <p class="mt-3 text-lab-muted">{claim.score}</p>
              {claim.retrieval && <p class="text-lab-success mt-1">{claim.retrieval}</p>}
            </div>

            <dl class="grid sm:grid-cols-2 gap-3 text-sm">
              {claim.answerModel && (
                <div class="bg-lab-surface border border-lab-border rounded p-3">
                  <dt class="text-lab-muted text-xs uppercase tracking-widest">Answer model</dt>
                  <dd class="mt-1 break-words">{claim.answerModel}</dd>
                </div>
              )}
              {claim.judgeModel && (
                <div class="bg-lab-surface border border-lab-border rounded p-3">
                  <dt class="text-lab-muted text-xs uppercase tracking-widest">Judge</dt>
                  <dd class="mt-1 break-words">{claim.judgeModel}</dd>
                </div>
              )}
              {claim.judgeCalls !== null && (
                <div class="bg-lab-surface border border-lab-border rounded p-3">
                  <dt class="text-lab-muted text-xs uppercase tracking-widest">Judge calls</dt>
                  <dd class="mt-1">{claim.judgeCalls}</dd>
                </div>
              )}
              {claim.judgeErrors !== null && (
                <div class="bg-lab-surface border border-lab-border rounded p-3">
                  <dt class="text-lab-muted text-xs uppercase tracking-widest">Judge errors</dt>
                  <dd class="mt-1">{claim.judgeErrors}</dd>
                </div>
              )}
            </dl>

            {claim.categoryBreakdown && (
              <div class="overflow-x-auto">
                <table class="w-full text-sm">
                  <thead>
                    <tr class="border-b border-lab-border text-left text-lab-muted">
                      <th class="py-2 pr-4 font-normal uppercase tracking-widest text-xs">Category</th>
                      <th class="py-2 font-normal uppercase tracking-widest text-xs">Score</th>
                    </tr>
                  </thead>
                  <tbody>
                    {claim.categoryBreakdown.map((row) => (
                      <tr class="border-b border-lab-border/60">
                        <td class="py-2 pr-4 capitalize">{row.label}</td>
                        <td class="py-2 text-lab-accent-text">{row.value}</td>
                      </tr>
                    ))}
                  </tbody>
                </table>
              </div>
            )}

            {claim.failureSplit && (
              <p class="text-sm text-lab-muted border-l-2 border-lab-secondary pl-4">{claim.failureSplit}</p>
            )}

            <div class="mt-auto border-t border-lab-border pt-4 text-xs text-lab-muted space-y-2">
              <p>
                <span class="text-lab-text">Source:</span>
                <a href={benchmarkData.links.experimentLog} target="_blank" rel="noopener noreferrer" class="text-lab-accent-text hover:underline">
                  {sourceLabel(claim.source)}
                </a>
              </p>
              {claim.artifact && (
                <p>
                  <span class="text-lab-text">Artifact:</span>
                  <code>{claim.artifact.path}</code>
                  {claim.artifact.gitignored && <span> (generated, gitignored)</span>}
                </p>
              )}
              {claim.artifact?.sha256 && (
                <p class="break-all"><span class="text-lab-text">SHA256:</span> {claim.artifact.sha256}</p>
              )}
            </div>
          </article>
          ))}
        </div>
      </div>
    </section>

    <section class="px-4 md:px-12 py-20 border-b border-lab-border bg-lab-surface">
      <div class="comment-header">:: CANARY_AND_EXPLORATORY</div>
      <div class="max-w-6xl mx-auto grid lg:grid-cols-[0.85fr_1.15fr] gap-8">
        <div>
          <h2 class="text-3xl font-bold mb-4">Canonical vs exploratory</h2>
          <p class="text-lab-muted leading-relaxed">
            Canary runs catch drift quickly. Exploratory runs expose useful signals, but they are not public headline claims until the main repository promotes them through the official benchmark flow.
          </p>
          <div class="mt-6 border border-lab-border bg-lab-bg rounded-lg p-5 text-sm text-lab-muted">
            AutoMem should not be described as "best memory system" or a state-of-the-art winner from these rows. External comparisons need apples-to-apples reruns with current systems, judge policies, dataset versions, and scale settings.
          </div>
        </div>

        <div class="space-y-8">
          <div class="overflow-x-auto border-2 border-lab-text rounded-lg bg-lab-bg shadow-hard">
            <table class="w-full text-sm">
              <caption class="text-left px-4 py-3 font-bold border-b border-lab-border">Verification canaries</caption>
              <thead>
                <tr class="border-b border-lab-border text-left text-lab-muted">
                  <th class="p-4 font-normal uppercase tracking-widest text-xs">Benchmark</th>
                  <th class="p-4 font-normal uppercase tracking-widest text-xs">Scope</th>
                  <th class="p-4 font-normal uppercase tracking-widest text-xs">Score</th>
                  <th class="p-4 font-normal uppercase tracking-widest text-xs">Status</th>
                </tr>
              </thead>
              <tbody>
                {canaryClaims.map((claim) => (
                  <tr class="border-b border-lab-border/60 last:border-b-0">
                    <td class="p-4 font-bold">{claim.benchmark}</td>
                    <td class="p-4 text-lab-muted">{claim.scope}</td>
                    <td class="p-4 text-lab-accent-text whitespace-nowrap">{claim.score}</td>
                    <td class="p-4"><span class={`inline-flex border px-2 py-1 rounded text-xs ${toneClasses(claim.status)}`}>{claim.statusLabel}</span></td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>

          <div class="overflow-x-auto border-2 border-lab-text rounded-lg bg-lab-bg shadow-hard">
            <table class="w-full text-sm">
              <caption class="text-left px-4 py-3 font-bold border-b border-lab-border">Exploratory signals</caption>
              <thead>
                <tr class="border-b border-lab-border text-left text-lab-muted">
                  <th class="p-4 font-normal uppercase tracking-widest text-xs">Benchmark</th>
                  <th class="p-4 font-normal uppercase tracking-widest text-xs">Scope</th>
                  <th class="p-4 font-normal uppercase tracking-widest text-xs">Result</th>
                </tr>
              </thead>
              <tbody>
                {supplementalClaims.map((claim) => (
                  <tr class="border-b border-lab-border/60 last:border-b-0">
                    <td class="p-4 font-bold">{claim.benchmark}</td>
                    <td class="p-4 text-lab-muted">{claim.scope}</td>
                    <td class="p-4 text-lab-muted">{claim.score}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </section>

    <section class="px-4 md:px-12 py-20 bg-lab-bg">
      <div class="comment-header">:: REPRODUCE</div>
      <div class="max-w-6xl mx-auto grid lg:grid-cols-3 gap-8">
        <div class="lg:col-span-2">
          <h2 class="text-3xl font-bold mb-4">Reproduction trail</h2>
          <p class="text-lab-muted leading-relaxed max-w-3xl">
            The website consumes <code>artifact-manifest.json</code> from the main repository benchmark artifact directory.
            Detailed result JSON files may remain generated and gitignored; the durable claim source is the committed experiment log plus the synced artifact manifest.
          </p>

          <div class="mt-8 grid sm:grid-cols-3 gap-4">
            <a href={benchmarkData.links.experimentLog} target="_blank" rel="noopener noreferrer" class="btn-lab">Experiment Log</a>
            <a href={benchmarkData.links.judgePolicy} target="_blank" rel="noopener noreferrer" class="btn-lab">Judge Policy</a>
            <a href={benchmarkData.links.publicationBundle} target="_blank" rel="noopener noreferrer" class="btn-lab">Artifacts</a>
          </div>
        </div>

        <div class="border-2 border-lab-text bg-lab-surface rounded-lg shadow-hard p-6">
          <h3 class="font-bold mb-4">Not yet canonical</h3>
          <ul class="space-y-3 text-sm text-lab-muted">
            {notYetRunClaims.map((item) => (
              <li class="flex gap-3">
                <span class="text-lab-secondary">[ ]</span>
                <span>{item}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </section>
  </main>
</Layout>

<style>
  .benchmark-external-shell {
    background: rgb(var(--lab-surface));
  }

  .benchmark-external-head {
    background: rgb(var(--lab-text));
    color: rgb(var(--lab-bg));
  }

  .benchmark-external-row:nth-child(odd) {
    background: rgb(var(--lab-bg));
  }

  .benchmark-external-row:nth-child(even) {
    background: rgb(var(--lab-surface));
  }

  .benchmark-external-row:hover {
    background: rgba(var(--lab-accent), 0.12);
  }

  .benchmark-score,
  .benchmark-source {
    color: rgb(var(--lab-accent-text));
  }

  .benchmark-source {
    text-decoration-color: rgba(var(--lab-accent-text), 0.45);
    font-weight: 700;
  }
</style>
