---
// import { getEmDashCollection } from 'emdash'; // emdash disabled temporarily
import Layout from '../../layouts/Layout.astro';
import Navigation from '../../components/Navigation.astro';
import PersonSchema from '../../components/schemas/PersonSchema.astro';
import '../../styles/global.css';

// emdash disabled — return empty posts for now
const posts: any[] = [];
---

<Layout
  title="Jack Arturo - Author at AutoMem"
  description="Jack Arturo is a developer, open source advocate, and creator of AutoMem, WP Fusion, and EchoDash. Learn about his work in AI and WordPress development."
>
  <PersonSchema />
  <Navigation currentPath="/authors/jack-arturo" />

  <main class="min-h-screen py-20 px-6">
    <div class="max-w-4xl mx-auto">
      <!-- Author Header -->
      <div class="flex flex-col md:flex-row gap-8 items-start mb-12">
        <div class="flex-shrink-0">
          <img
            src="/jack-arturo.jpeg"
            alt="Jack Arturo"
            class="w-48 h-48 rounded-full object-cover border-4 border-automem-accent shadow-xl"
          />
        </div>
        <div class="flex-1">
          <h1 class="text-5xl font-bold mb-4">
            <span class="gradient-text">Jack Arturo</span>
          </h1>
          <p class="text-xl text-automem-muted mb-6">
            Developer, Open Source Advocate, AI Tool Builder
          </p>

          <!-- Social Links -->
          <div class="flex items-center gap-4 mb-6">
            <a
              href="https://github.com/verygoodplugins?utm_source=automem.ai&utm_medium=author-page&utm_campaign=social"
              target="_blank"
              rel="noopener noreferrer"
              class="flex items-center gap-2 px-4 py-2 bg-automem-surface rounded-lg border border-automem-border hover:border-automem-accent transition"
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
                <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
              </svg>
              GitHub
            </a>
            <a
              href="https://drunk.support?utm_source=automem.ai&utm_medium=author-page&utm_campaign=social"
              target="_blank"
              rel="noopener noreferrer"
              class="flex items-center gap-2 px-4 py-2 bg-automem-surface rounded-lg border border-automem-border hover:border-automem-accent transition"
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"></path>
                <path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"></path>
              </svg>
              Blog
            </a>
          </div>
        </div>
      </div>

      <!-- Bio Section -->
      <section class="mb-16">
        <div class="bg-automem-surface rounded-xl p-8 border border-automem-border shadow-lg">
          <h2 class="text-3xl font-bold mb-6 text-automem-text">About</h2>
          <div class="space-y-4 text-automem-muted">
            <p>
              Jack Arturo has been writing code since he was 12 years old. That's over two decades of turning ideas into software, most of it in the WordPress ecosystem where he's been building for the past 16-18 years.
            </p>
            <p>
              For the last 12 years, he's been running <a href="https://verygoodplugins.com?utm_source=automem.ai&utm_medium=author-page&utm_campaign=link" target="_blank" rel="noopener noreferrer" class="text-automem-accent hover:underline"><strong class="text-automem-text">Very Good Plugins</strong></a>, where he built <a href="https://wpfusion.com?utm_source=automem.ai&utm_medium=author-page&utm_campaign=link" target="_blank" rel="noopener noreferrer" class="text-automem-accent hover:underline">WP Fusion</a> — an integration tool that connects WordPress with CRM and email marketing systems like HubSpot, MailChimp, and Salesforce. WP Fusion helps thousands of WordPress businesses automate their marketing.
            </p>
            <p>
              More recently, Jack co-founded <a href="https://echodash.com?utm_source=automem.ai&utm_medium=author-page&utm_campaign=link" target="_blank" rel="noopener noreferrer" class="text-automem-accent hover:underline">EchoDash</a>, a platform that cuts through data noise to surface what actually matters. EchoDash lets you have conversations with your data and proactively offers insights based on your business context.
            </p>
            <p>
              These days, Jack is deep into AI development. He uses tools like <strong class="text-automem-text">Claude Code</strong> and <strong class="text-automem-text">Cursor</strong> extensively, and has built <strong class="text-automem-text">AutoJack</strong> — his personal AI assistant that helps automate everything from customer support to development workflows. He writes about this work on his <a href="https://drunk.support?utm_source=automem.ai&utm_medium=author-page&utm_campaign=link" target="_blank" rel="noopener noreferrer" class="text-automem-accent hover:underline">personal blog</a>.
            </p>
            <p>
              <strong class="text-automem-text">AutoMem</strong> grew out of that work. When Jack built the Claude Automation Hub and started giving AI assistants memory capabilities, he realized this shouldn't be proprietary technology locked behind walls. Everyone deserves AI that remembers.
            </p>
            <p>
              Jack believes in open source software and giving good stuff away. Not because it looks good on GitHub, but because better tools make better builders.
            </p>
          </div>

          <!-- Expertise -->
          <div class="mt-8 pt-8 border-t border-automem-border">
            <h3 class="text-xl font-semibold mb-4 text-automem-text">Areas of Expertise</h3>
            <div class="flex flex-wrap gap-2">
              <span class="px-3 py-1 bg-automem-accent/10 text-automem-accent rounded-full text-sm">WordPress Development</span>
              <span class="px-3 py-1 bg-automem-accent/10 text-automem-accent rounded-full text-sm">AI Development</span>
              <span class="px-3 py-1 bg-automem-accent/10 text-automem-accent rounded-full text-sm">Open Source</span>
              <span class="px-3 py-1 bg-automem-accent/10 text-automem-accent rounded-full text-sm">API Integrations</span>
              <span class="px-3 py-1 bg-automem-accent/10 text-automem-accent rounded-full text-sm">Marketing Automation</span>
              <span class="px-3 py-1 bg-automem-accent/10 text-automem-accent rounded-full text-sm">AI Assistants</span>
            </div>
          </div>
        </div>
      </section>

      <!-- Posts by Author -->
      <section>
        <h2 class="text-3xl font-bold mb-8 text-automem-text">
          Articles by Jack ({posts.length})
        </h2>
        <div class="space-y-6">
          {posts.map(post => (
            <article class="group">
              <a
                href={`/blog/${post.data.slug}`}
                class="block bg-automem-surface rounded-lg p-6 border border-automem-border hover:border-automem-accent transition-all hover:shadow-lg"
              >
                <div class="flex items-start justify-between gap-4">
                  <div class="flex-1">
                    <h3 class="text-2xl font-semibold mb-2 text-automem-text group-hover:text-automem-accent transition">
                      {post.data.title}
                    </h3>
                    <p class="text-automem-muted mb-3">
                      {post.data.excerpt}
                    </p>
                    <div class="flex items-center gap-4 text-sm">
                      <time class="text-automem-muted">
                        {(post.data.published_at ? new Date(post.data.published_at) : new Date()).toLocaleDateString('en-US', {
                          month: 'long',
                          day: 'numeric',
                          year: 'numeric'
                        })}
                      </time>
                      {false && (
                        <div class="flex gap-2">
                          {[].map(tag => (
                            <span class="px-2 py-1 bg-automem-accent/10 text-automem-accent rounded text-xs">
                              {tag}
                            </span>
                          ))}
                        </div>
                      )}
                    </div>
                  </div>
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="24"
                    height="24"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    class="text-automem-muted group-hover:text-automem-accent group-hover:translate-x-1 transition-all flex-shrink-0"
                  >
                    <line x1="5" y1="12" x2="19" y2="12"></line>
                    <polyline points="12 5 19 12 12 19"></polyline>
                  </svg>
                </div>
              </a>
            </article>
          ))}
        </div>

        {posts.length === 0 && (
          <div class="text-center py-12">
            <p class="text-automem-muted text-lg">No published articles yet.</p>
          </div>
        )}
      </section>
    </div>
  </main>
</Layout>
