---
import Layout from '../layouts/Layout.astro';
import Navigation from '../components/Navigation.astro';
---

<Layout title="Animation Lab">
  <Navigation currentPath="/animation-lab" />
  
  <main class="w-full min-h-screen bg-[#0d0d0d] pt-20 pb-24 overflow-hidden">
    <div class="max-w-6xl mx-auto px-6">
      
      <div class="text-center mb-8">
        <h1 class="text-4xl font-bold text-lab-text mb-4">Animation Lab</h1>
        <p class="text-lab-muted">Prototype: Memory-Powered AI Transformation</p>
        <button id="start-demo" class="mt-6 px-8 py-3 bg-lab-accent text-lab-bg font-bold rounded-lg hover:scale-105 transition-transform">
          ▶ Start Demo
        </button>
        <button id="reset-demo" class="mt-6 ml-4 px-8 py-3 border-2 border-lab-border text-lab-text font-bold rounded-lg hover:border-lab-accent transition-colors hidden">
          ↻ Reset
        </button>
      </div>
      
      <section class="memory-demo relative overflow-hidden min-h-[650px]" id="memory-demo">
        
        <div class="memory-graph absolute inset-0 pointer-events-none" id="memory-graph">
          <svg class="w-full h-full" viewBox="0 0 1000 600" preserveAspectRatio="xMidYMid slice">
            <defs>
              <radialGradient id="nodeGlow" cx="50%" cy="50%" r="50%">
                <stop offset="0%" style="stop-color:#F9D857;stop-opacity:1"/>
                <stop offset="100%" style="stop-color:#F9D857;stop-opacity:0"/>
              </radialGradient>
              <radialGradient id="nodeGlowPurple" cx="50%" cy="50%" r="50%">
                <stop offset="0%" style="stop-color:#a78bfa;stop-opacity:1"/>
                <stop offset="100%" style="stop-color:#a78bfa;stop-opacity:0"/>
              </radialGradient>
              <radialGradient id="nodeGlowGreen" cx="50%" cy="50%" r="50%">
                <stop offset="0%" style="stop-color:#34D399;stop-opacity:1"/>
                <stop offset="100%" style="stop-color:#34D399;stop-opacity:0"/>
              </radialGradient>
              <radialGradient id="nodeGlowOrange" cx="50%" cy="50%" r="50%">
                <stop offset="0%" style="stop-color:#fb923c;stop-opacity:1"/>
                <stop offset="100%" style="stop-color:#fb923c;stop-opacity:0"/>
              </radialGradient>
              <filter id="glow">
                <feGaussianBlur stdDeviation="4" result="coloredBlur"/>
                <feMerge>
                  <feMergeNode in="coloredBlur"/>
                  <feMergeNode in="SourceGraphic"/>
                </feMerge>
              </filter>
              <linearGradient id="diskGold" x1="0%" y1="0%" x2="0%" y2="100%">
                <stop offset="0%" style="stop-color:#FFE082"/>
                <stop offset="50%" style="stop-color:#F9D857"/>
                <stop offset="100%" style="stop-color:#DAA520"/>
              </linearGradient>
            </defs>
            
            <g class="connections" id="connections">
              <line class="connection c1" x1="580" y1="300" x2="700" y2="120"/>
              <line class="connection c2" x1="580" y1="300" x2="750" y2="220"/>
              <line class="connection c3" x1="580" y1="300" x2="720" y2="340"/>
              <line class="connection c4" x1="580" y1="300" x2="680" y2="450"/>
              <line class="connection c5" x1="580" y1="300" x2="850" y2="180"/>
              <line class="connection c6" x1="700" y1="120" x2="850" y2="100"/>
              <line class="connection c7" x1="700" y1="120" x2="870" y2="160"/>
              <line class="connection c8" x1="750" y1="220" x2="880" y2="250"/>
              <line class="connection c9" x1="750" y1="220" x2="900" y2="300"/>
              <line class="connection c10" x1="720" y1="340" x2="870" y2="380"/>
              <line class="connection c11" x1="720" y1="340" x2="860" y2="440"/>
              <line class="connection c12" x1="680" y1="450" x2="820" y2="500"/>
              <line class="connection c13" x1="680" y1="450" x2="840" y2="540"/>
            </g>
            
            <g class="nodes" id="nodes">
              <g class="node node-center" data-delay="0">
                <circle cx="580" cy="300" r="30" fill="url(#nodeGlow)" filter="url(#glow)"/>
                <circle cx="580" cy="300" r="15" fill="#F9D857"/>
                <text x="580" y="305" text-anchor="middle" class="node-label center-label">🔍</text>
              </g>
              
              <g class="node node-1" data-delay="400">
                <circle cx="700" cy="120" r="22" fill="url(#nodeGlowPurple)" filter="url(#glow)"/>
                <circle cx="700" cy="120" r="10" fill="#a78bfa"/>
                <text x="700" y="95" text-anchor="middle" class="node-label purple">👤 Identity</text>
              </g>
              
              <g class="node node-2" data-delay="800">
                <circle cx="850" cy="100" r="16" fill="url(#nodeGlowGreen)" filter="url(#glow)"/>
                <circle cx="850" cy="100" r="7" fill="#34D399"/>
                <text x="850" y="80" text-anchor="middle" class="node-label green">Jack Arturo</text>
              </g>
              
              <g class="node node-3" data-delay="1100">
                <circle cx="870" cy="160" r="14" fill="url(#nodeGlowGreen)" filter="url(#glow)"/>
                <circle cx="870" cy="160" r="6" fill="#34D399"/>
                <text x="870" y="185" text-anchor="middle" class="node-label green">Full-stack Dev</text>
              </g>
              
              <g class="node node-4" data-delay="1500">
                <circle cx="750" cy="220" r="22" fill="url(#nodeGlowPurple)" filter="url(#glow)"/>
                <circle cx="750" cy="220" r="10" fill="#a78bfa"/>
                <text x="750" y="200" text-anchor="middle" class="node-label purple">📂 Project</text>
              </g>
              
              <g class="node node-5" data-delay="1900">
                <circle cx="880" cy="250" r="16" fill="url(#nodeGlowGreen)" filter="url(#glow)"/>
                <circle cx="880" cy="250" r="7" fill="#34D399"/>
                <text x="880" y="230" text-anchor="middle" class="node-label green">AutoMem.ai</text>
              </g>
              
              <g class="node node-6" data-delay="2200">
                <circle cx="900" cy="300" r="14" fill="url(#nodeGlowGreen)" filter="url(#glow)"/>
                <circle cx="900" cy="300" r="6" fill="#34D399"/>
                <text x="900" y="325" text-anchor="middle" class="node-label green">Astro + TS</text>
              </g>
              
              <g class="node node-7" data-delay="2600">
                <circle cx="720" cy="340" r="22" fill="url(#nodeGlowPurple)" filter="url(#glow)"/>
                <circle cx="720" cy="340" r="10" fill="#a78bfa"/>
                <text x="720" y="320" text-anchor="middle" class="node-label purple">📜 History</text>
              </g>
              
              <g class="node node-8" data-delay="3000">
                <circle cx="870" cy="380" r="16" fill="url(#nodeGlowGreen)" filter="url(#glow)"/>
                <circle cx="870" cy="380" r="7" fill="#34D399"/>
                <text x="870" y="360" text-anchor="middle" class="node-label green">Homepage work</text>
              </g>
              
              <g class="node node-9" data-delay="3300">
                <circle cx="860" cy="440" r="14" fill="url(#nodeGlowGreen)" filter="url(#glow)"/>
                <circle cx="860" cy="440" r="6" fill="#34D399"/>
                <text x="860" y="465" text-anchor="middle" class="node-label green">MemoryHero.astro</text>
              </g>
              
              <g class="node node-10" data-delay="3700">
                <circle cx="680" cy="450" r="22" fill="url(#nodeGlowPurple)" filter="url(#glow)"/>
                <circle cx="680" cy="450" r="10" fill="#a78bfa"/>
                <text x="680" y="430" text-anchor="middle" class="node-label purple">⚙️ Preferences</text>
              </g>
              
              <g class="node node-11" data-delay="4100">
                <circle cx="820" cy="500" r="14" fill="url(#nodeGlowGreen)" filter="url(#glow)"/>
                <circle cx="820" cy="500" r="6" fill="#34D399"/>
                <text x="820" y="525" text-anchor="middle" class="node-label green">Concise fixes</text>
              </g>
              
              <g class="node node-12" data-delay="4400">
                <circle cx="840" cy="540" r="14" fill="url(#nodeGlowGreen)" filter="url(#glow)"/>
                <circle cx="840" cy="540" r="6" fill="#34D399"/>
                <text x="840" y="565" text-anchor="middle" class="node-label green">Direct tone</text>
              </g>
              
              <g class="node node-solution" data-delay="5000">
                <circle cx="850" cy="180" r="26" fill="url(#nodeGlowOrange)" filter="url(#glow)"/>
                <circle cx="850" cy="180" r="12" fill="#fb923c"/>
                <text x="850" y="215" text-anchor="middle" class="node-label orange">💡 Solution Found!</text>
              </g>
            </g>
            
            <g class="disk-group" id="disk-group" transform="translate(520, 240)">
              <g class="autojack-disk" id="autojack-disk">
                <rect x="0" y="0" width="100" height="100" rx="10" fill="url(#diskGold)" stroke="#1a1a1a" stroke-width="3"/>
                <rect x="25" y="8" width="50" height="30" rx="4" fill="#e5e5e5" stroke="#1a1a1a" stroke-width="2"/>
                <rect x="55" y="14" width="15" height="18" rx="2" fill="#1a1a1a"/>
                <g class="disk-face" id="disk-face">
                  <circle class="eye-left" cx="35" cy="60" r="6" fill="#1a1a1a"/>
                  <circle class="eye-right" cx="65" cy="60" r="6" fill="#1a1a1a"/>
                  <path class="mouth" d="M40 78 Q50 88 60 78" stroke="#1a1a1a" stroke-width="3" fill="none" stroke-linecap="round"/>
                </g>
                <circle class="blush-left" cx="22" cy="70" r="6" fill="#ff9999" opacity="0"/>
                <circle class="blush-right" cx="78" cy="70" r="6" fill="#ff9999" opacity="0"/>
              </g>
            </g>
          </svg>
        </div>
        
        <div class="max-w-lg relative z-10 ml-4 md:ml-8">
          <div class="chat-window bg-[#212121] rounded-2xl overflow-hidden shadow-2xl border border-[#2f2f2f]" id="chat-window">
            
            <div class="chat-header flex items-center justify-between px-4 py-3 border-b border-[#2f2f2f]">
              <div class="flex items-center gap-2">
                <svg class="w-6 h-6" viewBox="0 0 24 24" fill="none">
                  <circle cx="12" cy="12" r="10" fill="#6366f1"/>
                  <path d="M8 12h8M12 8v8" stroke="#fff" stroke-width="2" stroke-linecap="round"/>
                </svg>
                <span class="text-white font-medium">ChatABC</span>
                <span class="text-xs text-gray-500">Pro</span>
              </div>
              <div class="flex items-center gap-2">
                <span class="status-badge text-xs px-2 py-1 rounded-full bg-[#2f2f2f] text-gray-400" id="status-badge">Standard</span>
              </div>
            </div>
            
            <div class="chat-body p-5 min-h-[320px] flex flex-col" id="chat-body">
              
              <div class="flex-1 space-y-4">
                
                <div class="user-message opacity-0 flex justify-end" id="user-message">
                  <div class="bg-[#2f2f2f] rounded-2xl px-4 py-3 max-w-[85%]">
                    <p class="text-white text-sm" id="user-text"></p>
                  </div>
                </div>
                
                <div class="ai-response opacity-0" id="generic-response">
                  <div class="flex items-start gap-3">
                    <div class="w-7 h-7 rounded-full bg-[#6366f1] flex items-center justify-center flex-shrink-0">
                      <svg class="w-4 h-4" viewBox="0 0 24 24" fill="white">
                        <circle cx="12" cy="12" r="3"/>
                      </svg>
                    </div>
                    <div class="flex-1">
                      <p class="text-gray-300 leading-relaxed text-sm" id="generic-text"></p>
                    </div>
                  </div>
                </div>
                
                <div class="ai-response opacity-0 hidden" id="memory-response">
                  <div class="flex items-start gap-3">
                    <div class="w-7 h-7 rounded-full bg-[#F9D857] flex items-center justify-center flex-shrink-0 memory-avatar">
                      <svg class="w-4 h-4" viewBox="0 0 24 24" fill="#1a1a1a">
                        <rect x="4" y="4" width="16" height="16" rx="2"/>
                        <rect x="8" y="6" width="8" height="5" rx="1" fill="#fff"/>
                      </svg>
                    </div>
                    <div class="flex-1">
                      <p class="text-white leading-relaxed text-sm" id="memory-text"></p>
                    </div>
                  </div>
                </div>
              </div>
              
              <div class="chat-input mt-4 relative">
                <div class="bg-[#2f2f2f] rounded-xl border border-[#3f3f3f] px-4 py-2.5 flex items-center gap-3">
                  <input type="text" placeholder="Ask anything" class="flex-1 bg-transparent text-white placeholder-gray-500 outline-none text-sm" disabled />
                  <button class="text-gray-500 hover:text-white transition-colors">
                    <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                      <path d="M2.01 21L23 12 2.01 3 2 10l15 2-15 2z"/>
                    </svg>
                  </button>
                </div>
              </div>
            </div>
          </div>
        </div>
        
      </section>
      
    </div>
  </main>
</Layout>

<style>
  .memory-demo {
    min-height: 600px;
  }
  
  .memory-graph {
    opacity: 0;
    transition: opacity 0.8s ease;
  }
  
  .memory-graph.active {
    opacity: 1;
  }
  
  .connection {
    stroke: rgba(249, 216, 87, 0.2);
    stroke-width: 2;
    stroke-dasharray: 300;
    stroke-dashoffset: 300;
    transition: stroke-dashoffset 1s ease-out, stroke 0.4s ease;
  }
  
  .connection.active {
    stroke-dashoffset: 0;
    stroke: rgba(249, 216, 87, 0.5);
  }
  
  .node {
    opacity: 0;
    transform: scale(0);
    transform-origin: center;
    transition: opacity 0.5s ease, transform 0.6s cubic-bezier(0.34, 1.56, 0.64, 1);
  }
  
  .node.active {
    opacity: 1;
    transform: scale(1);
  }
  
  .node.active circle:first-child {
    animation: pulse-glow 2.5s ease-in-out infinite;
  }
  
  @keyframes pulse-glow {
    0%, 100% { opacity: 0.4; transform: scale(1); }
    50% { opacity: 0.7; transform: scale(1.15); }
  }
  
  .node-label {
    fill: rgba(249, 216, 87, 0.95);
    font-size: 12px;
    font-family: 'JetBrains Mono', monospace;
    font-weight: 600;
  }
  
  .node-label.purple {
    fill: #c4b5fd;
  }
  
  .node-label.green {
    fill: #6ee7b7;
    font-size: 11px;
  }
  
  .node-label.orange {
    fill: #fdba74;
    font-size: 13px;
    font-weight: 700;
  }
  
  .center-label {
    fill: #1a1a1a;
    font-size: 16px;
  }
  
  .chat-window {
    transition: box-shadow 0.6s ease, border-color 0.6s ease;
  }
  
  .chat-window.powered-up {
    border-color: #F9D857;
    box-shadow: 0 0 60px rgba(249, 216, 87, 0.4), 0 0 120px rgba(249, 216, 87, 0.2), 0 20px 40px rgba(0,0,0,0.4);
  }
  
  .status-badge.connected {
    background: rgba(249, 216, 87, 0.2);
    color: #F9D857;
    animation: badge-pulse 2s ease-in-out infinite;
  }
  
  @keyframes badge-pulse {
    0%, 100% { box-shadow: 0 0 0 0 rgba(249, 216, 87, 0.4); }
    50% { box-shadow: 0 0 0 4px rgba(249, 216, 87, 0); }
  }
  
  .memory-avatar {
    animation: avatar-pulse 1.5s ease-in-out infinite;
  }
  
  @keyframes avatar-pulse {
    0%, 100% { box-shadow: 0 0 0 0 rgba(249, 216, 87, 0.4); }
    50% { box-shadow: 0 0 0 6px rgba(249, 216, 87, 0); }
  }
  
  .typing-cursor {
    display: inline-block;
    width: 2px;
    height: 1em;
    background: white;
    margin-left: 2px;
    animation: blink 0.7s step-end infinite;
  }
  
  @keyframes blink {
    0%, 100% { opacity: 1; }
    50% { opacity: 0; }
  }
  
  .fade-out {
    opacity: 0 !important;
    transition: opacity 0.5s ease;
  }
  
  .autojack-disk {
    filter: drop-shadow(0 6px 20px rgba(249, 216, 87, 0.5));
    transition: filter 0.5s ease;
  }
  
  .autojack-disk.glowing {
    filter: drop-shadow(0 0 40px rgba(249, 216, 87, 0.8));
  }
  
  @media (prefers-reduced-motion: reduce) {
    .node, .connection, .chat-window, .autojack-disk {
      transition: none;
    }
    .node.active circle:first-child, .memory-avatar, .status-badge.connected {
      animation: none;
    }
  }
</style>

<script>
  class MemoryDemoAnimation {
    constructor() {
      this.startBtn = document.getElementById('start-demo');
      this.resetBtn = document.getElementById('reset-demo');
      this.graph = document.getElementById('memory-graph');
      this.nodes = document.querySelectorAll('.node');
      this.connections = document.querySelectorAll('.connection');
      this.disk = document.getElementById('autojack-disk');
      this.diskFace = document.getElementById('disk-face');
      this.chatWindow = document.getElementById('chat-window');
      this.userMessage = document.getElementById('user-message');
      this.userText = document.getElementById('user-text');
      this.genericResponse = document.getElementById('generic-response');
      this.genericText = document.getElementById('generic-text');
      this.memoryResponse = document.getElementById('memory-response');
      this.memoryText = document.getElementById('memory-text');
      this.statusBadge = document.getElementById('status-badge');
      
      this.isPlaying = false;
      
      this.userQuestion = "Can you help me fix an Uncaught TypeError on the homepage?";
      this.genericReply = "I'd be happy to help! Could you provide some more details about the error? Specifically:\n\n1. What does the error message say?\n2. Which script is causing the issue?\n3. What actions trigger the error?";
      this.memoryReply = `Welcome back, Jack! I see from our last session you were working on the homepage animations.

Found it! The TypeError is in **MemoryHero.astro** line 291 — TypeScript syntax in a browser script tag.

**Quick fix:** Remove type annotations and use vanilla JS.

✓ File updated. Reloading now...`;
      
      this.init();
    }
    
    init() {
      this.startBtn.addEventListener('click', () => this.play());
      this.resetBtn.addEventListener('click', () => {
        this.reset();
        this.resetBtn.classList.add('hidden');
      });
    }
    
    async play() {
      if (this.isPlaying) return;
      this.isPlaying = true;
      this.startBtn.classList.add('hidden');
      this.reset();
      
      await this.delay(400);
      this.userMessage.classList.remove('opacity-0');
      await this.typeText(this.userText, this.userQuestion, 30);
      
      await this.delay(600);
      this.genericResponse.classList.remove('opacity-0');
      await this.typeText(this.genericText, this.genericReply, 12);
      
      await this.delay(800);
      this.graph.classList.add('active');
      this.disk.classList.add('glowing');
      this.showBlissExpression();
      this.chatWindow.classList.add('powered-up');
      this.statusBadge.textContent = '✨ AutoMem Connected';
      this.statusBadge.classList.add('connected');
      
      for (let i = 0; i < this.nodes.length; i++) {
        const node = this.nodes[i];
        const nodeDelay = parseInt(node.getAttribute('data-delay') || '0');
        setTimeout(() => node.classList.add('active'), nodeDelay);
      }
      
      await this.delay(300);
      this.connections.forEach((conn, i) => {
        setTimeout(() => conn.classList.add('active'), i * 150);
      });
      
      await this.delay(5500);
      this.genericResponse.classList.add('fade-out');
      
      await this.delay(500);
      this.genericResponse.classList.add('hidden');
      this.memoryResponse.classList.remove('hidden');
      this.memoryResponse.classList.remove('opacity-0');
      await this.typeText(this.memoryText, this.memoryReply, 8);
      
      await this.delay(600);
      this.resetBtn.classList.remove('hidden');
      this.isPlaying = false;
    }
    
    showBlissExpression() {
      const eyeLeft = this.diskFace.querySelector('.eye-left');
      const eyeRight = this.diskFace.querySelector('.eye-right');
      const mouth = this.diskFace.querySelector('.mouth');
      const blushLeft = this.disk.querySelector('.blush-left');
      const blushRight = this.disk.querySelector('.blush-right');
      
      eyeLeft.setAttribute('r', '0');
      eyeRight.setAttribute('r', '0');
      
      const happyEyeLeft = document.createElementNS('http://www.w3.org/2000/svg', 'path');
      happyEyeLeft.setAttribute('d', 'M28 60 Q35 52 42 60');
      happyEyeLeft.setAttribute('stroke', '#1a1a1a');
      happyEyeLeft.setAttribute('stroke-width', '3');
      happyEyeLeft.setAttribute('fill', 'none');
      happyEyeLeft.setAttribute('stroke-linecap', 'round');
      happyEyeLeft.classList.add('happy-eye');
      
      const happyEyeRight = document.createElementNS('http://www.w3.org/2000/svg', 'path');
      happyEyeRight.setAttribute('d', 'M58 60 Q65 52 72 60');
      happyEyeRight.setAttribute('stroke', '#1a1a1a');
      happyEyeRight.setAttribute('stroke-width', '3');
      happyEyeRight.setAttribute('fill', 'none');
      happyEyeRight.setAttribute('stroke-linecap', 'round');
      happyEyeRight.classList.add('happy-eye');
      
      this.diskFace.appendChild(happyEyeLeft);
      this.diskFace.appendChild(happyEyeRight);
      
      mouth.setAttribute('d', 'M35 78 Q50 95 65 78');
      
      blushLeft.style.transition = 'opacity 0.5s ease';
      blushRight.style.transition = 'opacity 0.5s ease';
      blushLeft.style.opacity = '0.7';
      blushRight.style.opacity = '0.7';
    }
    
    async typeText(element, text, speed = 30) {
      element.innerHTML = '';
      
      const lines = text.split('\n');
      
      for (let l = 0; l < lines.length; l++) {
        const line = lines[l];
        
        for (let i = 0; i < line.length; i++) {
          element.innerHTML = element.innerHTML.replace('<span class="typing-cursor"></span>', '');
          
          if (line[i] === '*' && line[i+1] === '*') {
            const endBold = line.indexOf('**', i + 2);
            if (endBold > i) {
              const boldText = line.substring(i + 2, endBold);
              element.innerHTML += `<strong class="text-lab-accent">${boldText}</strong>`;
              i = endBold + 1;
            } else {
              element.innerHTML += line[i];
            }
          } else {
            element.innerHTML += line[i];
          }
          
          element.innerHTML += '<span class="typing-cursor"></span>';
          
          if (i % 2 === 0) {
            await this.delay(speed);
          }
        }
        
        if (l < lines.length - 1) {
          element.innerHTML = element.innerHTML.replace('<span class="typing-cursor"></span>', '');
          element.innerHTML += '<br><span class="typing-cursor"></span>';
          await this.delay(speed * 2);
        }
      }
      
      await this.delay(200);
      element.innerHTML = element.innerHTML.replace('<span class="typing-cursor"></span>', '');
    }
    
    reset() {
      this.graph.classList.remove('active');
      this.chatWindow.classList.remove('powered-up');
      this.disk.classList.remove('glowing');
      
      this.nodes.forEach(n => n.classList.remove('active'));
      this.connections.forEach(c => c.classList.remove('active'));
      
      this.userMessage.classList.add('opacity-0');
      this.genericResponse.classList.remove('hidden', 'fade-out');
      this.genericResponse.classList.add('opacity-0');
      this.memoryResponse.classList.add('hidden', 'opacity-0');
      
      const happyEyes = this.diskFace.querySelectorAll('.happy-eye');
      happyEyes.forEach(eye => eye.remove());
      
      const eyeLeft = this.diskFace.querySelector('.eye-left');
      const eyeRight = this.diskFace.querySelector('.eye-right');
      const mouth = this.diskFace.querySelector('.mouth');
      const blushLeft = this.disk.querySelector('.blush-left');
      const blushRight = this.disk.querySelector('.blush-right');
      
      if (eyeLeft) eyeLeft.setAttribute('r', '6');
      if (eyeRight) eyeRight.setAttribute('r', '6');
      if (mouth) mouth.setAttribute('d', 'M40 78 Q50 88 60 78');
      if (blushLeft) blushLeft.style.opacity = '0';
      if (blushRight) blushRight.style.opacity = '0';
      
      this.statusBadge.textContent = 'Standard';
      this.statusBadge.classList.remove('connected');
      
      this.userText.innerHTML = '';
      this.genericText.innerHTML = '';
      this.memoryText.innerHTML = '';
      
      this.startBtn.classList.remove('hidden');
    }
    
    delay(ms) {
      return new Promise(resolve => setTimeout(resolve, ms));
    }
  }
  
  new MemoryDemoAnimation();
</script>
