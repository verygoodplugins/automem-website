---
import Layout from '../layouts/Layout.astro';
import Navigation from '../components/Navigation.astro';

const currentDate = new Date().toLocaleDateString('en-US', { 
  weekday: 'long', 
  year: 'numeric', 
  month: 'long', 
  day: 'numeric' 
});
---

<Layout title="Animation Lab">
  <Navigation currentPath="/animation-lab" />
  
  <main class="w-full min-h-screen bg-[#0d0d0d] pt-20 pb-24 overflow-hidden">
    <div class="max-w-7xl mx-auto px-6">
      
      <div class="text-center mb-8">
        <h1 class="text-4xl font-bold text-lab-text mb-4">Animation Lab</h1>
        <p class="text-lab-muted">Prototype: Memory-Powered AI Transformation</p>
        <button id="start-demo" class="mt-6 px-8 py-3 bg-lab-accent text-lab-bg font-bold rounded-lg hover:scale-105 transition-transform">
          ▶ Start Demo
        </button>
        <button id="reset-demo" class="mt-6 ml-4 px-8 py-3 border-2 border-lab-border text-lab-text font-bold rounded-lg hover:border-lab-accent transition-colors hidden">
          ↻ Reset
        </button>
      </div>
      
      <div class="demo-container relative min-h-[750px]" id="demo-container">
        
        <!-- Memory bubbles container (fills right side) -->
        <div class="memory-bubbles-container absolute inset-0 pointer-events-none" id="memory-bubbles"></div>
        
        <!-- SVG for connection lines -->
        <svg class="connection-lines absolute inset-0 w-full h-full pointer-events-none" id="connection-lines"></svg>
        
        <!-- Main layout: Chat on left, disk animation on right -->
        <div class="flex items-center justify-start gap-0 h-full min-h-[650px]">
          
          <!-- Chat window (LEFT side) -->
          <div class="chat-window-wrapper relative z-10 flex-shrink-0" id="chat-wrapper">
            <div class="chat-window bg-[#212121] rounded-2xl overflow-hidden shadow-2xl w-[480px] border border-[#2f2f2f]" id="chat-window">
              
              <div class="chat-header flex items-center justify-between px-4 py-3 border-b border-[#2f2f2f]">
                <div class="flex items-center gap-2">
                  <svg class="w-6 h-6" viewBox="0 0 24 24" fill="none">
                    <circle cx="12" cy="12" r="10" fill="#6366f1"/>
                    <path d="M8 12h8M12 8v8" stroke="#fff" stroke-width="2" stroke-linecap="round"/>
                  </svg>
                  <span class="text-white font-medium">ChatABC</span>
                  <span class="text-xs text-gray-500">Pro</span>
                </div>
                <div class="flex items-center gap-2">
                  <span class="status-badge text-xs px-2 py-1 rounded-full bg-[#2f2f2f] text-gray-400" id="status-badge">Standard</span>
                </div>
              </div>
              
              <div class="chat-body p-6 min-h-[380px] flex flex-col" id="chat-body">
                
                <div class="flex-1 space-y-4">
                  
                  <div class="user-message opacity-0 flex justify-end" id="user-message">
                    <div class="bg-[#2f2f2f] rounded-2xl px-4 py-3 max-w-[85%]">
                      <p class="text-white" id="user-text"></p>
                    </div>
                  </div>
                  
                  <div class="ai-response opacity-0" id="generic-response">
                    <div class="flex items-start gap-3">
                      <div class="w-8 h-8 rounded-full bg-[#6366f1] flex items-center justify-center flex-shrink-0">
                        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="white">
                          <circle cx="12" cy="12" r="3"/>
                        </svg>
                      </div>
                      <div class="flex-1">
                        <p class="text-gray-300 leading-relaxed text-sm" id="generic-text"></p>
                      </div>
                    </div>
                  </div>
                  
                  <div class="ai-response opacity-0 hidden" id="memory-response">
                    <div class="flex items-start gap-3">
                      <div class="w-8 h-8 rounded-full bg-[#F9D857] flex items-center justify-center flex-shrink-0 memory-avatar">
                        <svg class="w-5 h-5" viewBox="0 0 24 24" fill="#1a1a1a">
                          <rect x="4" y="4" width="16" height="16" rx="2"/>
                          <rect x="8" y="6" width="8" height="5" rx="1" fill="#fff"/>
                        </svg>
                      </div>
                      <div class="flex-1">
                        <p class="text-white leading-relaxed text-sm" id="memory-text"></p>
                      </div>
                    </div>
                  </div>
                </div>
                
                <div class="chat-input mt-6 relative">
                  <div class="bg-[#2f2f2f] rounded-xl border border-[#3f3f3f] px-4 py-3 flex items-center gap-3">
                    <input type="text" placeholder="Ask anything" class="flex-1 bg-transparent text-white placeholder-gray-500 outline-none text-sm" disabled />
                    <button class="text-gray-500 hover:text-white transition-colors">
                      <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                        <path d="M2.01 21L23 12 2.01 3 2 10l15 2-15 2z"/>
                      </svg>
                    </button>
                  </div>
                </div>
              </div>
            </div>
            
            <!-- Drive slot on RIGHT side of chat -->
            <div class="drive-slot absolute top-1/2 -translate-y-1/2 -right-4 w-6 h-28 opacity-0" id="drive-slot">
              <div class="w-full h-full bg-[#1a1a1a] rounded-r-lg border-2 border-[#333] border-l-0 flex items-center justify-center">
                <div class="w-1 h-16 bg-[#2a2a2a] rounded"></div>
              </div>
            </div>
          </div>
          
          <!-- AutoJack disk (starts far right, slides left into side slot) -->
          <div class="autojack-disk absolute opacity-0" id="autojack-disk" style="right: -250px; top: 50%; transform: translateY(-50%);">
            <svg viewBox="0 0 100 100" width="200" height="200" class="drop-shadow-2xl disk-svg">
              <defs>
                <linearGradient id="diskGold" x1="0%" y1="0%" x2="0%" y2="100%">
                  <stop offset="0%" style="stop-color:#FFE082"/>
                  <stop offset="50%" style="stop-color:#F9D857"/>
                  <stop offset="100%" style="stop-color:#DAA520"/>
                </linearGradient>
                <filter id="diskGlow">
                  <feGaussianBlur stdDeviation="6" result="coloredBlur"/>
                  <feMerge>
                    <feMergeNode in="coloredBlur"/>
                    <feMergeNode in="SourceGraphic"/>
                  </feMerge>
                </filter>
              </defs>
              <!-- Disk body -->
              <rect x="10" y="10" width="80" height="80" rx="8" fill="url(#diskGold)" stroke="#1a1a1a" stroke-width="3"/>
              <!-- Metal shutter -->
              <rect x="30" y="15" width="40" height="25" rx="3" fill="#e5e5e5" stroke="#1a1a1a" stroke-width="2"/>
              <rect x="55" y="20" width="12" height="15" rx="2" fill="#1a1a1a"/>
              <!-- Face - starts confident, will change to bliss -->
              <g class="disk-face" id="disk-face">
                <!-- Confident expression (default) -->
                <circle class="eye-left" cx="38" cy="60" r="5" fill="#1a1a1a"/>
                <circle class="eye-right" cx="62" cy="60" r="5" fill="#1a1a1a"/>
                <path class="mouth" d="M42 72 Q50 80 58 72" stroke="#1a1a1a" stroke-width="3" fill="none" stroke-linecap="round"/>
              </g>
              <!-- Blush cheeks (hidden, shown for bliss) -->
              <circle class="blush-left" cx="28" cy="68" r="5" fill="#ff9999" opacity="0"/>
              <circle class="blush-right" cx="72" cy="68" r="5" fill="#ff9999" opacity="0"/>
            </svg>
          </div>
          
        </div>
        
      </div>
      
    </div>
  </main>
</Layout>

<style>
  .chat-window {
    transition: box-shadow 0.6s ease, border-color 0.6s ease;
  }
  
  .chat-window.powered-up {
    border-color: #F9D857;
    box-shadow: 0 0 100px rgba(249, 216, 87, 0.5), 0 0 200px rgba(249, 216, 87, 0.2), 0 20px 40px rgba(0,0,0,0.4);
  }
  
  .status-badge.connected {
    background: rgba(249, 216, 87, 0.2);
    color: #F9D857;
    animation: badge-pulse 2s ease-in-out infinite;
  }
  
  @keyframes badge-pulse {
    0%, 100% { box-shadow: 0 0 0 0 rgba(249, 216, 87, 0.4); }
    50% { box-shadow: 0 0 0 6px rgba(249, 216, 87, 0); }
  }
  
  .memory-avatar {
    animation: avatar-pulse 1.5s ease-in-out infinite;
  }
  
  @keyframes avatar-pulse {
    0%, 100% { box-shadow: 0 0 0 0 rgba(249, 216, 87, 0.4); }
    50% { box-shadow: 0 0 0 8px rgba(249, 216, 87, 0); }
  }
  
  .memory-bubble {
    position: absolute;
    background: rgba(13, 13, 13, 0.95);
    border: 2px solid rgba(249, 216, 87, 0.6);
    border-radius: 16px;
    padding: 12px 18px;
    font-family: 'JetBrains Mono', 'SF Mono', monospace;
    font-size: 12px;
    color: #F9D857;
    opacity: 0;
    transform: scale(0.3) translateY(20px);
    transition: all 0.6s cubic-bezier(0.34, 1.56, 0.64, 1);
    white-space: nowrap;
    box-shadow: 0 8px 32px rgba(249, 216, 87, 0.15), 0 0 0 1px rgba(249, 216, 87, 0.1);
    min-width: 100px;
    text-align: center;
    backdrop-filter: blur(8px);
  }
  
  .memory-bubble.visible {
    opacity: 1;
    transform: scale(1) translateY(0);
  }
  
  .memory-bubble.primary {
    background: linear-gradient(135deg, #F9D857 0%, #DAA520 100%);
    color: #1a1a1a;
    font-weight: 600;
    border: none;
    box-shadow: 0 8px 32px rgba(249, 216, 87, 0.4), 0 0 60px rgba(249, 216, 87, 0.2);
  }
  
  .memory-bubble.category {
    border-color: rgba(99, 102, 241, 0.6);
    color: #a5b4fc;
    box-shadow: 0 8px 32px rgba(99, 102, 241, 0.15);
  }
  
  .memory-bubble.detail {
    font-size: 11px;
    padding: 8px 14px;
    border-color: rgba(52, 211, 153, 0.6);
    color: #6ee7b7;
    box-shadow: 0 8px 32px rgba(52, 211, 153, 0.15);
  }
  
  .memory-bubble.insight {
    border-color: rgba(251, 146, 60, 0.6);
    color: #fdba74;
    box-shadow: 0 8px 32px rgba(251, 146, 60, 0.15);
  }
  
  .memory-bubble .bubble-text {
    min-height: 1em;
  }
  
  .memory-bubble .typing-cursor {
    display: inline-block;
    width: 2px;
    height: 1em;
    background: currentColor;
    margin-left: 2px;
    animation: blink 0.5s step-end infinite;
    vertical-align: middle;
  }
  
  .connection-line {
    stroke: rgba(249, 216, 87, 0.25);
    stroke-width: 2;
    stroke-dasharray: 300;
    stroke-dashoffset: 300;
    transition: stroke-dashoffset 1.2s ease-out;
    fill: none;
  }
  
  .connection-line.visible {
    stroke-dashoffset: 0;
  }
  
  .connection-line.category-line {
    stroke: rgba(99, 102, 241, 0.3);
  }
  
  .connection-line.detail-line {
    stroke: rgba(52, 211, 153, 0.3);
  }
  
  .connection-line.insight-line {
    stroke: rgba(251, 146, 60, 0.3);
  }
  
  .typing-cursor {
    display: inline-block;
    width: 2px;
    height: 1em;
    background: white;
    margin-left: 2px;
    animation: blink 0.7s step-end infinite;
  }
  
  @keyframes blink {
    0%, 100% { opacity: 1; }
    50% { opacity: 0; }
  }
  
  .fade-out {
    opacity: 0 !important;
    transition: opacity 0.5s ease;
  }
  
  .memory-bubble.visible .bubble-text {
    animation: gentle-float 4s ease-in-out infinite;
  }
  
  .memory-bubble:nth-child(odd).visible .bubble-text {
    animation-delay: 1s;
  }
  
  .memory-bubble:nth-child(3n).visible .bubble-text {
    animation-delay: 0.5s;
  }
  
  @keyframes gentle-float {
    0%, 100% { transform: translateY(0px); }
    50% { transform: translateY(-4px); }
  }
  
  .drive-slot.active {
    box-shadow: 0 0 30px rgba(249, 216, 87, 0.5);
  }
  
  .drive-slot.active .w-1 {
    background: #F9D857;
    box-shadow: 0 0 10px rgba(249, 216, 87, 0.8);
  }
  
  @media (prefers-reduced-motion: reduce) {
    .memory-bubble, .connection-line, .chat-window {
      transition: none;
    }
    .memory-avatar, .memory-bubble.visible, .status-badge.connected {
      animation: none;
    }
  }
</style>

<script define:vars={{ currentDate }}>
  class MemoryDemoAnimation {
    constructor() {
      this.startBtn = document.getElementById('start-demo');
      this.resetBtn = document.getElementById('reset-demo');
      this.chatWindow = document.getElementById('chat-window');
      this.chatWrapper = document.getElementById('chat-wrapper');
      this.demoContainer = document.getElementById('demo-container');
      this.userMessage = document.getElementById('user-message');
      this.userText = document.getElementById('user-text');
      this.genericResponse = document.getElementById('generic-response');
      this.genericText = document.getElementById('generic-text');
      this.memoryResponse = document.getElementById('memory-response');
      this.memoryText = document.getElementById('memory-text');
      this.disk = document.getElementById('autojack-disk');
      this.diskFace = document.getElementById('disk-face');
      this.driveSlot = document.getElementById('drive-slot');
      this.statusBadge = document.getElementById('status-badge');
      this.memoryBubbles = document.getElementById('memory-bubbles');
      this.connectionLines = document.getElementById('connection-lines');
      
      this.isPlaying = false;
      this.bubbleElements = {};
      
      this.userQuestion = "Can you help me fix an Uncaught TypeError on the homepage?";
      this.genericReply = "I'd be happy to help! Could you provide some more details about the error? Specifically:\n\n1. What does the error message say exactly?\n2. Which script is causing the issue?\n3. What actions trigger the error?";
      this.memoryReply = `Welcome back, Jack! I see from our last session you were working on the homepage animations. Let me check those logs...

Found it! The TypeError is in **MemoryHero.astro** line 291 — TypeScript syntax in a browser script tag.

**Quick fix:** Convert to vanilla JavaScript:
• Remove type annotations like \`: HTMLElement | null\`
• Replace \`private\` with direct property assignments

✓ File updated. Reloading now...`;
      
      this.memoryNodes = [
        { id: 'query', text: '🔍 Analyzing query...', x: 580, y: 80, delay: 0, isPrimary: true },
        
        { id: 'identity', text: '👤 Identity', x: 720, y: 140, delay: 800, parent: 'query', type: 'category' },
        { id: 'user', text: 'Jack Arturo', x: 850, y: 100, delay: 1200, parent: 'identity', type: 'detail' },
        { id: 'role', text: 'Full-stack developer', x: 880, y: 160, delay: 1600, parent: 'identity', type: 'detail' },
        
        { id: 'context', text: '📂 Project Context', x: 700, y: 240, delay: 2200, parent: 'query', type: 'category' },
        { id: 'project', text: 'AutoMem.ai website', x: 860, y: 220, delay: 2600, parent: 'context', type: 'detail' },
        { id: 'stack', text: 'Astro + Tailwind + TS', x: 870, y: 280, delay: 3000, parent: 'context', type: 'detail' },
        
        { id: 'history', text: '📜 Session History', x: 680, y: 340, delay: 3600, parent: 'query', type: 'category' },
        { id: 'session', text: 'Last: homepage animations', x: 850, y: 320, delay: 4000, parent: 'history', type: 'detail' },
        { id: 'file', text: 'Editing: MemoryHero.astro', x: 860, y: 380, delay: 4400, parent: 'history', type: 'detail' },
        
        { id: 'preferences', text: '⚙️ Preferences', x: 640, y: 440, delay: 5000, parent: 'query', type: 'category' },
        { id: 'style', text: 'Prefers concise fixes', x: 820, y: 440, delay: 5400, parent: 'preferences', type: 'detail' },
        { id: 'tone', text: 'Direct communication', x: 840, y: 500, delay: 5800, parent: 'preferences', type: 'detail' },
        
        { id: 'solution', text: '💡 Solution Found!', x: 720, y: 560, delay: 6400, parent: 'query', type: 'insight' },
      ];
      
      this.init();
    }
    
    init() {
      this.startBtn.addEventListener('click', () => this.play());
      this.resetBtn.addEventListener('click', () => {
        this.reset();
        this.resetBtn.classList.add('hidden');
      });
    }
    
    async play() {
      if (this.isPlaying) return;
      this.isPlaying = true;
      this.startBtn.classList.add('hidden');
      
      await this.delay(400);
      this.userMessage.classList.remove('opacity-0');
      await this.typeText(this.userText, this.userQuestion, 40);
      
      await this.delay(700);
      this.genericResponse.classList.remove('opacity-0');
      await this.typeText(this.genericText, this.genericReply, 15);
      
      await this.delay(1000);
      this.driveSlot.classList.remove('opacity-0');
      this.driveSlot.style.opacity = '1';
      this.driveSlot.style.transition = 'opacity 0.4s ease';
      
      await this.delay(300);
      this.disk.classList.remove('opacity-0');
      this.disk.style.opacity = '1';
      this.disk.style.transition = 'right 1s cubic-bezier(0.34, 1.56, 0.64, 1), opacity 0.4s ease';
      
      await this.delay(150);
      const chatRect = this.chatWrapper.getBoundingClientRect();
      const containerRect = this.demoContainer.getBoundingClientRect();
      const targetRight = containerRect.width - (chatRect.right - containerRect.left) - 80;
      this.disk.style.right = targetRight + 'px';
      
      await this.delay(800);
      this.disk.style.right = (targetRight + 15) + 'px';
      
      await this.delay(400);
      this.showBlissExpression();
      this.chatWindow.classList.add('powered-up');
      this.driveSlot.classList.add('active');
      this.statusBadge.textContent = '✨ AutoMem Connected';
      this.statusBadge.classList.add('connected');
      
      await this.delay(800);
      await this.animateMemoryBubbles();
      
      await this.delay(800);
      this.genericResponse.classList.add('fade-out');
      
      await this.delay(500);
      this.genericResponse.classList.add('hidden');
      this.memoryResponse.classList.remove('hidden');
      this.memoryResponse.classList.remove('opacity-0');
      await this.typeText(this.memoryText, this.memoryReply, 8);
      
      await this.delay(600);
      this.resetBtn.classList.remove('hidden');
      this.isPlaying = false;
    }
    
    showBlissExpression() {
      const diskSvg = this.disk.querySelector('svg');
      
      const eyeLeft = diskSvg.querySelector('.eye-left');
      const eyeRight = diskSvg.querySelector('.eye-right');
      const mouth = diskSvg.querySelector('.mouth');
      const blushLeft = diskSvg.querySelector('.blush-left');
      const blushRight = diskSvg.querySelector('.blush-right');
      
      eyeLeft.setAttribute('r', '0');
      eyeRight.setAttribute('r', '0');
      
      const happyEyeLeft = document.createElementNS('http://www.w3.org/2000/svg', 'path');
      happyEyeLeft.setAttribute('d', 'M33 60 Q38 53 43 60');
      happyEyeLeft.setAttribute('stroke', '#1a1a1a');
      happyEyeLeft.setAttribute('stroke-width', '3');
      happyEyeLeft.setAttribute('fill', 'none');
      happyEyeLeft.setAttribute('stroke-linecap', 'round');
      happyEyeLeft.classList.add('happy-eye');
      
      const happyEyeRight = document.createElementNS('http://www.w3.org/2000/svg', 'path');
      happyEyeRight.setAttribute('d', 'M57 60 Q62 53 67 60');
      happyEyeRight.setAttribute('stroke', '#1a1a1a');
      happyEyeRight.setAttribute('stroke-width', '3');
      happyEyeRight.setAttribute('fill', 'none');
      happyEyeRight.setAttribute('stroke-linecap', 'round');
      happyEyeRight.classList.add('happy-eye');
      
      this.diskFace.appendChild(happyEyeLeft);
      this.diskFace.appendChild(happyEyeRight);
      
      mouth.setAttribute('d', 'M38 72 Q50 88 62 72');
      
      blushLeft.style.transition = 'opacity 0.5s ease';
      blushRight.style.transition = 'opacity 0.5s ease';
      blushLeft.style.opacity = '0.7';
      blushRight.style.opacity = '0.7';
      
      diskSvg.style.filter = 'drop-shadow(0 0 40px rgba(249, 216, 87, 0.7))';
      diskSvg.style.transition = 'filter 0.5s ease';
    }
    
    async animateMemoryBubbles() {
      this.memoryBubbles.innerHTML = '';
      this.connectionLines.innerHTML = '';
      this.bubbleElements = {};
      
      for (const node of this.memoryNodes) {
        await this.delay(node.delay > 0 ? 500 : 0);
        
        const bubble = document.createElement('div');
        let bubbleClass = 'memory-bubble';
        if (node.isPrimary) bubbleClass += ' primary';
        if (node.type === 'category') bubbleClass += ' category';
        if (node.type === 'detail') bubbleClass += ' detail';
        if (node.type === 'insight') bubbleClass += ' primary';
        bubble.className = bubbleClass;
        bubble.style.left = node.x + 'px';
        bubble.style.top = node.y + 'px';
        bubble.innerHTML = '<span class="bubble-text"></span>';
        
        this.memoryBubbles.appendChild(bubble);
        this.bubbleElements[node.id] = { element: bubble, x: node.x, y: node.y };
        
        await this.delay(80);
        bubble.classList.add('visible');
        
        if (node.parent && this.bubbleElements[node.parent]) {
          const parent = this.bubbleElements[node.parent];
          this.drawConnection(parent.x, parent.y, node.x, node.y, node.type);
        }
        
        await this.typeBubbleText(bubble.querySelector('.bubble-text'), node.text, 35);
        
        await this.delay(150);
      }
    }
    
    drawConnection(fromX, fromY, toX, toY, type) {
      const line = document.createElementNS('http://www.w3.org/2000/svg', 'path');
      
      const midX = (fromX + toX) / 2;
      const midY = (fromY + toY) / 2;
      const controlX = midX + (Math.random() - 0.5) * 40;
      const controlY = midY + (Math.random() - 0.5) * 20;
      const curve = `M ${fromX + 50} ${fromY + 15} Q ${controlX} ${controlY} ${toX} ${toY + 15}`;
      
      line.setAttribute('d', curve);
      let lineClass = 'connection-line';
      if (type === 'category') lineClass += ' category-line';
      if (type === 'detail') lineClass += ' detail-line';
      if (type === 'insight') lineClass += ' insight-line';
      line.setAttribute('class', lineClass);
      this.connectionLines.appendChild(line);
      
      setTimeout(() => line.classList.add('visible'), 100);
    }
    
    async typeBubbleText(element, text, speed) {
      element.innerHTML = '<span class="typing-cursor"></span>';
      
      for (let i = 0; i < text.length; i++) {
        element.innerHTML = text.substring(0, i + 1) + '<span class="typing-cursor"></span>';
        await this.delay(speed);
      }
      
      await this.delay(150);
      element.innerHTML = text;
    }
    
    async typeText(element, text, speed = 30) {
      element.innerHTML = '';
      
      const lines = text.split('\n');
      
      for (let l = 0; l < lines.length; l++) {
        const line = lines[l];
        
        for (let i = 0; i < line.length; i++) {
          element.innerHTML = element.innerHTML.replace('<span class="typing-cursor"></span>', '');
          
          if (line[i] === '*' && line[i+1] === '*') {
            const endBold = line.indexOf('**', i + 2);
            if (endBold > i) {
              const boldText = line.substring(i + 2, endBold);
              element.innerHTML += `<strong>${boldText}</strong>`;
              i = endBold + 1;
            } else {
              element.innerHTML += line[i];
            }
          } else {
            element.innerHTML += line[i];
          }
          
          element.innerHTML += '<span class="typing-cursor"></span>';
          
          if (i % 2 === 0) {
            await this.delay(speed);
          }
        }
        
        if (l < lines.length - 1) {
          element.innerHTML = element.innerHTML.replace('<span class="typing-cursor"></span>', '');
          element.innerHTML += '<br><span class="typing-cursor"></span>';
          await this.delay(speed * 3);
        }
      }
      
      await this.delay(200);
      element.innerHTML = element.innerHTML.replace('<span class="typing-cursor"></span>', '');
    }
    
    reset() {
      this.chatWindow.classList.remove('powered-up');
      this.driveSlot.classList.remove('active');
      this.userMessage.classList.add('opacity-0');
      this.genericResponse.classList.remove('hidden', 'fade-out');
      this.genericResponse.classList.add('opacity-0');
      this.memoryResponse.classList.add('hidden', 'opacity-0');
      
      this.disk.style.opacity = '0';
      this.disk.style.right = '-250px';
      this.driveSlot.style.opacity = '0';
      
      const diskSvg = this.disk.querySelector('svg');
      const happyEyes = diskSvg.querySelectorAll('.happy-eye');
      happyEyes.forEach(eye => eye.remove());
      
      const eyeLeft = diskSvg.querySelector('.eye-left');
      const eyeRight = diskSvg.querySelector('.eye-right');
      const mouth = diskSvg.querySelector('.mouth');
      const blushLeft = diskSvg.querySelector('.blush-left');
      const blushRight = diskSvg.querySelector('.blush-right');
      
      eyeLeft.setAttribute('r', '5');
      eyeRight.setAttribute('r', '5');
      mouth.setAttribute('d', 'M42 72 Q50 80 58 72');
      blushLeft.style.opacity = '0';
      blushRight.style.opacity = '0';
      diskSvg.style.filter = '';
      
      this.statusBadge.textContent = 'Standard';
      this.statusBadge.classList.remove('connected');
      
      this.userText.innerHTML = '';
      this.genericText.innerHTML = '';
      this.memoryText.innerHTML = '';
      
      this.memoryBubbles.innerHTML = '';
      this.connectionLines.innerHTML = '';
      this.bubbleElements = {};
      
      this.startBtn.classList.remove('hidden');
    }
    
    delay(ms) {
      return new Promise(resolve => setTimeout(resolve, ms));
    }
  }
  
  new MemoryDemoAnimation();
</script>
