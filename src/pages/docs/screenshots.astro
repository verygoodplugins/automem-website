---
import Layout from '../../layouts/Layout.astro';
import Navigation from '../../components/Navigation.astro';
import '../../styles/global.css';
---

<Layout title="Screenshots - RAG in Action">
  <Navigation currentPath="/docs/screenshots" />
  <main class="min-h-screen py-20 px-6">
    <div class="max-w-7xl mx-auto">
      <!-- Hero Section -->
      <div class="max-w-4xl mx-auto text-center mb-16">
        <h1 class="text-5xl font-bold mb-6">
          <span class="gradient-text">Retrieval Augmented Generation</span>
        </h1>
        <p class="text-xl text-gray-600 dark:text-gray-300 mb-8">
          See how AutoMem enhances the tools you're already using with the power of memory and RAG
        </p>
      </div>

      <!-- RAG Explanation -->
      <section class="max-w-4xl mx-auto mb-16">
        <div class="bg-automem-surface rounded-xl p-8 border border-automem-border shadow-lg">
          <h2 class="text-3xl font-bold mb-6 text-automem-text">What is RAG?</h2>
          <div class="prose prose-invert max-w-none space-y-4 text-automem-muted">
            <p>
              <strong class="text-automem-text">Retrieval Augmented Generation (RAG)</strong> is a technique that enhances AI responses by retrieving relevant context from a knowledge base before generating answers.
            </p>
            <p>
              Instead of relying solely on the AI's training data, RAG systems:
            </p>
            <ul class="list-disc list-inside space-y-2 ml-4">
              <li><strong class="text-automem-accent">Retrieve</strong> relevant memories, preferences, and context from a database</li>
              <li><strong class="text-automem-accent">Augment</strong> the AI's prompt with this personalized information</li>
              <li><strong class="text-automem-accent">Generate</strong> responses that are contextually aware and tailored to you</li>
            </ul>
            <div class="bg-automem-bgdark/50 rounded-lg p-6 border border-automem-border/50 mt-6">
              <h3 class="text-xl font-semibold mb-3 text-automem-accent">AutoMem's RAG Advantage</h3>
              <p class="mb-3">
                AutoMem automatically injects relevant memories at the beginning of every conversation with your AI tools. This means:
              </p>
              <ul class="list-disc list-inside space-y-2 ml-4">
                <li>Claude Desktop remembers your coding preferences from last week</li>
                <li>Cursor recalls your project architecture decisions</li>
                <li>ChatGPT knows your communication style and priorities</li>
                <li>Every AI tool you use shares the same contextual memory</li>
              </ul>
            </div>
          </div>
        </div>
      </section>

      <!-- Screenshots Grid -->
      <section class="mb-12">
        <h2 class="text-3xl font-bold mb-8 text-center text-automem-text">
          RAG Across Platforms
        </h2>
        <p class="text-center text-automem-muted mb-12 max-w-3xl mx-auto">
          Click any screenshot to view full-size. See how AutoMem seamlessly integrates with your favorite AI tools.
          <a href="https://github.com/verygoodplugins/mcp-automem?utm_source=automem.ai&utm_medium=screenshots&utm_campaign=docs-link" target="_blank" rel="noopener noreferrer" class="text-automem-accent hover:underline ml-1">
            View technical documentation →
          </a>
        </p>

        <!-- Bento Grid -->
        <div class="bento-grid">
          <!-- Screenshot 1: Claude Desktop (Large) -->
          <div class="screenshot-card large" data-screenshot="1">
            <img
              src="/screenshots/claude-desktop-with-instructions.jpg"
              alt="Claude Desktop with AutoMem custom instructions"
              class="screenshot-img"
            />
            <div class="screenshot-caption">
              <h3 class="font-semibold text-lg mb-2">Claude Desktop</h3>
              <p class="text-sm text-automem-muted">
                Claude automatically recalls memories at conversation start using custom instructions. Your preferences and context are injected before the first message.
              </p>
            </div>
          </div>

          <!-- Screenshot 2: Cursor IDE -->
          <div class="screenshot-card" data-screenshot="2">
            <img
              src="/screenshots/cursor-1.jpg"
              alt="Cursor IDE with automem.mdc rules"
              class="screenshot-img"
            />
            <div class="screenshot-caption">
              <h3 class="font-semibold text-lg mb-2">Cursor IDE</h3>
              <p class="text-sm text-automem-muted">
                Cursor uses <code class="text-xs bg-automem-bgdark px-1 py-0.5 rounded">automem.mdc</code> rules to automatically recall and store memories during coding sessions.
              </p>
            </div>
          </div>

          <!-- Screenshot 3: ChatGPT (Wide) -->
          <div class="screenshot-card wide" data-screenshot="3">
            <img
              src="/screenshots/chatgpt-memories.jpg"
              alt="ChatGPT using AutoMem via SSE connector"
              class="screenshot-img"
            />
            <div class="screenshot-caption">
              <h3 class="font-semibold text-lg mb-2">ChatGPT with SSE Connector</h3>
              <p class="text-sm text-automem-muted">
                ChatGPT accesses AutoMem memories via the SSE sidecar in developer mode. Cross-platform memory without vendor lock-in.
              </p>
            </div>
          </div>

          <!-- Screenshot 4: Claude Web -->
          <div class="screenshot-card" data-screenshot="4">
            <img
              src="/screenshots/claude-ai-web-memories.jpg"
              alt="Claude.ai web with remote MCP"
              class="screenshot-img"
            />
            <div class="screenshot-caption">
              <h3 class="font-semibold text-lg mb-2">Claude Web</h3>
              <p class="text-sm text-automem-muted">
                Claude.ai website connected to AutoMem via remote MCP (SSE). Your memories work everywhere, not just desktop.
              </p>
            </div>
          </div>

          <!-- Screenshot 5: Claude Code -->
          <div class="screenshot-card" data-screenshot="5">
            <img
              src="/screenshots/claude-code-1.jpg"
              alt="Claude Code with git commits auto-stored"
              class="screenshot-img"
            />
            <div class="screenshot-caption">
              <h3 class="font-semibold text-lg mb-2">Claude Code</h3>
              <p class="text-sm text-automem-muted">
                Git commits, builds, and deployments automatically stored to memory. Context persists across development sessions.
              </p>
            </div>
          </div>

          <!-- Screenshot 6: Claude iOS (Tall) -->
          <div class="screenshot-card tall" data-screenshot="6">
            <img
              src="/screenshots/claude-ios-app.jpeg"
              alt="Claude iOS app with AutoMem"
              class="screenshot-img"
            />
            <div class="screenshot-caption">
              <h3 class="font-semibold text-lg mb-2">Claude Mobile (iOS)</h3>
              <p class="text-sm text-automem-muted">
                Claude Mobile connected to AutoMem via remote MCP. Same memories across desktop, web, and mobile.
              </p>
            </div>
          </div>
        </div>
      </section>

      <!-- CTA Section -->
      <section class="max-w-4xl mx-auto text-center py-12">
        <div class="bg-gradient-to-r from-automem-accent/10 to-purple-500/10 rounded-xl p-8 border border-automem-border">
          <h2 class="text-3xl font-bold mb-4 text-automem-text">Ready to Try AutoMem?</h2>
          <p class="text-automem-muted mb-6">
            Deploy in under 5 minutes and start experiencing RAG across all your AI tools
          </p>
          <div class="flex flex-col sm:flex-row gap-4 justify-center">
            <a
              href="/docs/quickstart"
              class="gradient-bg text-white px-8 py-4 rounded-lg font-semibold hover:opacity-90 transition"
            >
              Quick Start Guide
            </a>
            <a
              href="https://github.com/verygoodplugins/mcp-automem?utm_source=automem.ai&utm_medium=screenshots&utm_campaign=cta"
              target="_blank"
              rel="noopener noreferrer"
              class="border-2 border-automem-accent text-automem-accent px-8 py-4 rounded-lg font-semibold hover:bg-automem-surface transition"
            >
              View on GitHub
            </a>
          </div>
        </div>
      </section>
    </div>
  </main>

  <!-- Lightbox Modal -->
  <div id="lightbox" class="lightbox hidden">
    <div class="lightbox-backdrop"></div>
    <div class="lightbox-content">
      <button id="lightbox-close" class="lightbox-close" aria-label="Close">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="18" y1="6" x2="6" y2="18"></line>
          <line x1="6" y1="6" x2="18" y2="18"></line>
        </svg>
      </button>

      <!-- Previous Button -->
      <button id="lightbox-prev" class="lightbox-nav lightbox-prev" aria-label="Previous image">
        <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="15 18 9 12 15 6"></polyline>
        </svg>
      </button>

      <!-- Next Button -->
      <button id="lightbox-next" class="lightbox-nav lightbox-next" aria-label="Next image">
        <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="9 18 15 12 9 6"></polyline>
        </svg>
      </button>

      <div class="lightbox-image-container">
        <img id="lightbox-img" src="" alt="" />
      </div>

      <!-- Caption Container -->
      <div class="lightbox-caption-container">
        <h3 id="lightbox-title" class="lightbox-title"></h3>
        <p id="lightbox-description" class="lightbox-description"></p>
        <div id="lightbox-counter" class="lightbox-counter"></div>
      </div>
    </div>
  </div>

  <style>
    /* Bento Grid Layout */
    .bento-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
      gap: 1.5rem;
      margin-bottom: 2rem;
    }

    @media (min-width: 768px) {
      .bento-grid {
        grid-template-columns: repeat(3, 1fr);
        grid-auto-rows: 250px;
      }

      .screenshot-card.large {
        grid-column: span 2;
        grid-row: span 2;
      }

      .screenshot-card.wide {
        grid-column: span 2;
      }

      .screenshot-card.tall {
        grid-row: span 2;
      }
    }

    /* Screenshot Card Styles */
    .screenshot-card {
      position: relative;
      background: var(--color-surface);
      border: 1px solid var(--color-border);
      border-radius: 12px;
      overflow: hidden;
      cursor: pointer;
      transition: all 0.3s ease;
      box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06);
    }

    .screenshot-card:hover {
      transform: translateY(-4px);
      box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.2), 0 10px 10px -5px rgba(0, 0, 0, 0.1);
      border-color: var(--color-accent);
    }

    .screenshot-card:hover .screenshot-img {
      transform: scale(1.05);
    }

    .screenshot-img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      transition: transform 0.3s ease;
    }

    .screenshot-caption {
      position: absolute;
      bottom: 0;
      left: 0;
      right: 0;
      background: linear-gradient(to top, rgba(0, 0, 0, 0.9), rgba(0, 0, 0, 0.7), transparent);
      padding: 2rem 1.5rem 1.5rem;
      color: white;
      transform: translateY(100%);
      transition: transform 0.3s ease;
    }

    .screenshot-card:hover .screenshot-caption {
      transform: translateY(0);
    }

    /* Lightbox Styles */
    .lightbox {
      position: fixed;
      inset: 0;
      z-index: 9999;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 2rem;
    }

    .lightbox.hidden {
      display: none;
    }

    .lightbox-backdrop {
      position: absolute;
      inset: 0;
      background: rgba(0, 0, 0, 0.95);
      backdrop-filter: blur(4px);
    }

    .lightbox-content {
      position: relative;
      max-width: 90vw;
      max-height: 90vh;
      z-index: 10;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 1.5rem;
    }

    .lightbox-image-container {
      position: relative;
      max-width: 100%;
      max-height: 70vh;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .lightbox-image-container img {
      max-width: 100%;
      max-height: 70vh;
      object-fit: contain;
      border-radius: 8px;
      box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
    }

    .lightbox-close {
      position: absolute;
      top: -3rem;
      right: 0;
      background: rgba(255, 255, 255, 0.1);
      border: none;
      color: white;
      width: 40px;
      height: 40px;
      border-radius: 50%;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      transition: all 0.2s;
      z-index: 20;
    }

    .lightbox-close:hover {
      background: rgba(255, 255, 255, 0.2);
      transform: rotate(90deg);
    }

    /* Navigation Buttons */
    .lightbox-nav {
      position: absolute;
      top: 50%;
      transform: translateY(-50%);
      background: rgba(255, 255, 255, 0.1);
      border: 2px solid rgba(255, 255, 255, 0.2);
      color: white;
      width: 56px;
      height: 56px;
      border-radius: 50%;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      transition: all 0.3s;
      z-index: 20;
      backdrop-filter: blur(8px);
    }

    .lightbox-nav:hover {
      background: rgba(255, 255, 255, 0.2);
      border-color: var(--color-accent);
      transform: translateY(-50%) scale(1.1);
    }

    .lightbox-prev {
      left: -80px;
    }

    .lightbox-next {
      right: -80px;
    }

    @media (max-width: 768px) {
      .lightbox-prev {
        left: 1rem;
      }

      .lightbox-next {
        right: 1rem;
      }
    }

    /* Caption Container */
    .lightbox-caption-container {
      background: rgba(0, 0, 0, 0.8);
      backdrop-filter: blur(12px);
      border: 1px solid rgba(255, 255, 255, 0.1);
      border-radius: 12px;
      padding: 1.5rem 2rem;
      max-width: 600px;
      text-align: center;
      animation: slideUpFade 0.4s ease;
    }

    .lightbox-title {
      font-size: 1.5rem;
      font-weight: 600;
      color: white;
      margin-bottom: 0.5rem;
      background: linear-gradient(135deg, var(--color-accent), #a855f7);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    .lightbox-description {
      font-size: 1rem;
      color: rgba(255, 255, 255, 0.8);
      line-height: 1.6;
      margin-bottom: 0.75rem;
    }

    .lightbox-counter {
      font-size: 0.875rem;
      color: rgba(255, 255, 255, 0.6);
      font-weight: 500;
    }

    @keyframes slideUpFade {
      from {
        opacity: 0;
        transform: translateY(20px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    /* Scroll Animations */
    .screenshot-card {
      opacity: 0;
      animation: fadeInUp 0.6s ease forwards;
    }

    .screenshot-card:nth-child(1) { animation-delay: 0.1s; }
    .screenshot-card:nth-child(2) { animation-delay: 0.2s; }
    .screenshot-card:nth-child(3) { animation-delay: 0.3s; }
    .screenshot-card:nth-child(4) { animation-delay: 0.4s; }
    .screenshot-card:nth-child(5) { animation-delay: 0.5s; }
    .screenshot-card:nth-child(6) { animation-delay: 0.6s; }

    @keyframes fadeInUp {
      from {
        opacity: 0;
        transform: translateY(30px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }
  </style>

  <script>
    // Lightbox functionality with navigation
    const screenshots = document.querySelectorAll('.screenshot-card');
    const lightbox = document.getElementById('lightbox');
    const lightboxImg = document.getElementById('lightbox-img');
    const lightboxClose = document.getElementById('lightbox-close');
    const lightboxBackdrop = lightbox?.querySelector('.lightbox-backdrop');
    const lightboxPrev = document.getElementById('lightbox-prev');
    const lightboxNext = document.getElementById('lightbox-next');
    const lightboxTitle = document.getElementById('lightbox-title');
    const lightboxDescription = document.getElementById('lightbox-description');
    const lightboxCounter = document.getElementById('lightbox-counter');

    // Store screenshot data
    const screenshotData: Array<{
      src: string;
      alt: string;
      title: string;
      description: string;
    }> = [];

    let currentIndex = 0;

    // Collect screenshot data
    screenshots.forEach((card, index) => {
      const img = card.querySelector('.screenshot-img') as HTMLImageElement;
      const caption = card.querySelector('.screenshot-caption');
      const title = caption?.querySelector('h3')?.textContent || '';
      const description = caption?.querySelector('p')?.textContent || '';

      if (img) {
        screenshotData.push({
          src: img.src,
          alt: img.alt,
          title,
          description,
        });
      }

      // Click handler
      card.addEventListener('click', () => {
        openLightbox(index);
      });
    });

    function openLightbox(index: number) {
      currentIndex = index;
      updateLightboxContent();
      if (lightbox) {
        lightbox.classList.remove('hidden');
        document.body.style.overflow = 'hidden';
      }
    }

    function updateLightboxContent() {
      const data = screenshotData[currentIndex];
      if (!data) return;

      if (lightboxImg) {
        lightboxImg.src = data.src;
        lightboxImg.alt = data.alt;
      }
      if (lightboxTitle) {
        lightboxTitle.textContent = data.title;
      }
      if (lightboxDescription) {
        lightboxDescription.textContent = data.description;
      }
      if (lightboxCounter) {
        lightboxCounter.textContent = `${currentIndex + 1} / ${screenshotData.length}`;
      }
    }

    function closeLightbox() {
      if (lightbox) {
        lightbox.classList.add('hidden');
        document.body.style.overflow = '';
      }
    }

    function showPrevious() {
      currentIndex = currentIndex > 0 ? currentIndex - 1 : screenshotData.length - 1;
      updateLightboxContent();
    }

    function showNext() {
      currentIndex = currentIndex < screenshotData.length - 1 ? currentIndex + 1 : 0;
      updateLightboxContent();
    }

    // Event listeners
    lightboxClose?.addEventListener('click', closeLightbox);
    lightboxBackdrop?.addEventListener('click', closeLightbox);
    lightboxPrev?.addEventListener('click', showPrevious);
    lightboxNext?.addEventListener('click', showNext);

    // Keyboard navigation
    document.addEventListener('keydown', (e) => {
      if (!lightbox?.classList.contains('hidden')) {
        switch (e.key) {
          case 'Escape':
            closeLightbox();
            break;
          case 'ArrowLeft':
            showPrevious();
            break;
          case 'ArrowRight':
            showNext();
            break;
        }
      }
    });
  </script>
</Layout>
