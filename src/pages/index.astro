---
export const prerender = true;
import Layout from '../layouts/Layout.astro';
import Navigation from '../components/Navigation.astro';
import ChatDemo from '../components/ChatDemo.astro';
import EmailSignup from '../components/EmailSignup.astro';
import OrganizationSchema from '../components/schemas/OrganizationSchema.astro';
import Typewriter from '../components/Typewriter.astro';
import MemoryDrive from '../components/MemoryDrive.astro';
import MemoryHero from '../components/MemoryHero.astro';

const GITHUB_URL = 'https://github.com/verygoodplugins/automem';
const GITHUB_URL_UTM = `${GITHUB_URL}?utm_source=automem.ai&utm_medium=gate&utm_campaign=waitlist`;

const timelineEntries = [
  {
    date: '2026-04-23',
    time: '22:00 UTC',
    title: '0.15.2 • Recall Quality & Tag Ops',
    description:
      'Keyword scoring for vector results with a softer adaptive floor. Expansion candidates now bypass the tag filter so graph walks aren\'t cut off at the seed set. Memory-by-tag pagination and bulk delete endpoints. LoCoMo judge runs hardened against flaky rate limits.',
  },
  {
    date: '2026-04-23',
    time: '20:00 UTC',
    title: 'MCP 0.14.0 • OpenClaw Plugin-First & Antigravity',
    description:
      'Plugin-first memory parity for OpenClaw with shared policy across plugin, MCP, and skill modes. Google Antigravity setup templates shipped. Claude Code plugin deprecated in favor of the CLI installer. Windows Python wrapper for hook scripts.',
  },
  {
    date: '2026-03-25',
    time: '18:00 UTC',
    title: '0.15.0 • Relationship Engine & Benchmarks',
    description:
      'Optimized relationship taxonomy for cleaner graph traversal. LoCoMo cat5 multi-hop judge for automated recall quality scoring. priority_ids now boosts relevance instead of hard-filtering. Embedding dimension validation catches provider mismatches at startup.',
  },
  {
    date: '2026-03-25',
    time: '12:00 UTC',
    title: 'MCP 0.13.0 • OpenClaw Overhaul & Cursor Rules',
    description:
      'Complete OpenClaw plugin rewrite — native MCP integration and new skill setup. Split global vs. project rules for Cursor. Hook stdin parsing with truncation guards and dedup checks.',
  },
  {
    date: '2026-03-08',
    time: '04:30 UTC',
    title: '0.14.0 • Docker & Hardened Deployments',
    description:
      'Official Docker build workflow. QDRANT_HOST + QDRANT_PORT for flexible Qdrant config. Stateless MCP bridge transport for resilient connections. Consolidation overhaul: reduced decay rate, importance floor, archived memory filtering. Voyage AI set as recommended embedding default.',
  },
  {
    date: '2026-03-02',
    time: '09:00 UTC',
    title: '0.13.0 • Adaptive Recall & Graph Viewer',
    description:
      'min_score threshold with adaptive floor filtering — low-relevance results get cut automatically. LoCoMo benchmark harness for rapid experiment iteration. Graph viewer externalized as standalone module.',
  },
  {
    date: '2026-02-20',
    time: '05:55 UTC',
    title: '0.12.0 • Recall Quality Lab & JIT Enrichment',
    description:
      'Just-in-time enrichment on recall for higher-quality results. Recall Quality Lab for data-driven recall optimization. LongMemEval benchmark harness (ICLR 2025) for measuring memory quality. relevance_score now synced to Qdrant payload for accurate vector search.',
  },
  {
    date: '2026-02-16',
    time: '11:56 UTC',
    title: '0.11.0 • Embedding Providers & Memory Lookup',
    description:
      'Voyage AI embedding provider for high-accuracy recall. OpenAI-compatible providers via OPENAI_BASE_URL (LM Studio, Ollama, xAI, etc.). GET /memory/<id> endpoint for direct memory lookup. Hardened time parser for numeric timestamps.',
  },
  {
    date: '2026-02-07',
    time: '07:40 UTC',
    title: '0.10.1 • Stability Fixes',
    description:
      'Temporal query bound to 7-day window with timeout to prevent runaway queries. Skip temperature param for o-series and gpt-5 models.',
  },
  {
    date: '2026-02-06',
    time: '19:56 UTC',
    title: '0.10.0 • Visualization & Observability',
    description:
      'Interactive graph visualization API. automem-watch real-time observability with SSE streaming and TUI. Ollama embedding provider for fully local deployments. Memory content size governance with auto-summarization. Streamable HTTP transport for MCP connections.',
  },
  {
    date: '2026-02-06',
    time: '14:00 UTC',
    title: 'MCP 0.12.0 • OpenClaw Integration',
    description:
      'Native OpenClaw integration replacing mcporter dependency chain. Direct HTTP API calls to AutoMem with new SKILL.md template. Simplified setup and troubleshooting documentation.',
  },
  {
    date: '2026-02-03',
    time: '12:00 UTC',
    title: 'MCP 0.11.0 • Claude Code Plugin',
    description:
      'Claude Code plugin with automatic memory capture hooks. Session start recall, session end summary. Cursor hooks integration for automatic capture. Integration tests and CLI smoke tests.',
  },
];
---

<Layout title="Home">
  <OrganizationSchema />
  <Navigation currentPath="/" />

  <main class="w-full pt-12 pb-24">
    <!-- Hero Section: Memory Lab -->
    <section
      class="px-4 md:px-12 pt-12 pb-24 border-b border-lab-border bg-lab-bg relative overflow-hidden"
    >
      <!-- Lab Label -->
      <div class="comment-header">:: SEQUENCE_INIT</div>

      <div
        class="max-w-6xl mx-auto grid md:grid-cols-2 gap-12 items-center relative z-10"
      >
        <!-- Left: Manifesto -->
        <div>
          <h1
            class="text-5xl md:text-7xl font-bold tracking-tighter mb-6 leading-[0.9]"
          >
            Recall is<br />
            <span class="text-lab-accent">Power.</span>
          </h1>

          <div
            class="space-y-6 text-lg md:text-xl leading-relaxed border-l-4 border-lab-secondary pl-6 py-2"
          >
            <p>
              <Typewriter
                text="Deploy once. Remember everywhere."
                delay="{200}"
              />
              <br />
              <Typewriter
                text="The universal memory layer for your AI agents."
                delay="{1500}"
                class="text-lab-muted"
              />
            </p>
          </div>

          <div class="mt-12 flex flex-wrap gap-4">
            <a href="/docs/overview" class="btn-lab-accent shadow-hard">
              INIT_SYSTEM.sh
            </a>
            <a
              href="https://github.com/verygoodplugins/automem?utm_source=automem.ai&utm_medium=gate&utm_campaign=waitlist"
              class="btn-lab group gap-2"
            >
              <span>SOURCE_CODE</span>
              <span class="text-xs bg-lab-text text-lab-bg px-1.5 rounded"
                >GITHUB</span
              >
            </a>
          </div>
        </div>

        <!-- Right: The Machine (Chat Demo) -->
        <div class="relative">
          <div
            class="absolute inset-0 bg-lab-accent/5 blur-3xl rounded-full"
          ></div>
          <ChatDemo />
        </div>
      </div>
    </section>

    <!-- Memory Transformation: Before/After Animation -->
    <section
      class="px-4 md:px-12 py-12 md:py-16 border-b border-lab-border bg-lab-bg relative overflow-hidden"
    >
      <div class="comment-header">:: MEMORY_TRANSFORMATION</div>
      <div class="relative z-10">
        <div class="text-center mb-6">
          <h2 class="text-3xl font-bold mb-4">From Forgetful to Brilliant.</h2>
          <p class="text-lab-muted max-w-xl mx-auto">
            Watch how AutoMem transforms your AI from a blank slate into a context-aware assistant.
          </p>
        </div>
        <MemoryHero />
      </div>
      <div
        class="absolute inset-0 bg-[radial-gradient(#333_1px,transparent_1px)] [background-size:16px_16px] opacity-20 pointer-events-none"
      ></div>
    </section>

    <!-- Features: The Circuit -->
    <section
      class="px-4 md:px-12 py-24 border-b border-lab-border bg-lab-bg/50 relative"
    >
      <div class="comment-header">:: SYSTEM_ARCHITECTURE</div>

      <div class="max-w-6xl mx-auto">
        <div class="grid md:grid-cols-3 gap-8">
          <!-- Node 1 -->
          <div
            class="border-2 border-lab-text p-6 rounded-lg shadow-hard bg-lab-bg hover:translate-y-[-4px] transition-transform relative group"
          >
            <div
              class="absolute -top-3 left-6 bg-lab-secondary text-lab-bg px-2 text-xs font-bold uppercase"
            >
              Input
            </div>
            <h3 class="text-xl font-bold mb-2 mt-2">Universal I/O</h3>
            <p class="text-lab-muted text-sm leading-relaxed">
              Compatible with Claude Code, Cursor, ChatGPT, OpenClaw,
              Antigravity, and any MCP client. Local or remote — works everywhere
              via MCP and Streamable HTTP.
            </p>
            <div class="mt-4 flex gap-2">
              <span
                class="w-2 h-2 bg-lab-success rounded-full animate-pulse"
              ></span>
              <span class="text-xs font-mono opacity-50">LISTENING...</span>
            </div>
          </div>

          <!-- Node 2 -->
          <div
            class="border-2 border-lab-text p-6 rounded-lg shadow-hard bg-lab-bg hover:translate-y-[-4px] transition-transform relative group"
          >
            <div
              class="absolute -top-3 left-6 bg-lab-accent text-[#1a1a1a] px-2 text-xs font-bold uppercase"
            >
              Process
            </div>
            <h3 class="text-xl font-bold mb-2 mt-2">Graph Engine</h3>
            <p class="text-lab-muted text-sm leading-relaxed">
              FalkorDB + Qdrant hybrid core. Maps relationships between
              memories, not just vector similarity.
            </p>
            <div class="mt-4 flex gap-1">
              {[1,2,3].map(() =>
              <div class="w-2 h-4 bg-lab-muted/30"></div>
              )}
            </div>
          </div>

          <!-- Node 3 -->
          <div
            class="border-2 border-lab-text p-6 rounded-lg shadow-hard bg-lab-bg hover:translate-y-[-4px] transition-transform relative group"
          >
            <div
              class="absolute -top-3 left-6 bg-lab-text text-lab-bg px-2 text-xs font-bold uppercase"
            >
              Output
            </div>
            <h3 class="text-xl font-bold mb-2 mt-2">Instant Recall</h3>
            <p class="text-lab-muted text-sm leading-relaxed">
              Sub-50ms latency. Your agent knows what you know before you finish
              typing the prompt.
            </p>
            <div class="mt-4 font-mono text-xs text-lab-accent">>> 48ms</div>
          </div>
        </div>
      </div>
    </section>

    <!-- Memory Graph Visualization -->
    <section
      class="px-4 md:px-12 py-24 border-b border-lab-border bg-lab-bg relative overflow-hidden"
    >
      <div class="comment-header">:: VISUALIZE_MEMORY</div>
      <div class="relative z-10">
        <div class="text-center mb-16">
          <h2 class="text-3xl md:text-4xl font-bold mb-4">Dreams while you dream.</h2>
          <p class="text-lab-muted max-w-2xl mx-auto leading-relaxed">
            AutoMem runs quietly in the background, stitching every thought into a retrieval graph.
            It notices patterns, links context, and keeps the right edges warm—without you ever thinking about it.
          </p>
        </div>
        <MemoryDrive />
      </div>
      <div
        class="absolute inset-0 bg-[radial-gradient(#333_1px,transparent_1px)] [background-size:16px_16px] opacity-20 pointer-events-none"
      ></div>
    </section>

    <!-- Timeline / Changelog -->
    <section class="px-4 md:px-12 py-24 border-b border-lab-border bg-lab-bg">
      <div class="comment-header">:: MEMORY_STREAM</div>

      <div class="max-w-4xl mx-auto relative mt-12" id="project-timeline">
        <div class="timeline-line"></div>
        <div class="timeline-line-fill" id="timeline-line-fill"></div>

        <div class="space-y-12 relative timeline-entries">
          {timelineEntries.map((entry) => (
          <div class={`timeline-item flex gap-6 ${entry.pending ? 'pending' : ''}`} data-timeline-item>
            <div
              class="font-mono text-sm text-lab-muted text-right w-28 pt-1 hidden md:block"
            >
              {entry.pending ? (
                <span class="text-lab-accent font-bold">{entry.date}</span>
              ) : (
                <>{entry.date}<br />{entry.time}</>
              )}
            </div>
            <div class={`flex-1 border-l-2 ${entry.pending ? 'border-lab-accent border-dashed' : 'border-lab-border'} pl-8 relative`}>
              <div class={`timeline-dot ${entry.pending ? 'pending' : ''}`}></div>
              <div class="md:hidden text-xs font-mono text-lab-muted mb-1">
                {entry.pending ? (
                  <span class="text-lab-accent font-bold">{entry.date}</span>
                ) : (
                  <>{entry.date} · {entry.time}</>
                )}
              </div>
              <h3 class="text-xl font-bold">
                {entry.pending && <span class="text-lab-accent">[PENDING] </span>}
                {entry.title}
              </h3>
              <p class="mt-2 text-lab-text/80 max-w-xl">{entry.description}</p>
            </div>
          </div>
          ))}
        </div>

        <div class="timeline-fadeout"></div>
      </div>

      <div class="text-center mt-8">
        <a href="/docs/development/changelog/" class="inline-flex items-center gap-2 font-mono text-sm text-lab-muted hover:text-lab-accent transition-colors">
          View full changelog <span aria-hidden="true">→</span>
        </a>
      </div>
    </section>

    <!-- Deployment Options -->
    <section class="px-4 md:px-12 py-24 bg-lab-surface">
      <div class="comment-header">:: DEPLOYMENT_PROTOCOLS</div>
      <div class="max-w-6xl mx-auto">
        <div class="text-center max-w-2xl mx-auto mb-16">
          <h2 class="text-4xl font-bold mb-6 tracking-tighter">
            Open Source & Portable
          </h2>
          <p class="text-xl text-lab-muted">
            Your memory infrastructure should be as portable as your code. Run
            it on your laptop, your private cloud, or our managed service.
          </p>
        </div>

        <div class="grid md:grid-cols-3 gap-8">
          <!-- Option 1: Docker -->
          <div
            class="bg-lab-bg border-2 border-lab-text p-8 rounded-lg shadow-hard relative group hover:translate-y-[-4px] transition-transform"
          >
            <div
              class="absolute -top-3 left-1/2 -translate-x-1/2 bg-lab-text text-lab-bg px-3 py-1 text-xs font-bold uppercase tracking-widest"
            >
              Standard
            </div>
            <div class="text-4xl mb-4">🐳</div>
            <h3 class="text-2xl font-bold mb-2">Docker</h3>
            <p class="text-lab-muted mb-6 text-sm min-h-[40px]">
              The standard container. Run it locally or on any VPS.
            </p>
            <div
              class="bg-lab-surface border border-lab-text p-3 rounded font-mono text-xs text-left mb-6"
            >
              docker run -p 3000:3000<br />automem/server:latest
            </div>
            <a
              href="https://github.com/verygoodplugins/automem"
              class="btn-lab w-full"
              >View Image</a
            >
          </div>

          <!-- Option 2: Railway -->
          <div
            class="bg-lab-bg border-2 border-lab-accent p-8 rounded-lg shadow-hard relative group hover:translate-y-[-4px] transition-transform scale-105 z-10"
          >
            <div
              class="absolute -top-3 left-1/2 -translate-x-1/2 bg-lab-accent text-[#1a1a1a] px-3 py-1 text-xs font-bold uppercase tracking-widest"
            >
              Fastest
            </div>
            <div class="text-4xl mb-4">🚂</div>
            <h3 class="text-2xl font-bold mb-2">Railway</h3>
            <p class="text-lab-muted mb-6 text-sm min-h-[40px]">
              One-click production deployment. Handles DBs & updates
              automatically.
            </p>
            <div
              class="bg-lab-bg border border-lab-accent p-3 rounded font-mono text-xs text-left mb-6 text-lab-accent"
            >
              > Deploying to prod...<br />> Success (24s)
            </div>
            <a
              href="https://railway.com/deploy/automem-ai-memory-service"
              class="btn-lab-accent w-full"
              >One-Click Deploy</a
            >
          </div>

          <!-- Option 3: Source -->
          <div
            class="bg-lab-bg border-2 border-lab-text p-8 rounded-lg shadow-hard relative group hover:translate-y-[-4px] transition-transform"
          >
            <div
              class="absolute -top-3 left-1/2 -translate-x-1/2 bg-lab-text text-lab-bg px-3 py-1 text-xs font-bold uppercase tracking-widest"
            >
              Hacker
            </div>
            <div class="text-4xl mb-4">💻</div>
            <h3 class="text-2xl font-bold mb-2">Source</h3>
            <p class="text-lab-muted mb-6 text-sm min-h-[40px]">
              Fork the repo. Hack the graph logic. It's your code.
            </p>
            <div
              class="bg-lab-surface border border-lab-text p-3 rounded font-mono text-xs text-left mb-6"
            >
              git clone ...<br />npm install
            </div>
            <a
              href="https://github.com/verygoodplugins/automem"
              class="btn-lab w-full"
              >Fork Repo</a
            >
          </div>
        </div>
      </div>
    </section>
  </main>

  <style>
    #project-timeline {
      position: relative;
    }

    .timeline-line {
      position: absolute;
      left: 1.05rem;
      top: 0;
      bottom: 0;
      width: 2px;
      background: #1f1f1f;
      opacity: 0.7;
    }

    .timeline-line-fill {
      position: absolute;
      left: 1.05rem;
      top: 0;
      width: 2px;
      height: 0;
      background: linear-gradient(180deg, #f472b6, #22c55e);
      transition: height 0.4s ease;
    }

    .timeline-item {
      opacity: 0;
      transform: translateY(16px);
      transition: opacity 0.5s ease, transform 0.5s ease;
    }

    .timeline-item.visible {
      opacity: 1;
      transform: translateY(0);
    }

    .timeline-dot {
      position: absolute;
      left: -11px;
      top: 0;
      width: 14px;
      height: 14px;
      background: #0a0a0a;
      border: 2px solid #f472b6;
      border-radius: 999px;
      box-shadow: 0 0 0 3px rgba(244, 114, 182, 0.12);
    }

    .timeline-dot.pending {
      border-color: rgb(var(--lab-accent));
      box-shadow: 0 0 0 3px rgba(var(--lab-accent), 0.2);
      animation: pending-pulse 2s ease-in-out infinite;
    }

    @keyframes pending-pulse {
      0%, 100% { box-shadow: 0 0 0 3px rgba(var(--lab-accent), 0.2); }
      50% { box-shadow: 0 0 0 6px rgba(var(--lab-accent), 0.1); }
    }

    .timeline-item.pending {
      opacity: 0.9;
    }

    .timeline-fadeout {
      position: relative;
      height: 120px;
      margin-top: -120px;
      background: linear-gradient(to bottom, transparent, rgb(var(--lab-bg)));
      pointer-events: none;
      z-index: 10;
    }
  </style>

  <script>
    const timeline = document.getElementById("project-timeline");
    const items = Array.from(document.querySelectorAll("[data-timeline-item]"));
    const fill = document.getElementById("timeline-line-fill");

    function updateFill(target) {
      if (!timeline || !fill || !target) return;
      const containerTop =
        timeline.getBoundingClientRect().top + window.scrollY;
      const rect = target.getBoundingClientRect();
      const center =
        rect.top + window.scrollY - containerTop + rect.height * 0.5;
      const maxHeight = timeline.offsetHeight || 0;
      fill.style.height = `${Math.min(center, maxHeight)}px`;
    }

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add("visible");
            updateFill(entry.target);
          }
        });
      },
      { threshold: 0.35 }
    );

    items.forEach((item) => observer.observe(item));
  </script>
</Layout>
