---
export const prerender = false;
import Layout from '../layouts/Layout.astro';
import Navigation from '../components/Navigation.astro';
import MemoryHero from '../components/MemoryHero.astro';
import MemoryDrive from '../components/MemoryDrive.astro';
import OrganizationSchema from '../components/schemas/OrganizationSchema.astro';

const GITHUB_URL = 'https://github.com/verygoodplugins/automem';
const INSTAPODS_REFERRAL_URL = 'https://instapods.com/apps/automem/?ref=jack';
const RAILWAY_DEPLOY_URL =
  'https://railway.com/deploy/automem-ai-memory-service?referralCode=VuFE6g&utm_medium=integration&utm_source=template&utm_campaign=generic';
const INSTALL_COMMAND = 'curl -fsSL https://automem.ai/install.sh | sh';
const SKILL_URL = 'https://automem.ai/skill.md';
const homepageDescription =
  'AutoMem gives Claude, Cursor, Copilot, Codex, ChatGPT, and MCP-compatible AI tools persistent memory through MCP and Streamable HTTP.';

const terminalChecks = ['detect environment', 'choose local or cloud', 'provision AutoMem', 'wire MCP clients'];

const agentClients = [
  { name: 'Codex', mark: '⌬' },
  { name: 'Claude Code', mark: 'AI' },
  { name: 'Cursor', mark: '◈' },
  { name: 'ChatGPT', mark: '◌' },
];

const setupPaths = [
  {
    title: 'Local (Docker)',
    tone: 'green',
    badge: 'recommended',
    icon: '▱',
    detail: 'Run everything on your machine.',
    bullets: ['Full control, no external deps', 'Data stays local', 'Works offline'],
    command: 'curl -fsSL https://automem.ai/install.sh | AUTOMEM_INSTALL_TARGET=local sh',
  },
  {
    title: 'Railway',
    tone: 'violet',
    icon: '▤',
    detail: 'Managed cloud in minutes.',
    bullets: ['One-command deploy', 'Auto updates & backups', 'Global availability'],
    command: 'curl -fsSL https://automem.ai/install.sh | AUTOMEM_INSTALL_TARGET=cloud sh',
    href: RAILWAY_DEPLOY_URL,
  },
  {
    title: 'InstaPods',
    tone: 'gold',
    icon: '⬡',
    detail: 'Self-hosted cloud in your infra.',
    bullets: ['Your VPC, your data', 'K8s native', 'Enterprise ready'],
    command: 'curl -fsSL https://automem.ai/install.sh | AUTOMEM_INSTALL_TARGET=cloud sh',
    href: INSTAPODS_REFERRAL_URL,
  },
];

const installerSteps = [
  {
    number: '1',
    title: 'Detect environment',
    detail: 'Identifies OS, Docker/K8s, and available resources.',
  },
  {
    number: '2',
    title: 'Choose deployment',
    detail: 'You pick Local, Railway, InstaPods, or Existing Endpoint.',
  },
  {
    number: '3',
    title: 'Provision AutoMem',
    detail: 'Pulls images, starts services, and runs health checks.',
  },
  {
    number: '4',
    title: 'Wire MCP clients',
    detail: 'Generates config and shows you how to connect your agents.',
  },
];

const compatibilityRows = [
  ['Codex (CLI)', 'MCP'],
  ['Claude Code', 'MCP'],
  ['Cursor', 'MCP'],
  ['ChatGPT (Code Interpreter)', 'MCP'],
  ['Custom MCP Clients', 'MCP'],
];

const extendedClients =
  'Claude Desktop, Claude Code, Cursor, GitHub Copilot, Codex, Windsurf, ChatGPT, Any MCP-compatible client';
---

<Layout title="Home" description={homepageDescription}>
  <OrganizationSchema />
  <Navigation currentPath="/" />

  <main class="w-full">
    <!-- 1. HERO — install entrypoint + agent-clients visual -->
    <section class="relative overflow-hidden px-4 pb-10 pt-10 sm:px-7 lg:px-10 lg:pb-12 lg:pt-14">
      <div class="absolute inset-0 bg-[radial-gradient(circle_at_65%_12%,rgb(var(--lab-secondary)/0.14),transparent_34rem)]"></div>
      <div class="relative mx-auto grid max-w-[1360px] gap-10 xl:grid-cols-[0.54fr_0.46fr] xl:gap-16">
        <div class="w-full min-w-0 max-w-full">
          <h1 class="hero-wordmark text-[3.85rem] font-extrabold leading-[0.82] min-[380px]:text-[4.25rem] sm:text-[6rem] lg:text-[7rem]">
            AutoMem
          </h1>
          <h2 class="mt-5 max-w-[13ch] text-3xl font-extrabold leading-[1.03] tracking-normal text-lab-text sm:text-4xl lg:text-[2.75rem]">
            Persistent memory for every agent you use.
          </h2>
          <p class="mt-5 max-w-[66ch] text-sm leading-6 text-lab-muted">
            Open-source memory layer your agents and MCP tools can read, write, and reason over-across sessions and systems.
          </p>
          <p class="mt-3 max-w-[66ch] text-xs leading-5 text-lab-muted">
            Claude, Cursor, Copilot, Codex, ChatGPT, and remote agents connect through MCP and Streamable HTTP.
          </p>

          <div class="relative mt-6 sm:mb-8">
            <div class="hero-terminal w-full max-w-[calc(100vw-2rem)] overflow-hidden rounded-md border border-lab-line bg-lab-surface/90 sm:max-w-full">
              <div class="flex items-center justify-between border-b border-lab-border px-5 py-3">
                <div class="flex items-center gap-2 text-sm font-bold text-lab-accent-text">
                  <span>$</span>
                  <span>automem install</span>
                </div>
                <div class="flex items-center gap-3 text-lab-muted sm:gap-6">
                  <span aria-hidden="true">−</span>
                  <span aria-hidden="true">□</span>
                  <span aria-hidden="true">×</span>
                </div>
              </div>
              <div class="p-5 sm:p-7">
                <a href="/install" class="block max-w-full break-all text-[13px] font-medium leading-6 text-lab-text no-underline [overflow-wrap:anywhere] sm:text-2xl sm:leading-normal">
                  <span>curl -fsSL </span><span class="text-lab-accent-text">https://automem.ai/install.sh</span><span> | sh</span>
                </a>
                <div class="mt-5 rounded border border-lab-border bg-lab-bg/70 p-4">
                  {terminalChecks.map((check) => (
                    <div class="grid grid-cols-[1rem_minmax(0,1fr)_1.5rem] items-center gap-2 py-1 text-xs min-[380px]:text-sm sm:gap-3">
                      <span class="flex h-4 w-4 items-center justify-center rounded-full bg-lab-success text-[10px] font-bold text-lab-bg">✓</span>
                      <span class="min-w-0 text-lab-muted">{check}</span>
                      <span class="text-right text-lab-success">ok</span>
                    </div>
                  ))}
                </div>
              </div>
            </div>
          </div>

          <div class="mt-5 grid w-full max-w-[calc(100vw-2rem)] overflow-hidden rounded border border-lab-line bg-lab-surface/80 sm:max-w-full sm:grid-cols-[4rem_1fr_3rem]">
            <div class="flex items-center justify-center border-b border-lab-line p-4 text-3xl text-lab-secondary sm:border-b-0 sm:border-r">›</div>
            <a href={SKILL_URL} class="border-b border-lab-line p-4 text-sm no-underline sm:border-b-0 sm:border-r">
              <span class="block text-lab-muted">Point your agent at</span>
              <span class="mt-1 block break-all text-base font-bold text-lab-secondary">{SKILL_URL}</span>
            </a>
            <button
              type="button"
              data-copy-skill-url={SKILL_URL}
              class="flex items-center justify-center p-4 text-lab-muted transition-colors hover:text-lab-accent-text"
              aria-label="Copy skill URL"
            >
              <svg class="copy-icon h-5 w-5" viewBox="0 0 20 20" fill="none" aria-hidden="true">
                <path d="M7 7h8v8H7zM5 13H3V3h10v2" stroke="currentColor" stroke-width="1.5" />
              </svg>
              <svg class="copy-check hidden h-5 w-5 text-lab-success" viewBox="0 0 20 20" fill="none" aria-hidden="true">
                <path d="M4 10.5 8 14.5 16 5.5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
            </button>
          </div>

          <div class="mt-5 flex flex-col gap-4 sm:flex-row">
            <a href="/install" class="btn-lab-accent w-full sm:w-auto">
              <span>›</span>
              <span class="ml-2 sm:hidden">Install AutoMem</span>
              <span class="ml-2 hidden sm:inline">{INSTALL_COMMAND}</span>
            </a>
            <a href="/install" class="btn-lab w-full sm:w-auto">
              <span>Open install guide</span>
              <span class="ml-3">→</span>
            </a>
          </div>
          <p class="mt-3 text-xs text-lab-muted">macOS, Linux, and Windows (WSL2)</p>
        </div>

        <div class="relative min-h-[560px] w-full max-w-full min-w-0 overflow-hidden rounded-md xl:min-h-[580px] xl:rounded-none">
          <div class="absolute left-0 right-0 top-0 text-center text-xs font-bold uppercase tracking-[0.16em] text-lab-muted">AGENT CLIENTS</div>
          <div class="grid min-w-0 grid-cols-2 gap-3 pt-9 sm:grid-cols-4 sm:gap-4">
            {agentClients.map((client) => (
              <div class="glass-panel flex h-20 min-w-0 flex-col items-center justify-center gap-2 text-center sm:h-24">
                <div class="text-2xl font-bold text-lab-text sm:text-3xl">{client.mark}</div>
                <div class="max-w-full truncate px-2 text-[11px] font-bold text-lab-text sm:text-xs">{client.name}</div>
              </div>
            ))}
          </div>

          <div class="mx-auto mt-8 h-10 w-px bg-lab-secondary"></div>
          <div class="mx-auto flex h-12 w-20 items-center justify-center rounded border-2 border-lab-secondary bg-lab-surface text-2xl font-bold shadow-[0_0_30px_rgb(var(--lab-secondary)/0.2)]">
            MCP
          </div>
          <p class="mx-auto mt-3 max-w-[10rem] text-center text-xs leading-4 text-lab-muted sm:absolute sm:right-2 sm:top-[12.2rem] sm:mt-0 sm:text-left">Model Context Protocol</p>

          <div class="mx-auto h-8 w-px bg-lab-secondary"></div>
          <div class="mx-auto flex w-full max-w-[min(100%,27.5rem)] items-center justify-center gap-4 rounded border-2 border-lab-accent bg-lab-surface/92 px-4 py-6 text-center sm:gap-6 sm:px-8 sm:py-7">
            <img src="/automem-icon.svg" alt="" class="h-12 w-12 shrink-0 rounded-md sm:h-14 sm:w-14" loading="eager" decoding="async" />
            <div class="min-w-0 text-left">
              <div class="hero-wordmark text-2xl font-extrabold min-[380px]:text-3xl sm:text-4xl">AutoMem</div>
              <div class="mt-2 text-sm text-lab-text sm:text-base">Persistent Memory Layer</div>
            </div>
          </div>

          <div class="mx-auto grid max-w-[440px] grid-cols-2 gap-10 sm:gap-24">
            <div class="h-12 border-r border-dashed border-lab-line"></div>
            <div class="h-12 border-l border-dashed border-lab-line"></div>
          </div>
          <div class="grid gap-4 min-[520px]:grid-cols-2 sm:gap-10">
            <div class="glass-panel flex min-h-24 items-center gap-3 p-4 sm:min-h-28 sm:gap-4 sm:p-5">
              <span class="text-3xl text-lab-success sm:text-4xl">⌘</span>
              <div>
                <div class="text-lg font-bold text-lab-text sm:text-xl">FalkorDB</div>
                <div class="text-xs text-lab-muted">Graph Storage</div>
              </div>
            </div>
            <div class="glass-panel flex min-h-24 items-center gap-3 p-4 sm:min-h-28 sm:gap-4 sm:p-5">
              <span class="text-3xl text-lab-accent-text sm:text-4xl">◈</span>
              <div>
                <div class="text-lg font-bold text-lab-text sm:text-xl">Qdrant</div>
                <div class="text-xs text-lab-muted">Vector Store</div>
              </div>
            </div>
          </div>
          <p class="mt-7 text-center text-sm text-lab-muted">Graph for relationships. Vector for meaning.</p>
        </div>
      </div>
    </section>

    <!-- 2. WHY — agents forget; AutoMem remembers (with/without demo) -->
    <section class="border-t border-lab-border/70 px-4 py-12 sm:px-7 lg:px-10">
      <div class="mx-auto max-w-[1360px]">
        <div class="max-w-[54rem]">
          <p class="text-xs font-bold uppercase tracking-[0.16em] text-lab-secondary">Why agent memory</p>
          <h2 class="mt-3 text-2xl font-bold sm:text-3xl">From forgetful to brilliant.</h2>
          <p class="mt-3 max-w-[64ch] text-sm leading-6 text-lab-muted">
            Out of the box, every agent starts each session from zero — re-asking your stack, your conventions,
            the decision you settled yesterday. AutoMem is the memory layer that fixes that. It captures what
            matters as you work and recalls it the moment it's relevant, so your tools stop forgetting and
            start compounding.
          </p>
        </div>
        <div class="mt-8">
          <MemoryHero />
        </div>
      </div>
    </section>

    <!-- 3. WHAT YOU GET — graph + vector -->
    <section class="border-t border-lab-border/70 px-4 py-12 sm:px-7 lg:px-10">
      <div class="mx-auto grid max-w-[1360px] gap-8 lg:grid-cols-[0.82fr_0.72fr_0.58fr] lg:items-center">
        <div>
          <h2 class="text-2xl font-bold">Built on research. Designed for recall.</h2>
          <p class="mt-5 max-w-[48rem] text-sm leading-6 text-lab-muted">
            AutoMem combines a knowledge graph and vector search so agents can recall both facts and their context.
          </p>
          <div class="mt-8 space-y-6">
            <div class="flex gap-5">
              <span class="text-4xl text-lab-success">⌘</span>
              <p class="max-w-[28rem] text-base text-lab-muted"><span class="text-lab-text">Graph (FalkorDB)</span> captures entities, relationships, and time.</p>
            </div>
            <div class="flex gap-5">
              <span class="text-4xl text-lab-secondary">✣</span>
              <p class="max-w-[28rem] text-base text-lab-muted"><span class="text-lab-text">Vector (Qdrant)</span> captures meaning, similarity, and intent.</p>
            </div>
          </div>
        </div>

        <pre class="glass-panel overflow-x-auto p-6 text-sm leading-6 text-lab-muted"><code><span class="text-lab-secondary"># Example: hybrid recall</span>

MATCH (p:Project)-[:USES]-&gt;(t:Tool)
WHERE p.name = 'AutoMem'
RETURN p, t
ORDER BY ts DESC
LIMIT 20;

<span class="text-lab-secondary"># + vector search for semantic matches</span>

SEARCH "install script errors WSL" LIMIT 20;</code></pre>

        <div>
          <p class="text-base leading-7 text-lab-muted">
            The result: fewer repeats, more relevant answers, and memory that compounds over time.
          </p>
          <a href="/docs/research/" class="mt-8 inline-flex font-bold text-lab-accent-text no-underline hover:underline">Read the research overview →</a>
        </div>
      </div>
    </section>

    <!-- 4. HOW IT WORKS — background consolidation / dreaming -->
    <section class="border-t border-lab-border/70 px-4 py-12 sm:px-7 lg:px-10">
      <div class="mx-auto max-w-[1360px]">
        <div class="max-w-[54rem]">
          <p class="text-xs font-bold uppercase tracking-[0.16em] text-lab-secondary">How it works</p>
          <h2 class="mt-3 text-2xl font-bold sm:text-3xl">Dreams while you dream.</h2>
          <p class="mt-3 max-w-[64ch] text-sm leading-6 text-lab-muted">
            AutoMem runs quietly in the background, consolidating new memories into a retrieval graph. It clusters
            related ideas, strengthens the connections you return to, lets noise decay, and enriches recall — so
            the memory you get back tomorrow is sharper than the one you stored today.
          </p>
        </div>
        <div class="mt-10">
          <MemoryDrive />
        </div>
      </div>
    </section>

    <!-- 5. WHERE IT WORKS — cross-agent compatibility -->
    <section class="border-t border-lab-border/70 px-4 py-10 sm:px-7 lg:px-10">
      <div class="mx-auto max-w-[1360px]">
        <h2 class="text-2xl font-bold">Works where agents already run</h2>
        <div class="mt-4 overflow-x-auto rounded border border-lab-line bg-lab-surface/72">
          <table class="w-full min-w-[900px] border-collapse text-sm">
            <thead>
              <tr class="border-b border-lab-line text-lab-text">
                <th class="border-r border-lab-border px-4 py-3 text-left font-bold">Client / Platform</th>
                <th class="border-r border-lab-border px-4 py-3 text-center font-bold">AutoMem MCP</th>
                <th class="border-r border-lab-border px-4 py-3 text-center font-bold">macOS</th>
                <th class="border-r border-lab-border px-4 py-3 text-center font-bold">Linux</th>
                <th class="border-r border-lab-border px-4 py-3 text-center font-bold">Windows (WSL2)</th>
                <th class="border-r border-lab-border px-4 py-3 text-center font-bold">Docker</th>
                <th class="px-4 py-3 text-center font-bold">Kubernetes</th>
              </tr>
            </thead>
            <tbody>
              {compatibilityRows.map(([client, mcp]) => (
                <tr class="border-b border-lab-border last:border-b-0">
                  <td class="border-r border-lab-border px-4 py-2 text-lab-text">{client}</td>
                  <td class="border-r border-lab-border px-4 py-2 text-center text-lab-text">{mcp}</td>
                  {[0, 1, 2, 3, 4].map(() => (
                    <td class="border-r border-lab-border px-4 py-2 text-center text-lg font-bold text-lab-success last:border-r-0">✓</td>
                  ))}
                </tr>
              ))}
            </tbody>
          </table>
        </div>
        <p class="mt-4 text-center text-sm text-lab-muted">
          If your client supports MCP, AutoMem works.
          <a href="/docs/platforms/codex/" class="ml-3 font-bold text-lab-secondary no-underline hover:underline">See full compatibility guide →</a>
        </p>
        <p class="mt-3 text-center text-xs text-lab-muted">Extended compatibility: {extendedClients}.</p>
      </div>
    </section>

    <!-- 6. GET STARTED — choose your setup -->
    <section class="border-t border-lab-border/70 px-4 py-10 sm:px-7 lg:px-10">
      <div class="mx-auto max-w-[1360px]">
        <h2 class="text-2xl font-bold">Choose your setup</h2>
        <p class="mt-2 text-sm font-bold text-lab-muted">Deploy Once. Remember Everywhere.</p>
        <div class="mt-5 grid gap-5 lg:grid-cols-3">
          {setupPaths.map((path) => (
            <article class={`setup-card setup-card-${path.tone} relative rounded border bg-lab-surface/74 p-5`}>
              {path.badge && <div class="absolute right-5 top-4 text-[10px] font-bold uppercase text-lab-success">{path.badge}</div>}
              <div class="flex items-start gap-4">
                <div class="flex h-10 w-10 items-center justify-center rounded border text-2xl">{path.icon}</div>
                <div>
                  <h3 class="text-xl font-bold">{path.title}</h3>
                  <p class="mt-2 text-sm text-lab-muted">{path.detail}</p>
                </div>
              </div>
              <ul class="mt-5 space-y-3 text-sm">
                {path.bullets.map((bullet) => (
                  <li class="flex items-center gap-3">
                    <span class="text-current">✓</span>
                    <span class="text-lab-text">{bullet}</span>
                  </li>
                ))}
              </ul>
              <a href={path.href ?? '/install'} target={path.href ? '_blank' : undefined} rel={path.href ? 'noopener noreferrer' : undefined} class="mt-5 block break-all rounded border border-lab-border bg-lab-bg/72 px-3 py-2 text-xs text-lab-muted no-underline">
                {path.command}
              </a>
            </article>
          ))}
        </div>
        <p class="mt-5 text-center text-sm text-lab-muted">
          All options expose the same MCP endpoint, including the Existing Endpoint path.
          <span class="ml-2">Self-hosted / Docker remains available for teams that want full control.</span>
          <a href="/install" class="ml-2 font-bold text-lab-secondary no-underline hover:underline">Learn more in the install guide →</a>
        </p>
      </div>
    </section>

    <!-- 7. GET STARTED — what the installer does + closing CTA -->
    <section class="border-t border-lab-border/70 px-4 py-10 sm:px-7 lg:px-10">
      <div class="mx-auto max-w-[1360px]">
        <h2 class="text-2xl font-bold">What the installer does</h2>
        <div class="mt-8 grid gap-6 lg:grid-cols-4 lg:gap-0">
          {installerSteps.map((step, index) => (
            <div class="relative lg:pr-8">
              {index < installerSteps.length - 1 && <div class="absolute left-14 right-4 top-5 hidden border-t border-lab-line lg:block"></div>}
              <div class="relative flex h-10 w-10 items-center justify-center rounded-full border-2 border-lab-secondary bg-lab-bg text-lg font-bold text-lab-secondary">{step.number}</div>
              <h3 class="mt-5 font-bold text-lab-secondary">{step.title}</h3>
              <p class="mt-2 max-w-[18rem] text-sm leading-5 text-lab-muted">{step.detail}</p>
            </div>
          ))}
        </div>
        <div class="mt-10 flex flex-col gap-4 sm:flex-row sm:items-center">
          <a href="/install" class="btn-lab-accent w-full sm:w-auto">
            <span>›</span>
            <span class="ml-2">Install AutoMem</span>
          </a>
          <a href={GITHUB_URL} target="_blank" rel="noopener noreferrer" class="btn-lab w-full sm:w-auto">
            <span>View on GitHub</span>
            <span class="ml-3">→</span>
          </a>
        </div>
      </div>
    </section>
  </main>

  <style>
    .setup-card {
      border-color: rgb(var(--lab-line));
      box-shadow: inset 0 1px 0 rgb(255 255 255 / 0.04);
    }
    /* Light mode: real elevation + an opaque surface so the blueprint grid
       doesn't read through the card. */
    :global(html.light) .setup-card {
      background-color: rgb(255 255 255 / 0.94);
      box-shadow: 0 10px 28px rgb(14 20 28 / 0.07);
    }
    .setup-card-green {
      color: rgb(var(--lab-success));
      border-color: rgb(var(--lab-success) / 0.55);
    }
    .setup-card-violet {
      color: rgb(var(--lab-secondary));
      border-color: rgb(var(--lab-secondary) / 0.55);
    }
    .setup-card-gold {
      color: rgb(var(--lab-accent));
      border-color: rgb(var(--lab-accent) / 0.65);
    }
  </style>

  <script>
    const copyButton = document.querySelector<HTMLButtonElement>('[data-copy-skill-url]');
    if (copyButton) {
      const url = copyButton.dataset.copySkillUrl ?? '';
      const icon = copyButton.querySelector('.copy-icon');
      const check = copyButton.querySelector('.copy-check');
      let resetTimer: ReturnType<typeof setTimeout> | undefined;
      copyButton.addEventListener('click', async () => {
        try {
          await navigator.clipboard.writeText(url);
          icon?.classList.add('hidden');
          check?.classList.remove('hidden');
          copyButton.setAttribute('aria-label', 'Copied skill URL');
          clearTimeout(resetTimer);
          resetTimer = setTimeout(() => {
            check?.classList.add('hidden');
            icon?.classList.remove('hidden');
            copyButton.setAttribute('aria-label', 'Copy skill URL');
          }, 2000);
        } catch {
          /* Clipboard API unavailable (insecure context / denied) — leave the URL visible to copy manually. */
        }
      });
    }
  </script>
</Layout>
