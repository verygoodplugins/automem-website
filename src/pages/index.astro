---
import Layout from '../layouts/Layout.astro';
import Navigation from '../components/Navigation.astro';
import ChatDemo from '../components/ChatDemo.astro';
import EmailSignup from '../components/EmailSignup.astro';
import OrganizationSchema from '../components/schemas/OrganizationSchema.astro';
import Typewriter from '../components/Typewriter.astro';

const GITHUB_URL = 'https://github.com/verygoodplugins/automem';
const GITHUB_URL_UTM = `${GITHUB_URL}?utm_source=automem.ai&utm_medium=gate&utm_campaign=waitlist`;
---

<Layout title="Home">
  <OrganizationSchema />
  <Navigation currentPath="/" />

  <main class="w-full pt-12 pb-24">
    <!-- Hero Section: Memory Lab -->
    <section
      class="px-6 md:px-12 pt-12 pb-24 border-b border-core-line bg-core-bg relative overflow-hidden"
    >
      <!-- Lab Label -->
      <div class="comment-header">:: SEQUENCE_INIT</div>

      <div
        class="max-w-6xl mx-auto grid md:grid-cols-2 gap-12 items-center relative z-10"
      >
        <!-- Left: Manifesto -->
        <div>
          <h1
            class="text-5xl md:text-7xl font-bold tracking-tighter mb-6 leading-[0.9]"
          >
            Recall is<br />
            <span class="text-core-accent">Power.</span>
          </h1>

          <div
            class="space-y-6 text-lg md:text-xl leading-relaxed border-l-4 border-core-secondary pl-6 py-2"
          >
            <p>
              <Typewriter
                text="Deploy once. Remember everywhere."
                delay="{200}"
              />
              <br />
              <Typewriter
                text="The universal memory layer for your AI agents."
                delay="{1500}"
                class="text-core-muted"
              />
            </p>
          </div>

          <div class="mt-12 flex flex-wrap gap-4">
            <a href="/docs" class="btn-core-accent shadow-hard">
              INIT_SYSTEM.sh
            </a>
            <a href="{GITHUB_URL}" class="btn-core group gap-2">
              <span>SOURCE_CODE</span>
              <span class="text-xs bg-core-text text-white px-1.5 rounded"
                >GITHUB</span
              >
            </a>
          </div>
        </div>

        <!-- Right: The Machine (Chat Demo) -->
        <div class="relative">
          <div
            class="absolute inset-0 bg-core-accent/5 blur-3xl rounded-full"
          ></div>
          <ChatDemo />
        </div>
      </div>
    </section>

    <!-- Features: The Circuit -->
    <section
      class="px-6 md:px-12 py-24 border-b border-core-line bg-white relative"
    >
      <div class="comment-header">System Architecture</div>

      <div class="max-w-6xl mx-auto">
        <div class="grid md:grid-cols-3 gap-8">
          <!-- Node 1 -->
          <div
            class="border-2 border-core-text p-6 rounded-lg shadow-hard bg-core-bg hover:translate-y-[-4px] transition-transform relative group"
          >
            <div
              class="absolute -top-3 left-6 bg-core-secondary text-white px-2 text-xs font-bold uppercase"
            >
              Input
            </div>
            <h3 class="text-xl font-bold mb-2 mt-2">Universal I/O</h3>
            <p class="text-core-muted text-sm leading-relaxed">
              Compatible with Cursor, Claude, and ChatGPT. Connects to any LLM
              via MCP or SSE sidecar.
            </p>
            <div class="mt-4 flex gap-2">
              <span
                class="w-2 h-2 bg-green-400 rounded-full animate-pulse"
              ></span>
              <span class="text-xs font-mono opacity-50">LISTENING...</span>
            </div>
          </div>

          <!-- Node 2 -->
          <div
            class="border-2 border-core-text p-6 rounded-lg shadow-hard bg-core-bg hover:translate-y-[-4px] transition-transform relative group"
          >
            <div
              class="absolute -top-3 left-6 bg-core-accent text-white px-2 text-xs font-bold uppercase"
            >
              Process
            </div>
            <h3 class="text-xl font-bold mb-2 mt-2">Graph Engine</h3>
            <p class="text-core-muted text-sm leading-relaxed">
              FalkorDB + Qdrant hybrid core. Maps relationships between
              memories, not just vector similarity.
            </p>
            <div class="mt-4 flex gap-1">
              {[1,2,3].map(() =>
              <div class="w-2 h-4 bg-core-muted/30"></div>
              )}
            </div>
          </div>

          <!-- Node 3 -->
          <div
            class="border-2 border-core-text p-6 rounded-lg shadow-hard bg-core-bg hover:translate-y-[-4px] transition-transform relative group"
          >
            <div
              class="absolute -top-3 left-6 bg-core-text text-white px-2 text-xs font-bold uppercase"
            >
              Output
            </div>
            <h3 class="text-xl font-bold mb-2 mt-2">Instant Recall</h3>
            <p class="text-core-muted text-sm leading-relaxed">
              Sub-50ms latency. Your agent knows what you know before you finish
              typing the prompt.
            </p>
            <div class="mt-4 font-mono text-xs text-core-accent">>> 48ms</div>
          </div>
        </div>
      </div>
    </section>

    <!-- Timeline / Changelog -->
    <section class="px-6 md:px-12 py-24 border-b border-core-line bg-core-bg">
      <div class="comment-header">:: MEMORY_STREAM</div>

      <div class="max-w-4xl mx-auto space-y-12">
        <!-- Log Entry -->
        <div class="flex gap-6">
          <div
            class="font-mono text-sm text-core-muted text-right w-24 pt-1 hidden md:block"
          >
            2025-10-15<br />14:00:00
          </div>
          <div class="flex-1 border-l-2 border-core-line pl-8 relative">
            <div
              class="absolute -left-[9px] top-0 w-4 h-4 bg-white border-2 border-core-secondary rounded-full"
            ></div>
            <h3 class="text-xl font-bold">SSE Sidecar Activated</h3>
            <p class="mt-2 text-core-text/80 max-w-xl">
              Real-time memory streaming enabled for non-MCP platforms.
              <span class="bg-core-secondary/20 px-1 rounded">ChatGPT</span> and
              <span class="bg-core-secondary/20 px-1 rounded">ElevenLabs</span>
              integrations live.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Deployment Options -->
    <section class="px-6 md:px-12 py-24 bg-white">
      <div class="comment-header">:: DEPLOYMENT_PROTOCOLS</div>
      <div class="max-w-6xl mx-auto">
        <div class="text-center max-w-2xl mx-auto mb-16">
          <h2 class="text-4xl font-bold mb-6 tracking-tighter">
            Open Source & Portable
          </h2>
          <p class="text-xl text-core-muted">
            Your memory infrastructure should be as portable as your code. Run
            it on your laptop, your private cloud, or our managed service.
          </p>
        </div>

        <div class="grid md:grid-cols-3 gap-8">
          <!-- Option 1: Docker -->
          <div
            class="bg-core-bg border-2 border-core-text p-8 rounded-lg shadow-hard relative group hover:translate-y-[-4px] transition-transform"
          >
            <div
              class="absolute -top-3 left-1/2 -translate-x-1/2 bg-core-text text-white px-3 py-1 text-xs font-bold uppercase tracking-widest"
            >
              Standard
            </div>
            <div class="text-4xl mb-4">🐳</div>
            <h3 class="text-2xl font-bold mb-2">Docker</h3>
            <p class="text-core-muted mb-6 text-sm min-h-[40px]">
              The standard container. Run it locally or on any VPS.
            </p>
            <div
              class="bg-white border border-core-text p-3 rounded font-mono text-xs text-left mb-6"
            >
              docker run -p 3000:3000<br />automem/server:latest
            </div>
            <a
              href="https://github.com/verygoodplugins/automem"
              class="btn-core w-full"
              >View Image</a
            >
          </div>

          <!-- Option 2: Railway -->
          <div
            class="bg-white border-2 border-core-accent p-8 rounded-lg shadow-hard relative group hover:translate-y-[-4px] transition-transform scale-105 z-10"
          >
            <div
              class="absolute -top-3 left-1/2 -translate-x-1/2 bg-core-accent text-white px-3 py-1 text-xs font-bold uppercase tracking-widest"
            >
              Fastest
            </div>
            <div class="text-4xl mb-4">🚂</div>
            <h3 class="text-2xl font-bold mb-2">Railway</h3>
            <p class="text-core-muted mb-6 text-sm min-h-[40px]">
              One-click production deployment. Handles DBs & updates
              automatically.
            </p>
            <div
              class="bg-core-bg border border-core-accent p-3 rounded font-mono text-xs text-left mb-6 text-core-accent"
            >
              > Deploying to prod...<br />> Success (24s)
            </div>
            <a
              href="https://railway.com/deploy/automem-ai-memory-service"
              class="btn-core-accent w-full"
              >One-Click Deploy</a
            >
          </div>

          <!-- Option 3: Source -->
          <div
            class="bg-core-bg border-2 border-core-text p-8 rounded-lg shadow-hard relative group hover:translate-y-[-4px] transition-transform"
          >
            <div
              class="absolute -top-3 left-1/2 -translate-x-1/2 bg-core-text text-white px-3 py-1 text-xs font-bold uppercase tracking-widest"
            >
              Hacker
            </div>
            <div class="text-4xl mb-4">💻</div>
            <h3 class="text-2xl font-bold mb-2">Source</h3>
            <p class="text-core-muted mb-6 text-sm min-h-[40px]">
              Fork the repo. Hack the graph logic. It's your code.
            </p>
            <div
              class="bg-white border border-core-text p-3 rounded font-mono text-xs text-left mb-6"
            >
              git clone ...<br />npm install
            </div>
            <a
              href="https://github.com/verygoodplugins/automem"
              class="btn-core w-full"
              >Fork Repo</a
            >
          </div>
        </div>
      </div>
    </section>
  </main>
</Layout>
