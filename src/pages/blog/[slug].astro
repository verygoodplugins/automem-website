---
import { getEmDashEntry } from 'emdash';
import { PortableText } from 'emdash/ui';
import { getCollection, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Navigation from '../../components/Navigation.astro';
import AuthorBio from '../../components/AuthorBio.astro';
import BlogPostingSchema from '../../components/schemas/BlogPostingSchema.astro';
import SEOMeta from '../../components/SEOMeta.astro';
import { publicBlogSlug } from '../../lib/blog-slugs';
import '../../styles/global.css';

const { slug } = Astro.params;
const { entry: post, isPreview, error } = await getEmDashEntry("posts", slug!);

const contentPosts = await getCollection('blog', ({ data }) => !data.draft);
const contentPost = post
  ? undefined
  : contentPosts.find((entry) => {
      const publicSlug = publicBlogSlug(entry);
      return publicSlug === slug || entry.slug === slug || entry.id === slug;
    });

if (error && !contentPost) {
  console.error("Failed to load post:", error);
}

if (!post && !contentPost) {
  return new Response(null, { status: 404, statusText: 'Not Found' });
}

// CDN caching (preview requests are handled by emdash middleware with no-store)
if (!isPreview) {
  Astro.response.headers.set('Cache-Control', 'public, s-maxage=3600, stale-while-revalidate=86400');
}

const renderedContentPost = contentPost ? await render(contentPost) : undefined;
const ContentPost = renderedContentPost?.Content;
// emdash posts expose their summary as `excerpt`; content-collection posts use `description`.
// `contentPost` is undefined whenever the post came from emdash, so every fallback must be
// optional — non-null assertions here crash on emdash posts (TypeError reading 'data').
const title = post?.data.title ?? contentPost?.data.title ?? 'Untitled';
const description = post?.data.description ?? post?.data.excerpt ?? contentPost?.data.description ?? '';
const tags = post?.data.tags ?? contentPost?.data.tags ?? [];
const date = (post
  ? post.data.publishedAt ?? post.data.createdAt
  : contentPost?.data.date) ?? undefined;
const formattedDate = date?.toLocaleDateString('en-US', {
  month: 'long',
  day: 'numeric',
  year: 'numeric'
}) ?? '';
---

<Layout title={`${title} - AutoMem Blog`} description={description ?? ''}>
  <SEOMeta
    title={`${title} - AutoMem Blog`}
    description={description ?? ''}
    url={`/blog/${slug}`}
    type="article"
    publishedTime={date?.toISOString()}
    tags={tags}
  />
  <BlogPostingSchema
    title={title}
    description={description ?? ''}
    datePublished={date ?? new Date()}
    slug={slug!}
    tags={tags}
  />
  <Navigation currentPath="/blog" />

  <main class="min-h-screen py-12 sm:py-20 px-4 sm:px-6 bg-lab-bg">
    <article class="max-w-3xl mx-auto min-w-0">
      <!-- Back to Blog -->
      <a
        href="/blog"
        class="inline-flex items-center gap-2 text-lab-muted hover:text-lab-accent-text transition mb-8 font-mono text-sm"
      >
        ← Back to Blog
      </a>

      <!-- Post Header -->
      <header class="mb-10 sm:mb-12 bg-lab-surface p-4 sm:p-8 rounded-lg border-2 border-lab-text shadow-hard min-w-0">
        <div class="comment-header mb-4">:: POST_CONTENT</div>
        <h1 class="text-3xl sm:text-4xl md:text-5xl font-bold mb-4 text-lab-text tracking-tighter leading-tight break-words">
          {title}
        </h1>
        <p class="text-base sm:text-xl text-lab-muted mb-6 font-mono border-l-4 border-lab-accent pl-4 break-words">
          {description}
        </p>
        <div class="flex flex-wrap items-center gap-4 text-sm">
          <time class="text-lab-muted font-mono bg-lab-bg px-2 py-1 border border-lab-border">
            {formattedDate}
          </time>
          {tags.length > 0 && (
            <div class="flex flex-wrap gap-2">
              {tags.map(tag => (
                <span class="px-2 py-1 bg-lab-secondary/20 text-lab-secondary border border-lab-secondary/30 text-xs font-bold uppercase">
                  {tag}
                </span>
              ))}
            </div>
          )}
        </div>
      </header>

      <!-- Post Content -->
      <div class="prose prose-lg max-w-none bg-lab-surface p-4 sm:p-8 rounded-lg border-2 border-lab-text min-w-0">
        {post ? <PortableText value={post.data.content} /> : ContentPost && <ContentPost />}
      </div>

      <!-- Author Bio -->
      <AuthorBio />

      <!-- Footer -->
      <footer class="mt-16 pt-8 border-t-2 border-lab-border">
        <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4 font-mono text-sm">
          <a
            href="/blog"
            class="text-lab-accent-text hover:underline"
          >
            ← All Posts
          </a>
          <a
            href="/"
            class="text-lab-accent-text hover:underline"
          >
            Return Home →
          </a>
        </div>
      </footer>
    </article>
  </main>
</Layout>

<style>
  @reference "../../styles/global.css";
  /* Prose styling for blog content - Memory Lab theme */
  .prose {
    @apply text-lab-text font-mono text-base leading-relaxed;
  }


  .prose :global(*) {
    @apply break-words;
  }

  .prose :global(img),
  .prose :global(video),
  .prose :global(iframe),
  .prose :global(table) {
    @apply max-w-full h-auto;
  }

  .prose :global(h2) {
    @apply text-lab-text text-2xl font-bold mt-10 mb-4 pb-2 border-b-2 border-lab-border;
  }

  .prose :global(h3) {
    @apply text-lab-text text-xl font-bold mt-8 mb-3;
  }

  .prose :global(p) {
    @apply mb-6 text-lab-text/80;
  }

  .prose :global(a) {
    @apply text-lab-accent-text underline decoration-lab-accent/30 hover:decoration-lab-accent transition-all;
  }

  .prose :global(ul),
  .prose :global(ol) {
    @apply mb-6 pl-6 text-lab-text/80;
  }

  .prose :global(li) {
    @apply mb-2;
  }

  .prose :global(strong) {
    @apply text-lab-text font-bold;
  }

  .prose :global(code) {
    @apply bg-lab-bg px-1.5 py-0.5 text-sm border border-lab-border text-lab-accent-text;
  }

  .prose :global(pre) {
    @apply bg-lab-text text-lab-bg p-4 rounded-lg overflow-x-auto mb-6 border-2 border-lab-text shadow-hard;
  }

  .prose :global(pre code) {
    @apply bg-transparent p-0 border-none text-lab-bg;
  }

  .prose :global(blockquote) {
    @apply border-l-4 border-lab-accent pl-4 ml-0 mb-6 italic text-lab-muted bg-lab-bg p-4 rounded-r-lg;
  }
</style>
