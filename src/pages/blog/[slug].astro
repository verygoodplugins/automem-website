---
import { getEmDashEntry, getEntryTerms, getSeoMeta } from 'emdash';
import type { ContentBylineCredit } from 'emdash';
import { CommentForm, Comments, Image, PortableText, WidgetArea } from 'emdash/ui';
import { createPublicPageContext } from 'emdash/page';
import Layout from '../../layouts/Layout.astro';
import Navigation from '../../components/Navigation.astro';
import AuthorBio from '../../components/AuthorBio.astro';
import { getCmsChrome } from '../../lib/cms-chrome';
import { hydrateCmsSeo } from '../../lib/cms-seo';
import '../../styles/global.css';

interface CmsMediaValue {
  id: string;
  src?: string;
  filename?: string;
  mimeType?: string;
  width?: number;
  height?: number;
  alt?: string;
  provider?: string;
  meta?: Record<string, unknown>;
}

interface CmsPostData {
  id: string;
  slug?: string | null;
  title: string;
  excerpt?: string;
  content?: unknown[];
  publishedAt?: Date;
  createdAt?: Date;
  updatedAt?: Date;
  featured_image?: CmsMediaValue | string | null;
  bylines?: ContentBylineCredit[];
}

const { slug } = Astro.params;
const chrome = await getCmsChrome();
const { entry: post, isPreview, error, cacheHint } = await getEmDashEntry<'posts', CmsPostData>('posts', slug!);

if (error) {
  console.error('Failed to load CMS post:', error);
  return new Response('CMS post temporarily unavailable.', {
    status: 503,
    headers: {
      'Cache-Control': 'no-store',
      'Content-Type': 'text/plain; charset=utf-8',
    },
  });
}

if (!post) {
  return new Response(null, { status: 404, statusText: 'Not Found' });
}

Astro.cache.set(cacheHint);

if (!isPreview) {
  Astro.response.headers.set('Cache-Control', 'public, s-maxage=3600, stale-while-revalidate=86400');
}

const [tags, categories] = await Promise.all([
  getEntryTerms('posts', post.data.id, 'tag'),
  getEntryTerms('posts', post.data.id, 'category'),
]);

const date = post.data.publishedAt ?? post.data.createdAt;
const formattedDate = date?.toLocaleDateString('en-US', {
  month: 'long',
  day: 'numeric',
  year: 'numeric',
}) ?? '';
const postSlug = post.data.slug ?? slug!;
const byline = post.data.bylines?.[0]?.byline;
const bylineName = byline?.displayName ?? 'Jack Arturo';
const siteUrl = Astro.site?.toString().replace(/\/$/, '') ?? 'https://automem.ai';
const seoPost = await hydrateCmsSeo(Astro.locals, 'posts', post);
const seo = getSeoMeta(seoPost, {
  siteTitle: chrome.siteTitle,
  siteUrl,
  path: `/blog/${postSlug}`,
  defaultOgImage: `${siteUrl}/og-image.png`,
});
const pageContext = createPublicPageContext({
  Astro,
  kind: 'content',
  pageType: 'article',
  title: seo.title,
  description: seo.description,
  canonical: seo.canonical,
  image: seo.ogImage,
  content: {
    collection: 'posts',
    id: post.data.id,
    slug: postSlug,
  },
  seo: {
    ogTitle: seo.ogTitle,
    ogDescription: seo.ogDescription,
    ogImage: seo.ogImage,
    robots: seo.robots,
  },
  articleMeta: {
    publishedTime: date?.toISOString(),
    modifiedTime: post.data.updatedAt?.toISOString() ?? date?.toISOString(),
    author: bylineName,
  },
  siteName: chrome.siteTitle,
});
---

<Layout
  title={post.data.title}
  description={seo.description ?? post.data.excerpt ?? ''}
  pageContext={pageContext}
  footerMenuItems={chrome.footerMenuItems}
>
  <Navigation
    currentPath="/blog"
    menuItems={chrome.primaryMenuItems}
    siteTitle={chrome.siteTitle}
  />

  <main class="min-h-screen py-12 sm:py-20 px-4 sm:px-6 bg-lab-bg">
    <div class="mx-auto grid max-w-6xl gap-10 lg:grid-cols-[minmax(0,1fr)_280px]">
      <article class="min-w-0" {...post.edit}>
        <a
          href="/blog"
          class="inline-flex items-center gap-2 text-lab-muted hover:text-lab-accent-text transition mb-8 font-mono text-sm"
        >
          ← Back to Blog
        </a>

        <header class="mb-10 sm:mb-12 bg-lab-surface p-4 sm:p-8 rounded-lg border-2 border-lab-text shadow-hard min-w-0">
          <div class="comment-header mb-4">:: POST_CONTENT</div>
          <div class="mb-4 flex flex-wrap gap-2">
            {categories.map((category) => (
              <a
                href={`/blog/category/${category.slug}`}
                class="px-2 py-1 bg-lab-accent/10 text-lab-accent-text border border-lab-accent/45 text-xs font-bold uppercase no-underline"
              >
                {category.label}
              </a>
            ))}
          </div>
          <h1
            class="text-3xl sm:text-4xl md:text-5xl font-bold mb-4 text-lab-text tracking-tighter leading-tight break-words"
            {...post.edit.title}
          >
            {post.data.title}
          </h1>
          {post.data.excerpt && (
            <p class="text-base sm:text-xl text-lab-muted mb-6 font-mono border-l-4 border-lab-accent pl-4 break-words" {...post.edit.excerpt}>
              {post.data.excerpt}
            </p>
          )}
          <div class="flex flex-wrap items-center gap-4 text-sm">
            {formattedDate && (
              <time class="text-lab-muted font-mono bg-lab-bg px-2 py-1 border border-lab-border">
                {formattedDate}
              </time>
            )}
            {bylineName && (
              <span class="text-lab-muted font-mono bg-lab-bg px-2 py-1 border border-lab-border">
                {byline?.slug ? (
                  <a href={`/authors/${byline.slug}`} class="text-lab-muted no-underline hover:text-lab-accent-text">
                    {bylineName}
                  </a>
                ) : bylineName}
              </span>
            )}
            {tags.length > 0 && (
              <div class="flex flex-wrap gap-2">
                {tags.map((tag) => (
                  <a
                    href={`/blog/tag/${tag.slug}`}
                    class="px-2 py-1 bg-lab-secondary/20 text-lab-secondary border border-lab-secondary/30 text-xs font-bold uppercase no-underline"
                  >
                    #{tag.label}
                  </a>
                ))}
              </div>
            )}
          </div>
        </header>

        {post.data.featured_image && (
          <div class="mb-10 overflow-hidden rounded-lg border-2 border-lab-text bg-lab-bg shadow-hard">
            <Image
              image={post.data.featured_image}
              alt={post.data.title}
              priority
              class="aspect-[16/9] w-full object-cover"
            />
          </div>
        )}

        <div class="prose prose-lg max-w-none bg-lab-surface p-4 sm:p-8 rounded-lg border-2 border-lab-text min-w-0" {...post.edit.content}>
          {post.data.content && <PortableText value={post.data.content} />}
        </div>

        <AuthorBio />

        <section class="mt-12 space-y-6">
          <Comments collection="posts" contentId={post.data.id} threaded />
          <CommentForm collection="posts" contentId={post.data.id} />
        </section>

        <footer class="mt-16 pt-8 border-t-2 border-lab-border">
          <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4 font-mono text-sm">
            <a href="/blog" class="text-lab-accent-text hover:underline">← All Posts</a>
            <a href="/" class="text-lab-accent-text hover:underline">Return Home →</a>
          </div>
        </footer>
      </article>

      <aside class="lg:pt-12">
        <WidgetArea name="blog-sidebar" class="space-y-6" />
      </aside>
    </div>
  </main>
</Layout>

<style>
  @reference "../../styles/global.css";

  .prose {
    @apply text-lab-text font-mono text-base leading-relaxed;
  }

  .prose :global(*) {
    @apply break-words;
  }

  .prose :global(img),
  .prose :global(video),
  .prose :global(iframe),
  .prose :global(table) {
    @apply max-w-full h-auto;
  }

  .prose :global(h2) {
    @apply text-lab-text text-2xl font-bold mt-10 mb-4 pb-2 border-b-2 border-lab-border;
  }

  .prose :global(h3) {
    @apply text-lab-text text-xl font-bold mt-8 mb-3;
  }

  .prose :global(p) {
    @apply mb-6 text-lab-text/80;
  }

  .prose :global(a) {
    @apply text-lab-accent-text underline decoration-lab-accent/30 hover:decoration-lab-accent transition-all;
  }

  .prose :global(ul),
  .prose :global(ol) {
    @apply mb-6 pl-6 text-lab-text/80;
  }

  .prose :global(li) {
    @apply mb-2;
  }

  .prose :global(strong) {
    @apply text-lab-text font-bold;
  }

  .prose :global(code) {
    @apply bg-lab-bg px-1.5 py-0.5 text-sm border border-lab-border text-lab-accent-text;
  }

  .prose :global(pre) {
    @apply bg-lab-text text-lab-bg p-4 rounded-lg overflow-x-auto mb-6 border-2 border-lab-text shadow-hard;
  }

  .prose :global(pre code) {
    @apply bg-transparent p-0 border-none text-lab-bg;
  }

  .prose :global(blockquote) {
    @apply border-l-4 border-lab-accent pl-4 ml-0 mb-6 italic text-lab-muted bg-lab-bg p-4 rounded-r-lg;
  }
</style>
