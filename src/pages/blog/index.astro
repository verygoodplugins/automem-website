---
import { getEmDashCollection, getTermsForEntries } from 'emdash';
import { Image } from 'emdash/ui';
import Layout from '../../layouts/Layout.astro';
import Navigation from '../../components/Navigation.astro';
import { getCmsChrome } from '../../lib/cms-chrome';
import '../../styles/global.css';

interface CmsMediaValue {
  id: string;
  src?: string;
  filename?: string;
  mimeType?: string;
  width?: number;
  height?: number;
  alt?: string;
  provider?: string;
  meta?: Record<string, unknown>;
}

interface CmsByline {
  displayName?: string;
  slug?: string;
}

interface CmsPostData {
  id: string;
  title: string;
  excerpt?: string;
  publishedAt?: Date;
  createdAt?: Date;
  featured_image?: CmsMediaValue | string | null;
  byline?: CmsByline | null;
}

const cursor = Astro.url.searchParams.get('cursor') ?? undefined;
const chrome = await getCmsChrome();

const { entries: posts, error, cacheHint, nextCursor } = await getEmDashCollection<'posts', CmsPostData>('posts', {
  status: 'published',
  limit: 20,
  cursor,
  orderBy: { published_at: 'desc' },
});

Astro.cache.set(cacheHint);
Astro.response.headers.set('Cache-Control', 'public, s-maxage=3600, stale-while-revalidate=86400');

if (error) {
  console.error('Failed to load CMS posts:', error);
}

const postIds = posts.map((post) => post.data.id);
const [tagsByPost, categoriesByPost] = await Promise.all([
  getTermsForEntries('posts', postIds, 'tag'),
  getTermsForEntries('posts', postIds, 'category'),
]);

const postsByYear: Record<number, typeof posts> = {};
posts.forEach((post) => {
  const date = post.data.publishedAt ?? post.data.createdAt;
  if (!date) return;
  const year = date.getFullYear();
  postsByYear[year] ??= [];
  postsByYear[year].push(post);
});

const years = Object.keys(postsByYear).map(Number).sort((a, b) => b - a);
const nextHref = nextCursor ? `/blog?cursor=${encodeURIComponent(nextCursor)}` : undefined;
---

<Layout
  title="Blog - AutoMem"
  description="Articles about AI, memory systems, and open source development"
  footerMenuItems={chrome.footerMenuItems}
>
  <Navigation
    currentPath="/blog"
    menuItems={chrome.primaryMenuItems}
    siteTitle={chrome.siteTitle}
  />

  <main class="min-h-screen py-12 sm:py-20 px-4 sm:px-6 bg-lab-bg">
    <div class="max-w-5xl mx-auto">
      <div class="mb-12">
        <div class="comment-header">:: TRANSMISSION_LOG</div>
        <h1 class="text-4xl sm:text-5xl font-bold mb-4 tracking-tighter">
          <span class="text-lab-secondary">Blog</span>
        </h1>
        <p class="text-base sm:text-xl text-lab-muted font-mono border-l-4 border-lab-accent pl-4">
          Thoughts on AI, memory systems, and building in the open.
        </p>
      </div>

      {years.map((year) => (
        <section class="mb-16">
          <h2 class="text-2xl sm:text-3xl font-bold mb-6 text-lab-text font-mono">{year}</h2>
          <div class="space-y-6">
            {postsByYear[year].map((post) => {
              const date = post.data.publishedAt ?? post.data.createdAt;
              const tags = tagsByPost.get(post.data.id) ?? [];
              const categories = categoriesByPost.get(post.data.id) ?? [];
              return (
                <article class="group">
                  <a
                    href={`/blog/${post.id}`}
                    class="grid gap-5 bg-lab-surface rounded-lg p-4 sm:p-6 border-2 border-lab-text hover:translate-x-[-2px] hover:translate-y-[-2px] hover:shadow-hard transition-all active:translate-x-[0] active:translate-y-[0] active:shadow-none md:grid-cols-[minmax(0,1fr)_180px]"
                  >
                    <div class="min-w-0">
                      <div class="mb-3 flex flex-wrap items-center gap-2 text-xs font-mono uppercase">
                        {categories.map((category) => (
                          <span class="border border-lab-accent/45 bg-lab-accent/10 px-2 py-1 text-lab-accent-text">
                            {category.label}
                          </span>
                        ))}
                      </div>
                      <h3 class="text-xl sm:text-2xl font-bold mb-2 text-lab-text group-hover:text-lab-accent-text transition break-words">
                        {post.data.title}
                      </h3>
                      {post.data.excerpt && (
                        <p class="text-lab-muted mb-3 font-mono text-sm break-words">
                          {post.data.excerpt}
                        </p>
                      )}
                      <div class="flex flex-wrap items-center gap-3 sm:gap-4 text-sm">
                        {date && (
                          <time class="text-lab-muted font-mono text-xs">
                            {date.toLocaleDateString('en-US', {
                              month: 'short',
                              day: 'numeric',
                              year: 'numeric',
                            })}
                          </time>
                        )}
                        {post.data.byline?.displayName && (
                          <span class="text-lab-muted font-mono text-xs">
                            {post.data.byline.displayName}
                          </span>
                        )}
                      </div>
                      {tags.length > 0 && (
                        <div class="mt-4 flex flex-wrap gap-2">
                          {tags.map((tag) => (
                            <span class="px-2 py-1 bg-lab-secondary/20 text-lab-secondary border border-lab-secondary/30 text-xs font-bold uppercase">
                              #{tag.label}
                            </span>
                          ))}
                        </div>
                      )}
                    </div>
                    {post.data.featured_image && (
                      <div class="overflow-hidden rounded border-2 border-lab-text bg-lab-bg md:order-2">
                        <Image
                          image={post.data.featured_image}
                          alt={post.data.title}
                          class="aspect-[4/3] h-full w-full object-cover"
                        />
                      </div>
                    )}
                  </a>
                </article>
              );
            })}
          </div>
        </section>
      ))}

      {posts.length === 0 && (
        <div class="text-center py-12 bg-lab-surface rounded-lg border-2 border-lab-border">
          <p class="text-lab-muted text-lg font-mono">// No CMS posts are published yet.</p>
        </div>
      )}

      {nextHref && (
        <div class="mt-12 flex justify-center">
          <a href={nextHref} class="btn-lab-accent">Older Posts</a>
        </div>
      )}
    </div>
  </main>
</Layout>
