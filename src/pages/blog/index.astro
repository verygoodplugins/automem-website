---
import { getEmDashCollection } from 'emdash';
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Navigation from '../../components/Navigation.astro';
import { publicBlogSlug } from '../../lib/blog-slugs';
import '../../styles/global.css';

// CDN caching: 1h fresh, 24h stale-while-revalidate
Astro.response.headers.set('Cache-Control', 'public, s-maxage=3600, stale-while-revalidate=86400');

// Get all published posts from emdash CMS, newest first
const { entries: posts, error } = await getEmDashCollection("posts", {
  orderBy: { published_at: "desc" },
});

if (error) {
  console.error("Failed to load posts:", error);
}

const contentPosts = await getCollection('blog', ({ data }) => !data.draft);
const fallbackPosts = contentPosts
  .map((entry) => ({
    slug: publicBlogSlug(entry),
    data: {
      title: entry.data.title,
      description: entry.data.description,
      publishedAt: entry.data.date,
      createdAt: entry.data.date,
      tags: entry.data.tags ?? [],
    },
  }))
  .sort((a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime());
const displayPosts = posts.length > 0 ? posts : fallbackPosts;

// Group posts by year
type Post = (typeof displayPosts)[number];
const postsByYear: Record<number, Post[]> = {};
displayPosts.forEach(post => {
  const date = post.data.publishedAt ?? post.data.createdAt;
  if (!date) return;
  const year = date.getFullYear();
  if (!postsByYear[year]) {
    postsByYear[year] = [];
  }
  postsByYear[year].push(post);
});

// Get sorted years (newest first)
const years = Object.keys(postsByYear)
  .map(Number)
  .sort((a, b) => b - a);
---

<Layout title="Blog - AutoMem" description="Articles about AI, memory systems, and open source development">
  <Navigation currentPath="/blog" />

  <main class="min-h-screen py-12 sm:py-20 px-4 sm:px-6 bg-lab-bg">
    <div class="max-w-4xl mx-auto">
      <!-- Header -->
      <div class="mb-12">
        <div class="comment-header">:: TRANSMISSION_LOG</div>
        <h1 class="text-4xl sm:text-5xl font-bold mb-4 tracking-tighter">
          <span class="text-lab-secondary">Blog</span>
        </h1>
        <p class="text-base sm:text-xl text-lab-muted font-mono border-l-4 border-lab-accent pl-4">
          Thoughts on AI, memory systems, and building in the open.
        </p>
      </div>

      <!-- Posts by Year -->
      {years.map(year => (
        <section class="mb-16">
          <h2 class="text-2xl sm:text-3xl font-bold mb-6 text-lab-text font-mono">{year}</h2>
          <div class="space-y-6">
            {postsByYear[year].map(post => {
              const date = post.data.publishedAt ?? post.data.createdAt;
              const slug = post.slug ?? post.id;
              return (
              <article class="group">
                <a
                  href={`/blog/${slug}`}
                  class="block bg-lab-surface rounded-lg p-4 sm:p-6 border-2 border-lab-text hover:translate-x-[-2px] hover:translate-y-[-2px] hover:shadow-hard transition-all active:translate-x-[0] active:translate-y-[0] active:shadow-none"
                >
                  <div class="flex items-start justify-between gap-3 sm:gap-4 min-w-0">
                    <div class="flex-1 min-w-0">
                      <h3 class="text-xl sm:text-2xl font-bold mb-2 text-lab-text group-hover:text-lab-accent-text transition break-words">
                        {post.data.title}
                      </h3>
                      {post.data.description && (
                        <p class="text-lab-muted mb-3 font-mono text-sm break-words">
                          {post.data.description}
                        </p>
                      )}
                      <div class="flex flex-wrap items-center gap-3 sm:gap-4 text-sm">
                        {date && (
                          <time class="text-lab-muted font-mono text-xs">
                            {date.toLocaleDateString('en-US', {
                              month: 'short',
                              day: 'numeric',
                              year: 'numeric'
                            })}
                          </time>
                        )}
                      </div>
                    </div>
                    <div class="text-lab-muted group-hover:text-lab-accent-text group-hover:translate-x-1 transition-all flex-shrink-0 font-mono mt-1">
                      →
                    </div>
                  </div>
                </a>
              </article>
              );
            })}
          </div>
        </section>
      ))}

      {displayPosts.length === 0 && (
        <div class="text-center py-12 bg-lab-surface rounded-lg border-2 border-lab-border">
          <p class="text-lab-muted text-lg font-mono">// No posts yet. Check back soon.</p>
        </div>
      )}
    </div>
  </main>
</Layout>
