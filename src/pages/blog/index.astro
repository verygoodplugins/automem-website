---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Navigation from '../../components/Navigation.astro';
import '../../styles/global.css';

// Get all blog posts
const allPosts = await getCollection('blog');

// Filter out drafts and sort by date (newest first)
const posts = allPosts
  .filter(post => !post.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

// Group posts by year
const postsByYear: Record<number, typeof posts> = {};
posts.forEach(post => {
  const year = post.data.date.getFullYear();
  if (!postsByYear[year]) {
    postsByYear[year] = [];
  }
  postsByYear[year].push(post);
});

// Get sorted years (newest first)
const years = Object.keys(postsByYear)
  .map(Number)
  .sort((a, b) => b - a);
---

<Layout title="Blog - AutoMem" description="Articles about AI, memory systems, and open source development">
  <Navigation currentPath="/blog" />

  <main class="min-h-screen py-20 px-6 bg-lab-bg">
    <div class="max-w-4xl mx-auto">
      <!-- Header -->
      <div class="mb-12">
        <div class="comment-header">:: TRANSMISSION_LOG</div>
        <h1 class="text-5xl font-bold mb-4 tracking-tighter">
          <span class="text-lab-secondary">Blog</span>
        </h1>
        <p class="text-xl text-lab-muted font-mono border-l-4 border-lab-accent pl-4">
          Thoughts on AI, memory systems, and building in the open.
        </p>
      </div>

      <!-- Posts by Year -->
      {years.map(year => (
        <section class="mb-16">
          <h2 class="text-3xl font-bold mb-6 text-lab-text font-mono">{year}</h2>
          <div class="space-y-6">
            {postsByYear[year].map(post => (
              <article class="group">
                <a
                  href={`/blog/${post.slug}`}
                  class="block bg-lab-surface rounded-lg p-6 border-2 border-lab-text hover:translate-x-[-2px] hover:translate-y-[-2px] hover:shadow-hard transition-all active:translate-x-[0] active:translate-y-[0] active:shadow-none"
                >
                  <div class="flex items-start justify-between gap-4">
                    <div class="flex-1">
                      <h3 class="text-2xl font-bold mb-2 text-lab-text group-hover:text-lab-accent transition">
                        {post.data.title}
                      </h3>
                      <p class="text-lab-muted mb-3 font-mono text-sm">
                        {post.data.description}
                      </p>
                      <div class="flex items-center gap-4 text-sm">
                        <time class="text-lab-muted font-mono text-xs">
                          {post.data.date.toLocaleDateString('en-US', {
                            month: 'short',
                            day: 'numeric',
                            year: 'numeric'
                          })}
                        </time>
                        {post.data.tags && post.data.tags.length > 0 && (
                          <div class="flex gap-2">
                            {post.data.tags.map(tag => (
                              <span class="px-2 py-0.5 bg-lab-secondary/20 text-lab-secondary border border-lab-secondary/30 text-xs font-bold uppercase">
                                {tag}
                              </span>
                            ))}
                          </div>
                        )}
                      </div>
                    </div>
                    <div class="text-lab-muted group-hover:text-lab-accent group-hover:translate-x-1 transition-all flex-shrink-0 font-mono">
                      →
                    </div>
                  </div>
                </a>
              </article>
            ))}
          </div>
        </section>
      ))}

      {posts.length === 0 && (
        <div class="text-center py-12 bg-lab-surface rounded-lg border-2 border-lab-border">
          <p class="text-lab-muted text-lg font-mono">// No posts yet. Check back soon.</p>
        </div>
      )}
    </div>
  </main>
</Layout>
