---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Navigation from '../../components/Navigation.astro';
import AuthorBio from '../../components/AuthorBio.astro';
import BlogPostingSchema from '../../components/schemas/BlogPostingSchema.astro';
import SEOMeta from '../../components/SEOMeta.astro';
import '../../styles/global.css';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map(post => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();

const formattedDate = post.data.date.toLocaleDateString('en-US', {
  month: 'long',
  day: 'numeric',
  year: 'numeric'
});
---

<Layout title={`${post.data.title} - AutoMem Blog`} description={post.data.description}>
  <SEOMeta
    title={`${post.data.title} - AutoMem Blog`}
    description={post.data.description}
    url={`/blog/${post.slug}`}
    type="article"
    publishedTime={post.data.date.toISOString()}
    tags={post.data.tags}
  />
  <BlogPostingSchema
    title={post.data.title}
    description={post.data.description}
    datePublished={post.data.date}
    slug={post.slug}
    tags={post.data.tags}
  />
  <Navigation currentPath="/blog" />

  <main class="min-h-screen py-20 px-6 bg-core-bg">
    <article class="max-w-3xl mx-auto">
      <!-- Back to Blog -->
      <a
        href="/blog"
        class="inline-flex items-center gap-2 text-core-muted hover:text-core-accent transition mb-8 font-mono text-sm"
      >
        ← Back to Blog
      </a>

      <!-- Post Header -->
      <header class="mb-12 bg-white p-8 rounded-lg border-2 border-core-text shadow-hard">
        <div class="comment-header mb-4">:: POST_CONTENT</div>
        <h1 class="text-4xl md:text-5xl font-bold mb-4 text-core-text tracking-tighter leading-tight">
          {post.data.title}
        </h1>
        <p class="text-xl text-core-muted mb-6 font-mono border-l-4 border-core-accent pl-4">
          {post.data.description}
        </p>
        <div class="flex flex-wrap items-center gap-4 text-sm">
          <time class="text-core-muted font-mono bg-core-bg px-2 py-1 border border-core-line">
            {formattedDate}
          </time>
          {post.data.tags && post.data.tags.length > 0 && (
            <div class="flex gap-2">
              {post.data.tags.map(tag => (
                <span class="px-2 py-1 bg-core-secondary/20 text-core-secondary border border-core-secondary/30 text-xs font-bold uppercase">
                  {tag}
                </span>
              ))}
            </div>
          )}
        </div>
      </header>

      <!-- Post Content -->
      <div class="prose prose-lg max-w-none bg-white p-8 rounded-lg border-2 border-core-text">
        <Content />
      </div>

      <!-- Author Bio -->
      <AuthorBio />

      <!-- Footer -->
      <footer class="mt-16 pt-8 border-t-2 border-core-line">
        <div class="flex items-center justify-between font-mono text-sm">
          <a
            href="/blog"
            class="text-core-accent hover:underline"
          >
            ← All Posts
          </a>
          <a
            href="/"
            class="text-core-accent hover:underline"
          >
            Return Home →
          </a>
        </div>
      </footer>
    </article>
  </main>
</Layout>

<style>
  /* Prose styling for blog content - Memory Lab theme */
  .prose {
    @apply text-core-text font-mono text-base leading-relaxed;
  }

  .prose :global(h2) {
    @apply text-core-text text-2xl font-bold mt-10 mb-4 pb-2 border-b-2 border-core-line;
  }

  .prose :global(h3) {
    @apply text-core-text text-xl font-bold mt-8 mb-3;
  }

  .prose :global(p) {
    @apply mb-6 text-core-text/80;
  }

  .prose :global(a) {
    @apply text-core-accent underline decoration-core-accent/30 hover:decoration-core-accent transition-all;
  }

  .prose :global(ul),
  .prose :global(ol) {
    @apply mb-6 pl-6 text-core-text/80;
  }

  .prose :global(li) {
    @apply mb-2;
  }

  .prose :global(strong) {
    @apply text-core-text font-bold;
  }

  .prose :global(code) {
    @apply bg-core-bg px-1.5 py-0.5 text-sm border border-core-line text-core-accent;
  }

  .prose :global(pre) {
    @apply bg-core-text text-white p-4 rounded-lg overflow-x-auto mb-6 border-2 border-core-text shadow-hard;
  }

  .prose :global(pre code) {
    @apply bg-transparent p-0 border-none text-white;
  }

  .prose :global(blockquote) {
    @apply border-l-4 border-core-accent pl-4 ml-0 mb-6 italic text-core-muted bg-core-bg p-4 rounded-r-lg;
  }
</style>
