---
export const prerender = true;
import Layout from '../layouts/Layout.astro';
import Navigation from '../components/Navigation.astro';
import OrganizationSchema from '../components/schemas/OrganizationSchema.astro';

const GITHUB_URL = 'https://github.com/verygoodplugins/automem';
---

<Layout title="About">
  <OrganizationSchema />
  <Navigation currentPath="/about" />

  <main class="min-h-screen py-20 px-6 bg-lab-bg relative overflow-hidden">
    <div class="max-w-4xl mx-auto relative z-10">
      <!-- Header -->
      <div class="mb-16">
        <div class="comment-header">:: SYSTEM_IDENTITY</div>
        <div class="flex items-center gap-8 mb-8">
          <div class="relative">
            <div class="absolute inset-0 bg-lab-accent/20 translate-x-2 translate-y-2 rounded-full"></div>
            <img 
              src="/jack-arturo.jpeg" 
              alt="Jack Arturo" 
              class="w-48 h-48 rounded-full object-cover border-2 border-lab-text shadow-hard relative z-10 bg-lab-surface"
            />
          </div>
          <div>
            <h1 class="text-4xl md:text-6xl font-bold tracking-tighter mb-4">
              About <span class="text-lab-secondary">AutoMem</span>
            </h1>
            <p class="text-xl text-lab-muted leading-relaxed font-mono border-l-4 border-lab-accent pl-4">
              Building the memory layer for the AI age.
            </p>
          </div>
        </div>

        <!-- Bio Card -->
        <div class="bg-lab-surface rounded-lg p-8 border-2 border-lab-text shadow-hard relative group hover:translate-y-[-2px] transition-transform">
          <div class="absolute -top-3 left-6 bg-lab-text text-lab-bg px-2 text-xs font-bold uppercase">Builder_Log</div>
          
          <div class="prose prose-lg max-w-none space-y-6 text-lab-text font-mono text-sm md:text-base">
            <p>
              Jack is a developer, serial entrepreneur, and passionate advocate for open source software (he releases free tools for fun). He's the founder of <a href="https://verygoodplugins.com?utm_source=automem.ai&utm_medium=about&utm_campaign=bio" target="_blank" class="text-lab-accent hover:underline font-bold">Very Good Plugins</a>, creator of <a href="https://wpfusion.com?utm_source=automem.ai&utm_medium=about&utm_campaign=bio" target="_blank" class="text-lab-accent hover:underline font-bold">WP Fusion</a> and <a href="https://wordpress.org/plugins/jetstash-connect/" target="_blank" class="text-lab-accent hover:underline font-bold">Fatal Error Notify</a>, co-founder of <a href="https://echodash.com?utm_source=automem.ai&utm_medium=about&utm_campaign=bio" target="_blank" class="text-lab-accent hover:underline font-bold">EchoDash</a>, and creator of AutoMem. Jack lives in Berlin with his cat, Kitty Rick.
            </p>
            <p class="border-l-2 border-lab-text pl-4 italic text-lab-muted">
              AutoMem grew out of that work. When I started giving AI assistants memory capabilities, I realized this shouldn't be proprietary technology locked behind walls. Everyone deserves AI that remembers.
            </p>
          </div>
        </div>
      </div>

      <!-- Philosophy Section -->
      <div class="mb-16">
        <div class="bg-lab-surface text-lab-text rounded-lg p-8 border-2 border-lab-text shadow-hard relative overflow-hidden">
          <!-- Grid texture overlay -->
          <div class="absolute inset-0 bg-[radial-gradient(rgba(255,255,255,0.05)_1px,transparent_1px)] [background-size:16px_16px] opacity-50 pointer-events-none"></div>
          
          <div class="relative z-10">
            <h2 class="text-3xl font-bold mb-6 text-lab-secondary">Why Open Source?</h2>
            <div class="space-y-6 font-mono">
              <p>
                I believe in giving good stuff away. Not because it's trendy, but because <strong class="text-lab-accent">better tools make better builders</strong>.
              </p>
              <p>
                When we share our foundational blocks, we all build higher. I've benefited from open source my entire career; AutoMem is my contribution back to that stack.
              </p>
              
              <div class="bg-lab-bg/50 p-6 rounded border border-lab-border my-8">
                <h3 class="text-lg font-bold mb-4 text-lab-secondary uppercase tracking-widest">:: The Multiplier Effect</h3>
                <ul class="space-y-4 text-sm">
                  <li class="flex items-start gap-3">
                    <span class="text-lab-accent text-xl">→</span>
                    <span>If I build it alone, it solves my problem.</span>
                  </li>
                  <li class="flex items-start gap-3">
                    <span class="text-lab-accent text-xl">→</span>
                    <span>If we build it together, it solves problems I haven't even imagined yet.</span>
                  </li>
                  <li class="flex items-start gap-3">
                    <span class="text-lab-accent text-xl">→</span>
                    <span>Proprietary memory locks you in. Open memory sets you free.</span>
                  </li>
                </ul>
              </div>

              <p>
                The future of AI shouldn't be controlled by a handful of companies. <strong class="text-lab-accent">Your memories should belong to you.</strong>
              </p>
              <p class="text-lg font-bold text-lab-secondary mt-8 border-t border-lab-border pt-6">
                // Recall is Power.
              </p>
            </div>
          </div>
        </div>
      </div>

      <!-- Connect Links -->
      <div>
        <div class="comment-header">:: NETWORK_UPLINK</div>
        <div class="grid md:grid-cols-2 gap-6">
          <!-- GitHub -->
          <a href="https://github.com/verygoodplugins/automem" target="_blank" class="group flex items-center gap-4 p-4 bg-lab-bg rounded-lg border-2 border-lab-text hover:translate-x-[-2px] hover:translate-y-[-2px] hover:shadow-hard transition-all active:translate-x-[0] active:translate-y-[0] active:shadow-none">
            <div class="w-12 h-12 bg-lab-text text-lab-bg rounded-lg flex items-center justify-center text-xl font-mono">GH</div>
            <div>
              <h3 class="font-bold text-lab-text">AutoMem on GitHub</h3>
              <p class="text-xs text-lab-muted uppercase tracking-wider">Contribute</p>
            </div>
          </a>

          <!-- Personal Blog -->
          <a href="https://drunk.support?utm_source=automem.ai&utm_medium=about&utm_campaign=network" target="_blank" class="group flex items-center gap-4 p-4 bg-lab-bg rounded-lg border-2 border-lab-text hover:translate-x-[-2px] hover:translate-y-[-2px] hover:shadow-hard transition-all active:translate-x-[0] active:translate-y-[0] active:shadow-none">
            <div class="w-12 h-12 bg-lab-secondary text-lab-bg rounded-lg flex items-center justify-center text-xl font-mono">DS</div>
            <div>
              <h3 class="font-bold text-lab-text">Personal Blog</h3>
              <p class="text-xs text-lab-muted uppercase tracking-wider">Read Articles</p>
            </div>
          </a>

          <!-- VGP -->
          <a href="https://verygoodplugins.com?utm_source=automem.ai&utm_medium=about&utm_campaign=network" target="_blank" class="group flex items-center gap-4 p-4 bg-lab-bg rounded-lg border-2 border-lab-text hover:translate-x-[-2px] hover:translate-y-[-2px] hover:shadow-hard transition-all active:translate-x-[0] active:translate-y-[0] active:shadow-none">
            <div class="w-12 h-12 bg-lab-accent text-lab-bg rounded-lg flex items-center justify-center text-xl font-mono">VP</div>
            <div>
              <h3 class="font-bold text-lab-text">Very Good Plugins</h3>
              <p class="text-xs text-lab-muted uppercase tracking-wider">Company</p>
            </div>
          </a>

          <!-- $AUTOMEM Token -->
          <a href="https://bags.fm/CV485ySXfgFiwLtbh815JRukH4r9ChLhddqsAaZKBAGS" target="_blank" rel="noopener" class="group flex items-center gap-4 p-4 bg-lab-bg rounded-lg border-2 border-lab-text hover:translate-x-[-2px] hover:translate-y-[-2px] hover:shadow-hard transition-all active:translate-x-[0] active:translate-y-[0] active:shadow-none">
            <div class="w-12 h-12 bg-gradient-to-br from-purple-500 to-pink-500 text-lab-bg rounded-lg flex items-center justify-center text-xl font-mono">$A</div>
            <div>
              <h3 class="font-bold text-lab-text">$AUTOMEM on bags.fm</h3>
              <p class="text-xs text-lab-muted uppercase tracking-wider">Buy the Bag</p>
            </div>
          </a>
        </div>
      </div>

      <div class="mt-16">
        <a href="/" class="inline-flex items-center gap-2 text-lab-muted hover:text-lab-accent transition font-mono">
          ← RETURN_ROOT
        </a>
      </div>

    </div>
  </main>
</Layout>