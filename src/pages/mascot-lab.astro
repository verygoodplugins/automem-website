---
export const prerender = true;
import Layout from '../layouts/Layout.astro';
import AutoJack from '../components/AutoJack.astro';
import AutoJackDrive from '../components/AutoJackDrive.astro';
---

<Layout title="Mascot Lab - AutoJack">
  <div class="p-12 min-h-screen relative">
    <div class="max-w-6xl mx-auto">
        <div class="comment-header">:: IDENTITY_LAB_v2.0</div>
        <h1 class="text-5xl font-bold mb-4">Project: <span class="text-lab-secondary">AUTOJACK</span></h1>
        <p class="text-lab-muted mb-12 max-w-2xl">The gold floppy disk mascot for AutoMem. Designed to be confident, helpful, and delightful.</p>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-12 mb-16">
            
            <!-- Expression 1: Confident (Default) -->
            <div class="space-y-4">
                <div class="bg-lab-surface border border-lab-border p-8 rounded-xl flex items-center justify-center h-64 group hover:border-lab-accent transition-colors relative overflow-hidden">
                    <div class="absolute inset-0 bg-[radial-gradient(#333_1px,transparent_1px)] [background-size:16px_16px] opacity-20"></div>
                    <AutoJack size={140} expression="confident" animate={true} />
                </div>
                <h3 class="text-xl font-mono text-lab-muted">:: CONFIDENT</h3>
                <p class="text-sm text-lab-muted">Default resting state. Ready to help.</p>
            </div>

            <!-- Expression 2: Wink -->
            <div class="space-y-4">
                <div class="bg-lab-surface border border-lab-border p-8 rounded-xl flex items-center justify-center h-64 group hover:border-lab-secondary transition-colors relative overflow-hidden">
                    <div class="absolute inset-0 bg-[radial-gradient(#333_1px,transparent_1px)] [background-size:16px_16px] opacity-20"></div>
                    <AutoJack size={140} expression="wink" animate={true} />
                </div>
                <h3 class="text-xl font-mono text-lab-muted">:: WINK</h3>
                <p class="text-sm text-lab-muted">Playful moments. Tips and tricks.</p>
            </div>

            <!-- Expression 3: Happy -->
            <div class="space-y-4">
                <div class="bg-lab-surface border border-lab-border p-8 rounded-xl flex items-center justify-center h-64 group hover:border-lab-success transition-colors relative overflow-hidden">
                    <div class="absolute inset-0 bg-[radial-gradient(#333_1px,transparent_1px)] [background-size:16px_16px] opacity-20"></div>
                    <AutoJack size={140} expression="happy" animate={true} />
                </div>
                <h3 class="text-xl font-mono text-lab-muted">:: HAPPY</h3>
                <p class="text-sm text-lab-muted">Celebrations and achievements.</p>
            </div>

            <!-- Expression 4: Bliss -->
            <div class="space-y-4">
                <div class="bg-lab-surface border border-lab-border p-8 rounded-xl flex items-center justify-center h-64 group hover:border-lab-accent transition-colors relative overflow-hidden">
                    <div class="absolute inset-0 bg-[radial-gradient(#333_1px,transparent_1px)] [background-size:16px_16px] opacity-20"></div>
                    <AutoJack size={140} expression="bliss" animate={true} />
                </div>
                <h3 class="text-xl font-mono text-lab-muted">:: BLISS</h3>
                <p class="text-sm text-lab-muted">Memory loaded. Peak moments.</p>
            </div>

            <!-- Expression 5: Sleeping -->
            <div class="space-y-4">
                <div class="bg-lab-surface border border-lab-border p-8 rounded-xl flex items-center justify-center h-64 group hover:border-lab-muted transition-colors relative overflow-hidden">
                    <div class="absolute inset-0 bg-[radial-gradient(#333_1px,transparent_1px)] [background-size:16px_16px] opacity-20"></div>
                    <AutoJack size={140} expression="sleeping" animate={false} />
                </div>
                <h3 class="text-xl font-mono text-lab-muted">:: SLEEPING</h3>
                <p class="text-sm text-lab-muted">Powered down. Inactive state.</p>
            </div>

            <!-- Expression 6: Focused -->
            <div class="space-y-4">
                <div class="bg-lab-surface border border-lab-border p-8 rounded-xl flex items-center justify-center h-64 group hover:border-lab-secondary transition-colors relative overflow-hidden">
                    <div class="absolute inset-0 bg-[radial-gradient(#333_1px,transparent_1px)] [background-size:16px_16px] opacity-20"></div>
                    <AutoJack size={140} expression="focused" animate={true} />
                </div>
                <h3 class="text-xl font-mono text-lab-muted">:: FOCUSED</h3>
                <p class="text-sm text-lab-muted">Processing. Deep thought.</p>
            </div>

        </div>

        <!-- Drive Animation Section -->
        <div class="border-t border-lab-border pt-16">
          <div class="comment-header">:: MEMORY_DRIVE_ANIMATION</div>
          <h2 class="text-3xl font-bold mb-4">The Memory Loading Sequence</h2>
          <p class="text-lab-muted mb-12 max-w-2xl">Watch AutoJack insert into the drive, load memories, and return with a smile. Click to replay.</p>
          
          <div class="flex justify-center">
            <AutoJackDrive size={280} autoPlay={false} />
          </div>
        </div>

        <!-- Size Reference -->
        <div class="border-t border-lab-border pt-16 mt-16">
          <div class="comment-header">:: SIZE_REFERENCE</div>
          <h2 class="text-3xl font-bold mb-8">Size Guidelines</h2>
          
          <div class="flex flex-wrap items-end gap-8">
            <div class="text-center">
              <AutoJack size={24} expression="confident" animate={false} />
              <p class="text-xs text-lab-muted mt-2">24px</p>
              <p class="text-xs text-lab-muted">Complication</p>
            </div>
            <div class="text-center">
              <AutoJack size={32} expression="confident" animate={false} />
              <p class="text-xs text-lab-muted mt-2">32px</p>
              <p class="text-xs text-lab-muted">Nav Icon</p>
            </div>
            <div class="text-center">
              <AutoJack size={40} expression="confident" animate={false} />
              <p class="text-xs text-lab-muted mt-2">40px</p>
              <p class="text-xs text-lab-muted">Inline</p>
            </div>
            <div class="text-center">
              <AutoJack size={80} expression="confident" animate={true} />
              <p class="text-xs text-lab-muted mt-2">80px</p>
              <p class="text-xs text-lab-muted">Cards</p>
            </div>
            <div class="text-center">
              <AutoJack size={120} expression="confident" animate={true} />
              <p class="text-xs text-lab-muted mt-2">120px</p>
              <p class="text-xs text-lab-muted">Feature</p>
            </div>
            <div class="text-center">
              <AutoJack size={200} expression="confident" animate={true} />
              <p class="text-xs text-lab-muted mt-2">200px</p>
              <p class="text-xs text-lab-muted">Hero</p>
            </div>
          </div>
        </div>

        <!-- Color Palette -->
        <div class="border-t border-lab-border pt-16 mt-16">
          <div class="comment-header">:: COLOR_TOKENS</div>
          <h2 class="text-3xl font-bold mb-8">Brand Colors</h2>
          
          <div class="grid grid-cols-2 md:grid-cols-6 gap-4">
            <div class="space-y-2">
              <div class="w-full h-20 rounded-lg shadow-hard" style="background: #D4A425;"></div>
              <p class="text-sm font-mono">Gold Primary</p>
              <p class="text-xs text-lab-muted">#D4A425</p>
            </div>
            <div class="space-y-2">
              <div class="w-full h-20 rounded-lg shadow-hard" style="background: #B8860B;"></div>
              <p class="text-sm font-mono">Gold Secondary</p>
              <p class="text-xs text-lab-muted">#B8860B</p>
            </div>
            <div class="space-y-2">
              <div class="w-full h-20 rounded-lg shadow-hard" style="background: #e5e5e5;"></div>
              <p class="text-sm font-mono">Metal</p>
              <p class="text-xs text-lab-muted">#E5E5E5</p>
            </div>
            <div class="space-y-2">
              <div class="w-full h-20 rounded-lg shadow-hard" style="background: #1a1a1a;"></div>
              <p class="text-sm font-mono">Stroke</p>
              <p class="text-xs text-lab-muted">#1A1A1A</p>
            </div>
            <div class="space-y-2">
              <div class="w-full h-20 rounded-lg shadow-hard" style="background: #34D399;"></div>
              <p class="text-sm font-mono">Drive Green</p>
              <p class="text-xs text-lab-muted">#34D399</p>
            </div>
            <div class="space-y-2">
              <div class="w-full h-20 rounded-lg shadow-hard" style="background: #ff9999;"></div>
              <p class="text-sm font-mono">Blush</p>
              <p class="text-xs text-lab-muted">#FF9999</p>
            </div>
          </div>
        </div>

    </div>
  </div>
</Layout>
