graph TB
    ERROR["Error Occurs"]
    
    ERROR --> CHECK_TYPE{"Error Type"}
    
    CHECK_TYPE -->|"Network Error"| NETWORK["Network Exception"]
    CHECK_TYPE -->|"Parse Error"| PARSE["JSON Parse Failed"]
    CHECK_TYPE -->|"HTTP Error"| HTTP["HTTP Status != 2xx"]
    
    NETWORK --> CHECK_RETRY_NET{"retryCount < 3"}
    CHECK_RETRY_NET -->|"Yes"| RETRY_NET["Exponential backoff<br/>Recursive call"]
    CHECK_RETRY_NET -->|"No"| THROW_NET["Throw Error"]
    
    PARSE --> THROW_PARSE["Throw: Invalid JSON response"]
    
    HTTP --> CHECK_CODE{"Status Code"}
    CHECK_CODE -->|"5xx"| CHECK_RETRY_5XX{"retryCount < 3"}
    CHECK_CODE -->|"4xx"| THROW_4XX["Throw immediately<br/>(add auth hint for 401/403)"]
    
    CHECK_RETRY_5XX -->|"Yes"| RETRY_5XX["Exponential backoff<br/>Recursive call"]
    CHECK_RETRY_5XX -->|"No"| THROW_5XX["Throw Error"]