graph TB
    subgraph "Development (Local)"
        DEV["Developer commits"]
        HUSKY["Husky pre-commit hook"]
        COMMITLINT["commitlint validation"]
    end
    
    subgraph "GitHub Triggers"
        PR["Pull Request to main"]
        PUSH["Push to main"]
        SCHEDULE["Weekly cron schedule"]
        MANUAL["workflow_dispatch"]
    end
    
    subgraph "CI Workflow (.github/workflows/ci.yml)"
        LINKS["Job: links<br/>Check documentation links"]
        TEST["Job: test<br/>Lint, build, test, coverage"]
    end
    
    subgraph "Security Workflow (.github/workflows/security.yml)"
        CODEQL["Job: codeql<br/>CodeQL static analysis"]
        AUDIT["Job: audit<br/>npm audit + better-npm-audit"]
    end
    
    subgraph "Release Please Workflow (.github/workflows/release-please.yml)"
        RP["Job: release-please<br/>Version bump, changelog, release PR"]
        NPM["Job: npm-publish<br/>Publish to npm registry"]
        MCPB["Job: build-extension<br/>Build and upload .mcpb"]
    end
    
    DEV --> HUSKY
    HUSKY --> COMMITLINT
    COMMITLINT --> PR
    
    PR --> LINKS
    PR --> TEST
    PR --> CODEQL
    PR --> AUDIT
    
    PUSH --> LINKS
    PUSH --> TEST
    PUSH --> CODEQL
    PUSH --> AUDIT
    PUSH --> RP
    
    SCHEDULE --> CODEQL
    SCHEDULE --> AUDIT
    
    MANUAL --> CODEQL
    MANUAL --> AUDIT
    
    RP -->|"if release_created"| NPM
    RP -->|"if release_created"| MCPB