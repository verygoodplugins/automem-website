graph TB
    WIZARD["Setup wizard<br/>has endpoint + key"]
    WIZARD --> CREATE["Create config object<br/>{ endpoint, apiKey }"]
    CREATE --> CLIENT["new AutoMemClient(config)<br/>src/automem-client.ts"]
    
    CLIENT --> HEALTH["client.checkHealth()"]
    HEALTH --> HTTP["HTTP GET<br/>{endpoint}/health"]
    
    HTTP --> RESPONSE{HTTP<br/>Status}
    
    RESPONSE -->|200 OK| PARSE["Parse JSON response"]
    RESPONSE -->|4xx/5xx| ERROR_HTTP["Network/Auth error"]
    RESPONSE -->|Timeout| ERROR_TIMEOUT["Connection timeout"]
    
    PARSE --> CHECK_STATUS{response.status}
    
    CHECK_STATUS -->|"healthy"| SUCCESS_HEALTHY["✓ Connection successful!<br/>Status: healthy<br/>Backend: automem"]
    CHECK_STATUS -->|"error"| SUCCESS_DEGRADED["⚠️ Service degraded<br/>Show error details"]
    
    ERROR_HTTP --> FAIL["❌ Setup failed<br/>Check endpoint and key"]
    ERROR_TIMEOUT --> FAIL
    
    SUCCESS_HEALTHY --> CONTINUE["Continue to<br/>config snippet generation"]
    SUCCESS_DEGRADED --> CONTINUE
    FAIL --> ABORT["Exit with error<br/>No .env written"]
    
    style CLIENT fill:#f9f9f9
    style SUCCESS_HEALTHY fill:#f9f9f9
    style SUCCESS_DEGRADED fill:#f9f9f9
    style FAIL fill:#f9f9f9