flowchart TD
    Start["Memory needs removal?"]
    Start --> Reason{"Why delete?"}
    
    Reason -->|"Incorrect info<br/>can't correct"| CheckUpdate{"Can update<br/>fix it?"}
    CheckUpdate -->|Yes| Update["Use update_memory<br/>instead"]
    CheckUpdate -->|No| Delete["Use delete_memory"]
    
    Reason -->|"Duplicate<br/>memory"| CheckDup{"Which to<br/>keep?"}
    CheckDup -->|"Keep newer"| Delete
    CheckDup -->|"Keep more complete"| Delete
    
    Reason -->|"Sensitive<br/>information"| Delete
    
    Reason -->|"No longer<br/>relevant"| CheckAge{"How old?"}
    CheckAge -->|"Recent"| Lower["Lower importance<br/>with update_memory"]
    CheckAge -->|"Very old"| Delete
    
    Reason -->|"Clutters<br/>recall"| CheckFilter{"Can tag<br/>filtering help?"}
    CheckFilter -->|Yes| Tag["Use better tags<br/>in queries"]
    CheckFilter -->|No| Delete
    
    Update --> End["Memory preserved<br/>and corrected"]
    Delete --> Warn["⚠️ Permanent removal<br/>edges also deleted"]
    Lower --> End2["Memory downranked<br/>in future recalls"]
    Tag --> End3["Query tuning<br/>reduces noise"]
    
    Warn --> Confirm{"Really<br/>delete?"}
    Confirm -->|Yes| Execute["Execute deletion"]
    Confirm -->|No| Cancel["Cancel operation"]
    
    Execute --> Final["✓ Memory removed"]
    Cancel --> Final2["Memory unchanged"]