graph TB
    subgraph "Local MCP (Stdio Transport)"
        CD[Claude Desktop]
        CURSOR[Cursor IDE]
        CODE[Claude Code]
        
        LOCAL_SERVER["src/index.ts<br/>MCP Server<br/>(stdio)"]
        
        CD -->|"stdin/stdout"| LOCAL_SERVER
        CURSOR -->|"stdin/stdout"| LOCAL_SERVER
        CODE -->|"stdin/stdout"| LOCAL_SERVER
        
        LOCAL_SERVER -->|"HTTP"| AUTOMEM_LOCAL["AutoMem API<br/>:8001"]
    end
    
    subgraph "Remote MCP (HTTP/SSE Transport)"
        CGP[ChatGPT<br/>Developer Mode]
        CW[Claude.ai<br/>Web]
        CM[Claude Mobile<br/>iOS/Android]
        EL[ElevenLabs<br/>Agents]
        
        SIDECAR["MCP Sidecar<br/>(separate deployment)<br/>POST /mcp<br/>GET /mcp/sse"]
        
        CGP -->|"HTTP POST"| SIDECAR
        CW -->|"SSE GET"| SIDECAR
        CM -->|"SSE GET"| SIDECAR
        EL -->|"HTTP POST"| SIDECAR
        
        SIDECAR -->|"HTTP"| AUTOMEM_REMOTE["AutoMem API<br/>:8001"]
    end
    
    style LOCAL_SERVER fill:#f9f9f9
    style SIDECAR fill:#f9f9f9