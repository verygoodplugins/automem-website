sequenceDiagram
    participant App as "Your Application"
    participant Client as "AutoMemClient"
    participant Retry as "Retry Logic"
    participant API as "AutoMem API"
    
    App->>Client: storeMemory({content, tags, importance})
    Client->>Client: Construct MemoryRecord body
    Client->>Retry: makeRequest('POST', 'memory', body, 0)
    
    Retry->>API: POST /memory with Authorization header
    
    alt Success (200 OK)
        API-->>Retry: {memory_id, message}
        Retry-->>Client: response
        Client-->>App: {memory_id, message}
    else Network Error (retryable)
        API--xRetry: Connection refused
        Retry->>Retry: Wait 500ms (attempt 1/3)
        Retry->>API: POST /memory (retry)
        API-->>Retry: {memory_id, message}
        Retry-->>Client: response
        Client-->>App: {memory_id, message}
    else 5xx Error (retryable)
        API-->>Retry: 503 Service Unavailable
        Retry->>Retry: Wait 1000ms (attempt 2/3)
        Retry->>API: POST /memory (retry)
        API-->>Retry: 200 OK
        Retry-->>Client: response
        Client-->>App: {memory_id, message}
    else 4xx Error (not retryable)
        API-->>Retry: 401 Unauthorized
        Retry->>Retry: Format error with auth hint
        Retry--xClient: throw Error("check AUTOMEM_API_KEY")
        Client--xApp: Error propagated
    end