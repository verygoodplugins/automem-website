sequenceDiagram
    participant CD as "Claude Desktop"
    participant NPX as "npx process"
    participant SERVER as "MCP Server<br/>src/index.ts"
    participant STDIO as "StdioServerTransport"
    
    CD->>NPX: Spawn with env vars
    NPX->>SERVER: Load @verygoodplugins/mcp-automem
    SERVER->>SERVER: Detect mode (no CLI args)
    SERVER->>STDIO: new StdioServerTransport()
    STDIO->>STDIO: Attach stdin/stdout
    SERVER->>CD: Server capabilities<br/>(tools list)
    
    loop "Message Exchange"
        CD->>STDIO: JSON-RPC request
        STDIO->>SERVER: Parse and route
        SERVER->>CD: JSON-RPC response
    end