sequenceDiagram
    participant UI as "Claude Desktop UI"
    participant MCP as "MCP Client"
    participant TOOL as "recall_memory handler<br/>src/index.ts"
    participant CLIENT as "AutoMemClient<br/>src/automem-client.ts"
    participant API as "AutoMem API"
    
    UI->>MCP: Conversation starts
    MCP->>MCP: Custom instructions<br/>trigger recall
    MCP->>TOOL: Call recall_memory<br/>{query, tags, limit}
    TOOL->>CLIENT: recallMemory()
    
    alt "Tags Present"
        CLIENT->>API: Parallel queries<br/>GET /recall + /memory/by-tag
        API-->>CLIENT: Merged results
    else "No Tags"
        CLIENT->>API: GET /recall
        API-->>CLIENT: Results
    end
    
    CLIENT->>CLIENT: Sort by final_score
    CLIENT-->>TOOL: RecallResult[]
    TOOL-->>MCP: Formatted results
    MCP-->>UI: Integrate into response