graph TB
    START["User runs<br/>npx mcp-automem setup"]
    START --> ENTRY["src/index.ts:209<br/>command === 'setup'"]
    ENTRY --> IMPORT["Import runSetup<br/>from src/cli/setup.js"]
    IMPORT --> WIZARD["runSetup(argv)"]
    
    WIZARD --> PROMPT1["Prompt:<br/>AUTOMEM_ENDPOINT"]
    PROMPT1 --> PROMPT2["Prompt:<br/>AUTOMEM_API_KEY<br/>(optional)"]
    PROMPT2 --> DOTENV["Write to .env<br/>AUTOMEM_ENDPOINT=...<br/>AUTOMEM_API_KEY=..."]
    
    DOTENV --> CLIENT["Instantiate AutoMemClient<br/>src/automem-client.ts"]
    CLIENT --> HEALTH["Call client.checkHealth()"]
    HEALTH --> VALIDATE{Validation<br/>Result}
    
    VALIDATE -->|Success| SUCCESS["✓ Connection successful!"]
    VALIDATE -->|Error| ERROR["❌ Connection failed<br/>Show error details"]
    
    SUCCESS --> SNIPPETS["Generate config snippets<br/>for platforms"]
    SNIPPETS --> PRINT["Print to stdout:<br/>- Claude Desktop JSON<br/>- Cursor MCP config<br/>- Environment vars"]
    
    PRINT --> EXIT["Exit 0"]
    ERROR --> EXIT_ERR["Exit 1"]
    
    style WIZARD fill:#f9f9f9
    style CLIENT fill:#f9f9f9
    style SUCCESS fill:#f9f9f9
    style ERROR fill:#f9f9f9