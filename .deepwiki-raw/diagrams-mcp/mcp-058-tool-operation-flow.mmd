sequenceDiagram
    participant Platform as "AI Platform"
    participant MCP as "MCP Server<br/>(src/index.ts)"
    participant Client as "AutoMemClient<br/>(src/automem-client.ts)"
    participant API as "AutoMem API"
    
    Note over Platform,API: Tool Discovery
    Platform->>MCP: ListToolsRequest
    MCP->>Platform: tools array (6 tools)
    
    Note over Platform,API: Tool Invocation
    Platform->>MCP: CallToolRequest<br/>{name, arguments}
    MCP->>MCP: Switch on tool name<br/>(lines 882-1209)
    
    alt store_memory
        MCP->>MCP: Validate content size<br/>(SOFT_LIMIT=500, HARD_LIMIT=2000)
        MCP->>Client: storeMemory(args)
        Client->>API: POST /memory
        API-->>Client: {memory_id}
        Client-->>MCP: StoreResult
        MCP->>MCP: Build response + warnings
        MCP-->>Platform: Success + memory_id
    else recall_memory
        MCP->>MCP: Check if tags present
        alt Tags present
            par Parallel queries
                MCP->>Client: recallMemory(args)
                MCP->>Client: searchByTag(tags)
            end
            MCP->>MCP: Merge + deduplicate
        else No tags
            MCP->>Client: recallMemory(args)
        end
        Client->>API: GET /recall
        API-->>Client: RecallResult
        Client-->>MCP: Merged results
        MCP->>MCP: Format text output
        MCP-->>Platform: Results + metadata
    else Other tools
        MCP->>Client: Delegate to client method
        Client->>API: HTTP request
        API-->>Client: Response
        Client-->>MCP: Result
        MCP-->>Platform: Formatted response
    end