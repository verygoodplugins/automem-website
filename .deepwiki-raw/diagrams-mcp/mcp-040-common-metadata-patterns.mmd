graph TB
    subgraph "Metadata Patterns"
        FILES["files_modified: string[]<br/>Tracks changed files"]
        ERROR["error_signature: string<br/>Unique error identifier"]
        SOLUTION["solution_pattern: string<br/>Fix classification"]
        COMPONENT["component: string<br/>Affected component"]
        CONFIDENCE["confidence: number<br/>Type confidence (0-1)"]
        VALID["t_valid: string<br/>When memory becomes valid"]
        INVALID["t_invalid: string<br/>When memory expires"]
    end
    
    subgraph "Example: Bug Fix Metadata"
        EX1["files_modified: ['src/auth.ts']"]
        EX2["error_signature: 'TypeError: null'"]
        EX3["solution_pattern: 'null-check'"]
        EX4["component: 'auth'"]
        EX5["confidence: 0.95"]
    end
    
    FILES --> EX1
    ERROR --> EX2
    SOLUTION --> EX3
    COMPONENT --> EX4
    CONFIDENCE --> EX5