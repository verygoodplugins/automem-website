graph TB
    subgraph "Codex Execution Modes"
        CLI["Codex CLI<br/>Terminal commands"]
        IDE["Codex IDE Extension<br/>Editor integration"]
        CLOUD["Codex Cloud Agent<br/>chatgpt.com/codex"]
    end
    
    subgraph "Configuration Layer"
        TOML["~/.codex/config.toml<br/>MCP server definition"]
        AGENTS["AGENTS.md<br/>Memory rules template"]
        ENV["Environment Variables<br/>AUTOMEM_ENDPOINT<br/>AUTOMEM_API_KEY"]
    end
    
    subgraph "MCP Server Process"
        NPX["npx -y @verygoodplugins/mcp-automem<br/>or local build"]
        STDIO["StdioServerTransport<br/>stdin/stdout"]
        TOOLS["MCP Tools Registry<br/>store_memory<br/>recall_memory<br/>associate_memories"]
    end
    
    subgraph "Backend Service"
        CLIENT["AutoMemClient<br/>src/automem-client.ts"]
        API["AutoMem HTTP API<br/>:8001"]
    end
    
    CLI --> TOML
    IDE --> TOML
    CLOUD --> TOML
    
    TOML --> NPX
    AGENTS -.->|"Instructions"| CLI
    AGENTS -.->|"Instructions"| IDE
    AGENTS -.->|"Instructions"| CLOUD
    ENV -.->|"Read by"| NPX
    
    NPX --> STDIO
    STDIO --> TOOLS
    TOOLS --> CLIENT
    CLIENT --> API
    
    style TOML fill:#f9f9f9
    style AGENTS fill:#f9f9f9
    style NPX fill:#e8f4f8
    style CLIENT fill:#e8f4f8