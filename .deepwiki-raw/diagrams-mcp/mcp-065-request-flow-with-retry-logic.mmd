sequenceDiagram
    participant Caller as "API Method"
    participant MakeReq as "makeRequest()"
    participant Fetch as "node-fetch"
    participant API as "AutoMem API"
    
    Caller->>MakeReq: method, path, body
    MakeReq->>MakeReq: Build URL<br/>(normalize slashes)
    MakeReq->>MakeReq: Add headers<br/>(Content-Type, Authorization)
    MakeReq->>MakeReq: Set 25s timeout
    
    MakeReq->>Fetch: fetch(url, options)
    
    alt Network Error
        Fetch-->>MakeReq: Error
        MakeReq->>MakeReq: retryCount < 3?
        alt Yes
            MakeReq->>MakeReq: Wait 500ms * 2^retryCount
            MakeReq->>MakeReq: Recursive call (retryCount+1)
        else No
            MakeReq-->>Caller: Throw Error
        end
    else Success
        Fetch->>API: HTTP Request
        API-->>Fetch: HTTP Response
        Fetch-->>MakeReq: response
        
        MakeReq->>MakeReq: Parse JSON
        
        alt HTTP 5xx Error
            MakeReq->>MakeReq: retryCount < 3?
            alt Yes
                MakeReq->>MakeReq: Wait 500ms * 2^retryCount
                MakeReq->>MakeReq: Recursive call (retryCount+1)
            else No
                MakeReq-->>Caller: Throw Error
            end
        else HTTP 4xx Error
            MakeReq-->>Caller: Throw Error (no retry)
        else HTTP 2xx Success
            MakeReq-->>Caller: Return data
        end
    end