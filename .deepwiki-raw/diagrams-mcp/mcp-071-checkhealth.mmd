graph TB
    INPUT["No Arguments"]
    
    INPUT --> GET["GET /health"]
    GET --> CHECK{"Response status"}
    
    CHECK -->|"Success"| PARSE["Parse statistics:<br/>falkordb, qdrant,<br/>graph, timestamp"]
    CHECK -->|"Network/Parse Error"| CATCH["Catch Exception"]
    
    PARSE --> STATUS_CHECK{"status === 'healthy'"}
    STATUS_CHECK -->|"Yes"| HEALTHY["{status: 'healthy',<br/>backend: 'automem',<br/>statistics: {...}}"]
    STATUS_CHECK -->|"No"| UNHEALTHY["{status: 'error',<br/>backend: 'automem',<br/>statistics: {...},<br/>error: 'Service unhealthy'}"]
    
    CATCH --> ERROR["{status: 'error',<br/>backend: 'automem',<br/>statistics: {},<br/>error: error.message}"]