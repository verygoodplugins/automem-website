graph TB
    CLI["queue command"]
    PARSE["parseQueueArgs()"]
    EXISTS["Check queue file exists"]
    READ["Read JSONL file"]
    CONFIG["resolveAutoMemConfig()"]
    HEALTH["isEndpointHealthy()"]
    
    CLI --> PARSE
    PARSE --> EXISTS
    EXISTS -->|Not found| EXIT1["Exit: Nothing to do"]
    EXISTS -->|Found| READ
    READ -->|Empty| EXIT2["Exit: Queue empty"]
    READ -->|Has lines| CONFIG
    
    CONFIG --> HEALTH
    HEALTH -->|Unhealthy| EXIT3["Exit: Endpoint unavailable"]
    HEALTH -->|Healthy| LOOP["Process each line"]
    
    LOOP --> VALIDATE["Validate entry"]
    VALIDATE -->|Invalid| SKIP["Skip + increment skippedCount"]
    VALIDATE -->|Valid| DRYRUN{"--dry-run?"}
    
    DRYRUN -->|Yes| LOG["Log would-be operation"]
    DRYRUN -->|No| STORE["client.storeMemory()"]
    
    STORE -->|Success| ASSOC["Queue associations"]
    STORE -->|Failure| REMAIN["Add to remaining[]"]
    
    LOG --> NEXT["Next entry"]
    ASSOC --> NEXT
    SKIP --> NEXT
    REMAIN --> NEXT
    
    NEXT -->|More entries| LOOP
    NEXT -->|Done| PROCESS_ASSOC["Process associations"]
    
    PROCESS_ASSOC --> CLEANUP{"remaining.length == 0?"}
    CLEANUP -->|Yes| DELETE["Delete queue file"]
    CLEANUP -->|No| REWRITE["Rewrite queue with remaining"]
    
    DELETE --> SUMMARY["Log summary"]
    REWRITE --> SUMMARY