sequenceDiagram
    participant Platform as "AI Platform<br/>(Claude/Cursor/etc)"
    participant MCP as "MCP Server<br/>(src/index.ts)"
    participant Client as "AutoMemClient<br/>(src/automem-client.ts)"
    participant API as "AutoMem API<br/>(:8001)"
    participant FDB as "FalkorDB<br/>(Graph)"
    participant QDR as "Qdrant<br/>(Vectors)"
    
    Note over Platform,QDR: Store Memory Flow
    Platform->>MCP: "CallToolRequest<br/>{name: 'store_memory', arguments: {...}}"
    MCP->>MCP: "Validate content size<br/>(lines 886-914)"
    MCP->>Client: "client.storeMemory(args)"
    Client->>API: "POST /memory<br/>{content, tags, importance, ...}"
    par Parallel Writes
        API->>QDR: "Store 768-dim embedding"
        API->>FDB: "Create memory node + metadata"
    end
    API-->>Client: "{memory_id: '...'}"
    Client-->>MCP: "StoreMemoryResult"
    MCP-->>Platform: "{memory_id, message}"
    
    Note over Platform,QDR: Recall Memory Flow
    Platform->>MCP: "CallToolRequest<br/>{name: 'recall_memory', arguments: {...}}"
    MCP->>Client: "client.recallMemory(args)"
    Client->>Client: "Tag-based optimization:<br/>Parallel if tags present"
    par Parallel Queries (if tags)
        Client->>API: "GET /recall?query=...&tags=..."
        Client->>API: "GET /memory/by-tag?tags=..."
    end
    par Backend Processing
        API->>QDR: "Vector similarity search"
        API->>FDB: "Keyword + tag filtering"
        API->>FDB: "Graph expansion (if enabled)"
    end
    API-->>Client: "Merged + deduplicated results"
    Client->>Client: "Sort by final_score"
    Client-->>MCP: "RecallResult"
    MCP-->>Platform: "{count, results, dedup_removed}"