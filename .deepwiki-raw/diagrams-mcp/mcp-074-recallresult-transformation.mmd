graph TB
    BACKEND["Backend Response<br/>{results: [...], count, ...}"]
    
    BACKEND --> MAP_ARRAY["Map results array"]
    
    MAP_ARRAY --> ITEM["For each result"]
    
    ITEM --> MEM["Extract memory fields<br/>(handle timestamp variations)"]
    ITEM --> SCORE["Normalize scores<br/>(final_score ?? score ?? 0)"]
    ITEM --> META["Extract metadata<br/>(relations, expanded_from_entity,<br/>deduped_from)"]
    
    MEM --> RESULT_ITEM["Result Item"]
    SCORE --> RESULT_ITEM
    META --> RESULT_ITEM
    
    RESULT_ITEM --> OUTPUT["RecallResult<br/>{results, count,<br/>dedup_removed,<br/>expansion,<br/>entity_expansion,<br/>context_priority}"]