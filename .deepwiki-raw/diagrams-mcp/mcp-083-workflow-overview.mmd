graph TB
    PUSH["Push to main<br/>(with conventional commits)"]
    
    subgraph "Job: release-please"
        RP_ACTION["googleapis/release-please-action@v4"]
        RP_OUTPUT["Outputs:<br/>release_created<br/>tag_name"]
    end
    
    subgraph "Job: npm-publish (conditional)"
        NPM_CHECKOUT["actions/checkout@v4"]
        NPM_SETUP["actions/setup-node@v4<br/>Node 24, npm registry"]
        NPM_CI["npm ci"]
        NPM_BUILD["npm run build"]
        NPM_TEST["npm test"]
        NPM_PUBLISH["npm publish --provenance"]
    end
    
    subgraph "Job: build-extension (conditional)"
        EXT_CHECKOUT["actions/checkout@v4"]
        EXT_SETUP["actions/setup-node@v4<br/>Node 24"]
        EXT_CI["npm ci"]
        EXT_BUILD["npm run build"]
        EXT_PACK["npx @anthropic-ai/mcpb pack"]
        EXT_UPLOAD["softprops/action-gh-release@v2<br/>Upload .mcpb files"]
    end
    
    PUSH --> RP_ACTION
    RP_ACTION --> RP_OUTPUT
    RP_OUTPUT -->|"if release_created"| NPM_CHECKOUT
    RP_OUTPUT -->|"if release_created"| EXT_CHECKOUT
    
    NPM_CHECKOUT --> NPM_SETUP --> NPM_CI --> NPM_BUILD --> NPM_TEST --> NPM_PUBLISH
    EXT_CHECKOUT --> EXT_SETUP --> EXT_CI --> EXT_BUILD --> EXT_PACK --> EXT_UPLOAD