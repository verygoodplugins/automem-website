graph TB
    START["openclaw command invoked"]
    
    EXPLICIT{"--workspace<br/>flag provided?"}
    ENV{"OPENCLAW_WORKSPACE<br/>or CLAWDBOT_WORKSPACE<br/>env var exists?"}
    CONFIG{"Read workspace from<br/>~/.openclaw/openclaw.json<br/>agents.defaults.workspace?"}
    DEFAULTS{"Check default paths:<br/>~/.openclaw/workspace<br/>~/clawd<br/>~/.clawdbot/workspace"}
    
    ERROR["Error: Could not find workspace"]
    SUCCESS["Use resolved workspace"]
    
    START --> EXPLICIT
    EXPLICIT -->|Yes| SUCCESS
    EXPLICIT -->|No| ENV
    
    ENV -->|Yes & exists| SUCCESS
    ENV -->|No| CONFIG
    
    CONFIG -->|Found & valid| SUCCESS
    CONFIG -->|Not found| DEFAULTS
    
    DEFAULTS -->|Found| SUCCESS
    DEFAULTS -->|None exist| ERROR