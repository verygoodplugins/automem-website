graph TB
    Input["API response:<br/>{results: [<br/>{memory: {...}, final_score, relations}]}"]
    
    subgraph formatter["formatRecallAsItems(results, options)"]
        Extract["Extract per memory:<br/>- id, content, tags<br/>- score, dedup_count<br/>- type, timestamp, importance<br/>- relations[]"]
        
        CompactFormat["Compact format:<br/>'1. {content} [{tags}] score=X.XXX<br/>ID: {id}'"]
        
        DetailedFormat["Detailed format:<br/>'1. {content}<br/>ID: {id}<br/>Type: {type}<br/>Timestamp: {timestamp}<br/>Importance: X.XXX<br/>Tags: {tags}<br/>Relations: {rel1}; {rel2}'"]
    end
    
    Output["MCP content items:<br/>[{type: 'text', text: '...'}]"]
    
    Input --> Extract
    Extract -->|"detailed=false"| CompactFormat
    Extract -->|"detailed=true"| DetailedFormat
    CompactFormat --> Output
    DetailedFormat --> Output