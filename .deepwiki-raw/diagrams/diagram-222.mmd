graph TB
    subgraph "Development Lifecycle"
        Start["make dev"]
        Start -->|"docker compose up --build"| Running["Services Running"]
        
        Running -->|"make logs"| Logs["docker compose logs -f flask-api"]
        Running -->|"make test-integration"| Tests["Run Integration Tests"]
        Running -->|"make clean"| Stop["docker compose down -v"]
        
        Tests -->|"AUTOMEM_RUN_INTEGRATION_TESTS=1"| PyTest["pytest -rs"]
        
        Stop -->|Removes| Containers["Containers Deleted"]
        Stop -->|Removes| Networks["Networks Deleted"]
        Stop -->|"-v flag"| Volumes["Volumes Deleted"]
        
        Volumes -.->|"⚠️ Data Loss"| Warning["All memory data<br/>and cached models<br/>permanently deleted"]
    end
    
    subgraph "File Watching (Development)"
        CodeChange["Edit Python file"]
        CodeChange -->|"Volume mount<br/>. → /app"| Flask["Flask detects change"]
        Flask -->|"FLASK_DEBUG=1"| Reload["Auto-reload"]
        Reload -->|"~2s"| Running
    end