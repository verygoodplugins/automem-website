graph TB
    Trigger["POST /memory<br/>or PATCH /memory"]
    EnqueueJob["enrichment_queue.put()<br/>EnrichmentJob(memory_id)"]
    
    Trigger -->|"after FalkorDB write"| EnqueueJob
    
    Worker["Enrichment Worker Thread<br/>_enrichment_worker()"]
    
    EnqueueJob -->|queued| Worker
    
    Worker --> ExtractEntities["extract_entities(content)<br/>spaCy NER + regex"]
    ExtractEntities --> GenerateSummary["generate_summary(content)<br/>First sentence, max 240 chars"]
    GenerateSummary --> FindTemporal["Find temporal links<br/>PRECEDED_BY to recent memories"]
    FindTemporal --> DetectPatterns["Detect patterns<br/>EXEMPLIFIES to Pattern nodes"]
    DetectPatterns --> LinkSemantic["Search semantic neighbors<br/>qdrant.search(limit=SIMILARITY_LIMIT)"]
    LinkSemantic --> WriteMeta["Update metadata<br/>enriched_at, entity tags"]
    
    WriteMeta -->|success| MarkSuccess["enrichment_pending.discard()<br/>stats.record_success()"]
    WriteMeta -->|"failure, attempts < MAX_ATTEMPTS"| Retry["Re-queue with backoff<br/>sleep(FAILURE_BACKOFF_SECONDS)"]
    WriteMeta -->|"failure, attempts >= MAX_ATTEMPTS"| MarkFailed["stats.record_failure()<br/>Remove from queue"]