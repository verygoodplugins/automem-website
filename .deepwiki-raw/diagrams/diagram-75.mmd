sequenceDiagram
    participant Client
    participant Middleware as "@app.before_request<br/>require_api_token()"
    participant Extract as "_extract_api_token()"
    participant Handler as "Route Handler"
    participant Admin as "_require_admin_token()"
    
    Client->>Middleware: "HTTP Request"
    Middleware->>Middleware: "Check endpoint<br/>skip /health"
    
    Middleware->>Extract: "Extract token from request"
    
    Note over Extract: "Try 3 methods:<br/>1. Authorization: Bearer<br/>2. X-API-Key header<br/>3. ?api_key= query param"
    
    Extract-->>Middleware: "token or None"
    
    alt "token == AUTOMEM_API_TOKEN"
        Middleware->>Handler: "Allow request"
        
        alt "Admin endpoint"
            Handler->>Admin: "Check X-Admin-Token"
            
            alt "admin_token == ADMIN_API_TOKEN"
                Admin-->>Handler: "Allow"
            else "Invalid admin token"
                Admin-->>Client: "401 Unauthorized"
            end
        else "Standard endpoint"
            Handler-->>Client: "Process and respond"
        end
    else "Invalid token"
        Middleware-->>Client: "401 Unauthorized"
    end