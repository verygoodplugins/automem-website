sequenceDiagram
    participant Client
    participant Middleware as "require_api_token"
    participant Route as "Route Handler"
    
    Client->>Middleware: HTTP request
    
    alt Public endpoint (/health)
        Middleware->>Route: Pass through
    else Protected endpoint
        Middleware->>Middleware: Extract token from:<br/>1. Authorization: Bearer<br/>2. X-API-Key header<br/>3. ?api_key= query param
        
        alt Token matches AUTOMEM_API_TOKEN
            Middleware->>Middleware: Check if admin endpoint
            alt Admin endpoint
                alt X-Admin-Token matches ADMIN_API_TOKEN
                    Middleware->>Route: Authorized
                else Admin token invalid
                    Middleware->>Client: 403 Forbidden
                end
            else Standard endpoint
                Middleware->>Route: Authorized
            end
        else Token invalid
            Middleware->>Client: 401 Unauthorized
        end
    end