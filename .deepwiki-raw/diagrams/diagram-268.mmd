graph TB
    subgraph "Railway Production Deployment"
        ProdApp["app.py<br/>(memory-service container)"]
        ProdCons["consolidation.py<br/>(imported by app.py)"]
        ProdBackup["backup_automem.py<br/>(scheduled via GitHub Actions)"]
    end
    
    subgraph "Docker Compose Local Stack"
        LocalApp["app.py<br/>(memory-service container)"]
        LocalCons["consolidation.py<br/>(imported by app.py)"]
        LocalCompose["docker-compose.yml<br/>(orchestrates FalkorDB + Qdrant)"]
    end
    
    subgraph "Bare Metal Development"
        DevApp["python app.py<br/>(runs on port 8001)"]
        DevCons["consolidation.py<br/>(imported by app.py)"]
        DevEnv[".env<br/>(local configuration)"]
    end
    
    subgraph "MCP Bridge (Optional)"
        MCPNode["mcp-sse-server/<br/>(Node.js on port 8080)"]
    end
    
    subgraph "Operational Scripts (Ad-hoc)"
        Scripts["scripts/*.py<br/>(run manually or via cron)"]
    end
    
    ProdApp -->|"imports"| ProdCons
    LocalApp -->|"imports"| LocalCons
    DevApp -->|"imports"| DevCons
    DevApp -->|"reads"| DevEnv
    
    MCPNode -.->|"HTTP calls"| ProdApp
    MCPNode -.->|"HTTP calls"| LocalApp
    MCPNode -.->|"HTTP calls"| DevApp
    
    Scripts -.->|"connects to same DBs"| ProdApp