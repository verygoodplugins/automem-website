graph TB
    subgraph "Docker Compose Stack"
        subgraph "Core Services"
            Flask["flask-api<br/>Port: 8001<br/>Build: Dockerfile"]
            FalkorDB["falkordb<br/>Image: falkordb/falkordb:latest<br/>Ports: 6379, 3000"]
            Qdrant["qdrant<br/>Image: qdrant/qdrant:v1.11.3<br/>Port: 6333"]
        end
        
        subgraph "Optional Services"
            Browser["falkordb-browser<br/>Image: falkordb/falkordb-browser:latest<br/>Port: 3001<br/>Profile: browser"]
        end
        
        subgraph "Persistent Volumes"
            FalkorVol["falkordb_data<br/>/data"]
            QdrantVol["qdrant_data<br/>/qdrant/storage"]
            FastEmbedVol["fastembed_models<br/>/root/.config/automem/models"]
        end
        
        subgraph "Host Filesystem"
            AppCode["./<br/>Source code"]
            FalkorBackup["./backups/falkordb<br/>Manual backups"]
            QdrantBackup["./backups/qdrant<br/>Manual backups"]
        end
    end
    
    Flask -->|"depends_on:<br/>condition: service_healthy"| FalkorDB
    Flask -->|"depends_on:<br/>condition: service_started"| Qdrant
    Browser -->|depends_on| FalkorDB
    
    FalkorDB -->|mounts| FalkorVol
    FalkorDB -->|mounts| FalkorBackup
    Qdrant -->|mounts| QdrantVol
    Qdrant -->|mounts| QdrantBackup
    Flask -->|mounts| AppCode
    Flask -->|mounts| FastEmbedVol
    
    Client[External Client] -->|"HTTP :8001"| Flask
    DevUI[FalkorDB UI] -->|"HTTP :3000"| FalkorDB
    BrowserUI[Browser UI] -->|"HTTP :3001"| Browser