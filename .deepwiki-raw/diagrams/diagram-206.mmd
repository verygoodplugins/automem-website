sequenceDiagram
    participant Alexa as "Alexa Device"
    participant Endpoint as "/alexa endpoint"
    participant Client as "AutoMemClient"
    participant Format as "formatRecallSpeech()"
    participant API as "GET /recall"

    Alexa->>Endpoint: "RecallIntent<br/>{query: 'milk'}"
    Endpoint->>Client: "recallMemory(query, tags, limit=5)"
    Client->>API: "GET /recall?query=milk&tags=alexa&tags=user:xyz"
    API-->>Client: "{results: [...]}"
    
    alt "Primary has results"
        Client-->>Endpoint: "results: [memory1, memory2]"
    else "Primary empty"
        Endpoint->>Client: "recallMemory(query, limit=5)<br/>(no tags)"
        Client->>API: "GET /recall?query=milk"
        API-->>Client: "{results: [...]}"
        Client-->>Endpoint: "results: [memory3]"
    end
    
    Endpoint->>Format: "Format for speech"
    Format-->>Endpoint: "'Item 1: Buy milk...'"
    Endpoint->>Alexa: "Speech response"