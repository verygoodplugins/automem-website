graph TB
    subgraph "Research Requirement"
        R1["Semantic Similarity<br/>(Vector space)"]
        R2["Relational Structure<br/>(Graph topology)"]
        R3["Hybrid Retrieval<br/>(Parallel search)"]
    end
    
    subgraph "Production Implementation"
        I1["Qdrant Vector Store<br/>QdrantClient<br/>768-d embeddings"]
        I2["FalkorDB Graph DB<br/>FalkorDB client<br/>Cypher queries"]
        I3["recall endpoint<br/>_vector_search() || _graph_keyword_search()"]
    end
    
    R1 --> I1
    R2 --> I2
    R3 --> I3
    
