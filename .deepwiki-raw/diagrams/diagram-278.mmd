graph TB
    subgraph "Flake8 Analysis Pipeline"
        Input["Python Source Files"]
        Tokenize["Tokenize & Parse"]
        StyleCheck["PEP 8 Style Checks"]
        LogicCheck["Logical Error Checks"]
        ComplexityCheck["Complexity Analysis"]
        Report["Generate Report"]
    end
    
    Input --> Tokenize
    Tokenize --> StyleCheck
    Tokenize --> LogicCheck
    Tokenize --> ComplexityCheck
    
    StyleCheck --> Report
    LogicCheck --> Report
    ComplexityCheck --> Report
    
    subgraph "Common Issues Detected"
        E501["E501: Line too long<br/>(>88 chars if not using Black)"]
        F401["F401: Unused import<br/>(e.g., import json but never use)"]
        F841["F841: Unused variable<br/>(e.g., result = func() but never read)"]
        E302["E302: Missing blank lines<br/>(before function definitions)"]
        W291["W291: Trailing whitespace"]
        F821["F821: Undefined name<br/>(typo in variable name)"]
    end
    
    Report --> E501
    Report --> F401
    Report --> F841
    Report --> E302
    Report --> W291
    Report --> F821