flowchart TD
    QueryText["Query text:<br/>'PostgreSQL migration plan'"]
    
    subgraph extraction ["Keyword Extraction"]
        Extract["_extract_keywords()<br/>Tokenize, filter stopwords<br/>Min length: 3 chars"]
        Keywords["keywords:<br/>['postgresql', 'migration', 'plan']"]
        Phrase["phrase:<br/>'postgresql migration plan'"]
    end
    
    subgraph cypher ["Cypher Query Construction"]
        BaseWhere["Base filters:<br/>m.content IS NOT NULL<br/>timestamp/tag predicates"]
        UnwindKW["UNWIND keywords<br/>Score per keyword<br/>content match: 2<br/>tag match: 1"]
        PhraseBoost["Phrase bonus:<br/>content match: 2<br/>tag match: 1"]
    end
    
    subgraph execution ["Query Execution"]
        FalkorDB[("FalkorDB<br/>MATCH Memory nodes")]
        ScoreCalc["SUM(keyword_score)<br/>+ phrase bonus<br/>WHERE score > 0"]
        OrderBy["ORDER BY<br/>score DESC<br/>importance DESC<br/>timestamp DESC"]
    end
    
    Matches["Keyword matches<br/>with match_type: 'keyword'"]
    
    QueryText --> Extract
    Extract --> Keywords
    Extract --> Phrase
    Keywords --> UnwindKW
    Phrase --> PhraseBoost
    BaseWhere --> FalkorDB
    UnwindKW --> FalkorDB
    PhraseBoost --> FalkorDB
    FalkorDB --> ScoreCalc
    ScoreCalc --> OrderBy
    OrderBy --> Matches