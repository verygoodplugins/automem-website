flowchart TD
    Decay["decay consolidation task"] --> Loop["for each memory"]
    Loop --> Calc["calculate_relevance_score()"]
    Calc --> GetCount["_get_relationship_count()"]
    GetCount --> HourKey["hour_key = int(time.time() / 3600)"]
    HourKey --> Cached["_get_relationship_count_cached_impl(id, hour_key)"]
    Cached --> Check{"In cache?"}
    Check -->|"Yes"| Return["return cached_count"]
    Check -->|"No"| Query["MATCH (m)-[r]-(other)<br/>RETURN COUNT(DISTINCT r)"]
    Query --> Store["Store in LRU cache"]
    Store --> Return
    Return --> RelFactor["relationship_factor calculation"]
    RelFactor --> UpdateScore["SET m.relevance_score"]