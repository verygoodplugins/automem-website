graph TB
    subgraph Host["Development Machine"]
        subgraph Venv["Python Virtual Environment"]
            App["python app.py<br/>Port: 8001<br/>Entry point: app.py:1496-1500"]
            Workers["Background Threads<br/>- EnrichmentWorker<br/>- EmbeddingWorker<br/>- ConsolidationScheduler"]
        end
        
        Env["Environment Variables<br/>FALKORDB_HOST<br/>FALKORDB_PORT<br/>PORT"]
    end
    
    subgraph External["External Services<br/>(Docker or Remote)"]
        ExtFDB["FalkorDB Instance<br/>localhost:6379 or remote"]
        ExtQDR["Qdrant Instance<br/>localhost:6333 or cloud"]
    end
    
    Env --> App
    App --> ExtFDB
    App -.->|Optional| ExtQDR
    Workers --> ExtFDB