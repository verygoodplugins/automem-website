graph TB
    Start["init_embedding_provider()<br/>app.py"]
    
    CheckMode{"EMBEDDING_PROVIDER<br/>config value"}
    
    subgraph "Explicit Mode"
        ForceVoyage["voyage:<br/>require VOYAGE_API_KEY"]
        ForceOpenAI["openai:<br/>require OPENAI_API_KEY"]
        ForceOllama["ollama:<br/>require OLLAMA_BASE_URL"]
        ForceLocal["local:<br/>require fastembed"]
        ForcePlaceholder["placeholder:<br/>always available"]
    end
    
    subgraph "Auto Mode (Priority Chain)"
        Try1{"VOYAGE_API_KEY<br/>set?"}
        Try2{"OPENAI_API_KEY<br/>set?"}
        Try3{"OLLAMA_BASE_URL<br/>reachable?"}
        Try4{"fastembed<br/>available?"}
        Fallback["Use placeholder<br/>hash-based vectors"]
        
        Try1 -->|Yes| VoyageProvider["VoyageEmbeddingProvider<br/>automem.embedding.voyage"]
        Try1 -->|No| Try2
        Try2 -->|Yes| OpenAIProvider["OpenAIEmbeddingProvider<br/>automem.embedding.openai"]
        Try2 -->|No| Try3
        Try3 -->|Yes| OllamaProvider["OllamaEmbeddingProvider<br/>automem.embedding.ollama"]
        Try3 -->|No| Try4
        Try4 -->|Yes| FastEmbedProvider["FastEmbedProvider<br/>automem.embedding.fastembed"]
        Try4 -->|No| Fallback
        Fallback --> PlaceholderProvider["PlaceholderEmbeddingProvider<br/>automem.embedding.placeholder"]
    end
    
    Start --> CheckMode
    CheckMode -->|"auto"| Try1
    CheckMode -->|"voyage"| ForceVoyage
    CheckMode -->|"openai"| ForceOpenAI
    CheckMode -->|"ollama"| ForceOllama
    CheckMode -->|"local"| ForceLocal
    CheckMode -->|"placeholder"| ForcePlaceholder
    
    ForceVoyage --> VoyageProvider
