graph LR
    subgraph "Auto-Recovery Flow"
        Detect["Detect Critical Drift<br/>> 50%"]
        Check["Check Auto-Recover Flag"]
        Alert["Send Critical Alert<br/>to Webhook"]
        Execute["Execute<br/>recover_from_qdrant.py"]
        Rebuild["Rebuild FalkorDB<br/>from Qdrant Vectors"]
        Verify["Verify Recovery<br/>Re-check Counts"]
        Success["Send Success<br/>Notification"]
        Manual["Log Event<br/>Wait for Manual Action"]
    end
    
    Detect --> Check
    Check -->|Enabled| Alert
    Alert --> Execute
    Execute --> Rebuild
    Rebuild --> Verify
    Verify --> Success
    
    Check -->|Disabled| Manual