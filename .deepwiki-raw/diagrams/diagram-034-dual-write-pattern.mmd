sequenceDiagram
    participant Handler as "Route Handler"
    participant Graph as "state.memory_graph<br/>FalkorDB"
    participant Vector as "state.qdrant<br/>Qdrant (optional)"
    participant Queue as "embedding_queue"
    
    Note over Handler,Queue: Memory Storage Flow
    
    Handler->>Graph: MERGE (m:Memory {id: uuid})<br/>SET m.content, m.tags, ...
    
    alt Graph write succeeds
        Graph-->>Handler: memory_id
        
        alt Embedding provided in request
            Handler->>Vector: upsert(id, vector, payload)
            alt Qdrant write succeeds
                Vector-->>Handler: OK
            else Qdrant write fails
                Note over Handler: Log warning, continue<br/>Graph is canonical source
                Vector-->>Handler: (ignored)
            end
        else No embedding provided
            Handler->>Queue: queue.put(memory_id, content)
            Queue-->>Handler: Queued for async embedding
        end
        
        Handler-->>Handler: Return 201 Created
        
    else Graph write fails
        Graph-->>Handler: Exception
        Handler-->>Handler: Return 500 Error<br/>Do NOT write to Qdrant
    end