graph TB
    Trigger["Trigger<br/>cron: 0 */6 * * *<br/>or workflow_dispatch"]
    
    subgraph Setup["Setup Steps"]
        Checkout["actions/checkout@v4<br/>Clone repository"]
        Python["actions/setup-python@v5<br/>Python 3.11"]
        Deps["pip install -r requirements.txt boto3<br/>Install dependencies"]
    end
    
    subgraph Verify["Connectivity Verification"]
        CheckHost["Verify FALKORDB_HOST<br/>Not .railway.internal<br/>Must be TCP proxy"]
        CheckTCP["timeout 10 bash -c<br/>echo > /dev/tcp/$HOST/$PORT<br/>Test TCP connectivity"]
    end
    
    subgraph Execute["Backup Execution"]
        RunBackup["python scripts/backup_automem.py<br/>--s3-bucket automem-backups<br/>--cleanup --keep 14"]
        EnvVars["Environment from secrets:<br/>FALKORDB_HOST/PORT/PASSWORD<br/>QDRANT_URL/API_KEY<br/>AWS credentials"]
    end
    
    subgraph Output["Output Steps"]
        Summary["echo Backup completed<br/>ls -lh backups/<br/>Log summary"]
    end
    
    Trigger --> Checkout
    Checkout --> Python
    Python --> Deps
    Deps --> CheckHost
    CheckHost --> CheckTCP
    CheckTCP -->|"Success"| RunBackup
    CheckTCP -->|"Failure"| Error["exit 1<br/>Error message<br/>Troubleshooting guide"]
    RunBackup --> EnvVars
    EnvVars --> Summary