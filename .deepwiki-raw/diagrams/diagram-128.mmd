sequenceDiagram
    participant Main as "app.py main"
    participant Init as "Initialization"
    participant Thread as "consolidation_worker()"
    participant Sched as "ConsolidationScheduler"
    participant Tasks as "Consolidation Tasks"
    
    Main->>Init: Create Flask app
    Init->>Init: Connect to FalkorDB + Qdrant
    Init->>Init: consolidator = MemoryConsolidator(graph, qdrant)
    Init->>Init: scheduler = ConsolidationScheduler(consolidator)
    Init->>Thread: Start daemon thread
    
    loop Every CONSOLIDATION_TICK_SECONDS (60s default)
        Thread->>Sched: run_scheduled_tasks()
        Sched->>Sched: Check if decay due (hourly)
        Sched->>Sched: Check if creative due (hourly)
        Sched->>Sched: Check if cluster due (6 hours)
        Sched->>Sched: Check if forget due (daily)
        
        alt Task is due
            Sched->>Tasks: consolidator.consolidate(mode='decay')
            Tasks-->>Sched: {processed: 1523, avg_relevance: 0.67}
            Sched->>Sched: Update schedules[task]['last_run']
            Sched->>Sched: Append to history
        end
        
        Thread->>Thread: sleep(CONSOLIDATION_TICK_SECONDS)
    end