sequenceDiagram
    participant Client
    participant Flask["@app.route('/memory/:id')<br/>DELETE"]
    participant Falkor["FalkorDB"]
    participant Qdrant["Qdrant"]
    
    Client->>Flask: DELETE /memory/:id
    Flask->>Falkor: MATCH (m:Memory {id: $id})<br/>DETACH DELETE m
    
    alt Qdrant configured
        Flask->>Qdrant: delete point
    end
    
    Flask-->>Client: 200 OK