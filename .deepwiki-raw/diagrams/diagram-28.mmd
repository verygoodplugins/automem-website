graph TB
    RecallRequest["GET /recall?expand_relations=true"]
    
    InitialResults["Initial Hybrid Search<br/>Up to limit results"]
    
    RecallRequest --> InitialResults
    
    InitialResults --> ExpandLoop["For each result<br/>(up to EXPANSION_LIMIT additions)"]
    
    ExpandLoop --> FetchRelations["MATCH (m:Memory)-[r]->(related)<br/>LIMIT: RELATION_LIMIT per memory"]
    
    FetchRelations --> FilterRelations["Filter by strength, importance<br/>Deduplicate by ID"]
    
    FilterRelations --> AddExpanded["Add to results if not seen<br/>Count toward EXPANSION_LIMIT"]
    
    AddExpanded --> RankAll["Re-rank all results<br/>Combine initial + expanded"]
    
    RankAll --> Return["Return final ranked list"]