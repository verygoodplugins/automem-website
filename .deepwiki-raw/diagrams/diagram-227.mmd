graph TB
    Start["Application Startup<br/>app.py:main()"]
    
    subgraph "Critical Validation (Fail Fast)"
        CheckFalkor["FalkorDB Connection<br/>FALKORDB_HOST, FALKORDB_PORT"]
        CheckAuth["API Authentication<br/>AUTOMEM_API_TOKEN, ADMIN_API_TOKEN"]
        CheckPort["Port Configuration<br/>PORT (default 8001)"]
        
        FailFalkor["503 Service Unavailable<br/>Cannot connect to FalkorDB"]
        FailAuth["500 Internal Server Error<br/>Missing required tokens"]
    end
    
    subgraph "Optional Validation (Graceful Degradation)"
        CheckQdrant["Qdrant Connection<br/>QDRANT_URL, QDRANT_API_KEY"]
        CheckEmbed["Embedding Provider<br/>OPENAI_API_KEY, VOYAGE_API_KEY"]
        
        WarnQdrant["Graph-only mode<br/>Vector search disabled"]
        WarnEmbed["Placeholder embeddings<br/>No semantic search"]
    end
    
    subgraph "Dimension Validation"
        CheckVectorSize["VECTOR_SIZE vs Qdrant collection"]
        
        FailDimension["Validation Error<br/>Prevents data corruption"]
        AllowDimension["Dimension accepted<br/>3072, 1024, 768, etc."]
    end
    
    Start --> CheckFalkor
    Start --> CheckAuth
    Start --> CheckPort
    
    CheckFalkor -->|Failed| FailFalkor
    CheckAuth -->|Failed| FailAuth
    CheckPort -->|Failed| FailAuth
    
    CheckFalkor -->|Success| CheckQdrant
    CheckAuth -->|Success| CheckQdrant
    
    CheckQdrant -->|Failed| WarnQdrant
    CheckQdrant -->|Success| CheckEmbed
    
    CheckEmbed -->|No keys| WarnEmbed
    CheckEmbed -->|Has keys| CheckVectorSize
    
    CheckVectorSize -->|Mismatch| FailDimension
    CheckVectorSize -->|Match| AllowDimension
    
    WarnQdrant --> Ready["Service Ready<br/>Graph-only mode"]
    WarnEmbed --> Ready2["Service Ready<br/>Placeholder embeddings"]
    AllowDimension --> Ready3["Service Ready<br/>Full functionality"]