graph TB
    Request["Incoming HTTP Request"]
    CheckBearer["Check Authorization: Bearer header"]
    CheckHeader["Check X-API-Key header"]
    CheckQuery["Check ?api_key= query param"]
    ValidateToken["Validate token against AUTOMEM_API_TOKEN"]
    CheckAdmin["Admin endpoint?"]
    ValidateAdmin["Validate X-Admin-Token against ADMIN_API_TOKEN"]
    Allow["Request Allowed"]
    Deny401["HTTP 401 Unauthorized"]
    
    Request --> CheckBearer
    CheckBearer -->|Found| ValidateToken
    CheckBearer -->|Not found| CheckHeader
    CheckHeader -->|Found| ValidateToken
    CheckHeader -->|Not found| CheckQuery
    CheckQuery -->|Found| ValidateToken
    CheckQuery -->|Not found| Deny401
    
    ValidateToken -->|Invalid| Deny401
    ValidateToken -->|Valid| CheckAdmin
    CheckAdmin -->|No| Allow
    CheckAdmin -->|Yes| ValidateAdmin
    ValidateAdmin -->|Invalid| Deny401
    ValidateAdmin -->|Valid| Allow