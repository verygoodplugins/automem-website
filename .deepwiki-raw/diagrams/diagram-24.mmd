graph TB
    MemoryWrite["POST /memory<br/>Memory storage"]
    EnqueueEmbed["embedding_queue.put()<br/>Add job to queue"]
    
    MemoryWrite -->|"if no embedding provided"| EnqueueEmbed
    
    Worker["Embedding Worker Thread<br/>_embedding_worker()"]
    CollectBatch["Collect up to BATCH_SIZE items<br/>Timeout: BATCH_TIMEOUT_SECONDS"]
    
    EnqueueEmbed -->|queued| Worker
    Worker --> CollectBatch
    
    CollectBatch -->|"batch ready"| GenerateBatch["provider.generate_embeddings_batch()<br/>Single API call"]
    
    GenerateBatch -->|"for each result"| UpsertQdrant["qdrant.upsert()<br/>Store vector with payload"]
    
    UpsertQdrant -->|"mark complete"| RemoveFromQueue["embedding_pending.discard()<br/>Job cleanup"]