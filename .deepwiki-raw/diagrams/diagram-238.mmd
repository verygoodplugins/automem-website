graph TB
    subgraph Layer1["Layer 1: Infrastructure Backups"]
        RailwayVol["Railway Volume Snapshots<br/>/var/lib/falkordb/data<br/>railway-template.json volumes config"]
        RedisArgs["REDIS_ARGS persistence<br/>--save 60 1 --appendonly yes<br/>--appendfsync everysec"]
    end
    
    subgraph Layer2["Layer 2: Dual Storage Redundancy"]
        DualWrite["Continuous Dual Writes<br/>app.py POST /memory<br/>FalkorDB write + Qdrant upsert"]
        SyncWorker["sync_worker() thread<br/>Drift detection + repair<br/>SYNC_CHECK_INTERVAL"]
    end
    
    subgraph Layer3["Layer 3: Application Backups"]
        BackupScript["scripts/backup_automem.py<br/>export_falkordb() + export_qdrant()<br/>Compressed JSON.gz exports"]
    end
    
    subgraph Layer4["Layer 4: Automated Execution"]
        GHA[".github/workflows/backup.yml<br/>cron: 0 */6 * * *<br/>GitHub Actions runner"]
        RailwaySvc["scripts/Dockerfile.backup<br/>while true; sleep 21600<br/>Railway service container"]
    end
    
    subgraph Storage["Backup Storage Destinations"]
        Local["./backups/falkordb/<br/>./backups/qdrant/<br/>Timestamped JSON.gz files"]
        S3["boto3.client.upload_file()<br/>s3://automem-backups/<br/>--s3-bucket flag"]
    end
    
    RailwayVol -.->|"Volume snapshots"| Layer1
    RedisArgs -.->|"RDB + AOF"| Layer1
    
    DualWrite -.->|"POST /memory"| Layer2
    SyncWorker -.->|"Background thread"| Layer2
    
    BackupScript -.->|"Manual/scheduled"| Layer3
    
    GHA -->|"Scheduled trigger"| BackupScript
    RailwaySvc -->|"Continuous trigger"| BackupScript
    
    BackupScript -->|"Always writes"| Local
    BackupScript -->|"--s3-bucket flag"| S3