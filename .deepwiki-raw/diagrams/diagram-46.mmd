graph LR
    subgraph "Memory Lifecycle"
        Future["Future Memory<br/>t_valid > now<br/>Not searchable"]
        Valid["Valid Memory<br/>t_valid ≤ now < t_invalid<br/>Searchable"]
        Expired["Expired Memory<br/>now ≥ t_invalid<br/>Excluded by default"]
    end
    
    Created["Memory Created<br/>timestamp set"]
    
    Created -->|"t_valid in future"| Future
    Created -->|"No t_valid or<br/>t_valid ≤ now"| Valid
    
    Future -->|"Clock advances"| Valid
    Valid -->|"Clock advances"| Expired
    
    Expired -->|"Can be queried<br/>with special flag"| Archive["Archived State"]