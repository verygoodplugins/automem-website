sequenceDiagram
    participant Client
    participant Flask as "Flask Request Handler"
    participant Auth as "require_api_token()"
    participant Classifier as "MemoryClassifier"
    participant Graph as "FalkorDB (memory_graph)"
    participant Vector as "Qdrant [optional]"
    participant EnrichQ as "enrichment_queue"
    participant EmbedQ as "embedding_queue"
    
    Client->>Flask: "POST /memory"
    Flask->>Auth: "Check Authorization header"
    Auth-->>Flask: "Valid token or 401"
    
    Note over Flask: "SYNCHRONOUS PHASE<br/>Blocks client response"
    
    Flask->>Flask: "Validate request body"
    Flask->>Flask: "_normalize_timestamp()"
    Flask->>Flask: "_normalize_tag_list()"
    Flask->>Flask: "_compute_tag_prefixes()"
    
    Flask->>Classifier: "classify(content, use_llm=True)"
    Classifier-->>Flask: "(type, confidence)"
    
    Flask->>Graph: "MERGE (m:Memory {id: $id})<br/>SET properties"
    Graph-->>Flask: "memory_id"
    
    alt "Embedding provided"
        Flask->>Vector: "upsert(id, vector, payload)"
        Vector-->>Flask: "Success [best-effort]"
    else "No embedding"
        Flask->>EmbedQ: "Queue(memory_id, content)"
    end
    
    Flask->>EnrichQ: "Queue(EnrichmentJob(memory_id))"
    Flask->>Client: "200 {id, type, confidence, queued_for_enrichment}"
    
    Note over EnrichQ,EmbedQ: "ASYNCHRONOUS PHASE<br/>Client has already received response"