graph LR
    subgraph "Manual Setup"
        Venv["python3 -m venv venv<br/>source venv/bin/activate"]
        Install["pip install -r requirements-dev.txt"]
        Env["export FALKORDB_HOST=...<br/>export PORT=8001"]
        Run["python app.py"]
        
        Venv --> Install
        Install --> Env
        Env --> Run
    end
    
    subgraph "External Services"
        ExtFalkor["FalkorDB Instance<br/>(local or remote)"]
        ExtQdrant["Qdrant Instance<br/>(optional)"]
    end
    
    Run -->|"redis://$FALKORDB_HOST:$FALKORDB_PORT"| ExtFalkor
    Run -.->|"$QDRANT_URL"| ExtQdrant