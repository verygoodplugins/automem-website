sequenceDiagram
    participant Client
    participant Flask as Flask API
    participant Auth as require_api_token()
    participant Admin as _require_admin_token()
    participant Handler as Endpoint Handler

    Client->>Flask: POST /admin/reembed<br/>Authorization: Bearer API_TOKEN<br/>X-Admin-Token: ADMIN_TOKEN
    
    Flask->>Auth: @app.before_request
    Auth->>Auth: Check API token<br/>(Authorization, X-API-Key, api_key param)
    
    alt API token invalid
        Auth-->>Client: 401 Unauthorized
    end
    
    Auth->>Handler: Continue
    Handler->>Admin: _require_admin_token()
    Admin->>Admin: Check admin token<br/>(X-Admin-Token, X-Admin-Api-Key, admin_token param)
    
    alt Admin token invalid
        Admin-->>Client: 401 Admin authorization required
    else Admin token missing
        Admin-->>Client: 403 Admin token not configured
    end
    
    Admin->>Handler: Authorized
    Handler->>Handler: Execute operation
    Handler-->>Client: 200 Success