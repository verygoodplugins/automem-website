sequenceDiagram
    participant Client
    participant POST_memory as "POST /memory<br/>app.py:1898"
    participant FalkorDB
    participant embedding_queue as "embedding_queue<br/>Queue"
    participant embedding_worker as "embedding_worker()<br/>Thread"
    
    Client->>POST_memory: "POST /memory<br/>{content, tags, ...}"
    
    POST_memory->>FalkorDB: "MERGE Memory node<br/>(immediate write)"
    FalkorDB-->>POST_memory: "memory_id"
    
    POST_memory->>embedding_queue: "put({<br/>  memory_id,<br/>  content,<br/>  attempt: 0<br/>})"
    
    POST_memory-->>Client: "201 Created<br/>{memory_id, embedding_status: queued}"
    
    Note over embedding_worker: "Batch accumulation<br/>(20 items or 2s timeout)"
    
    embedding_worker->>embedding_queue: "get_nowait() loop"
    embedding_queue-->>embedding_worker: "job batch"
    
    embedding_worker->>embedding_worker: "_process_embedding_batch()"