graph TB
    subgraph "API Layer"
        MemoryEndpoint["POST /memory"]
    end
    
    subgraph "Queue System"
        EmbedQueue["ServiceState.embedding_queue<br/>Queue[Dict]"]
        PendingSet["embedding_pending<br/>Set[str]"]
        InflightSet["embedding_inflight<br/>Set[str]"]
    end
    
    subgraph "Worker Thread"
        EmbedWorker["embedding_worker()<br/>Thread daemon=True"]
        BatchAccum["Batch Accumulator<br/>EMBEDDING_BATCH_SIZE=20<br/>EMBEDDING_BATCH_TIMEOUT_SECONDS=2.0"]
        ProcessBatch["_process_embedding_batch()"]
    end
    
    subgraph "Provider Layer"
        InitProvider["init_embedding_provider()"]
        ProviderInterface["EmbeddingProvider<br/>Abstract Base Class"]
        
        Voyage["VoyageEmbeddingProvider<br/>voyage-4: 1024d<br/>voyage-4-large: 2048d"]
        OpenAI["OpenAIEmbeddingProvider<br/>text-embedding-3-small: 768d<br/>text-embedding-3-large: 3072d"]
        FastEmbed["FastEmbedProvider<br/>BAAI/bge-base-en-v1.5: 768d"]
        Ollama["OllamaEmbeddingProvider<br/>Local LLM embeddings"]
        Placeholder["PlaceholderEmbeddingProvider<br/>Hash-based deterministic"]
    end
    
    subgraph "External Services"
        VoyageAPI["Voyage AI API<br/>HTTPS"]
        OpenAIAPI["OpenAI API<br/>HTTPS"]
        OllamaAPI["Ollama<br/>Local HTTP"]
    end
    
    subgraph "Storage"
        QdrantDB["Qdrant<br/>COLLECTION_NAME"]
        FalkorDB["FalkorDB<br/>Canonical record"]
    end
    
    MemoryEndpoint -->|"enqueue<br/>{memory_id, content, attempt}"| EmbedQueue
    EmbedQueue -->|"track"| PendingSet
    EmbedQueue -->|"poll"| EmbedWorker
    EmbedWorker -->|"move to inflight"| InflightSet
    EmbedWorker -->|"accumulate"| BatchAccum
    BatchAccum -->|"batch ready"| ProcessBatch
    
    ProcessBatch -->|"use"| ProviderInterface
    ProviderInterface -->|"concrete impl"| Voyage
    ProviderInterface -->|"concrete impl"| OpenAI
    ProviderInterface -->|"concrete impl"| FastEmbed
    ProviderInterface -->|"concrete impl"| Ollama
    ProviderInterface -->|"concrete impl"| Placeholder
    
    InitProvider -->|"auto-select or explicit"| ProviderInterface
    
    Voyage -->|"batch API call"| VoyageAPI
    OpenAI -->|"batch API call"| OpenAIAPI
    Ollama -->|"local inference"| OllamaAPI
    FastEmbed -->|"local ONNX"| FastEmbed
    
    ProcessBatch -->|"_store_embedding_in_qdrant()"| QdrantDB
    ProcessBatch -->|"fallback if Qdrant unavailable"| FalkorDB