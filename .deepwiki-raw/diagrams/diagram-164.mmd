sequenceDiagram
    participant Recall as "GET /recall"
    participant EmbedGen as "_generate_real_embedding()"
    participant Qdrant as "QdrantClient"
    participant Scoring as "Hybrid Scorer"
    
    Recall->>Recall: "Check if embedding provided"
    alt No embedding
        Recall->>EmbedGen: "Generate embedding for query"
        EmbedGen-->>Recall: "query_vector"
    end
    
    Recall->>Qdrant: "search(query_vector, limit, filters)"
    Qdrant-->>Recall: "[(id, score, payload)]"
    
    Recall->>Scoring: "Apply vector weight"
    Scoring-->>Recall: "weighted_vector_score"