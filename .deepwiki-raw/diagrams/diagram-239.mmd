graph TB
    Main["main()<br/>scripts/backup_automem.py"]
    
    subgraph Connections["Database Connections"]
        FalkorConn["redis.Redis()<br/>FALKORDB_HOST:FALKORDB_PORT<br/>password=FALKORDB_PASSWORD"]
        QdrantConn["QdrantClient()<br/>url=QDRANT_URL<br/>api_key=QDRANT_API_KEY"]
    end
    
    subgraph Export["Export Functions"]
        ExportFalkor["export_falkordb(client, graph)<br/>SCAN cursor iteration<br/>Serialize to JSON"]
        ExportQdrant["export_qdrant(client, collection)<br/>scroll() pagination<br/>Include vectors + payloads"]
    end
    
    subgraph Compress["Compression"]
        GzipFalkor["gzip.open(falkordb_file, 'wt')<br/>json.dump(data, f)<br/>70-80% compression"]
        GzipQdrant["gzip.open(qdrant_file, 'wt')<br/>json.dump(points, f)<br/>70-80% compression"]
    end
    
    subgraph Output["Local Output"]
        FalkorFile["backups/falkordb/<br/>falkordb_{timestamp}.json.gz<br/>strftime('%Y%m%d_%H%M%S')"]
        QdrantFile["backups/qdrant/<br/>qdrant_{timestamp}.json.gz<br/>strftime('%Y%m%d_%H%M%S')"]
    end
    
    subgraph S3Upload["Optional S3 Upload"]
        Boto3["boto3.client('s3')<br/>AWS_ACCESS_KEY_ID<br/>AWS_SECRET_ACCESS_KEY"]
        Upload["upload_file(local, bucket, key)<br/>Preserves directory structure"]
    end
    
    subgraph Cleanup["Retention Policy"]
        CleanupFn["cleanup_old_backups(dir, keep_days)<br/>--cleanup --keep N<br/>Delete by filename timestamp"]
    end
    
    Main --> FalkorConn
    Main --> QdrantConn
    
    FalkorConn --> ExportFalkor
    QdrantConn --> ExportQdrant
    
    ExportFalkor --> GzipFalkor
    ExportQdrant --> GzipQdrant
    
    GzipFalkor --> FalkorFile
    GzipQdrant --> QdrantFile
    
    FalkorFile -.->|"--s3-bucket flag"| Boto3
    QdrantFile -.->|"--s3-bucket flag"| Boto3
    Boto3 --> Upload
    
    FalkorFile -.->|"--cleanup flag"| CleanupFn
    QdrantFile -.->|"--cleanup flag"| CleanupFn