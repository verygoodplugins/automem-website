sequenceDiagram
    participant Worker as Enrichment Worker
    participant Graph as FalkorDB
    participant Vector as Qdrant
    
    Worker->>Graph: MATCH (m:Memory {id: $id})
    Graph-->>Worker: memory with embedding
    
    Worker->>Vector: search(embedding,<br/>limit=ENRICHMENT_SIMILARITY_LIMIT,<br/>threshold=ENRICHMENT_SIMILARITY_THRESHOLD)
    Vector-->>Worker: [(id, score), ...]
    
    loop For each similar memory
        Worker->>Graph: CREATE (m)-[r:SIMILAR_TO]->(other)<br/>SET r.strength = score,<br/>r.cosine_score = score
        Worker->>Graph: CREATE (other)-[r2:SIMILAR_TO]->(m)<br/>SET r2.strength = score,<br/>r2.cosine_score = score
    end