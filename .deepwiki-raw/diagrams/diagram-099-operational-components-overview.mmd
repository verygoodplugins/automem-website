graph TB
    subgraph "Core System"
        FlaskAPI["Flask API<br/>app.py:8001"]
        FalkorDB[("FalkorDB<br/>:6379")]
        Qdrant[("Qdrant<br/>:6333")]
        
        FlaskAPI --> FalkorDB
        FlaskAPI -.-> Qdrant
    end
    
    subgraph "Monitoring Layer"
        HealthEndpoint["/health endpoint<br/>automem/api/health.py"]
        HealthMonitor["health_monitor.py<br/>Drift detection"]
        SyncWorker["Sync Worker<br/>automem/workers/sync.py"]
        
        HealthEndpoint --> FlaskAPI
        HealthMonitor --> FalkorDB
        HealthMonitor --> Qdrant
        SyncWorker --> FalkorDB
        SyncWorker --> Qdrant
    end
    
    subgraph "Backup Layer"
        RailwayVolumes["Railway Volume Snapshots<br/>Automatic every 24h"]
        BackupScript["backup_automem.py<br/>scripts/"]
        GitHubActions["GitHub Actions<br/>.github/workflows/backup.yml"]
        S3["S3 Storage<br/>Optional"]
        
        BackupScript --> FalkorDB
        BackupScript --> Qdrant
        BackupScript --> S3
        GitHubActions --> BackupScript
        RailwayVolumes -.-> FalkorDB
    end
    
    subgraph "Recovery Layer"
        RecoverScript["recover_from_qdrant.py<br/>scripts/"]
        RestoreScript["restore_from_backup.py<br/>scripts/"]
        
        RecoverScript --> Qdrant
        RecoverScript --> FalkorDB
        RestoreScript --> Qdrant
        RestoreScript --> S3
    end
    
    subgraph "Performance Layer"
        EmbedBatch["Embedding Batching<br/>EMBEDDING_BATCH_SIZE=20"]
        LRUCache["LRU Cache<br/>_get_relationship_count_cached_impl"]
        AsyncQueue["Async Processing<br/>embedding_queue, enrichment_queue"]
        
        EmbedBatch --> FlaskAPI
        LRUCache --> FlaskAPI
        AsyncQueue --> FlaskAPI
    end
    
    subgraph "Alerting Layer"
        WebhookAlert["Webhook Alerts<br/>Slack/Discord"]
        
        HealthMonitor -.-> WebhookAlert
        GitHubActions -.-> WebhookAlert
    end