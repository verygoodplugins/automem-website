graph TB
    subgraph "API Layer"
        POST["/memory endpoint<br/>POST request"]
        GET["/recall endpoint<br/>GET request"]
    end
    
    subgraph "Storage Layer"
        Falkor["FalkorDB Graph<br/>Port 6379<br/>GRAPH_NAME='memories'"]
        Qdrant["Qdrant Vectors<br/>Port 6333<br/>COLLECTION_NAME='memories'"]
    end
    
    subgraph "FalkorDB Data"
        MemNode["Memory:id node<br/>properties: content, type,<br/>timestamp, importance"]
        Edges["Relationship edges<br/>RELATES_TO, PREFERS_OVER, etc."]
    end
    
    subgraph "Qdrant Data"
        Vector["768-d embedding vector"]
        Payload["Payload: all memory properties"]
    end
    
    POST -->|"1. Store node"| Falkor
    POST -->|"2. Store vector+payload"| Qdrant
    
    GET -->|"Keyword + graph search"| Falkor
    GET -->|"Vector similarity"| Qdrant
    
    Falkor --> MemNode
    Falkor --> Edges
    Qdrant --> Vector
    Qdrant --> Payload
    
    MemNode -.->|"Same UUID"| Vector