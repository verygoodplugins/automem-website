graph TB
    Input["_store_embedding_in_qdrant(<br/>  qdrant_client,<br/>  memory_id,<br/>  embedding,<br/>  payload<br/>)"]
    Check{"qdrant_client<br/>is None?"}
    Skip["Skip storage<br/>(Qdrant disabled)"]
    FetchPayload["Fetch full payload<br/>from FalkorDB if needed"]
    CreatePoint["PointStruct(<br/>  id=memory_id,<br/>  vector=embedding,<br/>  payload=memory_data<br/>)"]
    Upsert["client.upsert(<br/>  collection_name,<br/>  points=[point]<br/>)"]
