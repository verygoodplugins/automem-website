graph TB
    PostMemory["POST /memory<br/>{type: 'Decision'}"]
    PatchMemory["PATCH /memory/:id<br/>{type: 'Pattern'}"]
    Associate["POST /associate<br/>{type: 'LEADS_TO'}"]
    
    PostMemory --> ValidateMemType["normalize_memory_type(type)<br/>automem.config"]
    PatchMemory --> ValidateMemType
    
    Associate --> ValidateRelType["type in ALLOWED_RELATIONS<br/>automem.config"]
    
    ValidateMemType -->|"invalid type"| Reject1["400 Bad Request<br/>List valid types"]
    ValidateMemType -->|"valid or normalized"| StoreMemory["Create/update Memory node"]
    
    ValidateRelType -->|"invalid type"| Reject2["400 Bad Request<br/>List valid types"]
    ValidateRelType -->|"valid"| CreateRel["CREATE (m1)-[r:TYPE]->(m2)"]