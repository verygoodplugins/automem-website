graph TB
    subgraph "AutoMemClient Class"
        Constructor["constructor(config)<br/>{endpoint, apiKey}"]
        Request["_request(method, path, body)<br/>Generic HTTP handler"]
        
        Store["storeMemory(args)<br/>POST /memory"]
        Recall["recallMemory(args)<br/>GET /recall + URLSearchParams"]
        Associate["associateMemories(args)<br/>POST /associate"]
        Update["updateMemory(args)<br/>PATCH /memory/{id}"]
        Delete["deleteMemory(args)<br/>DELETE /memory/{id}"]
        Health["checkHealth()<br/>GET /health"]
    end
    
    subgraph "HTTP Request Flow"
        URLBuild["Build URL<br/>endpoint + path"]
        Headers["Set headers<br/>Authorization: Bearer"]
        Fetch["fetch(url, {method, headers, body})"]
        Parse["Parse JSON response"]
        ErrorCheck["Check res.ok<br/>Throw on error"]
    end
    
    Constructor --> Request
    
    Store --> Request
    Recall --> Request
    Associate --> Request
    Update --> Request
    Delete --> Request
    Health --> Request
    
    Request --> URLBuild
    URLBuild --> Headers
    Headers --> Fetch
    Fetch --> Parse
    Parse --> ErrorCheck