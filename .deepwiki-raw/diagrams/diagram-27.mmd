graph LR
    Query["GET /recall?query=...<br/>User query"]
    
    subgraph "Parallel Search"
        VectorSearch["qdrant.search()<br/>Semantic similarity"]
        KeywordSearch["graph.query()<br/>Cypher CONTAINS"]
        TagFilter["Tag filtering<br/>Prefix/exact match"]
    end
    
    Query --> VectorSearch
    Query --> KeywordSearch
    Query --> TagFilter
    
    VectorSearch --> Candidates["Candidate Results<br/>Deduplicated by ID"]
    KeywordSearch --> Candidates
    TagFilter --> Candidates
    
    subgraph "Scoring Components"
        VectorScore["vector_score * WEIGHT_VECTOR"]
        KeywordScore["keyword_score * WEIGHT_KEYWORD"]
        TagScore["tag_overlap * WEIGHT_TAG"]
        ImportanceScore["importance * WEIGHT_IMPORTANCE"]
        RecencyScore["recency_factor * WEIGHT_RECENCY"]
        ConfidenceScore["confidence * WEIGHT_CONFIDENCE"]
        ExactScore["token_overlap * WEIGHT_EXACT"]
    end
    
    Candidates --> VectorScore
    Candidates --> KeywordScore
    Candidates --> TagScore
    Candidates --> ImportanceScore
    Candidates --> RecencyScore
    Candidates --> ConfidenceScore
    Candidates --> ExactScore
    
    VectorScore --> FinalScore["final_score = SUM(components)<br/>Ranked results"]
    KeywordScore --> FinalScore
    TagScore --> FinalScore
    ImportanceScore --> FinalScore
    RecencyScore --> FinalScore
    ConfidenceScore --> FinalScore
    ExactScore --> FinalScore