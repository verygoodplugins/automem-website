sequenceDiagram
    participant Handler as "post_memory()<br/>Route handler"
    participant Classifier as "memory_classifier<br/>MemoryClassifier"
    participant Regex as "Regex patterns<br/>PATTERNS dict"
    participant LLM as "OpenAI API<br/>state.openai_client"
    
    Handler->>Classifier: classify(content, use_llm=True)
    
    Classifier->>Regex: Try pattern matching<br/>(Decision, Pattern, Preference, etc.)
    
    alt Pattern matches
        Regex-->>Classifier: (type, confidence)<br/>e.g., ("Decision", 0.6)
        Classifier-->>Handler: Return matched type
    else No pattern match
        alt use_llm=True and OpenAI available
            Classifier->>LLM: chat.completions.create()<br/>JSON response format
            LLM-->>Classifier: {"type": "Insight", "confidence": 0.7}
            Classifier->>Classifier: normalize_memory_type()
            Classifier-->>Handler: Return LLM type
        else LLM unavailable
            Classifier-->>Handler: ("Memory", 0.3)<br/>Default fallback
        end
    end