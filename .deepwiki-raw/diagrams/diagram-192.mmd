graph TB
    subgraph "Alexa Skill Request"
        Launch["LaunchRequest"]
        Intent["IntentRequest<br/>RememberIntent<br/>RecallIntent<br/>AMAZON.HelpIntent"]
    end
    
    subgraph "/alexa Handler (server.js:569-647)"
        Extract["Extract endpoint + token<br/>body.endpoint or env vars"]
        IntentType["Check request.type"]
        Router["Switch on intent.name"]
        
        Remember["RememberIntent<br/>getSlot(intent, 'note')"]
        Recall["RecallIntent<br/>getSlot(intent, 'query')"]
        Help["AMAZON.HelpIntent"]
        
        Tags["buildAlexaTags(body)<br/>['alexa', 'user:...', 'device:...']"]
    end
    
    subgraph "AutoMemClient Operations"
        Store["storeMemory({content, tags})"]
        RecallScoped["recallMemory({query, tags, limit: 5})"]
        RecallFallback["recallMemory({query, limit: 5})<br/>No tag filter"]
    end
    
    subgraph "Response Formatting"
        Speech["speech(text, {endSession})<br/>Build Alexa response payload"]
        Format["formatRecallSpeech(records, {limit: 2})<br/>Shorten to 240 chars"]
    end
    
    Launch --> IntentType
    Intent --> IntentType
    IntentType --> Router
    
    Router --> Remember
    Router --> Recall
    Router --> Help
    
    Remember --> Tags
    Tags --> Store
    Store --> Speech
    
    Recall --> Tags
    Tags --> RecallScoped
    RecallScoped -->|"No results"| RecallFallback
    RecallScoped -->|"Has results"| Format
    RecallFallback --> Format
    Format --> Speech
    
    Help --> Speech