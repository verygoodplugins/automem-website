        Client["API Clients"]
        GHA["GitHub Actions<br/>Backup Workflow"]
    end

    subgraph railway["Railway Internal Network (IPv6)"]
        subgraph dns["DNS Resolution"]
            Internal["*.railway.internal<br/>RAILWAY_PRIVATE_DOMAIN"]
