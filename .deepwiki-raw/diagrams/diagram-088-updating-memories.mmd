sequenceDiagram
    participant Client
    participant Flask["@app.route('/memory/:id')<br/>PATCH"]
    participant Falkor["FalkorDB"]
    participant Qdrant["Qdrant"]
    participant EmbedQueue["embedding_queue"]
    
    Client->>Flask: PATCH /memory/:id<br/>{content, importance}
    Flask->>Falkor: MATCH (m:Memory {id: $id})
    Falkor-->>Flask: existing memory
    
    Flask->>Flask: merge updates
    Flask->>Falkor: SET m.content = $content
    
    alt content changed
        Flask->>Qdrant: delete old point
        Flask->>EmbedQueue: queue regeneration
    else metadata only
        Flask->>Qdrant: update payload
    end
    
    Flask-->>Client: 200 OK<br/>{updated_at}