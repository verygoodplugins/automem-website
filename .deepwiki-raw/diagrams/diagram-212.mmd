sequenceDiagram
    participant User
    participant Railway as "Railway Platform"
    participant Template as "railway-template.json"
    participant GitHub as "GitHub Repo"
    participant Services as "Railway Services"

    User->>Railway: Click "Deploy on Railway" button
    Railway->>Template: Parse template configuration
    Template->>Railway: Service definitions<br/>+ variable references
    
    Railway->>Railway: Generate shared secrets<br/>AUTOMEM_API_TOKEN<br/>ADMIN_API_TOKEN<br/>FALKOR_PASSWORD
    
    Railway->>GitHub: Clone repository
    
    par Deploy Services
        Railway->>Services: Create "falkordb" service<br/>Mount volume: /var/lib/falkordb/data
        Railway->>Services: Create "memory-service"<br/>Build from root Dockerfile
        Railway->>Services: Create "mcp-sse-server"<br/>Build from mcp-sse-server/Dockerfile
    end
    
    Railway->>Services: Inject environment variables<br/>Resolve ${{"{{shared.XXX}}"}}
    Railway->>Services: Configure internal DNS<br/>*.railway.internal
    Railway->>Services: Generate public domains
    
    Services->>User: Deployment complete<br/>URLs provided