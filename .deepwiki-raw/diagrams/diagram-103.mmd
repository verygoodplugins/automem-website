classDiagram
    class EnrichmentJob {
        +str memory_id
        +int attempt
        +bool forced
    }
    
    class EnrichmentStats {
        +int processed_total
        +int successes
        +int failures
        +Optional~str~ last_success_id
        +Optional~str~ last_success_at
        +Optional~str~ last_error
        +Optional~str~ last_error_at
        +record_success(memory_id)
        +record_failure(error)
        +to_dict() dict
    }
    
    class ServiceState {
        +Optional~Queue~ enrichment_queue
        +Optional~Thread~ enrichment_thread
        +EnrichmentStats enrichment_stats
        +Set~str~ enrichment_inflight
        +Set~str~ enrichment_pending
        +Lock enrichment_lock
    }
    
    ServiceState --> EnrichmentJob : queues
    ServiceState --> EnrichmentStats : tracks