sequenceDiagram
    participant Monitor as health_monitor.py
    participant FalkorDB
    participant Qdrant
    participant Recovery as recover_from_qdrant.py
    participant Alert as Webhook
    
    loop Every 5 minutes
        Monitor->>FalkorDB: MATCH (m:Memory) RETURN count(m)
        FalkorDB-->>Monitor: count: 850
        
        Monitor->>Qdrant: GET /collections/memories
        Qdrant-->>Monitor: points_count: 893
        
        Monitor->>Monitor: Calculate drift<br/>(893-850)/893 = 4.8%
        
        alt Drift < 5%
            Monitor->>Monitor: Status: OK
        else Drift 5-50%
            Monitor->>Alert: POST webhook<br/>level: warning
            Monitor->>Monitor: Log drift details
        else Drift > 50%
            Monitor->>Alert: POST webhook<br/>level: critical
            alt Auto-recover enabled
                Monitor->>Recovery: Execute recovery script
                Recovery->>FalkorDB: Rebuild from Qdrant
            else Alert only
                Monitor->>Monitor: Log critical event
            end
        end
    end