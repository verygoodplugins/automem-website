sequenceDiagram
    participant Client
    participant API as "POST /associate"
    participant Config as "automem.config"
    participant Graph as "FalkorDB"
    
    Client->>API: "type: PREFERS_OVER"
    API->>Config: "Check ALLOWED_RELATIONS"
    Config-->>API: "Valid"
    API->>Graph: "MERGE (m1)-[r:PREFERS_OVER]->(m2)"
